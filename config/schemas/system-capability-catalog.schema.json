{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "System Capability Catalog",
  "type": "object",
  "required": ["version", "owner", "policy", "catalogs", "entries"],
  "properties": {
    "version": { "type": "string" },
    "owner": { "type": "string" },
    "policy": { "type": "object" },
    "catalogs": { "type": "object" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "category",
          "kind",
          "state",
          "maturity",
          "owner",
          "summary",
          "agent_access",
          "primary_refs",
          "security",
          "validation",
          "parity_targets",
          "data_stores"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "name": { "type": "string" },
          "category": { "type": "string" },
          "kind": { "type": "string" },
          "state": { "type": "string" },
          "maturity": { "type": "string" },
          "owner": { "type": "string" },
          "summary": { "type": "string" },
          "agent_access": { "type": "array", "items": { "type": "string" } },
          "primary_refs": { "type": "array", "items": { "type": "string" } },
          "security": {
            "type": "object",
            "required": ["admission", "risk", "required_gate"],
            "properties": {
              "admission": { "type": "string" },
              "intake_candidate_id": { "type": "string" },
              "risk": { "type": "string" },
              "required_gate": { "type": "string" }
            },
            "additionalProperties": true
          },
          "validation": { "type": "array", "items": { "type": "string" } },
          "parity_targets": { "type": "array", "items": { "type": "string" } },
          "data_stores": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
