{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aq.agent-ops-projection.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "health", "metrics", "dispatch_contract", "work"],
  "properties": {
    "schema_version": {"const": "aq.agent-ops-projection.v1"},
    "generated_at": {"type": "string", "format": "date-time"},
    "health": {
      "type": "object", "additionalProperties": false,
      "required": ["verdict", "reason_codes", "source_freshness"],
      "properties": {
        "verdict": {"enum": ["tracked", "degraded", "blocked"]},
        "reason_codes": {"type": "array", "maxItems": 128, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[a-z0-9_]+$"}},
        "source_freshness": {"enum": ["fresh", "stale", "unavailable"]}
      }
    },
    "metrics": {
      "type": "object", "additionalProperties": false,
      "required": ["inbox_pending_count", "inbox_processing_duration_seconds", "cgroup_correlation_failures_total"],
      "properties": {
        "inbox_pending_count": {"type": "integer", "minimum": 0},
        "inbox_processing_duration_seconds": {"type": ["integer", "null"], "minimum": 0},
        "cgroup_correlation_failures_total": {"type": "integer", "minimum": 0}
      }
    },
    "dispatch_contract": {
      "type": "object", "additionalProperties": false,
      "required": ["contract_version", "health", "broker_state", "adapter_health", "counts", "coverage_health", "reason_codes"],
      "properties": {
        "contract_version": {"const": "aq.dispatch.contract.v1"},
        "health": {"enum": ["healthy", "degraded", "blocked", "unavailable"]},
        "broker_state": {"enum": ["healthy", "degraded", "blocked", "not_assessed"]},
        "adapter_health": {"type": "object", "additionalProperties": false, "required": ["local", "claude", "codex", "antigravity"], "properties": {
          "local": {"enum": ["healthy", "degraded", "blocked", "unavailable"]},
          "claude": {"enum": ["healthy", "degraded", "blocked", "unavailable"]},
          "codex": {"enum": ["healthy", "degraded", "blocked", "unavailable"]},
          "antigravity": {"enum": ["healthy", "degraded", "blocked", "unavailable"]}
        }},
        "counts": {"type": "object", "additionalProperties": false, "required": ["queued", "running", "parked", "terminal"], "properties": {
          "queued": {"type": ["integer", "null"], "minimum": 0, "maximum": 1000000},
          "running": {"type": ["integer", "null"], "minimum": 0, "maximum": 1000000},
          "parked": {"type": ["integer", "null"], "minimum": 0, "maximum": 1000000},
          "terminal": {"type": ["integer", "null"], "minimum": 0, "maximum": 1000000}
        }},
        "coverage_health": {"type": "object", "additionalProperties": false, "required": ["aq_qa", "agent_ops", "web_dashboard"], "properties": {
          "aq_qa": {"enum": ["healthy", "blocked", "unavailable"]},
          "agent_ops": {"enum": ["healthy", "blocked", "unavailable"]},
          "web_dashboard": {"enum": ["healthy", "blocked", "unavailable"]}
        }},
        "reason_codes": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[a-z0-9_]+$"}}
      }
    },
    "work": {"type": "array", "maxItems": 9216, "items": {"$ref": "#/$defs/work"}}
  },
  "$defs": {
    "pid_identity": {
      "type": "object", "additionalProperties": false,
      "required": ["pid", "start_time", "ppid", "pgid", "session", "cgroup"],
      "properties": {
        "pid": {"type": "integer", "minimum": 1},
        "start_time": {"type": "integer", "minimum": 0},
        "ppid": {"type": "integer", "minimum": 0},
        "pgid": {"type": "integer", "minimum": 0},
        "session": {"type": "integer", "minimum": 0},
        "cgroup": {"type": ["string", "null"], "maxLength": 64}
      }
    },
    "work": {
      "type": "object", "additionalProperties": false,
      "required": ["work_id", "lane", "role", "model_profile", "authority", "state", "phase", "progress_age_s", "pid_identity", "dedup_group", "access", "terminal_reason", "artifact", "visibility", "reason_code", "freshness"],
      "properties": {
        "work_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{0,127}$"},
        "lane": {"enum": ["local", "claude", "codex", "antigravity", "system", "unknown"]},
        "role": {"type": ["string", "null"], "maxLength": 64},
        "model_profile": {"type": ["string", "null"], "maxLength": 64},
        "authority": {"enum": ["delegation_registry", "antigravity_inbox", "process_observer", "collaboration_event"]},
        "state": {"enum": ["queued", "running", "waiting", "cancelling", "terminal", "idle", "untracked", "conflict", "stale"]},
        "phase": {"type": ["string", "null"], "maxLength": 64},
        "progress_age_s": {"type": ["integer", "null"], "minimum": 0},
        "pid_identity": {"anyOf": [{"$ref": "#/$defs/pid_identity"}, {"type": "null"}]},
        "dedup_group": {"type": ["string", "null"], "maxLength": 128},
        "access": {"enum": ["writer", "read_only", "none"]},
        "terminal_reason": {"type": ["string", "null"], "maxLength": 64},
        "artifact": {"enum": ["expected", "present", "missing", "not_applicable"]},
        "visibility": {"enum": ["tracked", "degraded", "blocked"]},
        "reason_code": {"type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[a-z0-9_]+$"},
        "freshness": {"enum": ["fresh", "stale", "unavailable"]}
      }
    }
  }
}
