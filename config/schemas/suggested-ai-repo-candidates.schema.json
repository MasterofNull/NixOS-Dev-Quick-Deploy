{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Suggested AI Repo Candidates",
  "type": "object",
  "required": ["version", "owner", "policy", "candidates"],
  "additionalProperties": false,
  "properties": {
    "$schema": {"type": "string"},
    "version": {"type": "string"},
    "owner": {"type": "string"},
    "policy": {
      "type": "object",
      "required": ["source_of_truth", "default_state", "required_gate"],
      "additionalProperties": false,
      "properties": {
        "source_of_truth": {"type": "string"},
        "default_state": {"const": "research-only"},
        "required_gate": {"type": "string"},
        "notes": {"type": "string"}
      }
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "source_url",
          "category",
          "priority",
          "state",
          "maturity_signal",
          "why_research",
          "local_gap_targets",
          "parity_checks",
          "security_gates",
          "intake_action",
          "delegation_targets"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "name": {"type": "string"},
          "source_url": {"type": "string", "pattern": "^https://github\\.com/"},
          "category": {
            "enum": [
              "agent-framework",
              "coding-agent",
              "mcp-infrastructure",
              "browser-automation",
              "memory-rag",
              "benchmark"
            ]
          },
          "priority": {"enum": ["high", "medium", "low"]},
          "state": {"enum": ["research-only", "proposed", "defer", "reject"]},
          "maturity_signal": {"type": "string"},
          "why_research": {"type": "string"},
          "local_gap_targets": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "parity_checks": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "security_gates": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "intake_action": {"type": "string"},
          "delegation_targets": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
