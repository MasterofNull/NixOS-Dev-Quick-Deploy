    "minimum_independent_principals": {"maximum": 16, "minimum": 1, "title": "Minimum Independent Principals", "type": "integer"},
    "policy_version": {"maxLength": 128, "minLength": 1, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:+/-]*$", "title": "Policy Version", "type": "string"},
