{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aq.local-inference-transport/1.0",
  "oneOf": [
    {"$ref": "#/$defs/trustedSnapshot"},
    {"$ref": "#/$defs/headerClaim"},
    {"$ref": "#/$defs/canonicalOutput"},
    {"$ref": "#/$defs/transportPlan"},
    {"$ref": "#/$defs/observation"},
    {"$ref": "#/$defs/decodeSummary"},
    {"$ref": "#/$defs/parserFault"},
    {"$ref": "#/$defs/candidateWrapper"}
  ],
  "$defs": {
    "identity": {
      "type": "object", "additionalProperties": false,
      "required": ["request_id", "run_id", "trace_id"],
      "properties": {
        "request_id": {"type": "string", "format": "uuid"},
        "run_id": {"type": "string", "format": "uuid"},
        "trace_id": {"type": "string", "format": "uuid"}
      }
    },
    "header": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "value"],
      "properties": {
        "name": {"type": "string", "pattern": "^[!#$%&'*+.^_`|~0-9A-Za-z-]+$"},
        "value": {"type": "string", "maxLength": 4096}
      }
    },
    "trustedSnapshot": {
      "type": "object", "additionalProperties": false,
      "required": ["document_kind", "profile", "model", "snapshot_revision", "builder_revision", "builder_sha256", "capabilities", "authority"],
      "properties": {
        "document_kind": {"const": "trusted_snapshot"},
        "profile": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "snapshot_revision": {"type": "string", "minLength": 1},
        "builder_revision": {"type": "string", "minLength": 1},
        "builder_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "capabilities": {
          "type": "object", "additionalProperties": false,
          "required": ["streaming", "response_format", "tools", "cache_prompt", "thinking"],
          "properties": {
            "streaming": {"type": "boolean"}, "response_format": {"type": "boolean"},
            "tools": {"type": "boolean"}, "cache_prompt": {"type": "boolean"},
            "thinking": {"type": "boolean"}
          }
        },
        "authority": {
          "type": "object", "additionalProperties": false,
          "required": ["system_message_sha256", "chat_template_kwargs"],
          "properties": {
            "system_message_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
            "chat_template_kwargs": {"$ref": "#/$defs/chatTemplateKwargs"}
          }
        }
      }
    },
    "headerClaim": {
      "type": "object", "additionalProperties": false,
      "required": ["document_kind", "headers"],
      "properties": {"document_kind": {"const": "untrusted_header_claim"}, "headers": {"type": "array", "items": {"$ref": "#/$defs/header"}}}
    },
    "canonicalOutput": {
      "type": "object", "additionalProperties": false,
      "required": ["document_kind", "headers", "payload", "canonical_wire_utf8", "semantic_digest", "wire_digest"],
      "properties": {
        "document_kind": {"const": "canonical_output"},
        "headers": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/header"}},
        "payload": {"$ref": "#/$defs/payload"}, "canonical_wire_utf8": {"type": "string"},
        "semantic_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "wire_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "transportPlan": {
      "type": "object", "additionalProperties": false,
      "required": ["document_kind", "contract_version", "policy_version", "adapter_version", "digest_version", "target", "decoder_mode", "snapshot_revision", "canonical"],
      "properties": {
        "document_kind": {"const": "transport_plan"}, "contract_version": {"const": "1.0"},
        "policy_version": {"type": "string"}, "adapter_version": {"type": "string"}, "digest_version": {"type": "string"},
        "target": {"enum": ["direct_llama", "switchboard", "coordinator", "local_runtime", "ralph"]},
        "decoder_mode": {"enum": ["buffered_json", "openai_sse"]}, "snapshot_revision": {"type": "string"},
        "canonical": {"$ref": "#/$defs/canonicalOutput"}
      }
    },
    "observationContent": {
      "type": "object", "additionalProperties": false,
      "required": ["content"],
      "properties": {"content": {"type": "string"}}
    },
    "observationUsage": {
      "type": "object", "additionalProperties": false,
      "required": ["usage"],
      "properties": {"usage": {"$ref": "#/$defs/usage"}}
    },
    "observationFinish": {
      "type": "object", "additionalProperties": false,
      "required": ["reason"],
      "properties": {"reason": {"type": "string", "minLength": 1}}
    },
    "upstreamErrorObject": {
      "type": "object", "additionalProperties": false,
      "required": ["message"],
      "properties": {
        "message": {"type": "string", "minLength": 1, "maxLength": 512},
        "type": {"type": ["string", "null"]},
        "code": {"type": ["string", "integer", "null"]},
        "param": {"type": ["string", "integer", "null"]}
      }
    },
    "observationUpstreamError": {
      "type": "object", "additionalProperties": false,
      "required": ["error"],
      "properties": {"error": {"$ref": "#/$defs/upstreamErrorObject"}}
    },
    "observationEmpty": {
      "type": "object", "additionalProperties": false,
      "properties": {}
    },
    "observationDataUnion": {
      "oneOf": [
        {"$ref": "#/$defs/observationContent"},
        {"$ref": "#/$defs/observationUsage"},
        {"$ref": "#/$defs/toolCall"},
        {"$ref": "#/$defs/observationFinish"},
        {"$ref": "#/$defs/observationUpstreamError"},
        {"$ref": "#/$defs/observationEmpty"}
      ]
    },
    "observation": {
      "type": "object", "additionalProperties": false,
      "required": ["document_kind", "identity", "sequence", "kind", "data"],
      "properties": {
        "document_kind": {"const": "transport_observation"}, "identity": {"$ref": "#/$defs/identity"},
        "sequence": {"type": "integer", "minimum": 1},
        "kind": {"enum": ["content", "usage", "tool_call", "finish", "upstream_error", "done", "cancelled"]},
        "data": {"$ref": "#/$defs/observationDataUnion"}
      },
      "allOf": [
        {"if": {"properties": {"kind": {"const": "content"}}, "required": ["kind"]}, "then": {"properties": {"data": {"$ref": "#/$defs/observationContent"}}}},
        {"if": {"properties": {"kind": {"const": "usage"}}, "required": ["kind"]}, "then": {"properties": {"data": {"$ref": "#/$defs/observationUsage"}}}},
        {"if": {"properties": {"kind": {"const": "tool_call"}}, "required": ["kind"]}, "then": {"properties": {"data": {"$ref": "#/$defs/toolCall"}}}},
        {"if": {"properties": {"kind": {"const": "finish"}}, "required": ["kind"]}, "then": {"properties": {"data": {"$ref": "#/$defs/observationFinish"}}}},
        {"if": {"properties": {"kind": {"const": "upstream_error"}}, "required": ["kind"]}, "then": {"properties": {"data": {"$ref": "#/$defs/observationUpstreamError"}}}},
        {"if": {"properties": {"kind": {"enum": ["done", "cancelled"]}}, "required": ["kind"]}, "then": {"properties": {"data": {"$ref": "#/$defs/observationEmpty"}}}}
      ]
    },
    "decodeSummary": {
      "type": "object", "additionalProperties": false,
      "required": ["document_kind", "mode", "terminal_state", "content", "tool_calls", "usage", "finish_reason", "output_digest", "observations"],
      "properties": {
        "document_kind": {"const": "decode_summary"}, "mode": {"enum": ["buffered_json", "openai_sse"]},
        "terminal_state": {"enum": ["done", "upstream_error", "cancelled"]}, "content": {"type": "string"},
        "tool_calls": {"type": "array", "items": {"$ref": "#/$defs/toolCall"}}, "usage": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/usage"}]},
        "finish_reason": {"type": ["string", "null"]}, "output_digest": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
        "observations": {"type": "array", "items": {"$ref": "#/$defs/observation"}}
      }
    },
    "message": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["role", "content"],
          "properties": {
            "role": {"const": "system"},
            "content": {"type": "string", "maxLength": 12000}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["role", "content"],
          "properties": {
            "role": {"enum": ["user", "assistant", "tool"]},
            "content": {"type": "string", "maxLength": 12000},
            "call_id": {"type": ["string", "null"], "maxLength": 128}
          }
        }
      ]
    },
    "toolParameterSchema": {
      "type": "object", "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {"enum": ["object", "array", "string", "number", "integer", "boolean", "null"]},
        "description": {"type": "string"},
        "properties": {"type": "object", "additionalProperties": {"$ref": "#/$defs/toolParameterSchema"}},
        "required": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "items": {"$ref": "#/$defs/toolParameterSchema"},
        "enum": {"type": "array", "minItems": 1},
        "additionalProperties": {"type": "boolean"}
      }
    },
    "toolDefinition": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "function"],
      "properties": {
        "type": {"const": "function"},
        "function": {
          "type": "object", "additionalProperties": false,
          "required": ["name"],
          "properties": {
            "name": {"type": "string", "minLength": 1},
            "description": {"type": "string"},
            "parameters": {"$ref": "#/$defs/toolParameterSchema"}
          }
        }
      }
    },
    "toolChoice": {
      "oneOf": [
        {"enum": ["auto", "none", "required"]},
        {
          "type": "object", "additionalProperties": false,
          "required": ["type", "function"],
          "properties": {
            "type": {"const": "function"},
            "function": {
              "type": "object", "additionalProperties": false,
              "required": ["name"],
              "properties": {"name": {"type": "string", "minLength": 1}}
            }
          }
        }
      ]
    },
    "stopValue": {
      "oneOf": [
        {"type": "string", "minLength": 1},
        {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      ]
    },
    "responseFormat": {
      "type": "object", "additionalProperties": false,
      "required": ["type"],
      "properties": {"type": {"const": "json_object"}}
    },
    "streamOptions": {
      "type": "object", "additionalProperties": false,
      "required": ["include_usage"],
      "properties": {"include_usage": {"const": true}}
    },
    "chatTemplateKwargs": {
      "type": "object", "additionalProperties": false,
      "required": ["enable_thinking"],
      "properties": {
        "enable_thinking": {"type": "boolean"},
        "thinking_budget": {"type": "integer", "minimum": 1}
      },
      "if": {"required": ["thinking_budget"]},
      "then": {"properties": {"enable_thinking": {"const": true}}}
    },
    "payload": {
      "type": "object", "additionalProperties": false,
      "required": ["messages", "temperature", "max_tokens", "chat_template_kwargs", "repeat_penalty", "repeat_last_n", "frequency_penalty", "cache_prompt", "model"],
      "properties": {
        "messages": {"type": "array", "items": {"$ref": "#/$defs/message"}}, "temperature": {"type": "number"},
        "max_tokens": {"type": "integer", "minimum": 1}, "model": {"type": "string", "minLength": 1},
        "stream": {"type": "boolean"}, "stream_options": {"$ref": "#/$defs/streamOptions"}, "chat_template_kwargs": {"$ref": "#/$defs/chatTemplateKwargs"},
        "frequency_penalty": {"type": "number"}, "repeat_penalty": {"type": "number", "exclusiveMinimum": 0},
        "repeat_last_n": {"type": "integer", "minimum": 0}, "cache_prompt": {"type": "boolean"},
        "response_format": {"$ref": "#/$defs/responseFormat"}, "stop": {"$ref": "#/$defs/stopValue"},
        "tools": {"type": "array", "items": {"$ref": "#/$defs/toolDefinition"}}, "tool_choice": {"$ref": "#/$defs/toolChoice"}
      }
    },
    "usage": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "prompt_tokens": {"type": "integer", "minimum": 0},
        "completion_tokens": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0}
      }
    },
    "toolCall": {
      "type": "object", "additionalProperties": false,
      "required": ["index", "id", "type", "name", "arguments"],
      "properties": {
        "index": {"type": "integer", "minimum": 0}, "id": {"type": "string", "minLength": 1},
        "type": {"type": "string", "minLength": 1}, "name": {"type": "string", "minLength": 1},
        "arguments": {"oneOf": [{"type": "object"}, {"type": "string"}]}
      }
    },
    "parserFault": {
      "type": "object", "additionalProperties": false,
      "required": ["document_kind", "code", "reason_code", "message", "retryable"],
      "properties": {
        "document_kind": {"const": "parser_fault"}, "code": {"const": "transport_error"},
        "reason_code": {"type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$"},
        "message": {"type": "string", "minLength": 1, "maxLength": 256}, "retryable": {"const": false}
      }
    },
    "v1LifecycleError": {
      "type": "object", "additionalProperties": false,
      "required": ["contract_version", "code", "message", "retryable", "reason_code", "evidence_ref"],
      "properties": {
        "contract_version": {"const": "1.0"},
        "code": {"enum": ["invalid_request", "ineligible", "unauthorized", "unavailable_profile", "queue_timeout", "inference_timeout", "cancelled", "transport_error", "malformed_result", "degraded_fallback"]},
        "message": {"type": "string", "minLength": 1, "maxLength": 512}, "retryable": {"type": "boolean"},
        "reason_code": {"type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$"}, "evidence_ref": {"type": ["string", "null"], "maxLength": 1024}
      },
      "allOf": [
        {"if": {"properties": {"code": {"const": "cancelled"}}, "required": ["code"]}, "then": {"properties": {"retryable": {"const": false}}}},
        {"if": {"properties": {"code": {"enum": ["invalid_request", "ineligible", "unauthorized", "malformed_result"]}}, "required": ["code"]}, "then": {"properties": {"retryable": {"const": false}}}}
      ]
    },
    "v1EventPayload": {
      "type": "object", "additionalProperties": false,
      "required": ["content_delta", "usage_delta", "tool", "validation_check"],
      "properties": {
        "content_delta": {"type": ["string", "null"]},
        "usage_delta": {
          "type": "object", "additionalProperties": false,
          "required": ["input_tokens", "output_tokens"],
          "properties": {
            "input_tokens": {"type": "integer", "minimum": 0},
            "output_tokens": {"type": "integer", "minimum": 0}
          }
        },
        "tool": {"type": ["string", "null"]}, "validation_check": {"type": ["string", "null"]}
      }
    },
    "v1EventDocument": {
      "type": "object", "additionalProperties": false,
      "required": ["contract_version", "request_id", "run_id", "trace_id", "sequence", "event_type", "terminal", "payload", "error"],
      "properties": {
        "contract_version": {"const": "1.0"}, "request_id": {"type": "string", "format": "uuid"}, "run_id": {"type": "string", "format": "uuid"}, "trace_id": {"type": "string", "format": "uuid"},
        "sequence": {"type": "integer", "minimum": 1}, "event_type": {"enum": ["accepted", "queued", "started", "tool_call", "validation", "completed", "blocked", "failed", "cancelled"]},
        "terminal": {"type": "boolean"}, "payload": {"$ref": "#/$defs/v1EventPayload"}, "error": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/v1LifecycleError"}]}
      },
      "allOf": [
        {"if": {"properties": {"event_type": {"enum": ["accepted", "queued", "started", "tool_call", "validation"]}}, "required": ["event_type"]}, "then": {"properties": {"terminal": {"const": false}, "error": {"type": "null"}}}},
        {"if": {"properties": {"event_type": {"const": "completed"}}, "required": ["event_type"]}, "then": {"properties": {"terminal": {"const": true}, "error": {"type": "null"}}}},
        {"if": {"properties": {"event_type": {"enum": ["blocked", "failed", "cancelled"]}}, "required": ["event_type"]}, "then": {"properties": {"terminal": {"const": true}, "error": {"$ref": "#/$defs/v1LifecycleError"}}}},
        {"if": {"properties": {"event_type": {"const": "cancelled"}}, "required": ["event_type"]}, "then": {"properties": {"error": {"allOf": [{"$ref": "#/$defs/v1LifecycleError"}, {"properties": {"code": {"const": "cancelled"}, "retryable": {"const": false}}}]}}}},
        {"if": {"properties": {"error": {"allOf": [{"$ref": "#/$defs/v1LifecycleError"}, {"properties": {"code": {"const": "cancelled"}}, "required": ["code"]}]}}, "required": ["error"]}, "then": {"properties": {"event_type": {"const": "cancelled"}}}}
      ]
    },
    "v1ResultBudgets": {
      "type": "object", "additionalProperties": false,
      "required": ["input_tokens", "output_tokens", "deadline_ms", "queue_wait_ms", "max_tool_calls"],
      "properties": {
        "input_tokens": {"type": "integer", "minimum": 1}, "output_tokens": {"type": "integer", "minimum": 1},
        "deadline_ms": {"type": "integer", "minimum": 1}, "queue_wait_ms": {"type": "integer", "minimum": 1},
        "max_tool_calls": {"type": "integer", "minimum": 0}
      }
    },
    "v1ResultFallback": {
      "type": "object", "additionalProperties": false,
      "required": ["mode", "allowed_profiles", "max_attempts", "equivalence_registry_version"],
      "properties": {
        "mode": {"enum": ["deny", "queue", "same_capability", "best_effort"]},
        "allowed_profiles": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "max_attempts": {"type": "integer", "minimum": 1},
        "equivalence_registry_version": {"type": "string", "minLength": 1}
      }
    },
    "v1ResolvedPlan": {
      "type": "object", "additionalProperties": false,
      "required": ["contract_version", "config_version", "mode", "requested_profile", "profile", "model", "task_class", "effective_role", "side_effects", "tools", "budgets", "queue_band", "fallback", "capability_delta", "reasons"],
      "properties": {
        "contract_version": {"const": "1.0"}, "config_version": {"type": "string", "minLength": 1},
        "mode": {"enum": ["direct", "hybrid", "agent", "ralph"]},
        "requested_profile": {"type": "string", "minLength": 1}, "profile": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1}, "task_class": {"type": "string", "minLength": 1},
        "effective_role": {"enum": ["orchestrator", "architect", "implementer", "reviewer"]},
        "side_effects": {"enum": ["none", "read", "write"]},
        "tools": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "budgets": {"$ref": "#/$defs/v1ResultBudgets"}, "queue_band": {"enum": ["interactive", "normal", "background"]},
        "fallback": {"$ref": "#/$defs/v1ResultFallback"}, "capability_delta": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "reasons": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$"}}
      }
    },
    "v1ResultDocument": {
      "type": "object", "additionalProperties": false,
      "required": ["contract_version", "request_id", "run_id", "trace_id", "session_id", "sequence", "status", "resolved_plan", "artifact", "claims", "validation", "effects", "usage", "timing", "provenance", "error", "limitations", "next_action"],
      "properties": {
        "contract_version": {"const": "1.0"}, "request_id": {"type": "string", "format": "uuid"},
        "run_id": {"type": "string", "format": "uuid"}, "trace_id": {"type": "string", "format": "uuid"},
        "session_id": {"type": ["string", "null"], "format": "uuid"}, "sequence": {"type": "integer", "minimum": 1},
        "status": {"enum": ["complete", "partial", "blocked", "failed", "cancelled"]}, "resolved_plan": {"$ref": "#/$defs/v1ResolvedPlan"},
        "artifact": {"type": "object", "additionalProperties": false, "required": ["format", "content", "schema_valid"], "properties": {"format": {"enum": ["text", "json", "patch", "evidence_fragment"]}, "content": {}, "schema_valid": {"type": "boolean"}}},
        "claims": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["claim", "kind", "evidence_refs"], "properties": {"claim": {"type": "string", "minLength": 1}, "kind": {"enum": ["observed", "inferred", "proposed"]}, "evidence_refs": {"type": "array", "items": {"type": "string"}}}}},
        "validation": {"type": "object", "additionalProperties": false, "required": ["results", "missing_evidence"], "properties": {"results": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["check", "passed", "detail"], "properties": {"check": {"type": "string"}, "passed": {"type": "boolean"}, "detail": {"type": "string"}}}}, "missing_evidence": {"type": "array", "items": {"type": "string"}}}},
        "effects": {"type": "object", "additionalProperties": false, "required": ["changed_files", "executed_tools"], "properties": {"changed_files": {"type": "array", "items": {"type": "string"}}, "executed_tools": {"type": "array", "items": {"type": "string"}}}},
        "usage": {"type": "object", "additionalProperties": false, "required": ["input_tokens", "output_tokens", "tool_calls"], "properties": {"input_tokens": {"type": "integer", "minimum": 0}, "output_tokens": {"type": "integer", "minimum": 0}, "tool_calls": {"type": "integer", "minimum": 0}}},
        "timing": {"type": "object", "additionalProperties": false, "required": ["queue_ms", "ttft_ms", "inference_ms", "total_ms"], "properties": {"queue_ms": {"type": "integer", "minimum": 0}, "ttft_ms": {"type": "integer", "minimum": 0}, "inference_ms": {"type": "integer", "minimum": 0}, "total_ms": {"type": "integer", "minimum": 0}}},
        "provenance": {"type": "object", "additionalProperties": false, "required": ["producer", "template_version", "context_digest", "input_digest", "output_digest"], "properties": {"producer": {"type": "string", "minLength": 1}, "template_version": {"type": "string", "minLength": 1}, "context_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "input_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "output_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}},
        "error": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/v1LifecycleError"}]},
        "limitations": {"type": "array", "items": {"type": "string"}}, "next_action": {"type": "string"}
      },
      "allOf": [
        {"if": {"properties": {"status": {"enum": ["complete", "partial"]}}, "required": ["status"]}, "then": {"properties": {"error": {"type": "null"}}}},
        {"if": {"properties": {"status": {"enum": ["blocked", "failed", "cancelled"]}}, "required": ["status"]}, "then": {"properties": {"error": {"$ref": "#/$defs/v1LifecycleError"}}}},
        {"if": {"properties": {"status": {"const": "cancelled"}}, "required": ["status"]}, "then": {"properties": {"error": {"allOf": [{"$ref": "#/$defs/v1LifecycleError"}, {"properties": {"code": {"const": "cancelled"}, "retryable": {"const": false}}}]}}}},
        {"if": {"properties": {"error": {"allOf": [{"$ref": "#/$defs/v1LifecycleError"}, {"properties": {"code": {"const": "cancelled"}}, "required": ["code"]}]}}, "required": ["error"]}, "then": {"properties": {"status": {"const": "cancelled"}}}}
      ]
    },
    "candidateWrapper": {
      "type": "object", "additionalProperties": false,
      "required": ["document_kind", "candidate_kind", "authoritative", "event", "result"],
      "properties": {
        "document_kind": {"const": "v1_candidate_wrapper"}, "candidate_kind": {"const": "terminal_candidate"},
        "authoritative": {"const": false}, "event": {"$ref": "#/$defs/v1EventDocument"}, "result": {"$ref": "#/$defs/v1ResultDocument"}
      }
    }
  }
}
