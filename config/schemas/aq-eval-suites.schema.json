{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AQ Eval Suites",
  "type": "object",
  "required": ["version", "owner", "policy", "suites"],
  "additionalProperties": false,
  "properties": {
    "$schema": {"type": "string"},
    "version": {"type": "string"},
    "owner": {"type": "string"},
    "policy": {
      "type": "object",
      "required": ["source_of_truth", "default_mode", "external_frameworks_enabled", "activation_gate"],
      "additionalProperties": false,
      "properties": {
        "source_of_truth": {"type": "string"},
        "default_mode": {"const": "dry-run"},
        "external_frameworks_enabled": {"const": false},
        "activation_gate": {"const": "capability-intake"},
        "notes": {"type": "string"}
      }
    },
    "suites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "domain", "status", "description", "commands", "cases"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "domain": {"type": "string"},
          "status": {"enum": ["enabled", "disabled", "draft"]},
          "description": {"type": "string"},
          "commands": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "command", "timeout_seconds", "required"],
              "additionalProperties": false,
              "properties": {
                "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
                "command": {"type": "array", "minItems": 1, "items": {"type": "string"}},
                "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 600},
                "required": {"type": "boolean"}
              }
            }
          },
          "cases": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "prompt", "expected_keywords", "forbidden_keywords", "risk_tags"],
              "additionalProperties": false,
              "properties": {
                "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
                "prompt": {"type": "string"},
                "expected_keywords": {"type": "array", "minItems": 1, "items": {"type": "string"}},
                "forbidden_keywords": {"type": "array", "items": {"type": "string"}},
                "risk_tags": {"type": "array", "minItems": 1, "items": {"type": "string"}}
              }
            }
          }
        }
      }
    }
  }
}
