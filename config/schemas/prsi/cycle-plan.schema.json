{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PRSI Cycle Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "cycle_id",
    "created_at",
    "objective",
    "hypothesis",
    "risk_class",
    "bottleneck",
    "constraints",
    "acceptance_checks",
    "proposal",
    "rollback"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "cycle_id": { "type": "string", "minLength": 8 },
    "created_at": { "type": "string", "minLength": 10 },
    "objective": { "type": "string", "minLength": 10 },
    "hypothesis": { "type": "string", "minLength": 10 },
    "risk_class": { "type": "string", "enum": ["low", "medium", "high"] },
    "bottleneck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "impact_score", "confidence_score", "reversibility_score"],
      "properties": {
        "id": { "type": "string", "minLength": 3 },
        "description": { "type": "string", "minLength": 10 },
        "impact_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "reversibility_score": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "out_of_scope": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 }
    },
    "acceptance_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description", "metric", "operator", "target"],
        "properties": {
          "id": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 5 },
          "metric": { "type": "string", "minLength": 2 },
          "operator": { "type": "string", "enum": [">=", "<=", "==", "!="] },
          "target": { "type": ["number", "string"] }
        }
      }
    },
    "proposal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "change_type", "files", "expected_kpi_delta"],
      "properties": {
        "summary": { "type": "string", "minLength": 10 },
        "change_type": { "type": "string", "enum": ["knowledge", "maintenance", "routing", "prompt", "workflow"] },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 3 }
        },
        "expected_kpi_delta": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["metric", "direction", "expected_delta"],
            "properties": {
              "metric": { "type": "string", "minLength": 3 },
              "direction": { "type": "string", "enum": ["up", "down"] },
              "expected_delta": { "type": "number" }
            }
          }
        }
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command"],
      "properties": {
        "command": { "type": "string", "minLength": 5 },
        "notes": { "type": "string" }
      }
    }
  }
}
