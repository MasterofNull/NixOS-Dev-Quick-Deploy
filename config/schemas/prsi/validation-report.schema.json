{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PRSI Validation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "cycle_id",
    "executed_at",
    "required_checks",
    "summary",
    "auto_revert_triggered"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "cycle_id": { "type": "string", "minLength": 8 },
    "executed_at": { "type": "string", "minLength": 10 },
    "required_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 3 },
          "status": { "type": "string", "enum": ["pass", "fail", "skip"] },
          "evidence": {
            "type": "array",
            "items": { "type": "string", "minLength": 2 }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pass_count", "fail_count", "skip_count", "required_gate_failures"],
      "properties": {
        "pass_count": { "type": "integer", "minimum": 0 },
        "fail_count": { "type": "integer", "minimum": 0 },
        "skip_count": { "type": "integer", "minimum": 0 },
        "required_gate_failures": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 }
        }
      }
    },
    "auto_revert_triggered": { "type": "boolean" },
    "commands_run": {
      "type": "array",
      "items": { "type": "string", "minLength": 2 }
    }
  }
}
