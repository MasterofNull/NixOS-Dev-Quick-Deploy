      "id": "dashboard-html-js-syntax",
      "description": "dashboard.html inline JS syntax validation",
      "trigger_paths": [
        "dashboard.html"
      ],
      "command": [
        "node",
        "-e",
        "const fs=require('fs');const html=fs.readFileSync('dashboard.html','utf8');const scripts=[...html.matchAll(/<script(?:\\s[^>]*)?>([^]*?)<\\/script>/g)].filter(m=>!/type\\s*=\\s*[\"']?module/i.test(m[0])).map(m=>m[1]).filter(s=>s.trim());scripts.forEach((s,i)=>{try{new Function(s);}catch(e){process.stderr.write('Script block '+i+': '+e.message+'\\n');process.exit(1);}});console.log('Checked '+scripts.length+' non-module script blocks: syntax OK');"
      ],
      "tier": "structural",
      "timeout_seconds": 15,
      "require_tool": "node"
    },
