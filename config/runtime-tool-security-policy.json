{
  "version": "1.0",
  "blocked_tools": [
    "shell_exec",
    "remote_ssh_exec",
    "raw_system_command"
  ],
  "blocked_endpoint_patterns": [
    "/control/*",
    "*/reload-model",
    "*/session/*/mode"
  ],
  "blocked_reason_keywords": [
    "exec",
    "shell",
    "sudo",
    "delete",
    "truncate",
    "drop",
    "overwrite",
    "network egress"
  ],
  "strip_manifest_keys": [
    "exec",
    "command",
    "shell",
    "script",
    "sudo",
    "token",
    "api_key"
  ],
  "blocked_parameter_keys": [
    "exec",
    "command",
    "shell",
    "script",
    "sudo",
    "api_key",
    "token"
  ],
  "max_parameter_string_length": 4096
}
