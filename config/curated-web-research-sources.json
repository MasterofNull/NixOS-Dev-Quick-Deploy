            "article",
            "#content",
            ".content"
          ],
          "purpose": "California-native plant database landing page."
        },
        {
          "name": "calflora-what-grows-here",
          "url": "https://www.calflora.org/entry/wgh.html#srch=t&taxon=Eschscholzia+californica",
          "fetch_mode": "http",
          "fallback_fetch_mode": "browser",
          "selectors": [
            "main",
            "article",
            "#content",
            ".content"
          ],
          "purpose": "Calflora What Grows Here entry point for locality-oriented plant lookup."
        }
      ]
    },
    {
