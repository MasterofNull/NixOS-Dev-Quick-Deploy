{
  "$schema": "./schemas/aq-inference-benchmarks.schema.json",
  "version": "2026-06-29",
  "owner": "mlops-engineering",
  "policy": {
    "source_of_truth": "config/aq-inference-benchmarks.json",
    "default_mode": "dry-run",
    "localhost_only": true,
    "external_runtimes_enabled": false,
    "activation_gate": "capability-intake",
    "notes": "First slice compares local endpoints only. Planned runtimes stay non-executable until capability-intake approval and Nix wiring."
  },
  "backends": [
    {
      "id": "llama-cpp-local",
      "runtime": "llama.cpp",
      "status": "enabled",
      "base_url": "http://127.0.0.1:8080",
      "chat_path": "/v1/chat/completions",
      "health_path": "/health",
      "metrics_path": "/metrics",
      "service": "llama-cpp.service",
      "authority": ["localhost-model-server-read"],
      "observability": ["ttft_ms", "tokens_per_sec", "context_tokens", "json_valid_rate", "thermal_tier", "memory_pressure"]
    },
    {
      "id": "switchboard-local",
      "runtime": "switchboard",
      "status": "planned",
      "base_url": "http://127.0.0.1:8085",
      "chat_path": "/v1/chat/completions",
      "health_path": "/health",
      "metrics_path": "",
      "service": "ai-switchboard.service",
      "authority": ["localhost-switchboard-read"],
      "observability": ["ttft_ms", "tokens_per_sec", "context_tokens", "json_valid_rate", "thermal_tier", "memory_pressure"]
    },
    {
      "id": "vllm-local",
      "runtime": "vLLM",
      "status": "planned",
      "base_url": "http://127.0.0.1:18080",
      "chat_path": "/v1/chat/completions",
      "health_path": "/health",
      "metrics_path": "/metrics",
      "service": "vllm-local.service",
      "authority": ["capability-intake-required"],
      "observability": ["ttft_ms", "tokens_per_sec", "context_tokens", "json_valid_rate", "thermal_tier", "memory_pressure"]
    },
    {
      "id": "sglang-local",
      "runtime": "SGLang",
      "status": "planned",
      "base_url": "http://127.0.0.1:18081",
      "chat_path": "/v1/chat/completions",
      "health_path": "/health",
      "metrics_path": "/metrics",
      "service": "sglang-local.service",
      "authority": ["capability-intake-required"],
      "observability": ["ttft_ms", "tokens_per_sec", "context_tokens", "json_valid_rate", "thermal_tier", "memory_pressure"]
    },
    {
      "id": "ollama-local",
      "runtime": "Ollama",
      "status": "planned",
      "base_url": "http://127.0.0.1:11434",
      "chat_path": "/v1/chat/completions",
      "health_path": "/api/tags",
      "metrics_path": "",
      "service": "ollama.service",
      "authority": ["capability-intake-required"],
      "observability": ["ttft_ms", "tokens_per_sec", "context_tokens", "json_valid_rate", "thermal_tier", "memory_pressure"]
    },
    {
      "id": "mlx-local",
      "runtime": "MLX",
      "status": "planned",
      "base_url": "http://127.0.0.1:18082",
      "chat_path": "/v1/chat/completions",
      "health_path": "/health",
      "metrics_path": "",
      "service": "mlx-local.service",
      "authority": ["capability-intake-required"],
      "observability": ["ttft_ms", "tokens_per_sec", "context_tokens", "json_valid_rate", "thermal_tier", "memory_pressure"]
    }
  ],
  "cases": [
    {
      "id": "exact-short-answer",
      "prompt": "Reply with exactly: INFERENCE_BENCH_OK",
      "max_tokens": 12,
      "validation": "exact:INFERENCE_BENCH_OK"
    },
    {
      "id": "strict-json",
      "prompt": "Return valid JSON only with keys \"decision\" and \"reason\". Use decision=\"hold\".",
      "max_tokens": 80,
      "validation": "json_object_keys:decision,reason"
    }
  ]
}
