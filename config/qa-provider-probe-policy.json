      "argv": ["codex", "--help"]
    },
    {
      "provider_id": "qwen",
      "profile_id": "qwen_help",
      "mode": "exit_only",
      "executable": "qwen",
      "argv": ["qwen", "--help"]
    },
    {
      "provider_id": "claude",
      "profile_id": "claude_help",
      "mode": "exit_only",
      "executable": "claude",
      "argv": ["claude", "--help"]
    },
    {
      "provider_id": "pi",
      "profile_id": "pi_help",
      "mode": "exit_only",
      "executable": "pi",
      "argv": ["pi", "--help"]
    }
  ]
}
