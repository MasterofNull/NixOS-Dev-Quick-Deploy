#!/usr/bin/env bash
set -euo pipefail

if ! command -v git >/dev/null 2>&1; then
  echo "pre-commit: git not found" >&2
  exit 1
fi

echo "Running pre-commit validation..."

run_secret_scan() {
  # Phase 11.4.1 — block likely secrets from entering git history.
  # Skip if SKIP_SECRET_SCAN=1 (for development/testing workflows)
  if [[ "${SKIP_SECRET_SCAN:-0}" == "1" ]]; then
    echo "pre-commit: secret scan skipped (SKIP_SECRET_SCAN=1)"
    return 0
  fi

  local regexes=(
    'sk-[A-Za-z0-9]{48}'
    '-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----'
    'AKIA[0-9A-Z]{16}'
    'ghp_[A-Za-z0-9]{36,}'
  )

  local placeholder_regexes=(
    'AKIAIOSFODNN7EXAMPLE'
    'sk-(test|live|proj)-(example|dummy|fake|placeholder|test)[A-Za-z0-9_-]*'
    'ghp_(example|dummy|fake|placeholder|sample|test)[A-Za-z0-9_]*'
  )

  # Path patterns excluded from secret scanning (test fixtures, docs, examples)
  local excluded_paths=(
    'tests/fixtures/*'
    'tests/*/fixtures/*'
    '*/test_*.py'
    '*_test.go'
    '*.test.js'
    '*.test.ts'
    'docs/examples/*'
    '*.example'
    '*.sample'
    'config/*.example.*'
  )

  local files
  local blocked=0
  mapfile -t files < <(git diff --cached --name-only --diff-filter=ACM)
  [[ ${#files[@]} -eq 0 ]] && return 0

  for file in "${files[@]}"; do
    # Check if file matches any excluded path pattern
    local excluded=0
    for pattern in "${excluded_paths[@]}"; do
      # shellcheck disable=SC2053  # Glob matching is intentional here
      if [[ "$file" == $pattern ]]; then
        excluded=1
        break
      fi
    done
    [[ "$excluded" -eq 1 ]] && continue

    if ! git cat-file -e ":${file}" 2>/dev/null; then
      continue
    fi

    local added_lines
    added_lines="$(
      git diff --cached --unified=0 --no-color -- "$file" \
        | rg '^\+[^+]' \
        | sed 's/^+//' || true
    )"
    [[ -z "${added_lines}" ]] && continue

    for re in "${regexes[@]}"; do
      local matches
      matches=$(printf '%s\n' "${added_lines}" | rg -n --pcre2 "${re}" 2>/dev/null || true)
      if [[ -n "$matches" ]]; then
        local real_matches
        real_matches="$matches"

        local exempt_re
        for exempt_re in "${placeholder_regexes[@]}"; do
          real_matches=$(printf '%s\n' "${real_matches}" | rg -v --pcre2 "${exempt_re}" 2>/dev/null || true)
          [[ -z "${real_matches}" ]] && break
        done

        if [[ -n "${real_matches}" ]]; then
          real_matches=$(printf '%s\n' "${real_matches}" | grep -viE '(nosec|example|test|placeholder|fake|dummy|sample|xxx)' || true)
        fi

        if [[ -n "$real_matches" ]]; then
          echo "pre-commit: blocked potential secret in staged file '${file}' (pattern: ${re})" >&2
          printf '%s\n' "$real_matches" | head -3 >&2
          blocked=1
        fi
      fi
    done
  done

  if [[ "${blocked}" -ne 0 ]]; then
    cat >&2 <<'EOF'
Commit blocked by secret scanner.
Fix:
  1. Remove/redact the secret from staged files
  2. Re-stage changes
  3. Re-commit

To mark intentional test/example values, add one of these to the line:
  # nosec, example, test, placeholder, fake, dummy, sample

To skip secret scan entirely (development only):
  SKIP_SECRET_SCAN=1 git commit -m "message"
EOF
    return 1
  fi

  return 0
}

run_shell_validation() {
  local lint_script="scripts/governance/lint-color-echo-usage.sh"
  if [[ ! -f "${lint_script}" ]]; then
    echo "⚠ Warning: lint-color-echo-usage.sh not found, skipping shell echo validation"
    return 0
  fi

  chmod +x "${lint_script}"
  if ! "${lint_script}" --staged; then
    cat >&2 <<'EOF'
Commit blocked: shell script validation failed.
Some echo commands with color codes are missing -e.
Run: ./scripts/governance/lint-color-echo-usage.sh --staged
EOF
    return 1
  fi

  return 0
}

run_syntax_check() {
  # Phase 21.2 — block staged files with parse errors.
  local staged_files issues=0
  mapfile -t staged_files < <(git diff --cached --name-only --diff-filter=ACM)
  [[ ${#staged_files[@]} -eq 0 ]] && return 0

  for file in "${staged_files[@]}"; do
    [[ -f "$file" ]] || continue
    case "$file" in
      *.sh|*.bash)
        if ! bash -n "$file" 2>/dev/null; then
          echo "pre-commit: bash syntax error in '${file}'" >&2
          bash -n "$file" 2>&1 | head -5 >&2
          issues=1
        fi
        ;;
      *.py)
        if ! python3 -m py_compile "$file" 2>/dev/null; then
          echo "pre-commit: python syntax error in '${file}'" >&2
          python3 -m py_compile "$file" 2>&1 | head -5 >&2
          issues=1
        fi
        ;;
      *.nix)
        if command -v nix-instantiate >/dev/null 2>&1; then
          if ! nix-instantiate --parse "$file" >/dev/null 2>&1; then
            echo "pre-commit: nix parse error in '${file}'" >&2
            nix-instantiate --parse "$file" 2>&1 | head -5 >&2
            issues=1
          fi
        fi
        ;;
    esac
  done

  if [[ "$issues" -ne 0 ]]; then
    echo "pre-commit: fix syntax errors above, then re-stage and commit." >&2
    return 1
  fi
  return 0
}

run_repo_structure_validation() {
  if [[ ! -x "scripts/governance/repo-structure-lint.sh" ]]; then
    echo "⚠ Warning: repo-structure-lint not found, skipping structure validation"
    return 0
  fi

  if ! ./scripts/governance/repo-structure-lint.sh --staged; then
    cat >&2 <<'EOF'
Commit blocked: repository structure policy violation.
New files must follow repo structure policy and avoid root/docs-root/scripts-root sprawl.
Run: ./scripts/governance/repo-structure-lint.sh --staged
EOF
    return 1
  fi
  return 0
}

run_migration_governance_checks() {
  local checks=(
    "scripts/governance/check-repo-allowlist-integrity.sh"
    "scripts/governance/check-root-file-hygiene.sh"
    "scripts/governance/check-generated-artifact-hygiene.sh"
    "scripts/governance/check-doc-links.sh --active"
    "scripts/governance/check-doc-metadata-standards.sh"
    "scripts/governance/check-doc-script-path-migration.sh"
    "scripts/governance/check-script-shim-consistency.sh"
    "scripts/governance/check-archive-path-consistency.sh"
    "scripts/governance/check-legacy-deprecated-root.sh"
  )

  local check_cmd
  for check_cmd in "${checks[@]}"; do
    if ! bash -lc "$check_cmd" >/dev/null 2>&1; then
      echo "pre-commit: governance gate failed: ${check_cmd}" >&2
      echo "Run manually to inspect: ${check_cmd}" >&2
      return 1
    fi
  done

  return 0
}

run_secret_scan
run_shell_validation
run_syntax_check
run_repo_structure_validation
run_migration_governance_checks

exit 0
