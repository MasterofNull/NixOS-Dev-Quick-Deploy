#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "${ROOT_DIR}"

run_upstream_sync_check() {
  if [[ "${SKIP_PRE_PUSH_SYNC_CHECK:-false}" == "true" ]]; then
    echo "pre-push: SKIP_PRE_PUSH_SYNC_CHECK=true -> skipping upstream sync check"
    return 0
  fi

  if ! command -v git >/dev/null 2>&1; then
    echo "pre-push: git not found" >&2
    return 1
  fi

  local current_branch upstream_ref remote_name upstream_branch behind_count ahead_count

  current_branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
  [[ -n "${current_branch}" ]] || return 0

  upstream_ref="$(git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null || true)"
  [[ -n "${upstream_ref}" ]] || return 0

  remote_name="${upstream_ref%%/*}"
  upstream_branch="${upstream_ref#*/}"

  echo "Running pre-push upstream sync check..."
  git fetch --quiet "${remote_name}"

  read -r behind_count ahead_count < <(git rev-list --left-right --count "${upstream_ref}...HEAD")
  if [[ "${behind_count}" -gt 0 ]]; then
    cat >&2 <<EOF
pre-push: local branch '${current_branch}' is behind '${upstream_ref}' by ${behind_count} commit(s).
Sync before pushing:
  git pull --rebase --autostash ${remote_name} ${upstream_branch}

Then re-run your push.

If you need to inspect divergence first:
  git log --oneline --left-right ${upstream_ref}...HEAD

Temporary bypass (not recommended):
  SKIP_PRE_PUSH_SYNC_CHECK=true git push
EOF
    return 1
  fi

  return 0
}

if [[ "${SKIP_PRE_PUSH_LINT:-false}" == "true" ]]; then
  echo "pre-push: SKIP_PRE_PUSH_LINT=true -> skipping quick lint gate"
  exit 0
fi

if [[ ! -x "scripts/governance/quick-deploy-lint.sh" ]]; then
  echo "pre-push: missing scripts/governance/quick-deploy-lint.sh" >&2
  exit 1
fi

run_upstream_sync_check

echo "Running pre-push quick lint gate..."
./scripts/governance/quick-deploy-lint.sh --mode fast
