+def enforce_retention_policy(telemetry_root: Path, pointer_path: Path, repo_root_path: Path) -> None:
+    import json as _json
+    import time
+    from datetime import datetime, timezone
+
+    pointer_target = None
+    if pointer_path.exists():
+        try:
+            curr_data = _json.loads(pointer_path.read_text(encoding="utf-8"))
+            if "target_path" in curr_data:
+                pointer_target = (repo_root_path / curr_data["target_path"]).resolve()
+        except Exception:
+            pass
+
+    artifacts = []
+    for p in telemetry_root.glob("qa-results-*.json"):
+        if pointer_target and p.resolve() == pointer_target:
+            continue
+        try:
+            mtime = p.stat().st_mtime
+            size = p.stat().st_size
+            artifacts.append((p, mtime, size))
+        except Exception:
+            pass
+
+    artifacts.sort(key=lambda x: x[1], reverse=True)
+    now_ts = time.time()
+    seven_days_s = 7 * 24 * 3600
+    to_delete = []
+
+    for idx, (p, mtime, size) in enumerate(artifacts):
+        age_s = now_ts - mtime
+        if idx >= 64 and age_s > seven_days_s:
+            to_delete.append((p, size))
+
+    remaining_artifacts = [item for item in artifacts if item[0] not in [x[0] for x in to_delete]]
+    total_size = 0
+    for p in telemetry_root.glob("*"):
+        try:
+            total_size += p.stat().st_size
+        except Exception:
+            pass
+
+    max_retained_size = 64 * 1024 * 1024
+    while total_size > max_retained_size and remaining_artifacts:
+        p, mtime, size = remaining_artifacts.pop()
+        to_delete.append((p, size))
+        total_size -= size
+
+    deletion_log = telemetry_root / "deletion-evidence.jsonl"
+    for p, size in to_delete:
+        try:
+            p.unlink()
+            log_entry = {
+                "event": "artifact_pruned",
+                "filename": p.name,
+                "timestamp": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
+                "size_bytes": size
+            }
+            with open(deletion_log, "a", encoding="utf-8") as f:
+                f.write(_json.dumps(log_entry) + "\n")
+        except Exception:
+            pass
+
+
