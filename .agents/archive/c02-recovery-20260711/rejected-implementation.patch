+def resolve_telemetry_root() -> Path:
+    """Resolve the canonical telemetry root.
+
+    Checks AQ_TELEMETRY_ROOT environment variable first.
+    Falls back to `/var/lib/ai-stack/hybrid/telemetry` if it exists.
+    Otherwise falls back to `<repo_root>/.agents/telemetry`.
+    """
+    env_root = os.getenv("AQ_TELEMETRY_ROOT")
+    if env_root:
+        return Path(env_root).resolve()
+
+    deployed_dir = Path("/var/lib/ai-stack/hybrid/telemetry")
+    if deployed_dir.exists():
+        return deployed_dir.resolve()
+
+    return (repo_root() / ".agents" / "telemetry").resolve()
+
+
+def check_telemetry_root_divergence() -> None:
+    """Ensure there is no path divergence between dev and deployed defaults.
+
+    If both `/var/lib/ai-stack/hybrid/telemetry` and `<repo_root>/.agents/telemetry`
+    exist, and are not the same physical directory, raise PathDivergenceError.
+    """
+    if os.getenv("AQ_TELEMETRY_ROOT"):
+        return
+
+    deployed_dir = Path("/var/lib/ai-stack/hybrid/telemetry")
+    dev_dir = Path(repo_root() / ".agents" / "telemetry")
+
+    if deployed_dir.exists() and dev_dir.exists():
+        try:
+            if deployed_dir.resolve() != dev_dir.resolve():
+                raise PathDivergenceError("TELEMETRY_ROOT_DIVERGENCE")
+        except Exception as e:
+            if not isinstance(e, PathDivergenceError):
+                raise PathDivergenceError("TELEMETRY_ROOT_DIVERGENCE") from e
+            raise
+
+
+
 def repo_event_path(root: Path | None = None) -> Path:
     """Return the repo-local canonical agent-run event spool."""
     return (root or repo_root()) / ".agents" / "telemetry" / "agent-run-events.jsonl"
