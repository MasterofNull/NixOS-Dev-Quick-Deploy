# Version tracking
.nixos-quick-deploy-version
.nixos-deploy-last-backup

# Git metadata that should not be versioned
ai-stack/mcp-servers/hybrid-coordinator/venv/

# Python bytecode
__pycache__/
*.pyc

# ==============================================================================
# Secrets and credentials — NEVER commit (Phase 11.4.3)
# Rotate immediately if any of these are accidentally committed.
# Use: git rm --cached <file> then rotate the credential.
# ==============================================================================
*.key
*.pem
*.p12
*.pfx
*.crt
*.csr
*.age
age.key
id_rsa
id_ed25519
id_ecdsa
secrets.yaml
secrets.json
secrets.toml
*.sops.yaml

# Local secrets (generated)
ai-stack/compose/secrets/*
!ai-stack/compose/secrets/.gitkeep

# ==============================================================================
# Reports and Session Logs (stored in database, not repo)
# ==============================================================================

# All session reports and deployment logs should go to database.
# Scope these patterns to repository root so docs/** remains trackable.
/*-SUMMARY*.md
/*-COMPLETE*.md
/*-FIX*.md
/*-FIXES*.md
/*-IMPLEMENTATION*.md
/*-UPGRADE*.md
/*-DEPLOYMENT*.md
/*-SESSION*.md
/*-WORK*.md
/*-PROGRESS*.md
/*-ERROR*.md
/*-DEBUG*.md
/*-CONTAINER-*.md
/*-MIGRATION*.md

# Exception: Keep README and core documentation
!README.md
!CONTRIBUTING.md
!LICENSE.md
!HOSPITAL-DEPLOYMENT-STATUS.md
!SYSTEM-UPGRADE-ROADMAP.md
!SYSTEM-UPGRADE-ROADMAP-UPDATES.md
!.github/
!.github/**
!docs/**/*.md

# Fallback reports directory (when database unavailable)
.reports/
/reports/
/artifacts/

# Eval runtime artifacts (generated; stored outside repo by default)
ai-stack/eval/results/eval-*.json
ai-stack/eval/results/eval-*-summary.txt
ai-stack/eval/results/scores.sqlite
dist/harness-sdk-provenance/provenance.json
data/prsi-artifacts/*-latest.json
data/prsi-artifacts/runs/

# ==============================================================================
# Federated Learning Data Policy
# ==============================================================================

# Runtime data directories (NOT for federation - too large, system-specific)
.local/
**/nixos-system-dashboard/
**/nixos-ai-stack/telemetry/aidb-events.jsonl
**/nixos-ai-stack/telemetry/hybrid-events.jsonl
data/registry/
data/dashboard/
data/hybrid/

# BUT: Keep federated learning data in repo
!data/
!data/patterns/
!data/fine-tuning/
!data/collections/
!data/telemetry/snapshots/
!data/metrics/

# Temporary and backup files in data/
data/**/*.tmp
data/**/*.bak
data/**/*.backup

# Keep README files
!data/**/README.md
!data/**/.gitkeep
