*.lean-ctx.bak
LEAN-CTX.md
.cursorrules
ai-stack/local-agents/.agent/
ai-stack/local-agents/.agents/
.agents/improvement/candidates.lock

# ==============================================================================
# Agent collaboration runtime outputs — only validated code/docs in repo
# Most delegation/spool paths are covered above; these fill the remaining gaps.
# ==============================================================================

# Bench run data (generated per run; PROMOTED file tracks current state)
.agents/bench/**/run-*.json

# Pure-date archive dirs created by Rule 12 (No Delete — ARCHIVE).
# Named archives like 20260531-docs/ are preserved for historical reference;
# bare YYYYMMDD/ directories are ephemeral stray-file captures.
.agent/archive/[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]/

# Workflow optimization baseline/optimized JSON snapshots (generated; not source)
.agent/workflows/optimization-reports/

# profile lock files from delegate-to-antigravity (fcntl runtime locks)
.agents/delegation/*.lock

# Capability intake audit cache (runtime state)
.cache/capability-intake-tool-audit-cache.json

# Understand-Anything local scratch; knowledge-graph.json may be committed intentionally.
.understand-anything/intermediate/
.understand-anything/tmp/
.understand-anything/ua-batch-processor.py
.understand-anything/diff-overlay.json
.understand-anything/.trash-*/

# Volatile per-run metadata for harness-prompt-extensions (see training_ingest.py)
config/.harness-prompt-ext.meta.json

# Generated per-machine quickstart (aq-quickstart --write)
docs/QUICKSTART.generated.md

# Playwright CLI scratch page dumps (browser-test transient output)
.playwright-cli/

# Generated governance state snapshot (check-state-authorities.py --write)
.agents/governance/state-authorities-latest.json

# Runtime coordination state for the antigravity inbox (churns per drop)
.agent/collaboration/antigravity-inbox/.lane-state.json

# Quarantined rejected-collector evidence — retained on disk for audit, never committed
# (see .agents/plans/aqos-refoundation-cycle0/evidence/rejected/DISPOSITION.md)
.agents/plans/aqos-refoundation-cycle0/evidence/rejected/c0.3-antigravity-unauthorized-collector.py
.agents/plans/aqos-refoundation-cycle0/evidence/rejected/c0.3-antigravity-unauthorized-collector.py.gz

