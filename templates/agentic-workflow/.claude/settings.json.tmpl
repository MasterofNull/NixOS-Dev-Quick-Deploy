{
  "mcpServers": {
    "ai-stack-harness": {
      "command": "python3",
      "args": [
        "-m",
        "scripts.ai.mcp-bridge-hybrid"
      ],
      "env": {
        "HYBRID_URL": "http://localhost:8003",
        "AIDB_URL": "http://localhost:8002"
      }
    }
  },
  "permissions": {
    "allow": [
      "Bash(aq-hints*)",
      "Bash(aq-report*)",
      "Bash(aqd*)",
      "Bash(git *)",
      "Bash(curl -sf http://localhost:800*)"
    ]
  },
  "hints": {
    "enabled": true,
    "endpoint": "http://localhost:8003/hints",
    "autoFetch": true,
    "minScore": 0.55
  },
  "progressiveDisclosure": {
    "defaultLevel": "overview",
    "escalateOnBlock": true
  }
}
