#!/usr/bin/env python3
# aproc — Agentic Process: Token-optimized process viewer.
#
# Shows only high-resource or project-relevant processes to
# preserve context while monitoring system state.
import sys
import subprocess
import argparse
import re

def main():
    parser = argparse.ArgumentParser(description="Agentic Process: Token-optimized process viewer.")
    parser.add_argument("filter", nargs="?", help="Filter by process name (regex)")
    
    args = parser.parse_args()
    
    try:
        # Get process list with relevant columns
        cmd = ["ps", "-eo", "pid,pcpu,pmem,comm,args", "--sort=-pcpu"]
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        
        lines = result.stdout.splitlines()
        header = lines[0]
        processes = lines[1:]
        
        is_tty = sys.stdout.isatty()
        count = 0
        
        # Default filters to find project-relevant processes
        RELEVANT_PATTERNS = [
            re.compile(r'python|node|llama|postgres|redis|qdrant|agent|bash', re.IGNORECASE)
        ]
        
        if is_tty:
            print(f"\033[1;34m{header}\033[0m")
        else:
            print(header)
            
        for line in processes:
            if args.filter:
                if not re.search(args.filter, line, re.IGNORECASE):
                    continue
            else:
                # Default filter: show only relevant or high-resource processes
                if not any(p.search(line) for p in RELEVANT_PATTERNS):
                    # Check if CPU/MEM usage is significant (> 1.0)
                    parts = line.split()
                    try:
                        cpu = float(parts[1])
                        mem = float(parts[2])
                        if cpu < 1.0 and mem < 1.0:
                            continue
                    except:
                        continue
            
            count += 1
            print(line)
            if count >= 30: # Hard cap for agents
                if is_tty:
                    print("\033[1;33m[... Truncated for token efficiency ...]\033[0m")
                break
                
        if is_tty:
            print(f"\n---\nShown {count} processes.")
            
    except Exception as e:
        print(f"Error listing processes: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
