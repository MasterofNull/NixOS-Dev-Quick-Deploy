#!/usr/bin/env python3
# ahist — Agentic History: Token-optimized git history viewer.
#
# Provides compact, semantic commit logs while stripping terminal
# colors for efficient agentic parsing.
import sys
import subprocess
import argparse
import json

def main():
    parser = argparse.ArgumentParser(description="Agentic History: Token-optimized git history.")
    parser.add_argument("-n", "--count", type=int, default=10, help="Number of commits to show")
    parser.add_argument("--stat", action="store_true", help="Show file stats")
    
    args = parser.parse_args()
    
    # Format: hash | author | date | relative date | message
    fmt = "%C(yellow)%h%Creset | %C(green)%an%Creset | %C(cyan)%ar%Creset | %s"
    git_cmd = ["git", "log", f"-n{args.count}", f"--pretty=format:{fmt}"]
    
    if args.stat:
        git_cmd.append("--stat")
        
    try:
        result = subprocess.run(git_cmd, capture_output=True, text=True, check=True)
        
        is_tty = sys.stdout.isatty()
        
        if is_tty:
            print(f"\033[1;34mRecent Git History (last {args.count} commits)\033[0m")
            print("-" * 60)
            print(result.stdout)
        else:
            # Strip colors for agents
            clean_output = subprocess.run(["sed", r"s/\x1b\[[0-9;]*m//g"], 
                                         input=result.stdout, capture_output=True, text=True).stdout
            print(clean_output)
            
    except Exception as e:
        print(f"Error reading history: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
