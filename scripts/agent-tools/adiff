#!/usr/bin/env python3
# adiff — Agentic Diff: Token-optimized git diff viewer.
#
# Summarizes changes and collapses large additions/deletions to
# maintain context budget while reviewing code changes.
import sys
import subprocess
import argparse
import re

def summarize_hunk(hunk):
    """Summarize a single diff hunk to reduce tokens."""
    added = [line for line in hunk if line.startswith('+') and not line.startswith('+++')]
    removed = [line for line in hunk if line.startswith('-') and not line.startswith('---')]
    
    if len(added) > 10 or len(removed) > 10:
        return f"    [... Summarized: {len(added)} lines added, {len(removed)} lines removed ...]"
    
    return "\n".join(hunk)

def process_diff(diff_text, compact=True):
    lines = diff_text.splitlines()
    current_file = None
    output = []
    hunk = []
    
    for line in lines:
        if line.startswith('diff --git'):
            if hunk:
                output.append(summarize_hunk(hunk) if compact else "\n".join(hunk))
                hunk = []
            current_file = line.split(' b/')[-1]
            output.append(f"\033[1;32mFile: {current_file}\033[0m")
        elif line.startswith('@@'):
            if hunk:
                output.append(summarize_hunk(hunk) if compact else "\n".join(hunk))
                hunk = []
            output.append(f"  \033[1;34m{line}\033[0m")
        elif line.startswith('+') or line.startswith('-'):
            hunk.append(line)
        elif not line.startswith('index') and not line.startswith('---') and not line.startswith('+++'):
            if hunk:
                output.append(summarize_hunk(hunk) if compact else "\n".join(hunk))
                hunk = []
    
    if hunk:
        output.append(summarize_hunk(hunk) if compact else "\n".join(hunk))
        
    return "\n".join(output)

def main():
    parser = argparse.ArgumentParser(description="Agentic Diff: Token-optimized diff viewer.")
    parser.add_argument("args", nargs="*", help="Arguments to pass to git diff")
    parser.add_argument("--full", action="store_true", help="Show full diff (no summarization)")
    parser.add_argument("--staged", action="store_true", help="Show staged changes")
    
    args = parser.parse_args()
    
    git_cmd = ["git", "diff"]
    if args.staged:
        git_cmd.append("--staged")
    git_cmd.extend(args.args)
    
    try:
        result = subprocess.run(git_cmd, capture_output=True, text=True, check=True)
        if not result.stdout:
            print("No changes found.")
            return
            
        print(process_diff(result.stdout, not args.full))
        
    except subprocess.CalledProcessError as e:
        print(f"Error running git diff: {e.stderr}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
