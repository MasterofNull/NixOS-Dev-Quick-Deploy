"""
    return _write_file(AIDER_MD, content, dry_run, verbose)


def sync_gemini_context(claude_md: str, dry_run: bool, verbose: bool) -> bool:
    """Regenerate .gemini/context.md from CLAUDE.md rules."""
    port_policy = _extract_port_policy(claude_md)
    errors = _extract_recurring_errors(claude_md)
    hw_section = _extract_section(claude_md, "4. Hardware Context (ThinkPad P14s Gen 2a — AMD Ryzen)")

    content = f"""# Project Context — NixOS-Dev-Quick-Deploy

<!-- Phase 19.4.3 — {GENERATED_MARKER} -->
<!-- Last synced: {_now_utc()} from CLAUDE.md -->
<!-- Auto-loaded by Gemini CLI from .gemini/context.md -->

## What This Project Is

