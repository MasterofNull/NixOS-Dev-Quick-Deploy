#!/usr/bin/env python3
"""
sync-agent-instructions — Phase 19.4.4

Regenerates agent-specific instruction files from the project's source of truth:
  - CLAUDE.md   → rules, port policy, workflow standards
  - MEMORY.md   → project state and architectural decisions

Generates/updates:
  - AGENTS.md            Universal agent instructions (Codex, Qwen, any OpenAI-compatible)
  - .aider.md            Aider-specific project conventions
  - .gemini/context.md   Gemini CLI project context

Run after updating CLAUDE.md or MEMORY.md to propagate changes to all agents.

Usage:
  scripts/data/sync-agent-instructions [--dry-run] [--verbose]
"""
from __future__ import annotations

import argparse
import re
import sys
from datetime import datetime, timezone
from pathlib import Path

REPO_ROOT = Path(__file__).parent.parent
CLAUDE_MD  = REPO_ROOT / "CLAUDE.md"
# Authoritative repo copy of agent memory (git-tracked).
# sync_memory_md() keeps this in sync with the live Claude Code location.
MEMORY_MD  = REPO_ROOT / "ai-stack" / "agent-memory" / "MEMORY.md"

# Output files managed by this script
AGENTS_MD         = REPO_ROOT / "AGENTS.md"
AIDER_MD          = REPO_ROOT / ".aider.md"
GEMINI_CONTEXT_MD = REPO_ROOT / ".gemini" / "context.md"

GENERATED_MARKER = "<!-- sync-agent-instructions: auto-generated section -->"
GENERATED_END    = "<!-- sync-agent-instructions: end -->"


def _print_aidb_hint() -> None:
    print("  → run 'bash scripts/data/import-agent-instructions.sh' to push to AIDB (requires AIDB bugs fixed first — see Phase 11 in AI-STACK-QA-PLAN.md)")


def _parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(description="Propagate CLAUDE.md rules to all agent instruction files")
    p.add_argument("--dry-run", action="store_true", help="Print diffs but do not write files")
    p.add_argument("--verbose", "-v", action="store_true", help="Show what changed")
    return p.parse_args()


def _extract_section(text: str, heading: str) -> str:
    """Extract content from a markdown ## heading to the next ## heading."""
    pattern = rf"^## {re.escape(heading)}\n(.*?)(?=\n## |\Z)"
    m = re.search(pattern, text, re.MULTILINE | re.DOTALL)
    return m.group(1).strip() if m else ""


def _extract_table(text: str, heading: str) -> str:
    """Extract a markdown table from a section."""
    section = _extract_section(text, heading)
    table_lines = [l for l in section.splitlines() if l.startswith("|")]
    return "\n".join(table_lines)


def _load_file(path: Path) -> str:
    if not path.exists():
        return ""
    return path.read_text(encoding="utf-8")


def _write_file(path: Path, content: str, dry_run: bool, verbose: bool) -> bool:
    """Write content to path. Returns True if changed."""
    existing = _load_file(path)
    if existing == content:
        if verbose:
            print(f"  [unchanged] {path.relative_to(REPO_ROOT)}")
        return False
    if dry_run:
        print(f"  [would update] {path.relative_to(REPO_ROOT)}")
        return True
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")
    if verbose:
        print(f"  [updated] {path.relative_to(REPO_ROOT)}")
    return True


def _extract_port_policy(claude_md: str) -> str:
    """Extract port and service URL policy from CLAUDE.md §6."""
    section = _extract_section(claude_md, "6. Workflow Standards")
    # Grab the "Port and service URL policy" sub-section
    m = re.search(r"### Port and service URL policy.*?(?=\n### |\Z)", section, re.DOTALL)
    return m.group(0).strip() if m else ""


def _extract_recurring_errors(claude_md: str) -> str:
    return _extract_section(claude_md, "5. Recurring Errors — Quick Reference")


def _extract_nix_rules(claude_md: str) -> str:
    return _extract_section(claude_md, "3. NixOS Module System — Rules Learned the Hard Way")


def _extract_agent_model(claude_md: str) -> str:
    return _extract_section(claude_md, "8. Agent Coordination Model — DEFAULT BEHAVIOR (NON-NEGOTIABLE)")


def _now_utc() -> str:
    return datetime.now(tz=timezone.utc).strftime("%Y-%m-%d %H:%M UTC")


def _build_agents_section(claude_md: str) -> str:
    """Build the project-specific section to inject into AGENTS.md."""
    port_policy = _extract_port_policy(claude_md)
    nix_rules = _extract_nix_rules(claude_md)
    errors = _extract_recurring_errors(claude_md)
    agent_model = _extract_agent_model(claude_md)

    lines = [
        GENERATED_MARKER,
        f"<!-- Last synced: {_now_utc()} from CLAUDE.md -->",
        "",
        "## PROJECT-SPECIFIC RULES — NixOS-Dev-Quick-Deploy (READ FIRST)",
        "",
    ]
    if port_policy:
        lines += ["### Port and URL Policy (Non-Negotiable)", "", port_policy, ""]
    if nix_rules:
        lines += ["### NixOS Module Rules", "", nix_rules, ""]
    if errors:
        lines += ["### Recurring Errors — Quick Fix Reference", "", errors, ""]
    if agent_model:
        lines += ["### Agent Coordination Model", "", agent_model, ""]
    lines += [GENERATED_END]
    return "\n".join(lines)


def sync_agents_md(claude_md: str, dry_run: bool, verbose: bool) -> bool:
    """Inject/replace the auto-generated section in AGENTS.md."""
    existing = _load_file(AGENTS_MD)
    generated = _build_agents_section(claude_md)

    if GENERATED_MARKER in existing:
        # Replace between markers
        new_content = re.sub(
            rf"{re.escape(GENERATED_MARKER)}.*?{re.escape(GENERATED_END)}",
            generated,
            existing,
            flags=re.DOTALL,
        )
    else:
        # Prepend after the first heading block (insert before "**Agent Docs Index**" or similar)
        insert_point = existing.find("\n---\n")
        if insert_point != -1:
            new_content = existing[: insert_point + 5] + "\n" + generated + "\n" + existing[insert_point + 5 :]
        else:
            new_content = generated + "\n\n" + existing

    return _write_file(AGENTS_MD, new_content, dry_run, verbose)


def sync_aider_md(claude_md: str, dry_run: bool, verbose: bool) -> bool:
    """Regenerate .aider.md from CLAUDE.md rules."""
    port_policy = _extract_port_policy(claude_md)
    nix_rules = _extract_nix_rules(claude_md)
    errors = _extract_recurring_errors(claude_md)

    content = f"""# Aider Project Conventions — NixOS-Dev-Quick-Deploy

<!-- Phase 19.4.2 — {GENERATED_MARKER} -->
<!-- Last synced: {_now_utc()} from CLAUDE.md -->

## Critical Rules (enforce for every change)

{port_policy}

{nix_rules}

