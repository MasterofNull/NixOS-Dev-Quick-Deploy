[Unit]
Description=Staggered Repo Parity Database Update
After=network-online.target

[Service]
Type=oneshot
User=hyperd
Group=users
WorkingDirectory=/home/hyperd/Documents/NixOS-Dev-Quick-Deploy
ExecStart=/usr/bin/python3 /home/hyperd/Documents/NixOS-Dev-Quick-Deploy/scripts/automation/update-repo-parity.py
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
