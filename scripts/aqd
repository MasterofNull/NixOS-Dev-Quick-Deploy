#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
AQD_VERSION="0.2.0"

die() {
  echo "ERROR: $*" >&2
  exit 1
}

usage() {
  cat <<'EOF'
AQD CLI - Agent/Skill/MCP command wrapper

Usage:
  aqd --version

  aqd skill validate
  aqd skill quick-validate <skill-path>
  aqd skill init <name> [--path <dir>]
  aqd skill package <skill-path> [output-dir]
  aqd skill bundle-index [skills-dir] [bundles-dir] [index-json]
  aqd skill bundle-install <index-json> <skill-name> [target-dir] [--force]
  aqd skill sign-index [index-json] [private-key] [sig-path]
  aqd skill verify-index [index-json] [public-key] [sig-path]

  aqd mcp scaffold <name> [--type python|deno]
  aqd mcp validate <name>
  aqd mcp test <name>
  aqd mcp evaluate <evaluation-xml> [evaluation-args...]
  aqd mcp logs <name> [-f]
  aqd mcp deploy-aidb

  aqd workflows list
  aqd policy evaluate --profile <name> --task <text> [--tool <name>]
  aqd reasoning route --query <text>
  aqd parity advanced-suite
  aqd parity regression-gate [--offline|--online]
  aqd parity generate-provenance [output-dir]
  aqd parity check-auth
  aqd parity check-slo
  aqd parity check-boot-shutdown
  aqd parity chaos-smoke
  aqd parity cross-client-smoke

Notes:
  - Run from repository root or ensure this script can resolve repo paths.
  - This wrapper is the pinned MCP/skill-to-CLI converter implementation.
EOF
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "required command not found: $1"
}

run_python() {
  local -a args=("$@")

  if command -v python3 >/dev/null 2>&1; then
    python3 "${args[@]}"
    return
  fi

  if command -v nix-shell >/dev/null 2>&1; then
    local cmd="python3"
    local arg
    for arg in "${args[@]}"; do
      cmd+=" $(printf '%q' "$arg")"
    done
    nix-shell -p python3 --run "$cmd"
    return
  fi

  if command -v nix >/dev/null 2>&1; then
    nix --extra-experimental-features "nix-command flakes" shell nixpkgs#python3 --command python3 "${args[@]}"
    return
  fi

  die "required command not found: python3 (and nix fallback unavailable)"
}

run_python_with_yaml() {
  local -a args=("$@")

  if command -v python3 >/dev/null 2>&1; then
    if python3 - <<'PY' >/dev/null 2>&1
import yaml  # noqa: F401
PY
    then
      python3 "${args[@]}"
      return
    fi
  fi

  if command -v nix-shell >/dev/null 2>&1; then
    local cmd="python3"
    local arg
    for arg in "${args[@]}"; do
      cmd+=" $(printf '%q' "$arg")"
    done
    nix-shell -p python3 python3Packages.pyyaml --run "$cmd"
    return
  fi

  if command -v nix >/dev/null 2>&1; then
    nix --extra-experimental-features "nix-command flakes" shell \
      nixpkgs#python3 nixpkgs#python3Packages.pyyaml \
      --command python3 "${args[@]}"
    return
  fi

  die "required dependency missing: python3 + PyYAML (and nix fallback unavailable)"
}

cmd_workflows_list() {
  cat <<'EOF'
Priority workflow set (Phase 27.6):
1. skill validate
2. skill quick-validate
3. skill init
4. skill package
5. skill bundle-index
6. skill bundle-install
7. skill sign-index
8. skill verify-index
9. policy evaluate
10. reasoning route
11. parity advanced-suite
12. parity regression-gate
13. parity generate-provenance
14. parity check-auth
15. parity check-slo
16. parity check-boot-shutdown
17. parity chaos-smoke
18. parity cross-client-smoke
19. mcp scaffold
20. mcp validate
21. mcp evaluate
22. mcp logs
23. mcp deploy-aidb
EOF
}

cmd_skill_validate() {
  "${REPO_ROOT}/scripts/check-skill-source-of-truth.sh"
  "${REPO_ROOT}/scripts/lint-skill-external-deps.sh"
  "${REPO_ROOT}/scripts/validate-skill-references.sh"
  "${REPO_ROOT}/scripts/lint-skill-template.sh"
}

cmd_skill_quick_validate() {
  local skill_path="${1:-}"
  [[ -n "$skill_path" ]] || die "Usage: aqd skill quick-validate <skill-path>"
  run_python_with_yaml "${REPO_ROOT}/.agent/skills/skill-creator/scripts/quick_validate.py" "$skill_path"
}

cmd_skill_init() {
  local name="${1:-}"
  shift || true
  [[ -n "$name" ]] || die "Usage: aqd skill init <name> [--path <dir>]"
  run_python "${REPO_ROOT}/.agent/skills/skill-creator/scripts/init_skill.py" "$name" "$@"
}

cmd_skill_package() {
  local skill_path="${1:-}"
  local output_dir="${2:-}"
  [[ -n "$skill_path" ]] || die "Usage: aqd skill package <skill-path> [output-dir]"
  if [[ -n "$output_dir" ]]; then
    run_python_with_yaml "${REPO_ROOT}/.agent/skills/skill-creator/scripts/package_skill.py" "$skill_path" "$output_dir"
  else
    run_python_with_yaml "${REPO_ROOT}/.agent/skills/skill-creator/scripts/package_skill.py" "$skill_path"
  fi
}

cmd_skill_bundle_index() {
  local skills_dir="${1:-${REPO_ROOT}/.agent/skills}"
  local bundles_dir="${2:-${REPO_ROOT}/dist/skills/bundles}"
  local index_json="${3:-${REPO_ROOT}/dist/skills/index.json}"
  run_python "${REPO_ROOT}/scripts/skill-bundle-registry.py" \
    build-index \
    --skills-dir "$skills_dir" \
    --bundles-dir "$bundles_dir" \
    --index "$index_json"
}

cmd_skill_bundle_install() {
  local index_json="${1:-}"
  local skill_name="${2:-}"
  local target_dir="${3:-${REPO_ROOT}/.agent/skills}"
  shift 3 || true
  [[ -n "$index_json" ]] || die "Usage: aqd skill bundle-install <index-json> <skill-name> [target-dir] [--force]"
  [[ -n "$skill_name" ]] || die "Usage: aqd skill bundle-install <index-json> <skill-name> [target-dir] [--force]"
  run_python "${REPO_ROOT}/scripts/skill-bundle-registry.py" \
    install \
    --index "$index_json" \
    --skill-name "$skill_name" \
    --target-dir "$target_dir" \
    "$@"
}

cmd_skill_sign_index() {
  local index_json="${1:-${REPO_ROOT}/dist/skills/index.json}"
  local private_key="${2:-${REPO_ROOT}/config/keys/skill-registry-private.pem}"
  local sig_path="${3:-${index_json}.sig}"
  "${REPO_ROOT}/scripts/sign-skill-registry.sh" "$index_json" "$private_key" "$sig_path"
}

cmd_skill_verify_index() {
  local index_json="${1:-${REPO_ROOT}/dist/skills/index.json}"
  local public_key="${2:-${REPO_ROOT}/config/keys/skill-registry-public.pem}"
  local sig_path="${3:-${index_json}.sig}"
  "${REPO_ROOT}/scripts/verify-skill-registry.sh" "$index_json" "$public_key" "$sig_path"
}

cmd_policy_evaluate() {
  run_python "${REPO_ROOT}/scripts/evaluate-agent-policy.py" "$@"
}

cmd_reasoning_route() {
  run_python "${REPO_ROOT}/scripts/route-reasoning-mode.py" "$@"
}

cmd_parity_advanced_suite() {
  "${REPO_ROOT}/scripts/run-advanced-parity-suite.sh"
}

cmd_parity_regression_gate() {
  local mode="${1:---offline}"
  "${REPO_ROOT}/scripts/run-harness-regression-gate.sh" "$mode"
}

cmd_parity_generate_provenance() {
  local out_dir="${1:-}"
  if [[ -n "$out_dir" ]]; then
    "${REPO_ROOT}/scripts/generate-harness-sdk-provenance.sh" "$out_dir"
  else
    "${REPO_ROOT}/scripts/generate-harness-sdk-provenance.sh"
  fi
}

cmd_parity_check_auth() {
  "${REPO_ROOT}/scripts/check-api-auth-hardening.sh"
}

cmd_parity_check_slo() {
  "${REPO_ROOT}/scripts/validate-ai-slo-runtime.sh"
}

cmd_parity_check_boot_shutdown() {
  "${REPO_ROOT}/scripts/check-boot-shutdown-integration.sh"
}

cmd_parity_chaos_smoke() {
  "${REPO_ROOT}/scripts/chaos-harness-smoke.sh"
}

cmd_parity_cross_client_smoke() {
  "${REPO_ROOT}/scripts/smoke-cross-client-compat.sh"
}

cmd_mcp_scaffold() {
  local name="${1:-}"
  shift || true
  [[ -n "$name" ]] || die "Usage: aqd mcp scaffold <name> [--type python|deno]"

  local template="python"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --type)
        template="${2:-}"
        shift 2
        ;;
      *)
        die "Unknown option for mcp scaffold: $1"
        ;;
    esac
  done

  case "$template" in
    python|deno)
      ;;
    *)
      die "Invalid scaffold type: $template (expected python|deno)"
      ;;
  esac

  "${REPO_ROOT}/scripts/mcp-server" init -t "$template" "$name"
}

cmd_mcp_test() {
  local name="${1:-}"
  [[ -n "$name" ]] || die "Usage: aqd mcp test <name>"
  "${REPO_ROOT}/scripts/mcp-server" test "$name"
}

cmd_mcp_validate() {
  local name="${1:-}"
  [[ -n "$name" ]] || die "Usage: aqd mcp validate <name>"
  "${REPO_ROOT}/scripts/mcp-server" test "$name"
}

cmd_mcp_evaluate() {
  local eval_file="${1:-}"
  shift || true
  [[ -n "$eval_file" ]] || die "Usage: aqd mcp evaluate <evaluation-xml> [evaluation-args...]"

  # Ensure optional mcp-builder evaluation deps are present before execution.
  if ! run_python - <<'PY' >/dev/null 2>&1
import importlib.util
import sys
missing = [mod for mod in ("anthropic", "mcp") if importlib.util.find_spec(mod) is None]
sys.exit(0 if not missing else 1)
PY
  then
    die "Missing Python deps for MCP evaluation. Install: pip install -r ${REPO_ROOT}/.agent/skills/mcp-builder/scripts/requirements.txt"
  fi

  run_python "${REPO_ROOT}/.agent/skills/mcp-builder/scripts/evaluation.py" "$eval_file" "$@"
}

cmd_mcp_logs() {
  local name="${1:-}"
  shift || true
  [[ -n "$name" ]] || die "Usage: aqd mcp logs <name> [-f]"
  "${REPO_ROOT}/scripts/mcp-server" logs "$@" "$name"
}

cmd_mcp_deploy_aidb() {
  "${REPO_ROOT}/scripts/deploy-aidb-mcp-server.sh"
}

main() {
  local topic="${1:-}"
  local action="${2:-}"
  shift 2 || true

  case "$topic" in
    --version|-V|version)
      echo "aqd ${AQD_VERSION}"
      return 0
      ;;
  esac

  case "${topic}:${action}" in
    skill:validate) cmd_skill_validate "$@" ;;
    skill:quick-validate) cmd_skill_quick_validate "$@" ;;
    skill:init) cmd_skill_init "$@" ;;
    skill:package) cmd_skill_package "$@" ;;
    skill:bundle-index) cmd_skill_bundle_index "$@" ;;
    skill:bundle-install) cmd_skill_bundle_install "$@" ;;
    skill:sign-index) cmd_skill_sign_index "$@" ;;
    skill:verify-index) cmd_skill_verify_index "$@" ;;
    policy:evaluate) cmd_policy_evaluate "$@" ;;
    reasoning:route) cmd_reasoning_route "$@" ;;
    parity:advanced-suite) cmd_parity_advanced_suite "$@" ;;
    parity:regression-gate) cmd_parity_regression_gate "$@" ;;
    parity:generate-provenance) cmd_parity_generate_provenance "$@" ;;
    parity:check-auth) cmd_parity_check_auth "$@" ;;
    parity:check-slo) cmd_parity_check_slo "$@" ;;
    parity:check-boot-shutdown) cmd_parity_check_boot_shutdown "$@" ;;
    parity:chaos-smoke) cmd_parity_chaos_smoke "$@" ;;
    parity:cross-client-smoke) cmd_parity_cross_client_smoke "$@" ;;
    mcp:scaffold) cmd_mcp_scaffold "$@" ;;
    mcp:validate) cmd_mcp_validate "$@" ;;
    mcp:test) cmd_mcp_test "$@" ;;
    mcp:evaluate) cmd_mcp_evaluate "$@" ;;
    mcp:logs) cmd_mcp_logs "$@" ;;
    mcp:deploy-aidb) cmd_mcp_deploy_aidb "$@" ;;
    workflows:list) cmd_workflows_list ;;
    :|help:|--help:|-h:)
      usage
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
