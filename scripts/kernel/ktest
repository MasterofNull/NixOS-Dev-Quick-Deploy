#!/usr/bin/env bash
# ktest - Kernel Test Runner
# Automated testing for Linux kernel builds with QEMU, sparse, and more.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KERNEL_DIR="${KERNEL_DIR:-$HOME/kernel}"
LINUX_DIR="${KERNEL_DIR}/linux"
TEST_DIR="${KERNEL_DIR}/tests"
RESULTS_DIR="${KERNEL_DIR}/results"
ROOTFS_DIR="${KERNEL_DIR}/rootfs"

# AIDB for result tracking
AIDB_ENDPOINT="${AIDB_ENDPOINT:-http://127.0.0.1:8002}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[ktest]${NC} $*"; }
log_ok() { echo -e "${GREEN}[ktest]${NC} $*"; }
log_warn() { echo -e "${YELLOW}[ktest]${NC} $*" >&2; }
log_err() { echo -e "${RED}[ktest]${NC} $*" >&2; }
log_test() { echo -e "${CYAN}[TEST]${NC} $*"; }

# Test result tracking
declare -A TEST_RESULTS
TEST_PASS=0
TEST_FAIL=0
TEST_SKIP=0

record_result() {
    local name="$1"
    local status="$2"
    local message="${3:-}"

    TEST_RESULTS["$name"]="$status"
    case "$status" in
        PASS) ((TEST_PASS++)) ;;
        FAIL) ((TEST_FAIL++)) ;;
        SKIP) ((TEST_SKIP++)) ;;
    esac

    if [[ "$status" == "PASS" ]]; then
        log_ok "✓ ${name}"
    elif [[ "$status" == "FAIL" ]]; then
        log_err "✗ ${name}: ${message}"
    else
        log_warn "○ ${name}: ${message}"
    fi
}

cmd_help() {
    cat <<'EOF'
ktest - Kernel Test Runner

Usage: ktest <command> [options]

Commands:
  all               Run all tests
  boot              Quick boot test in QEMU
  build             Compile test (check for build errors)
  sparse            Static analysis with sparse
  checkpatch        Checkpatch.pl on uncommitted changes
  coccinelle        Run coccinelle semantic patches
  rust              Test Rust kernel module compilation
  selftests         Run kernel selftests subset
  report            Generate test report

Options:
  --kernel PATH     Kernel source directory (default: ~/kernel/linux)
  --arch ARCH       Target architecture (default: x86_64)
  --timeout SECS    Test timeout in seconds (default: 300)
  --verbose         Show detailed output
  --json            Output results as JSON

Examples:
  ktest all                    # Run full test suite
  ktest boot                   # Quick boot test
  ktest sparse --verbose       # Sparse with full output
  ktest rust                   # Test Rust module builds
  ktest report --json          # JSON test report

EOF
}

# ═══════════════════════════════════════════════════════════════════════════
# Test: Boot Test
# ═══════════════════════════════════════════════════════════════════════════

test_boot() {
    local timeout="${1:-120}"
    local kernel="${LINUX_DIR}/arch/x86/boot/bzImage"

    log_test "Running QEMU boot test (timeout: ${timeout}s)..."

    if [[ ! -f "$kernel" ]]; then
        record_result "boot" "SKIP" "Kernel image not found: ${kernel}"
        return 0
    fi

    if ! command -v qemu-system-x86_64 >/dev/null 2>&1; then
        record_result "boot" "SKIP" "QEMU not installed"
        return 0
    fi

    # Create minimal initramfs for boot test
    local initramfs
    initramfs=$(mktemp)
    create_minimal_initramfs "$initramfs"

    # Boot with timeout and capture output
    local boot_log
    boot_log=$(mktemp)

    if timeout "$timeout" qemu-system-x86_64 \
        -kernel "$kernel" \
        -initrd "$initramfs" \
        -append "console=ttyS0 panic=1 init=/init" \
        -nographic \
        -m 512M \
        -enable-kvm \
        -no-reboot 2>&1 | tee "$boot_log" | grep -q "BOOT_SUCCESS"; then
        record_result "boot" "PASS"
    else
        if grep -q "Kernel panic" "$boot_log"; then
            record_result "boot" "FAIL" "Kernel panic during boot"
        elif grep -q "BUG:" "$boot_log"; then
            record_result "boot" "FAIL" "Kernel BUG detected"
        else
            record_result "boot" "FAIL" "Boot did not complete"
        fi
    fi

    rm -f "$initramfs" "$boot_log"
}

create_minimal_initramfs() {
    local output="$1"
    local tmpdir
    tmpdir=$(mktemp -d)

    mkdir -p "$tmpdir"/{bin,dev,proc,sys}

    # Create minimal init script
    cat > "$tmpdir/init" <<'INIT'
#!/bin/sh
mount -t proc proc /proc
mount -t sysfs sys /sys
echo "BOOT_SUCCESS"
exec /bin/sh
INIT
    chmod +x "$tmpdir/init"

    # Copy busybox if available, otherwise create stub
    if command -v busybox >/dev/null 2>&1; then
        cp "$(command -v busybox)" "$tmpdir/bin/"
        ln -s busybox "$tmpdir/bin/sh"
    else
        # Create minimal shell stub
        cat > "$tmpdir/bin/sh" <<'SH'
#!/bin/true
SH
        chmod +x "$tmpdir/bin/sh"
    fi

    # Create initramfs
    (cd "$tmpdir" && find . | cpio -H newc -o 2>/dev/null | gzip) > "$output"
    rm -rf "$tmpdir"
}

# ═══════════════════════════════════════════════════════════════════════════
# Test: Build Test
# ═══════════════════════════════════════════════════════════════════════════

test_build() {
    local config="${1:-defconfig}"
    local jobs="${2:-$(nproc)}"

    log_test "Running build test with ${config}..."

    cd "$LINUX_DIR"

    if [[ ! -f .config ]]; then
        log_info "Generating ${config}..."
        if ! make "$config" >/dev/null 2>&1; then
            record_result "build-config" "FAIL" "Failed to generate config"
            return 1
        fi
        record_result "build-config" "PASS"
    else
        record_result "build-config" "SKIP" "Using existing .config"
    fi

    # Dry-run build to check for errors
    log_info "Building kernel (this may take a while)..."
    local build_log
    build_log=$(mktemp)

    if make -j"$jobs" 2>&1 | tee "$build_log" | tail -20; then
        if grep -q "Error" "$build_log"; then
            record_result "build" "FAIL" "Build errors detected"
        else
            record_result "build" "PASS"
        fi
    else
        record_result "build" "FAIL" "Build failed"
    fi

    rm -f "$build_log"
}

# ═══════════════════════════════════════════════════════════════════════════
# Test: Sparse Static Analysis
# ═══════════════════════════════════════════════════════════════════════════

test_sparse() {
    local target="${1:-kernel/}"

    log_test "Running sparse on ${target}..."

    cd "$LINUX_DIR"

    if ! command -v sparse >/dev/null 2>&1; then
        record_result "sparse" "SKIP" "sparse not installed"
        return 0
    fi

    if [[ ! -f .config ]]; then
        record_result "sparse" "SKIP" "No .config file"
        return 0
    fi

    local sparse_log
    sparse_log=$(mktemp)

    make C=2 "$target" 2>&1 | tee "$sparse_log" | grep -E "(warning|error):" | head -20

    local warnings
    warnings=$(grep -c "warning:" "$sparse_log" 2>/dev/null || echo 0)
    local errors
    errors=$(grep -c "error:" "$sparse_log" 2>/dev/null || echo 0)

    if [[ "$errors" -gt 0 ]]; then
        record_result "sparse" "FAIL" "${errors} errors, ${warnings} warnings"
    elif [[ "$warnings" -gt 50 ]]; then
        record_result "sparse" "WARN" "${warnings} warnings (threshold: 50)"
    else
        record_result "sparse" "PASS"
    fi

    rm -f "$sparse_log"
}

# ═══════════════════════════════════════════════════════════════════════════
# Test: Checkpatch
# ═══════════════════════════════════════════════════════════════════════════

test_checkpatch() {
    log_test "Running checkpatch on uncommitted changes..."

    cd "$LINUX_DIR"

    if [[ ! -x scripts/checkpatch.pl ]]; then
        record_result "checkpatch" "SKIP" "checkpatch.pl not found"
        return 0
    fi

    # Check uncommitted changes
    if ! git diff --quiet; then
        local checkpatch_log
        checkpatch_log=$(mktemp)

        git diff | scripts/checkpatch.pl --no-signoff - 2>&1 | tee "$checkpatch_log"

        local errors
        errors=$(grep -c "ERROR:" "$checkpatch_log" 2>/dev/null || echo 0)
        local warnings
        warnings=$(grep -c "WARNING:" "$checkpatch_log" 2>/dev/null || echo 0)

        if [[ "$errors" -gt 0 ]]; then
            record_result "checkpatch" "FAIL" "${errors} errors, ${warnings} warnings"
        elif [[ "$warnings" -gt 0 ]]; then
            record_result "checkpatch" "PASS" "${warnings} warnings (acceptable)"
        else
            record_result "checkpatch" "PASS"
        fi

        rm -f "$checkpatch_log"
    else
        record_result "checkpatch" "SKIP" "No uncommitted changes"
    fi
}

# ═══════════════════════════════════════════════════════════════════════════
# Test: Rust Module Compilation
# ═══════════════════════════════════════════════════════════════════════════

test_rust() {
    log_test "Testing Rust kernel module compilation..."

    cd "$LINUX_DIR"

    # Check if Rust is configured
    if ! grep -q "CONFIG_RUST=y" .config 2>/dev/null; then
        record_result "rust-config" "SKIP" "CONFIG_RUST not enabled"
        return 0
    fi

    # Check Rust toolchain
    if ! command -v rustc >/dev/null 2>&1; then
        record_result "rust-toolchain" "FAIL" "rustc not found"
        return 1
    fi

    local rust_version
    rust_version=$(rustc --version | awk '{print $2}')
    log_info "Rust version: ${rust_version}"
    record_result "rust-toolchain" "PASS"

    # Check bindgen
    if ! command -v bindgen >/dev/null 2>&1; then
        record_result "rust-bindgen" "FAIL" "bindgen not found"
        return 1
    fi
    record_result "rust-bindgen" "PASS"

    # Try to build Rust samples
    if grep -q "CONFIG_SAMPLES_RUST=y" .config 2>/dev/null; then
        log_info "Building Rust samples..."
        if make samples/rust/ 2>&1 | tail -5; then
            record_result "rust-samples" "PASS"
        else
            record_result "rust-samples" "FAIL" "Rust samples failed to build"
        fi
    else
        record_result "rust-samples" "SKIP" "CONFIG_SAMPLES_RUST not enabled"
    fi
}

# ═══════════════════════════════════════════════════════════════════════════
# Test: Coccinelle Semantic Patches
# ═══════════════════════════════════════════════════════════════════════════

test_coccinelle() {
    local target="${1:-kernel/}"

    log_test "Running coccinelle semantic patches on ${target}..."

    cd "$LINUX_DIR"

    if ! command -v spatch >/dev/null 2>&1; then
        record_result "coccinelle" "SKIP" "coccinelle not installed"
        return 0
    fi

    # Run a subset of important coccinelle scripts
    local cocci_scripts=(
        "scripts/coccinelle/api/ptr_ret.cocci"
        "scripts/coccinelle/null/deref_null.cocci"
        "scripts/coccinelle/free/kfree.cocci"
    )

    local found_issues=0
    for script in "${cocci_scripts[@]}"; do
        if [[ -f "$script" ]]; then
            local output
            output=$(spatch --very-quiet --sp-file "$script" "$target" 2>/dev/null || true)
            if [[ -n "$output" ]]; then
                ((found_issues++))
                log_warn "Issues found by $(basename "$script"):"
                echo "$output" | head -10
            fi
        fi
    done

    if [[ "$found_issues" -gt 0 ]]; then
        record_result "coccinelle" "WARN" "${found_issues} scripts found issues"
    else
        record_result "coccinelle" "PASS"
    fi
}

# ═══════════════════════════════════════════════════════════════════════════
# Test: All Tests
# ═══════════════════════════════════════════════════════════════════════════

cmd_all() {
    log_info "Running full kernel test suite..."
    echo "═══════════════════════════════════════════════════════════"

    local start_time
    start_time=$(date +%s)

    test_checkpatch
    test_sparse "kernel/"
    test_rust
    test_build
    test_boot
    test_coccinelle "kernel/"

    local end_time
    end_time=$(date +%s)
    local duration=$((end_time - start_time))

    echo ""
    echo "═══════════════════════════════════════════════════════════"
    generate_summary "$duration"
}

# ═══════════════════════════════════════════════════════════════════════════
# Report Generation
# ═══════════════════════════════════════════════════════════════════════════

generate_summary() {
    local duration="${1:-0}"

    echo ""
    echo "Test Summary"
    echo "════════════"
    echo "  Passed:  ${TEST_PASS}"
    echo "  Failed:  ${TEST_FAIL}"
    echo "  Skipped: ${TEST_SKIP}"
    echo "  Duration: ${duration}s"
    echo ""

    if [[ "$TEST_FAIL" -gt 0 ]]; then
        log_err "Some tests failed!"
        return 1
    else
        log_ok "All tests passed!"
    fi
}

cmd_report() {
    local format="${1:-text}"

    mkdir -p "$RESULTS_DIR"
    local report_file="${RESULTS_DIR}/report-$(date +%Y%m%d-%H%M%S)"

    if [[ "$format" == "--json" || "$format" == "json" ]]; then
        report_file="${report_file}.json"
        cat > "$report_file" <<EOF
{
    "timestamp": "$(date -Iseconds)",
    "kernel_dir": "${LINUX_DIR}",
    "results": {
        "pass": ${TEST_PASS},
        "fail": ${TEST_FAIL},
        "skip": ${TEST_SKIP}
    },
    "tests": $(declare -p TEST_RESULTS | sed "s/.*'(\(.*\))'.*/{\1}/" | tr -d "'" | sed 's/\[/"/g;s/\]=/": "/g;s/ /", "/g;s/$/"}/')
}
EOF
    else
        report_file="${report_file}.txt"
        {
            echo "Kernel Test Report"
            echo "=================="
            echo "Date: $(date)"
            echo "Kernel: ${LINUX_DIR}"
            echo ""
            echo "Results: ${TEST_PASS} pass, ${TEST_FAIL} fail, ${TEST_SKIP} skip"
            echo ""
            echo "Individual Tests:"
            for test in "${!TEST_RESULTS[@]}"; do
                echo "  ${test}: ${TEST_RESULTS[$test]}"
            done
        } > "$report_file"
    fi

    log_ok "Report saved to ${report_file}"

    # Send to AIDB if available
    if curl -sf "${AIDB_ENDPOINT}/health" >/dev/null 2>&1; then
        curl -sf "${AIDB_ENDPOINT}/kernel/tests" \
            -H "Content-Type: application/json" \
            -d "{\"pass\": ${TEST_PASS}, \"fail\": ${TEST_FAIL}, \"skip\": ${TEST_SKIP}}" \
            >/dev/null 2>&1 || true
    fi
}

# ═══════════════════════════════════════════════════════════════════════════
# Main Dispatch
# ═══════════════════════════════════════════════════════════════════════════

main() {
    local cmd="${1:-help}"
    shift || true

    # Parse global options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --kernel)
                LINUX_DIR="$2"
                shift 2
                ;;
            --verbose)
                set -x
                shift
                ;;
            *)
                break
                ;;
        esac
    done

    case "$cmd" in
        help|--help|-h)
            cmd_help
            ;;
        all)
            cmd_all "$@"
            ;;
        boot)
            test_boot "$@"
            generate_summary
            ;;
        build)
            test_build "$@"
            generate_summary
            ;;
        sparse)
            test_sparse "$@"
            generate_summary
            ;;
        checkpatch)
            test_checkpatch "$@"
            generate_summary
            ;;
        coccinelle)
            test_coccinelle "$@"
            generate_summary
            ;;
        rust)
            test_rust "$@"
            generate_summary
            ;;
        report)
            cmd_report "$@"
            ;;
        *)
            log_err "Unknown command: ${cmd}"
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
