#!/usr/bin/env python3
"""
aq-agent-loop — Run the local Qwen3.6-35B model in a coding agent loop.

Wires together the Phase 11 tool infrastructure (ToolRegistry, LocalAgentExecutor,
file_ops, shell, git tools) so the local model can read files, write changes,
validate, and produce an auditable output summary.

Usage:
    aq-agent-loop --task "implement X in file Y"
    aq-agent-loop --task "..." --output summary.json
    aq-agent-loop --task "..." --fallback
    aq-agent-loop --list-tools

Options:
    --task TEXT        Coding task objective (required unless --list-tools)
    --output FILE      Write JSON result summary to FILE
    --max-calls N      Deprecated compatibility flag; ignored
    --fallback         Allow fallback to remote hybrid-coordinator if local fails
    --llama-url URL    llama.cpp endpoint [default: http://127.0.0.1:8080]
    --timeout SECS     Per-inference timeout in seconds [default: 300]
    --list-tools       Print registered tools and exit
    --help             Show this help
"""

import argparse
import asyncio
import json
import logging
import os
import re
import sys
import time
from datetime import datetime, timezone
from pathlib import Path

# ── path setup ───────────────────────────────────────────────────────────────

_SCRIPT_DIR = Path(__file__).resolve().parent
_REPO_ROOT = _SCRIPT_DIR.parent.parent
_LOCAL_AGENTS = _REPO_ROOT / "ai-stack" / "local-agents"
_BUILTIN_TOOLS = _LOCAL_AGENTS / "builtin_tools"

for _p in [str(_LOCAL_AGENTS), str(_BUILTIN_TOOLS)]:
    if _p not in sys.path:
        sys.path.insert(0, _p)

# ── imports from Phase 11 infrastructure ─────────────────────────────────────

try:
    from harness_paths import AGENT_RUN_EVENTS as _AGENT_RUN_EVENTS_PATH
    from tool_registry import ToolRegistry, get_registry
    from agent_executor import LocalAgentExecutor, Task, AgentType, TaskStatus
    from file_operations import register_file_tools      # noqa: F401 (used via register call)
    from shell_tools import register_shell_tools          # noqa: F401
    from git_tools import register_git_tools              # noqa: F401
except ImportError as e:
    print(f"ERROR: Failed to import Phase 11 tool infrastructure: {e}", file=sys.stderr)
    print(f"  Expected at: {_LOCAL_AGENTS}", file=sys.stderr)
    sys.exit(1)

# ── logging ───────────────────────────────────────────────────────────────────

logging.basicConfig(
    level=logging.WARNING,   # suppress noisy debug from tool registry
    format="[aq-agent-loop] %(levelname)s %(message)s",
)
logger = logging.getLogger(__name__)


# ── helpers ───────────────────────────────────────────────────────────────────

_agent_loop_event_seq: dict[str, int] = {}


async def _async_append_jsonl(path: Path, event: dict) -> None:
    """Append one JSONL event without blocking the agent loop."""
    try:
        def _write() -> None:
            with path.open("a", encoding="utf-8") as _f:
                _f.write(json.dumps(event) + "\n")
        await asyncio.to_thread(_write)
    except Exception:
        pass


async def _emit_agent_event(task_id: str, event_type: str, payload: dict) -> None:
    """Fire-and-forget wrapper event for aq-agent-loop lifecycle."""
    path = Path(os.environ.get("AQ_AGENT_RUN_EVENTS_PATH", str(_AGENT_RUN_EVENTS_PATH)))
    seq = _agent_loop_event_seq.get(task_id, 0) + 1
    _agent_loop_event_seq[task_id] = seq
    event = {
        "task_id": task_id,
        "seq": seq,
        "event_type": event_type,
        "ts": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
        **payload,
    }
    asyncio.create_task(_async_append_jsonl(path, event))
    if event_type in {"agent_complete", "agent_failed"}:
        _agent_loop_event_seq.pop(task_id, None)

_SLIM_TOOLS = frozenset({
    "read_file", "edit_file", "write_file", "run_command",
    "git_add", "git_commit", "store_memory",
    "validate_before_commit",
    # ORIENT/RESEARCH phases — required for grounding before implementation
    "get_hint", "query_aidb",
})


def build_registry(tool_manifest: str = "full") -> ToolRegistry:
    """Create a fresh ToolRegistry populated with coding tools.

    tool_manifest:
      "full"             — all 29 tools (default; research/multi-step tasks)
      "self-improvement" — 10 tools for self-improvement slices:
                           read_file, edit_file, write_file, run_command, git_add, git_commit,
                           store_memory, validate_before_commit, get_hint, query_aidb.
                           Reduces schema from ~2507 tokens to ~750 tokens — saves ~1.8 min/call
                           on Renoir APU (10 tok/s prefill). get_hint/query_aidb enable ORIENT/RESEARCH phases.
    """
    registry = ToolRegistry()
    register_file_tools(registry)
    register_shell_tools(registry)
    register_git_tools(registry)
    from ai_coordination import register_ai_coordination_tools
    register_ai_coordination_tools(registry)
    try:
        from code_execution import register_code_execution_tools
        register_code_execution_tools(registry)
    except ImportError as e:
        logger.warning("[aq-agent-loop] code_execution tools unavailable: %s", e)
    try:
        from github_tools import register_github_tools
        register_github_tools(registry)
    except ImportError as e:
        logger.warning("[aq-agent-loop] github_tools unavailable: %s", e)
    try:
        from testing_tools import register_testing_tools
        register_testing_tools(registry)
    except ImportError as e:
        logger.warning("[aq-agent-loop] testing_tools unavailable: %s", e)
    if tool_manifest == "self-improvement":
        for _tool_name in list(registry.tools):
            if _tool_name not in _SLIM_TOOLS:
                registry.unregister(_tool_name)
    return registry


def list_tools(registry: ToolRegistry) -> None:
    tools = registry.list_tools()
    print(f"\nRegistered tools ({len(tools)} total):\n")
    for t in sorted(tools, key=lambda x: x.name):
        print(f"  {t.name:<30} [{t.safety_policy.value:<16}] {t.description[:70]}")
    print()


def _is_incomplete_result(result: str | None) -> bool:
    text = str(result or "").lower()
    incomplete_markers = (
        "task incomplete:",
        "reached max tool calls",
        "stagnation detected:",
        "exploration stagnation:",
        "file-not-found stagnation:",
        "repeated-read stagnation:",
        "analysis checkpoint stagnation:",
    )
    if any(marker in text for marker in incomplete_markers):
        return True
    normalized = " ".join(text.split())
    thought_count = normalized.count("thought:")
    completion_markers = (
        "completed:",
        "result:",
        "recommendation",
        "ranked",
        "validation",
        "implemented",
        "fixed",
        "commit",
    )
    if thought_count >= 3 and not any(marker in normalized for marker in completion_markers):
        return True
    sentences = [s.strip() for s in re.split(r"(?<=[.!?])\s+", normalized) if s.strip()]
    if thought_count >= 3 and len(set(sentences)) <= max(3, len(sentences) // 2):
        return True
    return False


async def run_task(
    task_text: str,
    output_file: str | None,
    max_calls: int,
    allow_fallback: bool,
    llama_url: str,
    timeout_secs: int,
    role: str | None = None,
    tool_manifest: str = "full",
    task_type: str | None = None,
) -> int:
    """Run the agent loop. Returns 0 on success, 1 on failure."""
    del max_calls  # Deprecated: loops are progress-guarded, not count-guarded.

    # LLAMA_CHUNK_TIMEOUT: per-SSE-chunk read timeout.
    # Long-horizon local tasks may spend a long time in prefill/generation on slow
    # hardware. The parent AgentRunner handles no-progress reaping; this inner
    # stream timeout should avoid killing legitimate overnight/day-long work.
    # The timer only fires if the server goes silent between chunks.
    os.environ["LLAMA_CHUNK_TIMEOUT"] = str(max(14400.0, float(timeout_secs) * 8))
    os.environ["LLAMA_FIRST_TOKEN_TIMEOUT"] = os.environ.get(
        "LLAMA_FIRST_TOKEN_TIMEOUT",
        # Cap at 1800s (30 min) for long-horizon tasks — large-context prefill on Renoir APU
        # can exceed the prior 600s ceiling for full-manifest prompts.
        str(max(120.0, min(1800.0, float(timeout_secs) * 0.5))),
    )
    # Token budget per LLM call. Tool-call JSON fits in 512; analysis/research output
    # needs 1200+ to produce a complete artifact (ranked lists, summaries, COMPLETED: signal).
    # research/deep_reasoning tasks get 2048 to avoid truncated final reports.
    # Slot-lock risk: 2048 @ 1-2 tok/s ≈ 17-34 min worst case — acceptable for overnight runs.
    if not os.environ.get("LLAMA_MAX_TOKENS"):
        _task_type_default = task_type or ""
        if _task_type_default in ("research", "deep_reasoning"):
            os.environ["LLAMA_MAX_TOKENS"] = "2048"
        elif _task_type_default in ("agent", "code", "reasoning"):
            os.environ["LLAMA_MAX_TOKENS"] = "1200"
        else:
            os.environ["LLAMA_MAX_TOKENS"] = "1200"  # upgrade from legacy 512

    # Observability: wire sidecar paths so agent_executor can stream per-step
    # telemetry without knowing the output file path.
    # - AGENT_PROGRESS_FILE: single-JSON state, overwritten after each tool call.
    #   Read by dashboards and dispatch.py watch for live status.
    # - AGENT_STEPS_FILE: append-only JSONL, one line per tool call.
    #   `tail -f <steps_file>` gives real-time tool call stream during execution.
    if output_file:
        os.environ["AGENT_PROGRESS_FILE"] = f"{output_file}.progress.json"
        os.environ["AGENT_STEPS_FILE"] = f"{output_file}.steps.jsonl"
    else:
        import tempfile as _tf
        _tmp_base = _tf.mktemp(prefix="aq-agent-", suffix=".tmp")
        os.environ["AGENT_PROGRESS_FILE"] = f"{_tmp_base}.progress.json"
        os.environ["AGENT_STEPS_FILE"] = f"{_tmp_base}.steps.jsonl"

    registry = build_registry(tool_manifest=tool_manifest)
    if tool_manifest != "full":
        logger.warning("[aq-agent-loop] tool_manifest=%s: %d tools registered", tool_manifest, len(registry.tools))

    executor = LocalAgentExecutor(
        llama_endpoint=llama_url,
        tool_registry=registry,
        enable_fallback=allow_fallback,
        offline_mode=not allow_fallback,
        allow_degraded_local_execution=True,
    )

    task_id = f"aq-{int(time.time())}"
    task = Task(
        id=task_id,
        objective=task_text,
        complexity=0.7,  # treat coding tasks as moderately complex → prefer local
        quality_critical=False,
        role=role,       # None = auto-assign from AGENT_TYPE_DEFAULT_ROLE mapping
        task_type=task_type,  # None = default agent profile; "research"/"deep_reasoning" enable thinking
    )

    print(f"[aq-agent-loop] Task: {task_id}")
    print(f"[aq-agent-loop] Objective: {task_text[:120]}{'...' if len(task_text) > 120 else ''}")
    print("[aq-agent-loop] Tool calls: progress-guarded (no fixed ceiling)")
    print(f"[aq-agent-loop] Fallback: {'enabled' if allow_fallback else 'disabled (local only)'}")
    print(f"[aq-agent-loop] Running...\n")

    start = time.time()
    wrapper_event_task_id = f"{task_id}:aq-agent-loop"
    await _emit_agent_event(
        wrapper_event_task_id,
        "agent_step_start",
        {"tool_call_count": 0},
    )
    result_task = await executor.execute_task(task, AgentType.AGENT)
    elapsed = time.time() - start

    incomplete_result = _is_incomplete_result(result_task.result)
    success = result_task.status in (TaskStatus.COMPLETED, TaskStatus.FALLBACK) and not incomplete_result
    status_label = "failed" if incomplete_result else result_task.status.value
    error_text = result_task.error or ("incomplete result returned by local agent loop" if incomplete_result else None)

    print(f"\n[aq-agent-loop] Status:     {status_label}")
    print(f"[aq-agent-loop] Elapsed:    {elapsed:.1f}s")
    print(f"[aq-agent-loop] Tool calls: {len(result_task.tool_calls_made)}")

    if result_task.degraded_reason:
        print(f"[aq-agent-loop] Note:       {result_task.degraded_reason}")

    if success:
        print(f"\n--- Result ---\n{result_task.result or '(no output)'}\n")
    else:
        print(f"\n--- Error ---\n{error_text or '(unknown error)'}\n", file=sys.stderr)

    if success:
        await _emit_agent_event(
            wrapper_event_task_id,
            "agent_complete",
            {
                "result_preview": str(result_task.result)[:200] if result_task.result is not None else "",
                "run_attempt": len(result_task.tool_calls_made),
            },
        )
        # Bridge into training_ingest pipeline: emit local_inference event so
        # training_ingest.py can extract (query → response) pairs from
        # hybrid-events.jsonl. Agent loop calls llama.cpp directly (not via
        # coordinator delegate path) so local_inference events are never emitted
        # there — this is the only emission point for agent tasks.
        if result_task.result:
            _hybrid_path = Path(os.environ.get(
                "AQ_AGENT_HYBRID_EVENTS_PATH",
                str(_REPO_ROOT / ".agents" / "telemetry" / "hybrid-events.jsonl"),
            ))

            async def _emit_training_signal(
                _q=task_text, _r=result_task.result,
                _lat=round(elapsed * 1000), _tc=len(result_task.tool_calls_made),
            ):
                import datetime as _dt
                _evt = json.dumps({
                    "event_type": "local_inference",
                    "timestamp": _dt.datetime.now(_dt.timezone.utc).isoformat().replace("+00:00", "Z"),
                    "query": _q[:4000],
                    "response": _r[:4000],
                    "model": "local",
                    "latency_ms": _lat,
                    "tool_calls": _tc,
                    "source": "aq-agent-loop",
                })
                try:
                    def _write(_p: Path, _line: str) -> None:
                        with open(_p, "a", encoding="utf-8") as _f:
                            _f.write(_line + "\n")
                    await asyncio.to_thread(_write, _hybrid_path, _evt)
                except Exception:
                    pass  # telemetry is best-effort

            asyncio.create_task(_emit_training_signal())
    else:
        await _emit_agent_event(
            wrapper_event_task_id,
            "agent_failed",
            {
                "error": error_text or "unknown error",
                "run_attempt": len(result_task.tool_calls_made),
            },
        )

    # Write JSON summary
    summary = {
        "task_id": task_id,
        "status": status_label,
        "success": success,
        "incomplete_result": incomplete_result,
        "elapsed_seconds": round(elapsed, 1),
        "tool_calls": [tc.to_dict() for tc in result_task.tool_calls_made],
        "result": result_task.result,
        "error": error_text,
        "degraded_reason": result_task.degraded_reason,
    }

    if output_file:
        Path(output_file).write_text(json.dumps(summary, indent=2, default=str))
        print(f"[aq-agent-loop] Summary written to: {output_file}")

    # Update progress sidecar to final state so dashboards show completion, not "running".
    _progress_path = os.environ.get("AGENT_PROGRESS_FILE")
    if _progress_path:
        try:
            Path(_progress_path).write_text(json.dumps({
                "task_id": summary["task_id"],
                "status": summary["status"],
                "success": summary["success"],
                "tool_call_count": len(summary["tool_calls"]),
                "elapsed_s": summary["elapsed_seconds"],
                "result_preview": (summary["result"] or "")[:200],
                "error": summary["error"],
                "timestamp": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
            }, indent=2))
        except Exception:
            pass

    if not output_file:
        print(f"[aq-agent-loop] (Use --output FILE to save JSON summary)")

    return 0 if success else 1


# ── main ──────────────────────────────────────────────────────────────────────

def main() -> int:
    parser = argparse.ArgumentParser(
        description="Run local Qwen3.6-35B in a coding agent loop",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        add_help=True,
    )
    parser.add_argument("--task",       help="Coding task objective")
    parser.add_argument("--output",     help="Write JSON result to this file")
    parser.add_argument("--max-calls",  type=int, default=0, help="Deprecated compatibility flag; ignored")
    parser.add_argument("--fallback",   action="store_true", help="Allow remote fallback if local fails")
    parser.add_argument("--llama-url",  default=os.environ.get("LLAMA_URL", "http://127.0.0.1:8080"))
    parser.add_argument("--timeout",    type=int, default=300, help="Per-inference timeout (seconds) [default: 300]")
    parser.add_argument("--role",       default=None,
                        choices=["orchestrator", "architect", "implementer", "reviewer"],
                        help="Authority role injected into system prompt (default: auto from AgentType mapping)")
    parser.add_argument("--list-tools", action="store_true", help="List registered tools and exit")
    parser.add_argument(
        "--task-type",
        default="agent",
        choices=["structured", "lookup", "code", "reasoning", "agent", "research", "deep_reasoning"],
        help=(
            "LLM task profile. Controls temperature, frequency_penalty, and enable_thinking. "
            "'research' enables thinking (100 tok budget, 0.4 temp) for PRSI/discovery tasks. "
            "'deep_reasoning' enables thinking (150 tok budget, 0.5 temp) for planning tasks. "
            "Default: 'agent' (frequency_penalty=0.0, temperature=0.3 — prevents JSON truncation)."
        ),
    )
    parser.add_argument(
        "--tool-manifest",
        default="full",
        choices=["full", "self-improvement"],
        help=(
            "Tool set to expose to the model. "
            "'full' = all 29 tools (default). "
            "'self-improvement' = 10 tools (adds get_hint/query_aidb for ORIENT/RESEARCH phases); "
            "reduces schema from ~2507 to ~750 tokens — saves ~1750 tokens per prefill call."
        ),
    )

    args = parser.parse_args()

    if args.list_tools:
        list_tools(build_registry(tool_manifest=getattr(args, "tool_manifest", "full")))
        return 0

    if not args.task:
        parser.error("--task is required (or use --list-tools)")

    return asyncio.run(run_task(
        task_text=args.task,
        output_file=args.output,
        max_calls=args.max_calls,
        allow_fallback=args.fallback,
        llama_url=args.llama_url,
        timeout_secs=args.timeout,
        role=args.role,
        tool_manifest=args.tool_manifest,
        task_type=args.task_type,
    ))


if __name__ == "__main__":
    sys.exit(main())
