_OUTPUTS_DIR = _DELEGATION_DIR / "outputs"
_REGISTRY = _DELEGATION_DIR / "registry.jsonl"
_PENDING_UPDATE = _HERE / "lib" / "pending-update"
_AUDIT_WRITE = _HERE / "lib" / "audit-write.sh"

# ── runtime configuration ──────────────────────────────────────────────────
# Port sourced from env; default matches nix/modules/core/options.nix switchboard default.
_SWITCHBOARD_URL = os.environ.get("SWITCHBOARD_URL", "http://127.0.0.1:8085").rstrip("/")

# ── constants ──────────────────────────────────────────────────────────────
_MIN_CONTENT_BYTES = 200
_MAX_CONCURRENT    = 3

# Maps --mode to switchboard profile names.
