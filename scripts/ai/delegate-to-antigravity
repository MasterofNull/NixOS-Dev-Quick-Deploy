)

def _load_harness_grounding() -> str:
    gf = _REPO / "config" / "local-agent-grounding.md"
    try:
        return gf.read_text().strip()
    except OSError:
        return ""

def _build_harness_system() -> str:
    grounding = _load_harness_grounding()
    if grounding:
        return _HARNESS_SYSTEM_BASE + "\n\n" + grounding + "\n"
    return _HARNESS_SYSTEM_BASE

_HARNESS_SYSTEM = _build_harness_system()

# ── switchboard readiness ──────────────────────────────────────────────────

def _check_switchboard_ready() -> "tuple[bool, str]":
    """Returns (is_ready, reason). Verifies switchboard is up and remote is configured."""
    try:
        req = urllib.request.Request(f"{_SWITCHBOARD_URL}/health")
        with urllib.request.urlopen(req, timeout=5) as resp:
            data = json.loads(resp.read())
    except (urllib.error.URLError, socket.timeout, OSError) as e:
        return False, (
            f"Switchboard not reachable at {_SWITCHBOARD_URL}: {e}\n"
            "Ensure ai-switchboard service is running."
        )
    except Exception as e:
        return False, f"Switchboard health check failed: {e}"

    if data.get("status") != "ok":
        return False, f"Switchboard status={data.get('status')!r}"

    if not data.get("remote_configured"):
        return False, (
            "Switchboard remote backend not configured.\n"
            "Set mySystem.ai.switchboard.remoteUrl in deploy-options.local.nix,\n"
            "then rebuild: sudo nixos-rebuild switch --flake .#hyperd-ai-dev"
        )

    return True, "switchboard healthy, remote configured"

# ── response parsing ───────────────────────────────────────────────────────

def _parse_switchboard_response(raw: bytes) -> "tuple[str, int, int]":
    """Parse switchboard response (JSON or SSE). Returns (content, tokens_in, tokens_out)."""
    text = raw.decode(errors="replace").strip()

    # SSE stream — collect content deltas and final usage chunk
    if text.startswith("data: "):
        parts: list[str] = []
        tokens_in = tokens_out = 0
        for line in text.splitlines():
            if not line.startswith("data: ") or line == "data: [DONE]":
                continue
            try:
                chunk = json.loads(line[6:])
                delta = chunk.get("choices", [{}])[0].get("delta", {})
                if "content" in delta and delta["content"]:
                    parts.append(delta["content"])
                usage = chunk.get("usage") or {}
                if usage.get("prompt_tokens"):
                    tokens_in = usage["prompt_tokens"]
                if usage.get("completion_tokens"):
                    tokens_out = usage["completion_tokens"]
            except (json.JSONDecodeError, IndexError, KeyError):
                pass
        return "".join(parts).strip(), tokens_in, tokens_out

    # Regular JSON completion
    try:
        data = json.loads(text)
    except json.JSONDecodeError as e:
        raise ValueError(f"Unexpected response format (not JSON, not SSE): {e}") from e

    if "error" in data:
        err = data["error"]
        raise ValueError(f"Switchboard error: {err.get('message', err)}")

    content = (
        data.get("choices", [{}])[0]
            .get("message", {})
            .get("content", "")
        or ""
    ).strip()

    usage = data.get("usage") or {}
    tokens_in  = usage.get("prompt_tokens", 0)
    tokens_out = usage.get("completion_tokens", 0)
    return content, tokens_in, tokens_out

# ── delegation via switchboard ─────────────────────────────────────────────

_MAX_RETRIES    = 4    # increased for free tier stability
_RETRY_BASE_SEC = 35   # matches OpenRouter free-tier Retry-After default
_QUEUE_TIMEOUT  = 300  # max seconds to wait in queue
_QUEUE_POLL_SEC = 5    # interval to re-check queue


def _run_via_switchboard(
    task_id: str,
    prompt: str,
    role: str,
    profile: str,
    timeout: int,
    log_path: Path,
    max_tokens: int = 8192,
    print_to_stdout: bool = False,
) -> "tuple[str, int, int]":
    """POST to switchboard /v1/chat/completions. Returns (status, tokens_in, tokens_out)."""
    url = f"{_SWITCHBOARD_URL}/v1/chat/completions"
    payload = json.dumps({
        "model": profile,
        "messages": [
            {"role": "system", "content": _HARNESS_SYSTEM},
            {"role": "user",   "content": f"[ROLE: {role}]\n\n{prompt}"},
        ],
        "max_tokens": min(max_tokens, 8192),
        "stream": False,
    }).encode()

    def _write_log(msg: str):
        with open(log_path, "a") as f:
            f.write(msg)
        if print_to_stdout:
            sys.stderr.write(msg)

    raw: bytes = b""
    for attempt in range(1, _MAX_RETRIES + 1):
        req = urllib.request.Request(url, data=payload, method="POST")
        req.add_header("Content-Type", "application/json")
        req.add_header("x-ai-profile", profile)   # switchboard profile selection header
        try:
            with urllib.request.urlopen(req, timeout=timeout) as resp:
                raw = resp.read()
            break  # success
        except urllib.error.HTTPError as e:
            body = e.read(2000).decode(errors="replace")
            if e.code == 429 and attempt < _MAX_RETRIES:
                wait = _RETRY_BASE_SEC
                try:
                    err_data = json.loads(body)
                    wait = int(err_data.get("error", {}).get("metadata", {})
                               .get("retry_after_seconds", wait)) + 2
                except (ValueError, KeyError):
                    pass
                _write_log(
                    f"[attempt {attempt}/{_MAX_RETRIES}] 429 rate-limited"
                    f" on profile={profile} — retrying in {wait}s\n"
                )
                time.sleep(wait)
                continue
            _write_log(
                f"ERROR: switchboard HTTP {e.code} on profile={profile}\n"
                f"Body: {body}\n"
                f"Check: is the remote backend configured and reachable?\n"
            )
            return "failed", 0, 0
        except (urllib.error.URLError, socket.timeout, OSError) as e:
            _write_log(
                f"ERROR: switchboard unreachable at {_SWITCHBOARD_URL}: {e}\n"
                "Check: ai-switchboard service running?\n"
            )
            return "failed", 0, 0
    else:
        _write_log(f"ERROR: exhausted {_MAX_RETRIES} retries (all 429) on profile={profile}\n")
        return "failed", 0, 0

    try:
        content, tokens_in, tokens_out = _parse_switchboard_response(raw)
    except ValueError as e:
        _write_log(f"ERROR: {e}\nRaw response (first 500 bytes): {raw[:500]!r}\n")
        return "failed", 0, 0

    if not content:
        _write_log(
            f"ERROR: empty content from switchboard profile={profile}\n"
            f"Raw response (first 500 bytes): {raw[:500]!r}\n"
        )
        return "failed", 0, 0

    with open(log_path, "a") as f:
        f.write(content)
        f.write("\n")
    if print_to_stdout:
        sys.stdout.write(content)
        sys.stdout.write("\n")
        sys.stdout.flush()

    status = "done" if len(content.encode()) >= _MIN_CONTENT_BYTES else "partial-success"
    return status, tokens_in, tokens_out

# ── task id & registry ─────────────────────────────────────────────────────

def _task_id() -> str:
    rand = "".join(random.choices("abcdefghijklmnopqrstuvwxyz0123456789", k=6))
    return f"antigravity-{datetime.now().strftime('%Y%m%d-%H%M%S')}-{rand}"


def _ensure_dirs():
    _OUTPUTS_DIR.mkdir(parents=True, exist_ok=True)
    _REGISTRY.touch(exist_ok=True)


def _registry_append(task_id: str, role: str, description: str, output_file: Path):
    ts = datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")
    entry = {
        "id": task_id, "agent": "antigravity", "role": role,
        "description": description[:200],
        "output_file": str(output_file.relative_to(_REPO)),
        "pid": None, "status": "running",
        "tokens_in": None, "tokens_out": None, "created": ts,
    }
    with open(_REGISTRY, "a") as fh:
        fcntl.flock(fh, fcntl.LOCK_EX)
        fh.write(json.dumps(entry) + "\n")
        fcntl.flock(fh, fcntl.LOCK_UN)


def _registry_set_pid(task_id: str, pid: int):
    _registry_update(task_id, "running", pid=pid)


def _registry_update(task_id: str, status: str, *,
                     tokens_in: "int | None" = None,
                     tokens_out: "int | None" = None,
                     pid: "int | None" = None):
    if not _REGISTRY.exists():
        return
    lines = []
    for line in _REGISTRY.read_text().splitlines():
        if not line.strip():
            continue
        try:
            e = json.loads(line)
            if e.get("id") == task_id:
                e["status"] = status
                if pid is not None:        e["pid"] = pid
                if tokens_in is not None:  e["tokens_in"] = tokens_in
                if tokens_out is not None: e["tokens_out"] = tokens_out
            lines.append(json.dumps(e))
        except Exception:
            lines.append(line)
    with open(_REGISTRY, "w") as fh:
        fcntl.flock(fh, fcntl.LOCK_EX)
        fh.write("\n".join(lines) + "\n")
        fcntl.flock(fh, fcntl.LOCK_UN)


def _pid_alive(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except (ProcessLookupError, PermissionError):
        return False


def _count_running() -> int:
    if not _REGISTRY.exists():
        return 0
    count = 0
    for line in _REGISTRY.read_text().splitlines():
        try:
            e = json.loads(line)
            if e.get("agent") == "antigravity" and e.get("status") == "running":
                pid = e.get("pid")
                if pid and _pid_alive(int(pid)):
                    count += 1
        except Exception:
            pass
    return count


def _wait_in_queue(task_id: str):
    """Wait until running count is below _MAX_CONCURRENT."""
    start_wait = time.time()
    while True:
        running = _count_running()
        if running < _MAX_CONCURRENT:
            return
        elapsed = time.time() - start_wait
        if elapsed > _QUEUE_TIMEOUT:
            sys.exit(f"ERROR: Task {task_id} timed out waiting in queue after {_QUEUE_TIMEOUT}s.")
        time.sleep(_QUEUE_POLL_SEC + random.uniform(0, 2))


def _profile_lock(profile: str):
    """Acquire a per-profile lock to serialize requests to rate-sensitive backends."""
    from contextlib import contextmanager
    
    lock_file = _DELEGATION_DIR / f"{profile}.lock"
    
    @contextmanager
    def locker():
        if profile != "remote-free":
            # Only lock for rate-sensitive free tiers for now
            yield
            return

        _ensure_dirs()
        with open(lock_file, "w") as f:
            try:
                fcntl.flock(f, fcntl.LOCK_EX)
                yield
            finally:
                fcntl.flock(f, fcntl.LOCK_UN)
    return locker()

# ── pending / audit helpers ─────────────────────────────────────────────────

import subprocess as _subprocess

def _pending_update(*args):
    try:
        _subprocess.run(
            [sys.executable, str(_PENDING_UPDATE)] + list(args),
            timeout=5, check=False, capture_output=True,
        )
    except Exception:
        pass


def _audit(verb: str, *args):
    try:
        _subprocess.run(
            ["bash", "-c",
             f'source "{_AUDIT_WRITE}" 2>/dev/null && audit_event_{verb} antigravity "$@"',
             "--"] + [str(a) for a in args],
            timeout=5, check=False, capture_output=True,
        )
    except Exception:
        pass

# ── subcommands ────────────────────────────────────────────────────────────

def cmd_list():
    if not _REGISTRY.exists():
        print("No delegated tasks yet.")
        return
    header = f"{'TASK ID':<38}  {'STATUS':<16}  {'ROLE':<12}  DESCRIPTION"
    print(header)
    print("-" * len(header))
    for line in _REGISTRY.read_text().splitlines():
        if not line.strip():
            continue
        try:
            e = json.loads(line)
            if e.get("agent") != "antigravity":
                continue
            desc = e.get("description", "")[:50]
            print(f"{e['id']:<38}  {e.get('status','?'):<16}  "
                  f"{e.get('role','?'):<12}  {desc}")
        except Exception:
            pass


def cmd_status(task_id: str):
    if not _REGISTRY.exists():
        sys.exit(f"Task not found: {task_id}")
    for line in _REGISTRY.read_text().splitlines():
        try:
            e = json.loads(line)
            if e.get("id") == task_id:
                print(json.dumps(e, indent=2))
                pid = e.get("pid")
                if pid and _pid_alive(int(pid)):
                    print(f"[delegate-to-antigravity] Process {pid} is still running.")
                else:
                    print("[delegate-to-antigravity] Process no longer running.")
                return
        except Exception:
            pass
    sys.exit(f"Task not found: {task_id}")


def cmd_check(task_id: str):
    if not _REGISTRY.exists():
        sys.exit(f"Task not found: {task_id}")
    for line in _REGISTRY.read_text().splitlines():
        try:
            e = json.loads(line)
            if e.get("id") == task_id:
                out = e.get("output_file", "")
                out_path = (_REPO / out) if not Path(out).is_absolute() else Path(out)
                if not out_path.exists():
                    sys.exit(f"Output not found: {out_path}  (task may still be running)")
                sys.stdout.write(out_path.read_text())
                return
        except Exception:
            pass
    sys.exit(f"Task not found: {task_id}")


def cmd_delegate(prompt: str, role: str, mode: str,
                 profile_override: "str | None", max_tokens: int,
                 timeout: int, wait: bool, loop: bool = False):
    _ensure_dirs()

    running_count = _count_running()
    profile = profile_override or _PROFILE_MAP.get(mode, "remote-gemini")
    tid = _task_id()

    if running_count >= _MAX_CONCURRENT:
        print(f"[delegate-to-antigravity] Busy ({running_count}/{_MAX_CONCURRENT} tasks). Waiting in queue...")
        _wait_in_queue(tid)

    # Fast-fail before forking: verify switchboard is reachable and remote is configured.
    ok, reason = _check_switchboard_ready()
    if not ok:
        sys.exit(f"ERROR: {reason}")

    tid = _task_id()
    log_path = _OUTPUTS_DIR / f"{tid}.log"
    rel_log = f".agents/delegation/outputs/{tid}.log"

    def _info(s: str):
        print(f"[delegate-to-antigravity] {s}")

    _info(f"Delegating task: {tid}")
    _info(f"Role:            {role}")
    _info(f"Profile:         {profile} (--mode {mode})")
    _info(f"Output file:     {log_path}")

    if loop:
        _info("Loop mode enabled. Dispatching to aq-antigravity-agent.")
        agent_cmd = [
            sys.executable,
            str(_REPO / "scripts" / "ai" / "aq-antigravity-agent"),
            "--task", prompt,
            "--role", role,
        ]
        if mode:
            agent_cmd.extend(["--mode", mode])
        if profile_override:
            agent_cmd.extend(["--model", profile_override])
        if not wait:
            child = os.fork()
            if child > 0:
                _info(f"Agent loop started in background (pid {child})")
                print(f"aq-loop-{int(time.time())}")
                return
            os.setsid()
            devnull = os.open("/dev/null", os.O_RDWR)
            os.dup2(devnull, sys.stdin.fileno())
            os.close(devnull)
            _subprocess.run(agent_cmd)
            os._exit(0)
        else:
            _subprocess.run(agent_cmd)
            return

    # Register before dispatch
    _registry_append(tid, role, prompt, log_path)
    _pending_update("add", tid, "antigravity", rel_log, prompt[:120])
    _audit("start", tid, prompt[:200])

    if wait:
        with _profile_lock(profile):
            status, ti, to = _run_via_switchboard(
                tid, prompt, role, profile, timeout, log_path,
                max_tokens=max_tokens, print_to_stdout=True,
            )
        _registry_update(tid, status, tokens_in=ti, tokens_out=to)
        _pending_update(status, tid)
        _audit("end", tid, "success" if status == "done" else "error", "0",
               f"{status}: {prompt[:100]}", role)
        _info(f"Task {tid} {status}  (in={ti} out={to})")
        print(tid)
        return

    child = os.fork()
    if child > 0:
        _registry_set_pid(tid, child)
        _info(f"Task {tid} started in background (pid {child})")
        _info(f"Check output:  delegate-to-antigravity --check {tid}")
        _info(f"Check status:  delegate-to-antigravity --status {tid}")
        print(tid)
        return

    os.setsid()
    devnull = os.open("/dev/null", os.O_RDWR)
    os.dup2(devnull, sys.stdin.fileno())
    os.close(devnull)

    try:
        with _profile_lock(profile):
            status, ti, to = _run_via_switchboard(
                tid, prompt, role, profile, timeout, log_path,
                max_tokens=max_tokens,
            )
        _registry_update(tid, status, tokens_in=ti, tokens_out=to)
        _pending_update(status, tid)
        _audit("end", tid, "success" if status == "done" else "error", "0",
               f"{status}: {prompt[:100]}", role)
    except Exception as exc:
        try:
            with open(log_path, "a") as f:
                f.write(f"FATAL: unhandled exception in child: {exc}\n")
        except Exception:
            pass
        _registry_update(tid, "failed")
        _pending_update("failed", tid)

    os._exit(0)

# ── argument parsing ────────────────────────────────────────────────────────

def _build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="delegate-to-antigravity",
        description=(
            "Headless AI delegation via the harness switchboard.\n"
            "Routes through remote-gemini / remote-reasoning profiles.\n"
            "Backend (model, API key, provider) is configured in deploy-options.local.nix."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Deployment configuration (deploy-options.local.nix):\n"
            "  mySystem.ai.switchboard.remoteUrl = \"https://openrouter.ai/api/v1\";\n"
            "  mySystem.ai.switchboard.remoteModelAliases.gemini = \"google/gemini-2.5-flash\";\n\n"
            "Profile override (advanced):\n"
            "  --model remote-coding     # use a specific switchboard profile\n"
            "  --model remote-reasoning  # high-judgment lane\n"
        ),
    )
    p.add_argument("--prompt",      metavar="TEXT", help="Task prompt")
    p.add_argument("--prompt-file", metavar="FILE", help="Read prompt from file")
    p.add_argument("--role", default="implementer",
                   help=f"Agent role [{', '.join(sorted(_VALID_ROLES))}]  [default: implementer]")
    p.add_argument("--mode", default="fast",
                   help=f"Model lane [{', '.join(sorted(_PROFILE_MAP))}]  [default: fast]")
    p.add_argument("--model", metavar="PROFILE",
                   help="Switchboard profile override (bypasses --mode; e.g. remote-coding)")
    p.add_argument("--max-tokens", type=int, default=8192,
                   help="Max output tokens hint [default: 8192] — enforced by switchboard profile")
    p.add_argument("--timeout", type=int, default=900,
                   help="HTTP request timeout in seconds [default: 900]")
    p.add_argument("--wait",   action="store_true", help="Block until completion, print output")
    p.add_argument("--check",  metavar="ID", help="Print output of a completed task")
    p.add_argument("--status", metavar="ID", help="Show status JSON for a task")
    p.add_argument("--list",   action="store_true", help="List all antigravity tasks")
    p.add_argument("--loop",   action="store_true",
                   help="Run as agentic loop with tool access (aq-antigravity-agent)")
    return p


def main():
    p = _build_parser()
    args = p.parse_args()

    if args.role not in _VALID_ROLES:
        p.error(f"Invalid --role '{args.role}'. Valid: {', '.join(sorted(_VALID_ROLES))}")
    if args.mode not in _PROFILE_MAP:
        p.error(f"Invalid --mode '{args.mode}'. Valid: {', '.join(sorted(_PROFILE_MAP))}")

    _ensure_dirs()

    if args.list:
        cmd_list()
    elif args.check:
        cmd_check(args.check)
    elif args.status:
        cmd_status(args.status)
    else:
        prompt = args.prompt or ""
        if args.prompt_file:
            pf = Path(args.prompt_file)
            if not pf.exists():
                p.error(f"Prompt file not found: {pf}")
            prompt = pf.read_text()
        if not prompt.strip():
            p.error("Provide --prompt TEXT or --prompt-file FILE")
        cmd_delegate(prompt, args.role, args.mode, args.model,
                     args.max_tokens, args.timeout, args.wait, args.loop)


if __name__ == "__main__":
    main()
