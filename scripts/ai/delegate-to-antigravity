#!/usr/bin/env python3
"""delegate-to-antigravity — Headless AI delegation via switchboard antigravity-collective profile.

Routes through the local switchboard (http://127.0.0.1:8085) using the
'antigravity-collective' profile, which forces provider=remote and uses the
configured remote backend (OpenRouter → google/gemini-2.5-flash-lite or equivalent).

Auth: handled by switchboard via /run/secrets/remote_llm_api_key (SOPS-managed, no
manual setup required).

Note: @google/gemini-cli (npm) and the oauth-personal/Code Assist path are RETIRED
as of 2026-07 (IneligibleTierError for free-tier). Do NOT use 'gemini' npm binary.

Usage:
  delegate-to-antigravity --prompt "task description"   # background dispatch
  delegate-to-antigravity --prompt "..." --wait         # blocking, prints output
  delegate-to-antigravity --check <task-id>             # read output
  delegate-to-antigravity --status <task-id>            # check status
  delegate-to-antigravity --list                        # list all tasks
  delegate-to-antigravity --prompt "..." --loop         # agentic loop (tool use)
"""

import argparse
import fcntl
import json
import os
import random
import socket
import subprocess
import sys
import time
import urllib.error
import urllib.request
from datetime import datetime, timezone
from pathlib import Path

# ── paths ──────────────────────────────────────────────────────────────────
_HERE = Path(__file__).resolve().parent
_REPO = Path(os.environ.get("REPO_ROOT", str(_HERE.parent.parent)))
_DELEGATION_DIR = _REPO / ".agents" / "delegation"
_OUTPUTS_DIR = _DELEGATION_DIR / "outputs"
_REGISTRY = _DELEGATION_DIR / "registry.jsonl"
_PENDING_UPDATE = _HERE / "lib" / "pending-update"
_AUDIT_WRITE = _HERE / "lib" / "audit-write.sh"

# ── constants ──────────────────────────────────────────────────────────────
_MIN_CONTENT_BYTES = 200
_MAX_CONCURRENT = 3

# Switchboard profile for Antigravity delegation.
# remote-free: forceProvider=remote → OpenRouter → meta-llama/llama-3.3-70b-instruct:free (no credits needed)
# antigravity-collective: forceProvider=remote → OpenRouter → google/gemini-2.5-flash-lite (requires credits)
# Switch to "antigravity-collective" when OpenRouter credits are available.
_SWB_PROFILE = os.environ.get("ANTIGRAVITY_SWB_PROFILE", "remote-free")

# Model hints passed to switchboard (profile may alias/override these).
# Use gemini model names; switchboard translates to OpenRouter model IDs.
_MODEL_MAP = {
    "fast":        "gemini-2.0-flash",
    "flash":       "gemini-2.0-flash",
    "pro":         "gemini-2.5-flash",
    "architect":   "gemini-2.5-flash",
    "implementer": "gemini-2.0-flash",
    "reviewer":    "gemini-2.0-flash",
}

def _swb_url() -> str:
    port = os.environ.get("SWITCHBOARD_PORT", os.environ.get("SWB_PORT", "8085"))
    host = os.environ.get("SWITCHBOARD_HOST", "127.0.0.1")
    return f"http://{host}:{port}/v1/chat/completions"

_VALID_ROLES = {
    "orchestrator", "architect", "implementer", "reviewer",
    "full-expert-team",
    "plan", "implement", "review", "research",
}

_HARNESS_SYSTEM_BASE = (
    "You are an AI agent in the NixOS-Dev-Quick-Deploy harness.\n"
    "SCOPE LOCK: Work only on what the task requests. No unsolicited refactors.\n"
    "PRD GATE: Write a brief plan to .agent/collaboration/PULSE.log before editing.\n"
    "PORT POLICY: Never hardcode ports/URLs. Source: nix/modules/core/options.nix.\n"
    "SECURITY: No hardcoded secrets, tokens, or credentials.\n"
    "ATOMIC PULSE: Append one line to PULSE.log after every file write.\n"
    "ATOMIC RESUME: Update .agent/collaboration/RESUME.json at every phase start.\n"
    "DO NOT COMMIT — the orchestrator (Claude) reviews and commits.\n"
)

def _load_harness_grounding() -> str:
    gf = _REPO / "config" / "local-agent-grounding.md"
    try:
        return gf.read_text().strip()
    except OSError:
        return ""

def _build_harness_system() -> str:
    grounding = _load_harness_grounding()
    if grounding:
        return _HARNESS_SYSTEM_BASE + "\n\n" + grounding + "\n"
    return _HARNESS_SYSTEM_BASE

_HARNESS_SYSTEM = _build_harness_system()

# ── switchboard health check ─────────────────────────────────────────────────

def _check_switchboard_ready() -> "tuple[bool, str]":
    """Check if local switchboard is reachable and has remote configured."""
    try:
        port = os.environ.get("SWITCHBOARD_PORT", os.environ.get("SWB_PORT", "8085"))
        url = f"http://127.0.0.1:{port}/health"
        with urllib.request.urlopen(url, timeout=3) as resp:
            d = json.loads(resp.read())
            if not d.get("remote_configured"):
                return False, "switchboard remote not configured (check REMOTE_LLM_URL and remote_llm_api_key secret)"
            return True, f"switchboard ok, remote_configured=True"
    except Exception as exc:
        return False, f"switchboard unreachable: {exc}"

# ── task id & registry ─────────────────────────────────────────────────────

def _task_id() -> str:
    rand = "".join(random.choices("abcdefghijklmnopqrstuvwxyz0123456789", k=6))
    return f"antigravity-{datetime.now().strftime('%Y%m%d-%H%M%S')}-{rand}"


def _ensure_dirs():
    _OUTPUTS_DIR.mkdir(parents=True, exist_ok=True)
    _REGISTRY.touch(exist_ok=True)


def _registry_append(task_id: str, role: str, description: str, output_file: Path):
    ts = datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")
    entry = {
        "id": task_id, "agent": "antigravity", "role": role,
        "description": description[:200],
        "output_file": str(output_file.relative_to(_REPO)),
        "pid": None, "status": "running",
        "tokens_in": None, "tokens_out": None, "created": ts,
    }
    with open(_REGISTRY, "a") as fh:
        fcntl.flock(fh, fcntl.LOCK_EX)
        fh.write(json.dumps(entry) + "\n")
        fcntl.flock(fh, fcntl.LOCK_UN)


def _registry_set_pid(task_id: str, pid: int):
    _registry_update(task_id, "running", pid=pid)


def _registry_update(task_id: str, status: str, *,
                     tokens_in: "int | None" = None,
                     tokens_out: "int | None" = None,
                     pid: "int | None" = None):
    if not _REGISTRY.exists():
        return
    lines = []
    for line in _REGISTRY.read_text().splitlines():
        if not line.strip():
            continue
        try:
            e = json.loads(line)
            if e.get("id") == task_id:
                e["status"] = status
                if pid is not None:        e["pid"] = pid
                if tokens_in is not None:  e["tokens_in"] = tokens_in
                if tokens_out is not None: e["tokens_out"] = tokens_out
            lines.append(json.dumps(e))
        except Exception:
            lines.append(line)
    with open(_REGISTRY, "w") as fh:
        fcntl.flock(fh, fcntl.LOCK_EX)
        fh.write("\n".join(lines) + "\n")
        fcntl.flock(fh, fcntl.LOCK_UN)


def _pid_alive(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except (ProcessLookupError, PermissionError):
        return False


def _count_running() -> int:
    if not _REGISTRY.exists():
        return 0
    count = 0
    for line in _REGISTRY.read_text().splitlines():
        try:
            e = json.loads(line)
            if e.get("agent") == "antigravity" and e.get("status") == "running":
                pid = e.get("pid")
                if pid and _pid_alive(int(pid)):
                    count += 1
        except Exception:
            pass
    return count

# ── delegation via switchboard ────────────────────────────────────────────────

def _run_switchboard(task_id: str, prompt: str, role: str, model: str,
                     timeout: int, log_path: Path,
                     print_to_stdout: bool = False) -> "tuple[str, int, int]":
    """POST to switchboard antigravity-collective profile. Returns (status, tokens_in, tokens_out)."""
    role_prefix = f"[ROLE: {role}]\n\n"
    full_prompt = role_prefix + _HARNESS_SYSTEM + "\n" + prompt

    payload = json.dumps({
        "model": model or "gemini-2.5-flash",
        "messages": [{"role": "user", "content": full_prompt}],
        "max_tokens": 2000,
        "stream": False,
    }).encode()

    url = _swb_url()

    # Try configured profile; if remote rate-limits or requires credits, fall back to local.
    profiles_to_try = [_SWB_PROFILE]
    if _SWB_PROFILE not in ("local-coding", "local-tool-calling"):
        profiles_to_try.append("local-coding")  # local Qwen3-35B fallback

    for current_profile in profiles_to_try:
        if current_profile != profiles_to_try[0]:
            sys.stderr.write(f"[delegate-to-antigravity] falling back to {current_profile} profile\n")
        attempt_req = urllib.request.Request(
            url,
            data=payload,
            headers={
                "Content-Type": "application/json",
                "X-AI-Profile": current_profile,
            },
            method="POST",
        )
        for attempt in range(1, 3):  # up to 2 attempts per profile
            try:
                with urllib.request.urlopen(attempt_req, timeout=timeout) as resp:
                    result = json.loads(resp.read())
                    content = (
                        result.get("choices", [{}])[0]
                        .get("message", {})
                        .get("content", "")
                        or ""
                    )
                    usage = result.get("usage", {})
                    tokens_in  = usage.get("prompt_tokens", 0) or 0
                    tokens_out = usage.get("completion_tokens", 0) or 0

                    if content:
                        with open(log_path, "a") as f:
                            f.write(content.strip() + "\n")
                        if print_to_stdout:
                            sys.stdout.write(content.strip() + "\n")
                            sys.stdout.flush()
                        status = "done" if len(content.encode()) >= _MIN_CONTENT_BYTES else "partial-success"
                        return status, tokens_in, tokens_out

                    with open(log_path, "a") as f:
                        f.write(f"ERROR: switchboard returned empty content ({current_profile}).\nResponse: {json.dumps(result)[:400]}\n")
                    break  # empty content — try next profile

            except urllib.error.HTTPError as exc:
                body = ""
                try:
                    body = exc.read().decode(errors="replace")[:400]
                except Exception:
                    pass
                if exc.code in (429, 402) and attempt < 2:
                    # Rate-limited or no credits — wait briefly then try next profile
                    retry_after = 5
                    try:
                        parsed = json.loads(body)
                        ra = parsed.get("error", {}).get("metadata", {}).get("retry_after_seconds", 5)
                        retry_after = min(int(ra), 10)
                    except Exception:
                        pass
                    sys.stderr.write(f"[delegate-to-antigravity] HTTP {exc.code} on {current_profile} (attempt {attempt}), waiting {retry_after}s\n")
                    time.sleep(retry_after)
                    continue
                elif exc.code in (429, 402):
                    # Exhausted retries on this profile — try next
                    sys.stderr.write(f"[delegate-to-antigravity] HTTP {exc.code} on {current_profile} — trying next profile\n")
                    break
                with open(log_path, "a") as f:
                    f.write(f"ERROR: switchboard HTTP {exc.code} ({current_profile}): {body}\n")
                return "failed", 0, 0

            except (socket.timeout, TimeoutError, urllib.error.URLError) as exc:
                if current_profile in ("local-coding", "local-tool-calling"):
                    # Local inference is slow (Renoir APU, 1 tok/s); slot may be busy.
                    with open(log_path, "a") as f:
                        f.write(f"ERROR: local inference timeout/unavailable ({current_profile}): {exc}\n"
                                f"  slot may be busy with another request — retry manually later\n")
                else:
                    sys.stderr.write(f"[delegate-to-antigravity] network error on {current_profile}: {exc}\n")
                break  # try next profile

            except json.JSONDecodeError as exc:
                # Empty or malformed response body — can happen when inference just started
                # and the switchboard returned before llama.cpp buffered the response.
                with open(log_path, "a") as f:
                    f.write(f"ERROR: empty response from {current_profile} (inference may still be running): {exc}\n")
                break  # try next profile

            except Exception as exc:
                with open(log_path, "a") as f:
                    f.write(f"ERROR: switchboard call failed ({current_profile}): {exc}\n")
                break  # try next profile

    with open(log_path, "a") as f:
        f.write("ERROR: all profiles exhausted — remote rate-limited and local fallback failed\n")
    return "failed", 0, 0

# ── pending / audit helpers ─────────────────────────────────────────────────

def _pending_update(*args):
    try:
        subprocess.run(
            [sys.executable, str(_PENDING_UPDATE)] + list(args),
            timeout=5, check=False, capture_output=True,
        )
    except Exception:
        pass


def _audit(verb: str, *args):
    try:
        subprocess.run(
            ["bash", "-c",
             f'source "{_AUDIT_WRITE}" 2>/dev/null && audit_event_{verb} antigravity "$@"',
             "--"] + [str(a) for a in args],
            timeout=5, check=False, capture_output=True,
        )
    except Exception:
        pass

# ── subcommands ────────────────────────────────────────────────────────────

def cmd_list():
    if not _REGISTRY.exists():
        print("No delegated tasks yet.")
        return
    header = f"{'TASK ID':<38}  {'STATUS':<16}  {'ROLE':<12}  DESCRIPTION"
    print(header)
    print("-" * len(header))
    for line in _REGISTRY.read_text().splitlines():
        if not line.strip():
            continue
        try:
            e = json.loads(line)
            if e.get("agent") != "antigravity":
                continue
            desc = e.get("description", "")[:50]
            print(f"{e['id']:<38}  {e.get('status','?'):<16}  "
                  f"{e.get('role','?'):<12}  {desc}")
        except Exception:
            pass


def cmd_status(task_id: str):
    if not _REGISTRY.exists():
        sys.exit(f"Task not found: {task_id}")
    for line in _REGISTRY.read_text().splitlines():
        try:
            e = json.loads(line)
            if e.get("id") == task_id:
                print(json.dumps(e, indent=2))
                pid = e.get("pid")
                if pid and _pid_alive(int(pid)):
                    print(f"[delegate-to-antigravity] Process {pid} is still running.")
                else:
                    print("[delegate-to-antigravity] Process no longer running.")
                return
        except Exception:
            pass
    sys.exit(f"Task not found: {task_id}")


def cmd_check(task_id: str):
    if not _REGISTRY.exists():
        sys.exit(f"Task not found: {task_id}")
    for line in _REGISTRY.read_text().splitlines():
        try:
            e = json.loads(line)
            if e.get("id") == task_id:
                out = e.get("output_file", "")
                out_path = (_REPO / out) if not Path(out).is_absolute() else Path(out)
                if not out_path.exists():
                    sys.exit(f"Output not found: {out_path}  (task may still be running)")
                sys.stdout.write(out_path.read_text())
                return
        except Exception:
            pass
    sys.exit(f"Task not found: {task_id}")


def cmd_delegate(prompt: str, role: str, mode: str,
                 model_override: "str | None", max_tokens: int,
                 timeout: int, wait: bool, loop: bool = False):
    _ensure_dirs()

    running_count = _count_running()
    if running_count >= _MAX_CONCURRENT:
        sys.exit(
            f"ERROR: {running_count} antigravity tasks already running (max {_MAX_CONCURRENT}).\n"
            "Wait for current tasks or read them with --check <id>."
        )

    model = model_override or _MODEL_MAP.get(mode, "gemini-2.0-flash")
    tid = _task_id()
    log_path = _OUTPUTS_DIR / f"{tid}.log"
    rel_log = f".agents/delegation/outputs/{tid}.log"

    def _info(s: str):
        print(f"[delegate-to-antigravity] {s}")

    _info(f"Delegating task: {tid}")
    _info(f"Role:            {role}")
    _info(f"Model:           {model} (--mode {mode})")
    _info(f"Output file:     {log_path}")

    if loop:
        _info("Loop mode enabled. Dispatching to aq-antigravity-agent.")
        agent_cmd = [
            sys.executable,
            str(_REPO / "scripts" / "ai" / "aq-antigravity-agent"),
            "--task", prompt,
            "--role", role,
        ]
        if mode:
            agent_cmd.extend(["--mode", mode])
        if model_override:
            agent_cmd.extend(["--model", model_override])
        if not wait:
            child = os.fork()
            if child > 0:
                _info(f"Agent loop started in background (pid {child})")
                print(f"aq-loop-{int(time.time())}")
                return
            os.setsid()
            devnull = os.open("/dev/null", os.O_RDWR)
            os.dup2(devnull, sys.stdin.fileno())
            os.close(devnull)
            subprocess.run(agent_cmd)
            os._exit(0)
        else:
            subprocess.run(agent_cmd)
            return

    # Register before dispatch
    _registry_append(tid, role, prompt, log_path)
    _pending_update("add", tid, "antigravity", rel_log, prompt[:120])
    _audit("start", tid, prompt[:200])

    if wait:
        status, ti, to = _run_switchboard(
            tid, prompt, role, model, timeout, log_path,
            print_to_stdout=True,
        )
        _registry_update(tid, status, tokens_in=ti, tokens_out=to)
        _pending_update(status, tid)
        _audit("end", tid, "success" if status == "done" else "error", "0",
               f"{status}: {prompt[:100]}", role)
        _info(f"Task {tid} {status}")
        print(tid)
        return

    child = os.fork()
    if child > 0:
        _registry_set_pid(tid, child)
        _info(f"Task {tid} started in background (pid {child})")
        _info(f"Check output:  delegate-to-antigravity --check {tid}")
        _info(f"Check status:  delegate-to-antigravity --status {tid}")
        print(tid)
        return

    os.setsid()
    devnull = os.open("/dev/null", os.O_RDWR)
    os.dup2(devnull, sys.stdin.fileno())
    os.close(devnull)

    try:
        status, ti, to = _run_switchboard(
            tid, prompt, role, model, timeout, log_path,
        )
        _registry_update(tid, status, tokens_in=ti, tokens_out=to)
        _pending_update(status, tid)
        _audit("end", tid, "success" if status == "done" else "error", "0",
               f"{status}: {prompt[:100]}", role)
    except Exception as exc:
        try:
            with open(log_path, "a") as f:
                f.write(f"FATAL: unhandled exception in child: {exc}\n")
        except Exception:
            pass
        _registry_update(tid, "failed")
        _pending_update("failed", tid)

    os._exit(0)

# ── argument parsing ────────────────────────────────────────────────────────

def _build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="delegate-to-antigravity",
        description=(
            "Headless Gemini delegation via switchboard antigravity-collective profile.\n"
            "Routes: local switchboard → forceProvider=remote → OpenRouter → google/gemini-2.5-flash-lite."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Backend: switchboard remote-free profile (default)\n"
            "  → forceProvider=remote → OpenRouter → meta-llama/llama-3.3-70b-instruct:free\n"
            "  Auth managed by switchboard via /run/secrets/remote_llm_api_key\n"
            "  Set ANTIGRAVITY_SWB_PROFILE=antigravity-collective to use google/gemini-2.5-flash-lite\n"
            "  (requires OpenRouter credits).\n"
        ),
    )
    p.add_argument("--prompt",      metavar="TEXT", help="Task prompt")
    p.add_argument("--prompt-file", metavar="FILE", help="Read prompt from file")
    p.add_argument("--role", default="implementer",
                   help=f"Agent role [{', '.join(sorted(_VALID_ROLES))}]  [default: implementer]")
    p.add_argument("--mode", default="fast",
                   help=f"Model mode [{', '.join(sorted(_MODEL_MAP))}]  [default: fast]")
    p.add_argument("--model", metavar="MODEL_ID",
                   help="Gemini model ID override (bypasses --mode; e.g. gemini-2.5-flash)")
    p.add_argument("--max-tokens", type=int, default=8192,
                   help="Max output tokens hint [default: 8192]")
    p.add_argument("--timeout", type=int, default=900,
                   help="Subprocess timeout in seconds [default: 900]")
    p.add_argument("--wait",   action="store_true", help="Block until completion, print output")
    p.add_argument("--check",  metavar="ID", help="Print output of a completed task")
    p.add_argument("--status", metavar="ID", help="Show status JSON for a task")
    p.add_argument("--list",   action="store_true", help="List all antigravity tasks")
    p.add_argument("--loop",   action="store_true",
                   help="Run as agentic loop with tool access (aq-antigravity-agent)")
    return p


def main():
    p = _build_parser()
    args = p.parse_args()

    if args.role not in _VALID_ROLES:
        p.error(f"Invalid --role '{args.role}'. Valid: {', '.join(sorted(_VALID_ROLES))}")
    if args.mode not in _MODEL_MAP:
        p.error(f"Invalid --mode '{args.mode}'. Valid: {', '.join(sorted(_MODEL_MAP))}")

    _ensure_dirs()

    if args.list:
        cmd_list()
    elif args.check:
        cmd_check(args.check)
    elif args.status:
        cmd_status(args.status)
    else:
        prompt = args.prompt or ""
        if args.prompt_file:
            pf = Path(args.prompt_file)
            if not pf.exists():
                p.error(f"Prompt file not found: {pf}")
            prompt = pf.read_text()
        if not prompt.strip():
            p.error("Provide --prompt TEXT or --prompt-file FILE")
        cmd_delegate(prompt, args.role, args.mode, args.model,
                     args.max_tokens, args.timeout, args.wait, args.loop)


if __name__ == "__main__":
    main()
