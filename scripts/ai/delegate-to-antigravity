#!/usr/bin/env python3
"""delegate-to-antigravity — Headless AI delegation via the harness switchboard.

Routes prompts through the switchboard's remote profiles (antigravity-collective,
remote-reasoning, etc.).  The switchboard handles provider routing, circuit
breaking, token budgets, and telemetry.  Backend (model / API key / endpoint)
is configured once in deploy-options.local.nix — this script never changes
when the provider changes.

Deployment-time configuration (deploy-options.local.nix):
  mySystem.ai.switchboard.remoteUrl            = "https://openrouter.ai/api/v1";
  mySystem.ai.switchboard.remoteModelAliases.gemini = "google/gemini-2.5-flash";

Runtime environment override:
  SWITCHBOARD_URL=http://127.0.0.1:8085   (default: port from options.nix)

Usage:
  delegate-to-antigravity --prompt "task description"   # background dispatch
  delegate-to-antigravity --prompt "..." --wait         # blocking, prints output
  delegate-to-antigravity --check <task-id>             # read output
  delegate-to-antigravity --status <task-id>            # check status
  delegate-to-antigravity --list                        # list all tasks
  delegate-to-antigravity --prompt "..." --loop         # agentic loop (tool use)
"""

