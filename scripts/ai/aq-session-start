#!/usr/bin/env bash
# aq-session-start — Phase 56.3/56.8: One-command session hydration
#
# Pulls AIDB context, ranked hints, and promoted lessons so agents start
# with institutional memory rather than a blank slate. Always exits 0
# even when coordinator is unavailable.
#
# Usage:
#   aq-session-start --task "implement X"
#   aq-session-start --task "..." --format brief   # 5-line stdout summary
#   aq-session-start --task "..." --summarize      # optional Qwen brief
#   aq-session-start --task "..." --no-write       # stdout only, no file

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
SCRATCHPAD="${REPO_ROOT}/.agents/scratchpad"
COORD_URL="${HYBRID_COORDINATOR_URL:-http://127.0.0.1:8003}"

task=""
format="brief"
summarize=0
no_write=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --task)        task="$2"; shift 2 ;;
        --format)      format="$2"; shift 2 ;;
        --summarize)   summarize=1; shift ;;
        --no-write)    no_write=1; shift ;;
        --help|-h)
            printf 'usage: aq-session-start --task "description" [--format brief|full] [--summarize] [--no-write]\n'
            exit 0 ;;
        *) printf 'unknown arg: %s\n' "$1" >&2; exit 2 ;;
    esac
done

[[ -n "$task" ]] || { printf 'error: --task is required\n' >&2; exit 2; }

TODAY="$(date +%Y%m%d)"
OUTPUT_FILE="${SCRATCHPAD}/session-context-${TODAY}.md"
mkdir -p "$SCRATCHPAD"

_curl_json() { curl -sf --max-time 8 "$@" 2>/dev/null || true; }

printf '=== aq-session-start: %s ===\n' "$task"

# ── 0. Workflow session registration ─────────────────────────────────────────
# Creates a record in workflow-sessions.json so aq-report operator_trust
# has data (intent_coverage). Silent on failure — never blocks hydration.
_curl_json -X POST "${COORD_URL}/workflow/run/start" \
    -H 'Content-Type: application/json' \
    -d "{\"query\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$task"),\"agent\":\"claude-code\",\"role\":\"orchestrator\"}" \
    > /dev/null || true

# ── 1. Context bootstrap ──────────────────────────────────────────────────────
printf '\n[1/3] Context bootstrap...\n'
bootstrap_out="$(_curl_json -X POST "${COORD_URL}/api/context/bootstrap" \
    -H 'Content-Type: application/json' \
    -d "{\"task\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$task")}")" || true

# ── 2. Ranked hints ───────────────────────────────────────────────────────────
printf '[2/3] Ranked hints...\n'
hints_out="$(_curl_json "${COORD_URL}/hints?q=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$task")&format=json&limit=5")" || true

# ── 3. Hierarchical context (AGENTS.md cascade) ───────────────────────────────
printf '[3/4] Hierarchical context...\n'
hier_context="$(python3 "${SCRIPT_DIR}/lib/context-merger.py" "${REPO_ROOT}" 2>/dev/null)" || true

# ── 4. Promoted lessons + constraints ────────────────────────────────────────
printf '[4/5] Lesson registry...\n'
# lessons endpoint returns both agent_lessons registry and constraints array (Phase 65.3)
lessons_out="$(_curl_json "${COORD_URL}/control/ai-coordinator/lessons")" || true

# ── 5. System intelligence artifact (Phase 115.5) ────────────────────────────
printf '[5/5] System state snapshot...\n'
_ARTIFACT_PATH="${SYSTEM_STATE_ARTIFACT_PATH:-/var/lib/ai-stack/hybrid/telemetry/latest-system-state.json}"
system_state_out=""
if [[ -r "$_ARTIFACT_PATH" ]]; then
    system_state_out="$(python3 - "$_ARTIFACT_PATH" <<'PYEOF'
import json, sys, time
from datetime import datetime, timezone
try:
    snap = json.loads(open(sys.argv[1]).read())
    gen_str = snap.get("generated_at", "")
    gen_ts = datetime.fromisoformat(gen_str.replace("Z", "+00:00"))
    age_s = int((datetime.now(timezone.utc) - gen_ts).total_seconds())
    if age_s > 900:
        print(f"STALE:{age_s}")
    else:
        # Summary text — compact single-line representation
        svcs = snap.get("services") or []
        active = sum(1 for s in svcs if s.get("status") == "active")
        failed_svcs = [s["name"] for s in svcs if s.get("status") in ("failed", "inactive") and s.get("sub_state") != "dead"]
        git = snap.get("git") or {}
        errors = snap.get("errors") or []
        agent = snap.get("agent") or {}
        val = snap.get("validation") or {}
        attn = snap.get("attention") or {}
        qa = (val.get("aq_qa") or {})
        open_tasks = agent.get("open_tasks") or []

        lines = []
        ts = gen_str[:19].replace("T", " ")
        partial = " [partial]" if snap.get("partial") else ""
        lines.append(f"Generated: {ts} UTC (age {age_s}s){partial}")
        if svcs:
            lines.append(f"Services: {active}/{len(svcs)} active" + (f", FAILED: {','.join(failed_svcs[:3])}" if failed_svcs else ""))
        if git:
            lines.append(f"Git: branch={git.get('branch','?')} uncommitted={len(git.get('uncommitted_files') or [])}")
        if qa.get("available"):
            lines.append(f"QA: {qa.get('passed',0)}/{qa.get('total',0)} pass")
        if errors:
            top = errors[0]
            lines.append(f"Errors(1h): {len(errors)} types, top={top.get('service','?')}/{top.get('type','?')} x{top.get('count',0)}")
        if agent.get("current_objective"):
            lines.append(f"Agent phase: {agent.get('phase','?')} | open tasks: {len(open_tasks)}")
            lines.append(f"Objective: {str(agent['current_objective'])[:80]}")
            for t in open_tasks[:3]:
                lines.append(f"  - {str(t)[:80]}")
        pending_gate = attn.get("pending_human_gate", 0)
        if pending_gate:
            lines.append(f"ATTENTION: {pending_gate} items pending human gate")
        print("\n".join(lines))
except Exception as e:
    print(f"ERROR:{e}")
PYEOF
    )" 2>/dev/null || true
fi

# ── 6. Collaborator awareness (multi-agent grounding) ─────────────────────────
# Grounding must include the current + recent status of OTHER running agents so we
# don't collide on the shared index, redo their work, or mis-attribute failures.
# json-only (no PyYAML dep), best-effort, never blocks hydration.
printf '[6/6] Collaborator awareness...\n'
_PULSE="${REPO_ROOT}/.agent/collaboration/PULSE.log"
_PENDING="${REPO_ROOT}/.agent/collaboration/PENDING.json"
running_agents="$(pgrep -af 'codex|gemini|opencode' 2>/dev/null \
    | grep -viE 'pgrep|aq-session-start|grep ' \
    | python3 -c "import sys,re
seen=set()
for ln in sys.stdin:
    for n in ('codex','gemini','opencode'):
        if re.search(r'\b'+n+r'\b', ln): seen.add(n)
print(', '.join(sorted(seen)) or '(none detected)')" 2>/dev/null || echo '(unknown)')"
uncommitted_n="$(git -C "$REPO_ROOT" status --porcelain 2>/dev/null | wc -l | tr -d ' ')"
collab_out="$(python3 - "$_PULSE" "$_PENDING" <<'PYEOF'
import sys, json, re
from collections import OrderedDict
pulse_path, pending_path = sys.argv[1], sys.argv[2]
out=[]
try:
    raw=open(pulse_path).read().splitlines()
    latest=OrderedDict()
    pat=re.compile(r'^\[?([0-9T:\-Z\.]+)\]?\s*\[?([A-Za-z0-9\-]+)\]?\s*(.*)$')
    for ln in raw[-100:]:
        m=pat.match(ln.strip())
        if not m: continue
        ts,agent,rest=m.group(1),m.group(2),m.group(3)
        a=agent.lower()
        if a in ('claude','codex','gemini','local') or 'claude' in a or 'codex' in a or 'gemini' in a:
            latest[agent]=(ts, rest[:90])
    if latest:
        out.append('Recent activity by agent:')
        for agent,(ts,act) in list(latest.items())[-6:]:
            out.append(f'  - {agent}: {act} ({ts[:19]})')
    for ln in reversed(raw[-50:]):
        low=ln.lower()
        if 'rebuild' in low and 'pending' in low:
            out.append(f'  ! PENDING REBUILD noted: {ln.strip()[:110]}')
            break
except Exception:
    pass
try:
    data=json.load(open(pending_path))
    tasks = data if isinstance(data,list) else (data.get('tasks') or data.get('pending') or [])
    inflight=[t for t in tasks if isinstance(t,dict) and str(t.get('status','')).lower() in ('pending','in-progress','in_progress','running','dispatched')]
    if inflight:
        out.append(f'In-flight delegated tasks: {len(inflight)}')
        for t in inflight[:5]:
            owner=t.get('agent') or t.get('owner') or t.get('assignee') or '?'
            desc=str(t.get('intent') or t.get('task') or t.get('description') or t.get('id') or '')[:70]
            out.append(f'  - [{owner}] {desc}')
except Exception:
    pass
print('\n'.join(out) if out else '(no recent collaborator activity)')
PYEOF
)" 2>/dev/null || collab_out="(collaborator awareness unavailable)"

# ── Build context document ────────────────────────────────────────────────────
{
    printf '# Session Context — %s\n\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
    printf '**Task**: %s\n\n' "$task"

    printf '## AIDB Context\n'
    if [[ -n "$bootstrap_out" ]]; then
        python3 - <<PYEOF
import json, sys
try:
    d = json.loads("""$bootstrap_out""")
    docs = d.get('documents') or d.get('results') or []
    for doc in docs[:3]:
        content = str(doc.get('content') or doc.get('text') or '')[:300]
        print(f"- {content}")
except Exception:
    print("(unavailable)")
PYEOF
    else
        printf '(coordinator unavailable — starting without AIDB context)\n'
    fi

    printf '\n## Hints\n'
    if [[ -n "$hints_out" ]]; then
        python3 - <<PYEOF
import json
try:
    d = json.loads("""$hints_out""")
    hints = d if isinstance(d, list) else d.get('hints', [])
    for h in hints[:5]:
        text = str(h.get('hint') or h.get('text') or h)[:200]
        print(f"- {text}")
except Exception:
    print("(unavailable)")
PYEOF
    else
        printf '(hints unavailable)\n'
    fi

    printf '\n## Promoted Lessons\n'
    if [[ -n "$lessons_out" ]]; then
        python3 - <<PYEOF
import json
try:
    d = json.loads("""$lessons_out""")
    registry = d.get('agent_lessons') or {}
    entries = registry.get('entries') or []
    active = [e for e in entries if e.get('state') in ('promoted', 'crystallized')]
    if active:
        for e in active[:5]:
            summary = str(e.get('summary') or e.get('lesson_key') or '')[:200]
            agent = e.get('source_agent', '')
            print(f"- [{agent}] {summary}")
    else:
        print("(no promoted lessons yet)")
except Exception:
    print("(unavailable)")
PYEOF
    else
        printf '(lessons unavailable)\n'
    fi

    printf '\n## Active Collaborators (multi-agent awareness)\n'
    printf 'Running agents: %s\n' "$running_agents"
    printf 'Uncommitted files in shared tree: %s (cross-check ownership via PULSE/HANDOFF before staging; use `git commit -o <pathspec>`)\n' "${uncommitted_n:-?}"
    printf '%s\n' "$collab_out"

    printf '\n## Hierarchical Context (AGENTS.md cascade)\n'
    if [[ -n "$hier_context" ]]; then
        printf '%s\n' "$hier_context" | head -40
    else
        printf '(no AGENTS.md files found in path)\n'
    fi

    printf '\n## System State (Phase 115)\n'
    if [[ -z "$system_state_out" ]]; then
        printf '(artifact not found — run aq-system-state or wait for ai-system-state.timer)\n'
    elif [[ "$system_state_out" == STALE:* ]]; then
        age="${system_state_out#STALE:}"
        printf '(artifact stale: %ss old — next refresh within 15min)\n' "$age"
    elif [[ "$system_state_out" == ERROR:* ]]; then
        printf '(artifact read error — %s)\n' "${system_state_out#ERROR:}"
    else
        printf '%s\n' "$system_state_out"
    fi

    printf '\n## Active Constraints (lesson registry)\n'
    if [[ -n "$lessons_out" ]]; then
        python3 - <<PYEOF
import json
try:
    d = json.loads("""$lessons_out""")
    constraints = d.get('constraints') or []
    if constraints:
        for c in constraints[:10]:
            print(f"- {str(c)[:200]}")
    else:
        print("(none — no lessons tagged constraint or state=active_constraint yet)")
except Exception:
    print("(unavailable)")
PYEOF
    else
        printf '(unavailable)\n'
    fi
} > /tmp/aq-session-context-$$.md 2>/dev/null || true

# ── Write / print ─────────────────────────────────────────────────────────────
if [[ "$no_write" -eq 0 ]]; then
    cp /tmp/aq-session-context-$$.md "$OUTPUT_FILE" 2>/dev/null || true
    printf '\nContext written to: %s\n' "$OUTPUT_FILE"
fi
rm -f /tmp/aq-session-context-$$.md

# Phase 117.3 — mirror RESUME.json to /var/lib telemetry so ai-system-state
# (runs as ai-hybrid, cannot traverse /home/hyperd/ DAC 700) can read agent state.
# Silent no-op until nixos-rebuild activates the 0770 telemetry dir tmpfiles rule.
_RESUME_SRC="${REPO_ROOT}/.agent/collaboration/RESUME.json"
_RESUME_MIRROR="/var/lib/ai-stack/hybrid/telemetry/agent-resume.json"
if [[ -f "$_RESUME_SRC" ]]; then
    cp "$_RESUME_SRC" "$_RESUME_MIRROR" 2>/dev/null || true
fi

# Brief summary to stdout
printf '\n--- Session Brief ---\n'
printf 'Task : %s\n' "$task"
printf 'Date : %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
printf 'Collab: running=[%s] uncommitted=%s\n' "$running_agents" "${uncommitted_n:-?}"
python3 - "$lessons_out" <<'PYEOF'
import json, sys
try:
    d = json.loads(sys.argv[1] or '{}')
    registry = d.get('agent_lessons') or {}
    entries = registry.get('entries') or []
    promoted = sum(1 for e in entries if e.get('state') in ('promoted','crystallized'))
    pending  = sum(1 for e in entries if e.get('state') == 'pending_review')
    print(f"Lessons: {promoted} promoted, {pending} pending review")
except Exception:
    print("Lessons: (unavailable)")
PYEOF
printf '%s\n' '--------------------'

# Optional Qwen brief
if [[ "$summarize" -eq 1 ]]; then
    _brief_prompt="In 3 bullet points summarise what context and lessons are relevant for: ${task:0:300}"
    printf '\n[Qwen brief requested — delegating async]\n'
    "${SCRIPT_DIR}/delegate-to-local" --mode direct \
        --prompt "$_brief_prompt" --wait \
        --timeout 150 2>/dev/null | head -20 || true
fi

exit 0
