#!/usr/bin/env python3
"""Security-gated intake helper for external agent capabilities."""

from __future__ import annotations

import argparse
import json
import re
import sys
from pathlib import Path
from typing import Any


REPO_ROOT = Path(__file__).resolve().parents[2]
REGISTRY_PATH = REPO_ROOT / "config" / "agent-capability-intake-candidates.json"
POLICY_PATH = REPO_ROOT / "config" / "runtime-tool-security-policy.json"
CACHE_PATH = REPO_ROOT / ".cache" / "capability-intake-tool-audit-cache.json"


def _load_auditor():
    sys.path.insert(0, str(REPO_ROOT / "ai-stack" / "mcp-servers"))
    from shared.tool_security_auditor import ToolSecurityAuditor  # type: ignore

    return ToolSecurityAuditor(
        service_name="capability-intake",
        policy_path=POLICY_PATH,
        cache_path=CACHE_PATH,
        enabled=True,
        enforce=False,
        cache_ttl_hours=24,
    )


def _load_registry(path: Path = REGISTRY_PATH) -> dict[str, Any]:
    with path.open("r", encoding="utf-8") as handle:
        payload = json.load(handle)
    if not isinstance(payload, dict) or not isinstance(payload.get("candidates"), list):
        raise ValueError(f"invalid candidate registry: {path}")
    return payload


def _candidate_by_id(registry: dict[str, Any], candidate_id: str) -> dict[str, Any]:
    for candidate in registry["candidates"]:
        if candidate.get("id") == candidate_id:
            return candidate
    raise KeyError(f"candidate not found: {candidate_id}")


def _levenshtein_distance(s1: str, s2: str) -> int:
    if len(s1) < len(s2):
        return _levenshtein_distance(s2, s1)
    if len(s2) == 0:
        return len(s1)
    previous_row = range(len(s2) + 1)
    for i, c1 in enumerate(s1):
        current_row = [i + 1]
        for j, c2 in enumerate(s2):
            insertions = previous_row[j + 1] + 1
            deletions = current_row[j] + 1
            substitutions = previous_row[j] + (c1 != c2)
            current_row.append(min(insertions, deletions, substitutions))
        previous_row = current_row
    return previous_row[-1]


# Param names that indicate command-execution capability. Matched by
# substring containment (case-insensitive) so both bare "command" and
# "command_override" are caught. "run" is included deliberately (spawns
# processes); "args" is handled separately below as a review-not-block
# signal since it is commonly legitimate (e.g. "search_args", "extra_args").
_HARD_RESTRICTED_PARAM_KEYWORDS = {"exec", "cmd", "command", "shell", "entrypoint", "run"}
_REVIEW_ONLY_PARAM_KEYWORDS = {"args"}


def _param_is_admitted(param_schema: dict[str, Any]) -> bool:
    """A flagged param is admitted only if it is bound to a strict enum, a
    regex pattern, or a bounded maxLength — an unconstrained free-form
    string is not admitted regardless of param name.
    """
    if not isinstance(param_schema, dict):
        return False
    enum = param_schema.get("enum")
    if isinstance(enum, list) and len(enum) > 0:
        return True
    pattern = param_schema.get("pattern")
    if isinstance(pattern, str) and pattern.strip():
        return True
    max_length = param_schema.get("maxLength")
    if isinstance(max_length, (int, float)) and not isinstance(max_length, bool) and max_length > 0:
        return True
    return False


def _validate_schema(schema: dict[str, Any]) -> tuple[bool, bool]:
    """Recursively validate a JSON Schema for dangerous parameters.

    Flags parameter names indicating command-execution capability (exec,
    cmd, command, shell, entrypoint, run — including compound names like
    "command_override") unless the param is admitted (enum/pattern/
    maxLength). Also flags "args"-named params under the same admission
    rule, but as a softer needs-review signal rather than a hard block,
    since bulk-argument params are commonly legitimate.

    Recurses into properties, items (array schemas, list or dict form),
    additionalProperties, patternProperties, $defs/definitions, and
    allOf/anyOf/oneOf — so a command param hidden in a nested object, an
    array-of-objects, or a map value cannot bypass detection.

    Returns (hard_unsafe, needs_review).
    """
    hard_unsafe = False
    needs_review = False
    if not isinstance(schema, dict):
        return hard_unsafe, needs_review

    def _merge(sub_schema: Any) -> None:
        nonlocal hard_unsafe, needs_review
        if isinstance(sub_schema, dict):
            sub_hard, sub_review = _validate_schema(sub_schema)
            hard_unsafe = hard_unsafe or sub_hard
            needs_review = needs_review or sub_review

    # 1. Named properties
    properties = schema.get("properties", {})
    if isinstance(properties, dict):
        for param_name, param_schema in properties.items():
            if not isinstance(param_schema, dict):
                continue
            param_name_lower = str(param_name).lower()
            matched_hard = any(kw in param_name_lower for kw in _HARD_RESTRICTED_PARAM_KEYWORDS)
            matched_review = any(kw in param_name_lower for kw in _REVIEW_ONLY_PARAM_KEYWORDS)
            if (matched_hard or matched_review) and not _param_is_admitted(param_schema):
                if matched_hard:
                    hard_unsafe = True
                else:
                    needs_review = True
            # Recurse into the param's own nested schema.
            _merge(param_schema)

    # 2. Array items — object or tuple form.
    items = schema.get("items")
    if isinstance(items, dict):
        _merge(items)
    elif isinstance(items, list):
        for sub_schema in items:
            _merge(sub_schema)

    # 3. additionalProperties (map-of-objects). Bool form carries no schema.
    _merge(schema.get("additionalProperties"))

    # 4. patternProperties (regex-keyed maps).
    pattern_properties = schema.get("patternProperties")
    if isinstance(pattern_properties, dict):
        for sub_schema in pattern_properties.values():
            _merge(sub_schema)

    # 5. $defs / definitions (referenced sub-schemas defined inline).
    for defs_key in ("$defs", "definitions"):
        defs = schema.get(defs_key)
        if isinstance(defs, dict):
            for sub_schema in defs.values():
                _merge(sub_schema)

    # 6. allOf / anyOf / oneOf combinators.
    for combinator in ("allOf", "anyOf", "oneOf"):
        combo_items = schema.get(combinator)
        if isinstance(combo_items, list):
            for sub_schema in combo_items:
                _merge(sub_schema)

    return hard_unsafe, needs_review


def _risk_flags(candidate: dict[str, Any], known_ids: list[str] | None = None) -> list[str]:
    flags: list[str] = []
    install = candidate.get("install") if isinstance(candidate.get("install"), dict) else {}
    command = str(install.get("command", "")).strip()
    args = [str(arg) for arg in install.get("args", []) if arg is not None]
    source_url = str(candidate.get("source_url", "")).strip()
    permissions = candidate.get("permissions") if isinstance(candidate.get("permissions"), dict) else {}

    joined = " ".join([command, *args]).lower()
    if "@latest" in joined or ":latest" in joined:
        flags.append("unpinned-version")
    if command in {"npx", "uvx", "pip", "pipx", "npm", "pnpm", "docker", "curl", "bash", "sh"}:
        flags.append(f"dynamic-installer:{command}")
    if "curl" in joined and ("|" in joined or "bash" in joined or "sh" in joined):
        flags.append("curl-pipe-install")
    if source_url and not (source_url.startswith("https://github.com/") or source_url == "local"):
        flags.append("non-github-source")
    report_only_writes = {"reports-only", "report-output-only", "knowledge-graph-output"}
    if permissions.get("writes") not in {False, "false", None, *report_only_writes}:
        flags.append("write-capable-or-report-writing")
    if permissions.get("secrets") not in {False, "false", None}:
        flags.append("secret-or-token-required")
    if permissions.get("network") not in {False, "false", None, "localhost"}:
        flags.append("network-capable")
    if re.search(r"\b(sudo|rm|delete|exec|shell)\b", joined):
        flags.append("dangerous-command-keyword")

    # Typo-squatting check against known candidate IDs
    if known_ids:
        # Tokenize joined string of command and args
        tokens = set(re.split(r'[^a-zA-Z0-9\-_]', joined))
        for token in tokens:
            if not token:
                continue
            token_lower = token.lower()
            for kid in known_ids:
                kid_lower = kid.lower()
                # If they are similar but not identical
                if token_lower != kid_lower:
                    if len(token_lower) >= 4 and len(kid_lower) >= 4:
                        if _levenshtein_distance(token_lower, kid_lower) <= 2:
                            flags.append("typo-squatting-detected")
                            break
            if "typo-squatting-detected" in flags:
                break

    # Schema parameter validation check
    tool_schemas = candidate.get("tool_schemas") or candidate.get("schemas") or {}
    if isinstance(tool_schemas, dict):
        schema_hard_unsafe = False
        schema_needs_review = False
        for tool_name, schema in tool_schemas.items():
            if isinstance(schema, dict):
                hard_unsafe, needs_review = _validate_schema(schema)
                schema_hard_unsafe = schema_hard_unsafe or hard_unsafe
                schema_needs_review = schema_needs_review or needs_review
        if schema_hard_unsafe:
            flags.append("unsafe-parameter-schema")
        elif schema_needs_review:
            flags.append("unbound-args-parameter-schema")

    for risk in candidate.get("risks", []):
        if isinstance(risk, str) and risk and risk not in flags:
            flags.append(risk)

    return flags


def _review_accepts_mitigations(candidate: dict[str, Any], risk_flags: list[str], tool_results: list[dict[str, Any]]) -> bool:
    if candidate.get("review_status") != "accepted-with-mitigations":
        return False
    if not candidate.get("pinned_version"):
        return False
    if not candidate.get("mitigations"):
        return False
    if any(result.get("safe") is False for result in tool_results):
        return False
    non_mitigable = {"curl-pipe-install", "unpinned-version"}
    return not any(flag in non_mitigable for flag in risk_flags)


def _admission(candidate: dict[str, Any], risk_flags: list[str], tool_results: list[dict[str, Any]]) -> str:
    if _review_accepts_mitigations(candidate, risk_flags, tool_results):
        return "accepted-with-mitigations"
    hard_blockers = {
        "curl-pipe-install",
        "dangerous-command-keyword",
        "unsafe-parameter-schema",
        "typo-squatting-detected",
    }
    if any(flag in hard_blockers for flag in risk_flags):
        return "blocked"
    if any(result.get("safe") is False for result in tool_results):
        return "needs-review"
    if any(
        flag.startswith("dynamic-installer:")
        or flag in {"unpinned-version", "secret-or-token-required", "unbound-args-parameter-schema"}
        for flag in risk_flags
    ):
        return "needs-review"
    if risk_flags:
        return "review-recommended"
    return "low-risk"


def audit_candidate(candidate: dict[str, Any], known_ids: list[str] | None = None) -> dict[str, Any]:
    auditor = _load_auditor()
    install = candidate.get("install") if isinstance(candidate.get("install"), dict) else {}
    tool_results: list[dict[str, Any]] = []

    if known_ids is None:
        try:
            registry = _load_registry(REGISTRY_PATH)
            known_ids = [c.get("id") for c in registry.get("candidates", []) if c.get("id")]
        except Exception:
            known_ids = []

    for tool_name in candidate.get("tool_allowlist", []):
        if not isinstance(tool_name, str) or not tool_name.strip():
            continue
        metadata = {
            "endpoint": f"candidate://{candidate.get('id')}/{tool_name}",
            "reason": f"candidate capability tool: {candidate.get('category', 'unknown')}",
            "manifest": {
                "name": candidate.get("id"),
                "version": candidate.get("pinned_version", ""),
                "source_url": candidate.get("source_url"),
                "install_type": install.get("type"),
                "command_name": install.get("command"),
            },
            "parameters": {
                "tool": tool_name,
                "permission_network": (candidate.get("permissions") or {}).get("network"),
                "permission_writes": (candidate.get("permissions") or {}).get("writes"),
            },
        }
        tool_results.append(auditor.audit_tool(tool_name, metadata))

    flags = _risk_flags(candidate, known_ids)
    return {
        "id": candidate.get("id"),
        "name": candidate.get("name"),
        "priority": candidate.get("priority"),
        "state": candidate.get("state"),
        "source_url": candidate.get("source_url"),
        "pinned_version": candidate.get("pinned_version"),
        "source_hash": candidate.get("source_hash"),
        "risk_flags": flags,
        "admission": _admission(candidate, flags, tool_results),
        "tool_count": len(tool_results),
        "unsafe_tool_count": sum(1 for result in tool_results if result.get("safe") is False),
        "tool_audits": [
            {
                "tool_name": result.get("tool_name"),
                "safe": result.get("safe"),
                "approved": result.get("approved"),
                "cached": result.get("cached"),
                "reasons": result.get("reasons", []),
            }
            for result in tool_results
        ],
        "activation_notes": candidate.get("activation_notes", ""),
    }


def cmd_list(args: argparse.Namespace) -> int:
    registry = _load_registry(Path(args.registry))
    rows = registry["candidates"]
    if args.json:
        print(json.dumps(rows, indent=2, sort_keys=True))
        return 0
    for candidate in rows:
        print(f"{candidate.get('id')}\t{candidate.get('priority')}\t{candidate.get('state')}\t{candidate.get('name')}")
    return 0


def cmd_audit(args: argparse.Namespace) -> int:
    registry = _load_registry(Path(args.registry))
    if args.all:
        candidates = registry["candidates"]
    else:
        candidates = [_candidate_by_id(registry, args.candidate_id)]
    known_ids = [c.get("id") for c in registry.get("candidates", []) if c.get("id")]
    reports = [audit_candidate(candidate, known_ids) for candidate in candidates]
    if args.json:
        print(json.dumps({"version": registry.get("version"), "reports": reports}, indent=2, sort_keys=True))
        return 0
    for report in reports:
        flags = ",".join(report["risk_flags"]) if report["risk_flags"] else "-"
        print(f"{report['id']}: admission={report['admission']} priority={report['priority']} risks={flags}")
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--registry", default=str(REGISTRY_PATH), help="Candidate registry path")
    sub = parser.add_subparsers(dest="cmd", required=True)

    list_parser = sub.add_parser("list", help="List candidate capabilities")
    list_parser.add_argument("--json", action="store_true", help="Emit JSON")
    list_parser.set_defaults(func=cmd_list)

    audit_parser = sub.add_parser("audit", help="Audit one candidate or all candidates")
    target = audit_parser.add_mutually_exclusive_group(required=True)
    target.add_argument("candidate_id", nargs="?", help="Candidate id")
    target.add_argument("--all", action="store_true", help="Audit all candidates")
    audit_parser.add_argument("--json", action="store_true", help="Emit JSON")
    audit_parser.set_defaults(func=cmd_audit)
    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return int(args.func(args))


if __name__ == "__main__":
    raise SystemExit(main())
