require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "required command not found: $1"
}

run_python() {
  local -a args=("$@")

  if command -v python3 >/dev/null 2>&1; then
    python3 "${args[@]}"
    return
  fi

  if command -v nix-shell >/dev/null 2>&1; then
    local cmd="python3"
    local arg
    for arg in "${args[@]}"; do
      cmd+=" $(printf '%q' "$arg")"
    done
    nix-shell -p python3 --run "$cmd"
    return
  fi

  if command -v nix >/dev/null 2>&1; then
    nix --extra-experimental-features "nix-command flakes" shell nixpkgs#python3 --command python3 "${args[@]}"
    return
  fi

  die "required command not found: python3 (and nix fallback unavailable)"
}

run_python_with_yaml() {
  local -a args=("$@")

  if command -v python3 >/dev/null 2>&1; then
    if python3 - <<'PY' >/dev/null 2>&1
import yaml  # noqa: F401
PY
    then
      python3 "${args[@]}"
      return
    fi
  fi

  if command -v nix-shell >/dev/null 2>&1; then
    local cmd="python3"
    local arg
    for arg in "${args[@]}"; do
      cmd+=" $(printf '%q' "$arg")"
    done
    nix-shell -p python3 python3Packages.pyyaml --run "$cmd"
    return
  fi

  if command -v nix >/dev/null 2>&1; then
    nix --extra-experimental-features "nix-command flakes" shell \
      nixpkgs#python3 nixpkgs#python3Packages.pyyaml \
      --command python3 "${args[@]}"
    return
  fi

  die "required dependency missing: python3 + PyYAML (and nix fallback unavailable)"
}

ai_layer_error() {
  local code="$1"
  local phase="$2"
  local detail="$3"
  local next_step="${4:-Review command usage and provide missing inputs.}"
  cat >&2 <<EOF
AI_LAYER_ERROR
- code: ${code}
- phase: ${phase}
- detail: ${detail}
- next_step: ${next_step}
EOF
}

prompt_if_empty() {
  local current="${1:-}"
  local prompt="${2:-Enter value}"
  if [[ -n "$current" ]]; then
    printf '%s' "$current"
    return 0
  fi
  local value=""
  read -r -p "${prompt}: " value
  printf '%s' "$value"
}

