    "agent_file_count": agent_file_count,
    "latest_evidence_files": [line for line in evidence_raw.splitlines() if line.strip()],
    "changed_files_count": changed_files_count,
    "next": [
        "request on-demand docs/telemetry only if needed",
        "run /brownfield or task-specific workflow after objective confirmation",
    ],
}

with open(out, "w", encoding="utf-8") as fh:
    json.dump(doc, fh, indent=2)
    fh.write("\n")
PY

