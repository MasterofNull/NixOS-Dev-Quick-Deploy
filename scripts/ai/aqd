scan_text_for_secrets() {
  local data="$1"
  # Lightweight denylist-based detector to keep token/runtime overhead low.
  local patterns=(
    'AKIA[0-9A-Z]{16}'
    'ghp_[A-Za-z0-9]{36}'
    'github_pat_[A-Za-z0-9_]{20,}'
    'sk-[A-Za-z0-9]{20,}'
    'xox[baprs]-[A-Za-z0-9-]{10,}'
    '-----BEGIN (RSA|EC|OPENSSH|DSA|PGP) PRIVATE KEY-----'
    '(?i)(password|passwd|secret|token|api[_-]?key)\s*[:=]\s*["'"'"']?[A-Za-z0-9_./+=-]{8,}'
  )

  local re
  for re in "${patterns[@]}"; do
    if printf '%s\n' "$data" | rg -n -I -e "$re" >/dev/null 2>&1; then
      return 0
    fi
  done
  return 1
}

install_git_secret_hooks() {
  local target_dir="$1"
  [[ -d "$target_dir/.git" ]] || {
    ai_layer_error "git_not_initialized" "git-guard" "Target is not a git repository: $target_dir" "Run: git -C '$target_dir' init"
    return 1
  }

  local hooks_dir="$target_dir/.git/hooks"
  mkdir -p "$hooks_dir"

  cat > "$hooks_dir/pre-commit" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

files="$(git diff --cached --name-only --diff-filter=ACM)"
[[ -n "${files}" ]] || exit 0

patterns=(
  'AKIA[0-9A-Z]{16}'
  'ghp_[A-Za-z0-9]{36}'
  'github_pat_[A-Za-z0-9_]{20,}'
  'sk-[A-Za-z0-9]{20,}'
  'xox[baprs]-[A-Za-z0-9-]{10,}'
  '-----BEGIN (RSA|EC|OPENSSH|DSA|PGP) PRIVATE KEY-----'
  '(?i)(password|passwd|secret|token|api[_-]?key)\s*[:=]\s*["'"'"']?[A-Za-z0-9_./+=-]{8,}'
)

blocked=0
while IFS= read -r file; do
  [[ -f "$file" ]] || continue
  staged="$(git show ":$file" 2>/dev/null || true)"
  [[ -n "$staged" ]] || continue
  for re in "${patterns[@]}"; do
    if printf '%s\n' "$staged" | rg -n -I -e "$re" >/tmp/aqd-secret-hit.txt 2>/dev/null; then
      echo "secret guard: potential secret detected in staged file '$file' (pattern: $re)" >&2
      sed -n '1,3p' /tmp/aqd-secret-hit.txt >&2 || true
      blocked=1
    fi
  done
done <<<"$files"

if [[ "$blocked" -eq 1 ]]; then
  echo "Commit blocked. Remove/redact secrets and try again." >&2
  exit 1
fi
exit 0
EOF

  cat > "$hooks_dir/pre-push" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

patterns=(
  'AKIA[0-9A-Z]{16}'
  'ghp_[A-Za-z0-9]{36}'
  'github_pat_[A-Za-z0-9_]{20,}'
  'sk-[A-Za-z0-9]{20,}'
  'xox[baprs]-[A-Za-z0-9-]{10,}'
  '-----BEGIN (RSA|EC|OPENSSH|DSA|PGP) PRIVATE KEY-----'
  '(?i)(password|passwd|secret|token|api[_-]?key)\s*[:=]\s*["'"'"']?[A-Za-z0-9_./+=-]{8,}'
)

blocked=0
while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ -z "${local_sha:-}" ]]; then
    continue
  fi

  range="$local_sha"
  if [[ "${remote_sha:-}" != "0000000000000000000000000000000000000000" ]]; then
    range="${remote_sha}..${local_sha}"
  fi

  while IFS= read -r commit; do
    patch="$(git show --format= --no-color "$commit" 2>/dev/null || true)"
    [[ -n "$patch" ]] || continue
    for re in "${patterns[@]}"; do
      if printf '%s\n' "$patch" | rg -n -I -e "$re" >/tmp/aqd-secret-hit.txt 2>/dev/null; then
        echo "secret guard: potential secret detected in to-push commit '$commit' (pattern: $re)" >&2
        sed -n '1,3p' /tmp/aqd-secret-hit.txt >&2 || true
        blocked=1
      fi
    done
  done < <(git rev-list "$range" 2>/dev/null || true)
done

if [[ "$blocked" -eq 1 ]]; then
  echo "Push blocked. Remove/redact secrets and amend commits before push." >&2
  exit 1
fi
exit 0
EOF

  chmod +x "$hooks_dir/pre-commit" "$hooks_dir/pre-push"
}

cmd_workflows_project_init() {
  local target_dir="."
  local project_name=""
  local goal=""
  local stack=""
  local owner=""
  local force="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --target) target_dir="${2:-}"; shift 2 ;;
      --name) project_name="${2:-}"; shift 2 ;;
      --goal) goal="${2:-}"; shift 2 ;;
      --stack) stack="${2:-}"; shift 2 ;;
      --owner) owner="${2:-}"; shift 2 ;;
      --force) force="true"; shift ;;
      *) ai_layer_error "unknown_option" "project-init" "Unknown option: $1" "Use: aqd workflows project-init --target <dir> --name <project> --goal <goal>"; return 1 ;;
    esac
  done

  mkdir -p "$target_dir"
  if [[ -n "$(find "$target_dir" -mindepth 1 -maxdepth 1 -not -name '.git' -print -quit 2>/dev/null)" ]]; then
    ai_layer_error "target_not_empty" "project-init" "Target directory is not empty: $target_dir" "Use an empty directory for /project-init."
    return 1
  fi

  project_name="$(prompt_if_empty "$project_name" "Project name")"
  goal="$(prompt_if_empty "$goal" "Primary goal")"
  stack="$(prompt_if_empty "$stack" "Preferred stack (or TBD)")"
  owner="$(prompt_if_empty "$owner" "Owner/team (or TBD)")"

  echo
  echo "[project-init] guided summary"
  echo "- target: $target_dir"
  echo "- name: $project_name"
  echo "- goal: $goal"
  echo "- stack: $stack"
  echo "- owner: $owner"
  echo

  local -a bootstrap_args=(
    --target "$target_dir"
    --name "$project_name"
    --goal "$goal"
    --stack "$stack"
    --owner "$owner"
  )
  if [[ "$force" == "true" ]]; then
    bootstrap_args+=(--force)
  fi
  cmd_workflows_bootstrap "${bootstrap_args[@]}"
  write_agent_command_specs "$target_dir" "$project_name" "$goal" "$stack" "$owner"

  if [[ ! -d "$target_dir/.git" ]]; then
    git -C "$target_dir" init >/dev/null 2>&1
  fi
  install_git_secret_hooks "$target_dir"

  cat <<EOF
/project-init complete.
- AI layer scaffold created
- slash command specs created in .agent/commands
- .claude and .agents/plans progressive-disclosure scaffolding created
- git secret guards installed (.git/hooks/pre-commit, .git/hooks/pre-push)
- next: run .agent/commands/start-workflow.sh with HYBRID_URL set
EOF
}

cmd_workflows_retrofit() {
  local target_dir="."
  local project_name=""
  local goal="retrofit existing project AI layer for guided workflow"
  local stack="TBD"
  local owner="TBD"
  local force="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --target) target_dir="${2:-}"; shift 2 ;;
      --name) project_name="${2:-}"; shift 2 ;;
      --goal) goal="${2:-}"; shift 2 ;;
      --stack) stack="${2:-}"; shift 2 ;;
      --owner) owner="${2:-}"; shift 2 ;;
      --force) force="true"; shift ;;
      *) ai_layer_error "unknown_option" "retrofit" "Unknown option: $1" "Use: aqd workflows retrofit --target <dir> --name <project> [--force]"; return 1 ;;
    esac
  done

  [[ -d "$target_dir" ]] || {
    ai_layer_error "missing_target" "retrofit" "Target directory does not exist: $target_dir"
    return 1
  }

  if [[ -z "$project_name" ]]; then
    project_name="$(basename "$(realpath "$target_dir")")"
  fi

  local -a bootstrap_args=(
    --target "$target_dir"
    --name "$project_name"
    --goal "$goal"
    --stack "$stack"
    --owner "$owner"
  )
  if [[ "$force" == "true" ]]; then
    bootstrap_args+=(--force)
  fi

  cmd_workflows_bootstrap "${bootstrap_args[@]}"
  write_agent_command_specs "$target_dir" "$project_name" "$goal" "$stack" "$owner"
  if [[ -d "$target_dir/.git" ]]; then
    install_git_secret_hooks "$target_dir"
  fi

  cat <<EOF
/retrofit complete.
- target: $target_dir
- regenerated/seeded AI layer artifacts for existing project
- next: run /brownfield workflow for first improvement slice
EOF
}

