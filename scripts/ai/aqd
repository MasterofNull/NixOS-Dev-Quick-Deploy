render_template_file() {
  local src="$1"
  local dest="$2"
  local project_name="${3:-TBD}"
  local goal="${4:-TBD}"
  local stack="${5:-TBD}"
  local owner="${6:-TBD}"

  [[ -f "$src" ]] || die "template file not found: $src"
  mkdir -p "$(dirname "$dest")"
  sed \
    -e "s|@PROJECT_NAME@|${project_name}|g" \
    -e "s|@GOAL@|${goal}|g" \
    -e "s|@STACK@|${stack}|g" \
    -e "s|@OWNER@|${owner}|g" \
    "$src" > "$dest"
}

