#!/usr/bin/env python3
"""aq-role-route — agent-agnostic role/eligibility selector.

Picks the agent that should fill a role instance (orchestrator, architect,
implementer, reviewer, binding-acceptance) at dispatch time instead of a
hardcoded lane. DESIGN SSOT: `.agents/plans/agent-agnostic-factory/DESIGN.md`
§2.1 + §3 item 1; role definitions/eligibility: `docs/architecture/role-matrix.md`
("Agnostic execution" section).

Selection order: availability (lane reachable / not in cooldown / not
flagged down) x capability+tier (role-matrix eligibility table below,
sourced from DESIGN.md §2.1) x independence (never return a lane in
--exclude, e.g. the producer for a reviewer/acceptance role) x cost
(cheapest eligible first, costs read from `config/model-coordinator.json`).

Availability probes are filesystem-only (no network, no credentials):
- codex: reuses the exact quota-cooldown file `delegate-to-codex` already
  writes/reads (`.agents/delegation/.codex-quota-cooldown`, an ISO-8601
  reset timestamp). Cooldown active => codex unavailable.
- any lane: a generic, easy-to-extend down-flag
  `.agents/delegation/.<lane>-down` — presence marks the lane unavailable.
  This is the stub other health checks (real HTTP probes, etc.) can replace
  per lane without touching the selection algorithm.

Binding acceptance never hardcodes a single lane: the algorithm walks the
eligibility table in cost order and returns whichever independent lane is
actually available, recording any substitution in `reason`.
"""

from __future__ import annotations

import argparse
import json
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

REPO = Path(__file__).resolve().parents[2]
DELEGATION_DIR = REPO / ".agents" / "delegation"
CODEX_COOLDOWN_FILE = DELEGATION_DIR / ".codex-quota-cooldown"
MODEL_COORDINATOR = REPO / "config" / "model-coordinator.json"

# Lane identity: canonical id, aliases an --exclude token may name (matched
# exactly), and the model-coordinator "models" key used to look up cost.
LANES: dict[str, dict[str, Any]] = {
    "codex": {
        "aliases": {"codex", "codex-cli"},
        "coordinator_model_key": "codex",
    },
    "claude": {
        "aliases": {
            "claude", "claude-flagship", "claude-fable-5", "claude-opus-4-8",
            "claude-sonnet-4-6", "claude-haiku-4-5-20251001", "claude-orchestrator",
            "claude-reasoning",
        },
        "coordinator_model_key": "claude-orchestrator",
    },
    "gemini": {
        "aliases": {"gemini", "antigravity", "gemini-orchestrator", "gemini-3.1-pro"},
        "coordinator_model_key": "gemini-orchestrator",
    },
    "local": {
        "aliases": {"local", "qwen", "local-qwen", "qwen3.6-35b", "llama-cpp-local"},
        "coordinator_model_key": "llama-cpp-local",
    },
}

# Preferred fill order per role, sourced verbatim from DESIGN.md §2.1's
# eligibility table (cost sort below may reorder within this candidate set,
# but this defines *membership* — only these lanes are eligible per role).
ROLE_ELIGIBILITY: dict[str, list[str]] = {
    "orchestrator": ["claude", "codex", "gemini"],
    "architect": ["gemini", "claude", "codex", "local"],
    "implementer": ["local", "codex", "claude", "gemini"],
    "reviewer": ["claude", "codex", "gemini"],
    "binding-acceptance": ["codex", "claude", "gemini", "local"],
}

ROLE_ALIASES = {
    "binding_acceptance": "binding-acceptance",
    "acceptance": "binding-acceptance",
    "prd": "architect",
    "plan": "architect",
    "design-review": "reviewer",
    "auth-review": "reviewer",
}

DEFAULT_COST_PER_1K = 0.0


def _now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def _load_json(path: Path) -> dict[str, Any]:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except (FileNotFoundError, json.JSONDecodeError):
        return {}


def _lane_cost(lane_id: str, coordinator: dict[str, Any]) -> float:
    key = LANES[lane_id]["coordinator_model_key"]
    model = coordinator.get("models", {}).get(key, {})
    cost = model.get("cost_per_1k_tokens", DEFAULT_COST_PER_1K)
    return float(cost) if isinstance(cost, (int, float)) else DEFAULT_COST_PER_1K


def _codex_cooldown_status() -> tuple[bool, str | None]:
    """Return (available, reason_if_unavailable). Mirrors delegate-to-codex's
    own read of COOLDOWN_FILE: an ISO-8601 reset timestamp; unparseable
    content is treated as an active cooldown (same fail-safe bias the
    writer uses when it falls back to a bounded cooldown on an unparseable
    reset line)."""
    if not CODEX_COOLDOWN_FILE.exists():
        return True, None
    raw = CODEX_COOLDOWN_FILE.read_text(encoding="utf-8").strip()
    if not raw:
        return True, None
    try:
        reset_at = datetime.fromisoformat(raw.replace("Z", "+00:00"))
    except ValueError:
        return False, "quota-cooldown-unparseable-reset-assume-active"
    if reset_at.tzinfo is None:
        reset_at = reset_at.replace(tzinfo=timezone.utc)
    now = datetime.now(timezone.utc)
    if now >= reset_at:
        return True, None
    return False, f"quota-cooldown-active-until-{raw}"


def _lane_down_flag(lane_id: str) -> Path:
    return DELEGATION_DIR / f".{lane_id}-down"


def _lane_health(lane_id: str) -> tuple[bool, str | None]:
    """Filesystem-only availability probe. Generic down-flag first (any
    lane, easy to extend/simulate), then lane-specific probes."""
    flag = _lane_down_flag(lane_id)
    if flag.exists():
        return False, "flagged-down"
    if lane_id == "codex":
        return _codex_cooldown_status()
    return True, None


def _normalize_role(role: str) -> str | None:
    role = role.strip().lower()
    role = ROLE_ALIASES.get(role, role)
    return role if role in ROLE_ELIGIBILITY else None


def _matches_exclude(lane_id: str, token: str) -> bool:
    token = token.strip().lower()
    if not token:
        return False
    if token == lane_id or token in LANES[lane_id]["aliases"]:
        return True
    # First hyphen segment covers concrete model ids naming a lane, e.g.
    # "claude-sonnet" / "claude-sonnet-4-6" both reduce to lane "claude".
    return token.split("-")[0] == lane_id


def _emit(payload: dict[str, Any], as_json: bool) -> int:
    if as_json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        for key, value in payload.items():
            if isinstance(value, (dict, list)):
                value = json.dumps(value, sort_keys=True)
            print(f"{key}: {value}")
    return 0 if payload.get("ok", True) else 1


def route(role: str, subject: str, exclude: list[str]) -> dict[str, Any]:
    normalized = _normalize_role(role)
    if normalized is None:
        return {
            "ok": False,
            "reason": "unknown-role",
            "role": role,
            "known_roles": sorted(ROLE_ELIGIBILITY),
        }

    coordinator = _load_json(MODEL_COORDINATOR)
    candidates = ROLE_ELIGIBILITY[normalized]
    excluded_lanes = {
        lane_id for lane_id in candidates
        if any(_matches_exclude(lane_id, token) for token in exclude)
    }
    eligible = [lane_id for lane_id in candidates if lane_id not in excluded_lanes]

    # Cheapest eligible first; DESIGN.md table order is the tiebreak so
    # binding-acceptance still prefers Codex among equal-cost lanes without
    # that preference ever being hardcoded — it falls out of the algorithm
    # and yields to availability/exclusion like any other candidate.
    ranked = sorted(
        eligible,
        key=lambda lane_id: (_lane_cost(lane_id, coordinator), candidates.index(lane_id)),
    )

    alternates: list[dict[str, Any]] = []
    chosen: str | None = None
    chosen_reason: str | None = None
    preferred = ranked[0] if ranked else None

    for lane_id in ranked:
        available, unavailable_reason = _lane_health(lane_id)
        entry = {
            "agent": lane_id,
            "cost_per_1k_tokens": _lane_cost(lane_id, coordinator),
            "available": available,
        }
        if not available:
            entry["unavailable_reason"] = unavailable_reason
        if chosen is None and available:
            chosen = lane_id
            if lane_id == preferred:
                chosen_reason = f"cheapest eligible independent lane for role '{normalized}'"
            else:
                chosen_reason = (
                    f"preferred lane '{preferred}' unavailable; substituted '{lane_id}' "
                    "(next cheapest eligible independent lane)"
                )
        else:
            alternates.append(entry)

    result: dict[str, Any] = {
        "ok": chosen is not None,
        "role": normalized,
        "subject": subject,
        "excluded": sorted(excluded_lanes),
        "ts": _now_iso(),
    }
    if chosen is not None:
        result["chosen_agent"] = chosen
        result["reason"] = chosen_reason
        result["alternates"] = alternates
    else:
        result["reason"] = "no-eligible-independent-lane-available"
        result["chosen_agent"] = None
        result["alternates"] = alternates
        result["all_candidates_down"] = [
            {"agent": lane_id, **dict(zip(("available", "unavailable_reason"), _lane_health(lane_id)))}
            for lane_id in ranked
        ]
    return result


def cmd_route(args: argparse.Namespace) -> int:
    payload = route(args.role, args.subject, args.exclude or [])
    return _emit(payload, args.json)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("role", help="orchestrator | architect | implementer | reviewer | binding-acceptance")
    parser.add_argument("--subject", required=True, help="Slice id / hash / commit the role instance applies to")
    parser.add_argument("--exclude", nargs="*", default=[], help="Agent id(s)/alias(es) to exclude (e.g. the producer)")
    parser.add_argument("--json", action="store_true")
    parser.set_defaults(func=cmd_route)
    return parser


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    return int(args.func(args))


if __name__ == "__main__":
    raise SystemExit(main())
