#!/usr/bin/env python3
"""
aq-integrity-scan (The Orphan Hunter)
--------------------------------------
Purpose: Detects gaps between Documentation, Implementation, and Registration.
Usage: aq-integrity-scan [--purge] [--json]

Heuristics:
1. Documentation Gap: Commands mentioned in .md files but missing in scripts/ai/.
2. Registration Gap: Async handlers in *_handlers.py but missing in mcp_handlers.py or server.py.
3. Import Gap: .py files in ai-stack with zero inbound imports.
4. Protocol Gap: HTTP routes in coordinator without corresponding MCP tool definitions.
"""

import argparse
import ast
import json
import re
import time
from pathlib import Path
from typing import Iterable, List

REPO_ROOT = Path(__file__).resolve().parent.parent.parent
AI_STACK = REPO_ROOT / "ai-stack"
SCRIPTS_AI = REPO_ROOT / "scripts/ai"
DOCS_DIR = REPO_ROOT / ".agent"
DEFAULT_TIMEOUT_SECONDS = 15.0
DEFAULT_MAX_FILES = 6000
DEFAULT_MAX_LOGICAL_FILES = 1500
DEFAULT_LOGICAL_BASELINE = REPO_ROOT / "config/aq-integrity-logical-orphans.json"
ENTRYPOINT_NAMES = {"server", "autonomous_loop", "agent_executor", "checkpoint_service"}
DOC_SCAN_EXCLUDED_PARTS = {"collaboration", "scratchpad", "archive"}

class IntegrityScanner:
    def __init__(
        self,
        *,
        timeout_seconds: float = DEFAULT_TIMEOUT_SECONDS,
        max_files: int = DEFAULT_MAX_FILES,
        max_logical_files: int = DEFAULT_MAX_LOGICAL_FILES,
        include_logical: bool = True,
        logical_baseline: Path | None = DEFAULT_LOGICAL_BASELINE,
    ):
        self.started_at = time.monotonic()
        self.timeout_seconds = max(0.1, float(timeout_seconds))
        self.max_files = max(1, int(max_files))
        self.max_logical_files = max(1, int(max_logical_files))
        self.include_logical = include_logical
        self.logical_baseline = logical_baseline
        self.findings = self._empty_findings()
        self.meta = {
            "version": "2.0",
            "bounded": True,
            "timeout_seconds": self.timeout_seconds,
            "max_files": self.max_files,
            "max_logical_files": self.max_logical_files,
            "files_scanned": 0,
            "files_skipped": 0,
            "logical_files_ignored": 0,
            "logical_baseline_entries": 0,
            "truncated": False,
            "warnings": [],
        }

    def _empty_findings(self):
        return {
            "doc_orphans": [],      # Commands in docs but not in scripts/
            "registration_gaps": [], # Logic implemented but not wired to MCP/HTTP
            "logical_orphans": [],   # Code with no callers
            "new_logical_orphans": [], # Logical orphans absent from the committed baseline
            "protocol_drifts": []    # HTTP/MCP mismatch
        }

    def _deadline_exceeded(self) -> bool:
        return (time.monotonic() - self.started_at) >= self.timeout_seconds

    def _safe_read_text(self, path: Path) -> str:
        try:
            return path.read_text(encoding="utf-8", errors="replace")
        except OSError as exc:
            self.meta["warnings"].append(f"read_failed:{path}:{exc}")
            return ""

    def _bounded_files(self, paths: Iterable[Path], *, limit: int | None = None) -> List[Path]:
        selected: List[Path] = []
        limit = limit or self.max_files
        for path in paths:
            if self._deadline_exceeded():
                self.meta["truncated"] = True
                self.meta["warnings"].append("scan_timeout_reached")
                break
            if len(selected) >= limit or self.meta["files_scanned"] >= self.max_files:
                self.meta["truncated"] = True
                self.meta["warnings"].append("file_scan_limit_reached")
                break
            if "__pycache__" in str(path):
                self.meta["files_skipped"] += 1
                continue
            selected.append(path)
            self.meta["files_scanned"] += 1
        return selected

    def scan_doc_consistency(self):
        """Find commands referenced in markdown that don't exist in scripts/ai."""
        documented_cmds = set()
        for md_file in self._bounded_files(DOCS_DIR.glob("**/*.md")):
            if any(part in DOC_SCAN_EXCLUDED_PARTS for part in md_file.relative_to(DOCS_DIR).parts):
                self.meta["files_skipped"] += 1
                continue
            content = self._safe_read_text(md_file)
            matches = re.findall(r'`(aq-[a-z0-9-]+)`', content)
            documented_cmds.update(matches)
        
        live_cmds = {f.name for f in SCRIPTS_AI.glob("aq-*")}
        for cmd in documented_cmds:
            if cmd not in live_cmds:
                self.findings["doc_orphans"].append({
                    "command": cmd,
                    "reason": "Referenced in documentation but missing from scripts/ai/"
                })

    def scan_coordinator_wiring(self):
        """Find handler modules in hybrid-coordinator that aren't wired to any routing surface.

        Strategy: modules register via register_routes(app) or by being imported into a wiring
        surface. We check at the MODULE level (not individual handler fn names), because a single
        register_routes() call wires all handlers in that module.

        Wiring surfaces checked:
          - http_server_impl.py  (monolith: ~20 register_routes() calls)
          - router.py            (Strangler Fig R2.x domain registrations)
          - server.py            (MCP + init)
          - extensions/mcp_handlers.py  (TOOL_DEFINITIONS + dispatch)
          - *_service.py         (domain service modules own their sub-routes)
        """
        coord_dir = AI_STACK / "mcp-servers/hybrid-coordinator"

        wiring_files = [
            coord_dir / "http_server_impl.py",
            coord_dir / "router.py",
            coord_dir / "server.py",
            coord_dir / "extensions/mcp_handlers.py",
        ]
        wiring_content = "".join([self._safe_read_text(f) for f in wiring_files if f.exists()])
        for svc_file in self._bounded_files(coord_dir.glob("**/*_service.py")):
            wiring_content += self._safe_read_text(svc_file)

        for h_file in self._bounded_files(coord_dir.glob("**/*_handlers.py")):
            content = self._safe_read_text(h_file)
            # Only check modules that define a register_routes() function — those are
            # HTTP handler modules that must be explicitly wired. Modules without
            # register_routes() are MCP-only (dispatched via mcp_handlers.dispatch_tool).
            if "def register_routes(" not in content:
                continue
            module_name = h_file.stem  # e.g. "hints_handlers"
            # Wired if: module imported by name OR register_routes called by module reference
            is_wired = (
                f"import {module_name}" in wiring_content
                or f"from {module_name}" in wiring_content
                or f"{module_name}.register_routes" in wiring_content
                or f"{module_name} import" in wiring_content
            )
            if not is_wired:
                self.findings["registration_gaps"].append({
                    "handler": f"{module_name}.register_routes()",
                    "file": str(h_file.relative_to(REPO_ROOT)),
                    "reason": "Module has register_routes() but is not imported/called in any wiring surface"
                })

    def scan_logical_orphans(self):
        """Find python files in ai-stack with zero imports from other files."""
        if not self.include_logical:
            self.meta["warnings"].append("logical_orphan_scan_skipped")
            return
        all_py_files = sorted(
            f for f in self._bounded_files(AI_STACK.glob("**/*.py"), limit=self.max_logical_files)
            if not self._ignore_logical_file(f)
        )
        py_names = {f.stem for f in all_py_files if f.name != "__init__.py"}
        
        import_map = {name: 0 for name in py_names}
        
        for py_file in all_py_files:
            if self._deadline_exceeded():
                self.meta["truncated"] = True
                self.meta["warnings"].append("logical_scan_timeout_reached")
                break
            imported_names = self._imported_module_names(py_file)
            for name in imported_names & py_names:
                if py_file.stem != name:
                    import_map[name] += 1

        baseline_paths = self._logical_baseline_paths()
        
        for py_file in all_py_files:
            name = py_file.stem
            count = import_map.get(name, 0)
            if count == 0:
                if name in ENTRYPOINT_NAMES:
                    continue
                rel_path = str(py_file.relative_to(REPO_ROOT))
                item = {
                    "module": name,
                    "path": rel_path,
                    "classification": self._classify_logical_orphan(py_file),
                    "reason": "Module exists but has 0 inbound imports in ai-stack (potential dead code)"
                }
                self.findings["logical_orphans"].append(item)
                if baseline_paths is not None and rel_path not in baseline_paths:
                    self.findings["new_logical_orphans"].append(item)

    def _imported_module_names(self, path: Path) -> set[str]:
        content = self._safe_read_text(path)
        try:
            tree = ast.parse(content, filename=str(path))
        except SyntaxError:
            self.meta["warnings"].append(f"syntax_skipped:{path}")
            return set(re.findall(r'^\s*(?:from|import)\s+([A-Za-z_][A-Za-z0-9_]*)\b', content, flags=re.MULTILINE))

        imported: set[str] = set()
        for node in ast.walk(tree):
            if isinstance(node, ast.Import):
                for alias in node.names:
                    parts = alias.name.split(".")
                    imported.add(parts[0])
                    imported.add(parts[-1])
            elif isinstance(node, ast.ImportFrom):
                if node.module:
                    parts = node.module.split(".")
                    imported.add(parts[0])
                    imported.add(parts[-1])
                for alias in node.names:
                    if alias.name != "*":
                        imported.add(alias.name.split(".")[-1])
        return imported

    def _logical_baseline_paths(self) -> set[str] | None:
        if not self.logical_baseline or not self.logical_baseline.exists():
            return None
        try:
            payload = json.loads(self.logical_baseline.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError) as exc:
            self.meta["warnings"].append(f"logical_baseline_unreadable:{self.logical_baseline}:{exc}")
            return set()
        entries = payload.get("entries", [])
        paths = {entry.get("path") for entry in entries if isinstance(entry, dict) and entry.get("path")}
        self.meta["logical_baseline_entries"] = len(paths)
        return paths

    def _classify_logical_orphan(self, path: Path) -> str:
        content = self._safe_read_text(path)
        stem = path.stem
        if "__main__" in content or content.startswith("#!"):
            return "entrypoint_candidate"
        if stem.endswith(("_service", "_daemon", "_server", "_cli", "_agent", "_manager")):
            return "runtime_component_candidate"
        if stem.endswith(("_test", "_bench", "_benchmark")) or "pytest" in content:
            return "test_like_candidate"
        return "library_candidate"

    def _ignore_logical_file(self, path: Path) -> bool:
        rel = str(path.relative_to(REPO_ROOT)) if path.is_relative_to(REPO_ROOT) else str(path)
        stem = path.stem
        ignored_parts = {
            "tests",
            "test",
            "migrations",
            "examples",
            "__pycache__",
        }
        if any(part in ignored_parts for part in path.parts):
            self.meta["logical_files_ignored"] += 1
            return True
        if stem.startswith(("test_", "example_", "bench_", "benchmark_")):
            self.meta["logical_files_ignored"] += 1
            return True
        if re.match(r"^\d{4}_", stem):
            self.meta["logical_files_ignored"] += 1
            return True
        if rel.endswith("/__init__.py"):
            self.meta["logical_files_ignored"] += 1
            return True
        return False

    def run(self):
        self.started_at = time.monotonic()
        self.findings = self._empty_findings()
        self.meta["files_scanned"] = 0
        self.meta["files_skipped"] = 0
        self.meta["logical_files_ignored"] = 0
        self.meta["logical_baseline_entries"] = 0
        self.meta["truncated"] = False
        self.meta["warnings"] = []
        self.scan_doc_consistency()
        self.scan_coordinator_wiring()
        self.scan_logical_orphans()
        self.meta["elapsed_seconds"] = round(time.monotonic() - self.started_at, 3)
        self.meta["finding_counts"] = {key: len(value) for key, value in self.findings.items()}
        return {"meta": self.meta, "findings": self.findings}

    def report(self):
        result = self.run()
        counts = result["meta"]["finding_counts"]
        print(
            "--- Integrity Scan Report: "
            f"{counts['registration_gaps'] + counts['doc_orphans']} doc/wiring issues, "
            f"{counts['new_logical_orphans']} new logical orphans ---"
        )
        print(
            f"Scanned {self.meta['files_scanned']} files in {self.meta['elapsed_seconds']}s"
            + (" (TRUNCATED)" if self.meta["truncated"] else "")
        )
        
        if self.findings["registration_gaps"]:
            print("\n[!] Registration Gaps (Half-Implemented):")
            for gap in self.findings["registration_gaps"]:
                print(f"  - {gap['handler']} in {gap['file']}")

        if self.findings["doc_orphans"]:
            print("\n[!] Documentation Orphans (Ghost Commands):")
            for gap in self.findings["doc_orphans"]:
                print(f"  - {gap['command']}")

        if self.findings["logical_orphans"]:
            print("\n[?] Logical Orphans (Potential Dead Code):")
            for gap in self.findings["logical_orphans"]:
                marker = "NEW " if gap in self.findings["new_logical_orphans"] else ""
                print(f"  - {marker}{gap['path']} ({gap['classification']})")

    def logical_baseline_payload(self):
        if not self.findings["logical_orphans"]:
            self.run()
        return {
            "version": 1,
            "generated_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
            "generated_by": "scripts/ai/aq-integrity-scan --write-logical-baseline",
            "policy": "Existing entries are known debt. New zero-inbound ai-stack modules must be wired, removed, or explicitly added with a classification rationale.",
            "entries": [
                {
                    "path": item["path"],
                    "module": item["module"],
                    "classification": item["classification"],
                    "owner": "unassigned",
                    "action": "classify",
                    "rationale": "Existing zero-inbound import candidate captured as technical-debt baseline.",
                }
                for item in sorted(self.findings["logical_orphans"], key=lambda entry: entry["path"])
            ],
        }

def main():
    parser = argparse.ArgumentParser(description="Bounded integrity scanner for docs, handler wiring, and logical orphan debt")
    parser.add_argument("--json", action="store_true", help="Emit machine-readable JSON")
    parser.add_argument("--skip-logical", action="store_true", help="Skip logical orphan scan for fast wiring/doc checks")
    parser.add_argument("--timeout-seconds", type=float, default=DEFAULT_TIMEOUT_SECONDS, help="Soft scan timeout")
    parser.add_argument("--max-files", type=int, default=DEFAULT_MAX_FILES, help="Maximum total files to scan")
    parser.add_argument("--max-logical-files", type=int, default=DEFAULT_MAX_LOGICAL_FILES, help="Maximum Python files for logical orphan scan")
    parser.add_argument("--logical-baseline", type=Path, default=DEFAULT_LOGICAL_BASELINE, help="Known logical-orphan baseline JSON")
    parser.add_argument("--no-logical-baseline", action="store_true", help="Do not compare logical orphan results with a baseline")
    parser.add_argument("--fail-on-new-logical", action="store_true", help="Exit non-zero when logical orphan candidates are not in the baseline")
    parser.add_argument("--write-logical-baseline", type=Path, help="Write the current logical orphan set as a baseline JSON file")
    args = parser.parse_args()

    scanner = IntegrityScanner(
        timeout_seconds=args.timeout_seconds,
        max_files=args.max_files,
        max_logical_files=args.max_logical_files,
        include_logical=not args.skip_logical,
        logical_baseline=None if args.no_logical_baseline else args.logical_baseline,
    )
    if args.write_logical_baseline:
        payload = scanner.logical_baseline_payload()
        args.write_logical_baseline.parent.mkdir(parents=True, exist_ok=True)
        args.write_logical_baseline.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
        return

    if args.json:
        result = scanner.run()
        print(json.dumps(result, sort_keys=True))
    else:
        scanner.report()
        result = {"findings": scanner.findings}
    if args.fail_on_new_logical and result["findings"]["new_logical_orphans"]:
        raise SystemExit(2)

if __name__ == "__main__":
    main()
