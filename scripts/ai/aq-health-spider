def _http_check(url: str, timeout: int = 5) -> Tuple[bool, Optional[float]]:
    """Returns (ok, latency_ms). ok=False on error or HTTP>=500."""
    try:
        t0 = time.monotonic()
        resp = urllib.request.urlopen(url, timeout=timeout)
        ms = (time.monotonic() - t0) * 1000
        resp.close()
        return True, round(ms, 1)
    except Exception:
        return False, None


def _semantic_probe_reason(check: str, data: Dict[str, Any]) -> str:
    """Return non-empty reason when a dashboard payload is semantically degraded."""
    if check == "aggregate_services":
        services = data.get("services") if isinstance(data.get("services"), dict) else {}
        bad = [
            f"{name}:{svc.get('status')}"
            for name, svc in services.items()
            if isinstance(svc, dict)
            and str(svc.get("status") or "").lower() in {"degraded", "down", "fail", "failed", "error", "unhealthy"}
        ]
        if bad:
            return f"degraded_services={','.join(bad[:8])}"
        return ""

    if check == "osi_layered_ready":
        if data.get("pending") is True and not data.get("running"):
            return "osi_layered_pending"
        layers = data.get("layers") if isinstance(data.get("layers"), dict) else {}
        passed = int(data.get("passed") or 0)
        failed = int(data.get("failed") or 0)
        total = passed + failed
        if not layers or total == 0:
            return "osi_layered_no_results"
        if failed > 0:
            return f"osi_layered_failed={failed}"
        return ""

    if check == "ragas_faithfulness":
        metrics = data.get("ragas_metrics") if isinstance(data.get("ragas_metrics"), dict) else {}
        if not metrics:
            return "ragas_metrics_missing"
        sample_count = int(metrics.get("sample_count") or 0)
        faithfulness_sample_count = int(metrics.get("faithfulness_sample_count") or 0)
        enabled = metrics.get("faithfulness_enabled", True) is not False
        value = metrics.get("faithfulness_avg")
        if sample_count <= 0:
            return "ragas_sample_count=0"
        if enabled and faithfulness_sample_count <= 0:
            return f"faithfulness_sample_count=0:samples={sample_count}"
        if enabled and value is None:
            return f"faithfulness_avg_missing:samples={sample_count}"
        if enabled and isinstance(value, (int, float)) and value <= 0:
            return f"faithfulness_avg={value}:samples={sample_count}"
        return ""

    if check == "audit_integrity":
        if data.get("valid") is not True:
            return "audit_integrity_valid=false"
        checked = int(data.get("checked_events") or 0)
        sealed = int(data.get("sealed_events") or 0)
        if checked <= 0:
            return "audit_integrity_checked=0"
        if sealed < checked:
            return f"audit_integrity_sealed={sealed}/{checked}"
        if data.get("fully_sealed") is not True:
            return "audit_integrity_fully_sealed=false"
        return ""

    return ""


def _json_probe(
    url: str,
    timeout: int = 5,
    required_keys: Optional[List[str]] = None,
    semantic_checks: Optional[List[str]] = None,
) -> Tuple[bool, Optional[float], str]:
    """Returns (ok, latency_ms, reason) for JSON dashboard/service probes."""
    try:
        t0 = time.monotonic()
        with urllib.request.urlopen(url, timeout=timeout) as resp:
            ms = (time.monotonic() - t0) * 1000
            if resp.status >= 500:
                return False, round(ms, 1), f"HTTP {resp.status}"
            data = json.loads(resp.read().decode("utf-8", errors="replace"))
        if not isinstance(data, dict):
            return False, round(ms, 1), "non-object JSON response"
        status = str(data.get("overall_status") or data.get("status") or "").lower()
        if status in {"degraded", "down", "fail", "failed", "error", "unhealthy"}:
            return False, round(ms, 1), f"status={status}"
        if data.get("available") is False:
            return False, round(ms, 1), "available=false"
        missing = [key for key in (required_keys or []) if key not in data]
        if missing:
            return False, round(ms, 1), f"missing_keys={','.join(missing)}"
        for check in semantic_checks or []:
            reason = _semantic_probe_reason(check, data)
            if reason:
                return False, round(ms, 1), reason
        return True, round(ms, 1), ""
    except urllib.error.HTTPError as e:
        return False, None, f"HTTP {e.code}"
    except Exception as e:
        return False, None, str(e)[:120]


def _service_check(service: str) -> str:
    """Returns systemctl is-active output: active/inactive/failed/unknown."""
    try:
        r = subprocess.run(
            ["systemctl", "is-active", service],
            capture_output=True, text=True, timeout=5,
        )
        return r.stdout.strip() or "unknown"
    except Exception:
        return "unknown"


def _failed_systemd_units() -> List[Dict[str, str]]:
    """Return currently failed systemd units from the host manager."""
    try:
        r = subprocess.run(
            ["systemctl", "--failed", "--no-legend", "--no-pager"],
            capture_output=True, text=True, timeout=8,
        )
    except Exception as e:
        return [{"unit": "systemctl", "load": "unknown", "active": "unknown", "sub": "unknown", "description": str(e)[:160]}]

    if r.returncode != 0 and not r.stdout.strip():
        return [{
            "unit": "systemctl",
            "load": "unknown",
            "active": "error",
            "sub": "error",
            "description": (r.stderr or f"systemctl exited {r.returncode}").strip()[:160],
        }]

    failed: List[Dict[str, str]] = []
    for raw in r.stdout.splitlines():
        line = raw.strip()
        if not line:
            continue
        line = line.lstrip("●").strip()
        parts = line.split(None, 4)
        if len(parts) < 4:
            continue
        failed.append({
            "unit": parts[0],
            "load": parts[1],
            "active": parts[2],
            "sub": parts[3],
            "description": parts[4] if len(parts) > 4 else "",
        })
    return failed


def _apparmor_scan(profile: str, since_ts: float) -> List[Dict[str, str]]:
    """Returns deduplicated list of {operation, path, mask} DENIED for profile since since_ts."""
    # journalctl --since expects local time (not UTC)
    since = datetime.fromtimestamp(since_ts).strftime("%Y-%m-%d %H:%M:%S")
    try:
        r = subprocess.run(
            ["journalctl", "-k", f"--since={since}", "--no-pager", "-q"],
            capture_output=True, text=True, timeout=15,
        )
    except Exception as e:
        logger.debug(f"AppArmor scan error: {e}")
        return []

    seen: set = set()
    denials: List[Dict[str, str]] = []
    for line in r.stdout.splitlines():
        if f'profile="{profile}"' not in line or 'apparmor="DENIED"' not in line:
            continue
        def _f(key: str) -> str:
            marker = f'{key}="'
            if marker not in line:
                return ""
            s = line.index(marker) + len(marker)
            return line[s:line.index('"', s)]
        op, path, mask, peer = _f("operation"), _f("name"), _f("requested_mask"), _f("peer")
        key = (op, path, peer)
        if key not in seen and (path or op in ("ptrace", "signal")):
            seen.add(key)
            denials.append({"operation": op, "path": path, "mask": mask, "peer": peer})
    return denials


def _emit_event(event_type: str, payload: Dict[str, Any]) -> None:
    """Append JSON event to user-space telemetry spool (non-fatal)."""
    try:
        TELEMETRY_SPOOL.parent.mkdir(parents=True, exist_ok=True)
        event = {
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "event": event_type,
            "event_type": event_type,
            "source": "health-spider",
            **payload,
        }
        with open(TELEMETRY_SPOOL, "a", encoding="utf-8") as f:
            f.write(json.dumps(event) + "\n")
    except Exception as e:
        logger.debug(f"emit_event error: {e}")


def _seed_rag(error_type: str, error_msg: str, context: str, solution: str, tags: List[str]) -> bool:
    """Seed one entry to Qdrant error-solutions via llama-embed. Returns True on success."""
    try:
        text = f"Error: {error_type} - {error_msg} Context: {context} Solution: {solution}"
        embed_req = urllib.request.Request(
            f"{EMBED_URL}/v1/embeddings",
            data=json.dumps({"input": text, "model": "bge-m3"}).encode(),
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        with urllib.request.urlopen(embed_req, timeout=10) as r:
            vector = json.loads(r.read())["data"][0]["embedding"]

        import uuid
        point_id = str(uuid.uuid5(uuid.NAMESPACE_DNS, f"health-spider:{error_type}:{error_msg[:60]}"))
        upsert_req = urllib.request.Request(
            f"{QDRANT_URL}/collections/error-solutions/points",
            data=json.dumps({"points": [{
                "id": point_id,
                "vector": vector,
                "payload": {
                    "error_type": error_type,
                    "error_message": error_msg,
                    "context": context,
                    "solution": solution,
                    "tags": tags,
                    "source": "health-spider",
                    "seeded_at": datetime.now(timezone.utc).isoformat(),
                },
            }]}).encode(),
            headers={"Content-Type": "application/json"},
            method="PUT",
        )
        with urllib.request.urlopen(upsert_req, timeout=10) as r:
            r.read()
        return True
    except Exception as e:
        logger.debug(f"RAG seed failed: {e}")
        return False


def _update_handoff(entry: str) -> None:
    """Append timestamped entry to HANDOFF.md."""
    try:
        ts = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
        with open(HANDOFF_MD, "a", encoding="utf-8") as f:
            f.write(f"\n### [{ts}] health-spider\n{entry}\n")
    except Exception as e:
        logger.debug(f"HANDOFF.md update failed: {e}")


def _push_memory_fact(anomaly_type: str, zone: str, detail: str, resolution: str) -> None:
    """
    Push health observation to coordinator /api/memory/facts via loopback.
    No API key required — 127.0.0.1 requests use loopback-agent auth.
    Makes health history available to all agents via memory recall.
    """
    try:
        fact = (
            f"Health spider ({zone}): {anomaly_type}. {detail} "
            f"Resolution: {resolution}"
        )
        payload = json.dumps({
            "content": fact,
            "category": "system_health",
            "scope": f"health_spider_{zone}",
            "tags": ["health-spider", anomaly_type, zone],
            "confidence": 0.9,
            "source": "health-spider",
        }).encode()
        req = urllib.request.Request(
            f"{COORDINATOR_URL}/api/memory/facts",
            data=payload,
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=5) as r:
            r.read()
    except Exception as e:
        logger.debug(f"memory fact push failed: {e}")


# ── HealthSpider ───────────────────────────────────────────────────────────────

class HealthSpider:
    def __init__(self, interval: int = 900):
        self.interval = interval
        self._apparmor_last: Dict[str, float] = {}
        self._known_issues: set = set()   # Dedup RAG seeding

    async def sample_zone(self, zone: str) -> List[Dict[str, Any]]:
        """Real health checks for one zone. Returns list of anomaly dicts."""
        cfg = ZONES[zone]
        anomalies: List[Dict[str, Any]] = []

        # 1. HTTP health check (fast, async)
        ok, ms = await asyncio.to_thread(_http_check, cfg["url"])
        if ok:
            logger.info(f"[{zone}] HTTP OK {ms}ms")
        else:
            logger.warning(f"[{zone}] HTTP FAILED {cfg['url']}")
            # 2. Service check only on HTTP failure (saves bandwidth)
            svc = cfg.get("service")
            state = await asyncio.to_thread(_service_check, svc) if svc else "unknown"
            if state not in ("active", "activating"):
                anomalies.append({
                    "type": "service_down", "zone": zone,
                    "service": svc, "state": state,
                    "timestamp": time.time(),
                })
            else:
                anomalies.append({
                    "type": "http_failure", "zone": zone,
                    "url": cfg["url"], "service_state": state,
                    "timestamp": time.time(),
                })

        # 1b. Semantic probes catch degraded dashboard cards that /api/health masks.
        for probe in cfg.get("probes", []):
            probe_ok, probe_ms, reason = await asyncio.to_thread(
                _json_probe,
                probe["url"],
                required_keys=probe.get("required_keys"),
                semantic_checks=probe.get("semantic_checks"),
            )
            if probe_ok:
                logger.info(f"[{zone}] probe {probe['name']} OK {probe_ms}ms")
                continue
            logger.warning(f"[{zone}] probe {probe['name']} DEGRADED {probe['url']} ({reason})")
            anomalies.append({
                "type": "dashboard_degraded",
                "zone": zone,
                "probe": probe["name"],
                "url": probe["url"],
                "reason": reason,
                "timestamp": time.time(),
            })

        # 3. AppArmor denial scan (only zones with a profile)
        profile = cfg.get("apparmor_profile")
        if profile:
            since = self._apparmor_last.get(profile, time.time() - self.interval * 1.5)
            denials = await asyncio.to_thread(_apparmor_scan, profile, since)
            self._apparmor_last[profile] = time.time()
            if denials:
                logger.warning(f"[{zone}] AppArmor: {len(denials)} denial(s) → profile '{profile}'")
                anomalies.append({
                    "type": "apparmor_denial", "zone": zone,
                    "profile": profile, "denials": denials,
                    "timestamp": time.time(),
                })

        return anomalies

    async def handle_anomaly(self, anomaly: Dict[str, Any]) -> bool:
        """Handle anomaly and return True when it should count as unresolved."""
        atype, zone = anomaly["type"], anomaly["zone"]
        _emit_event(f"health_spider_{atype}", anomaly)

        if atype == "apparmor_denial":
            return await self._fix_apparmor(anomaly) != "covered"

        elif atype == "service_down":
            svc = anomaly.get("service", zone)
            # human_gate, severity=high
            try:
                push(
                    source="health-spider",
                    severity="high",
                    autonomy_boundary="human_gate",
                    title=f"Service {svc} is DOWN in zone {zone}",
                    detail=f"Service state: {anomaly.get('state', 'unknown')}. HTTP health check failed.",
                    proposed_action=f"Investigate and restart {svc} via systemctl.",
                    payload=anomaly
                )
            except Exception:
                pass
            key = f"service_down:{svc}"
            if key not in self._known_issues:
                self._known_issues.add(key)
                resolution = f"Check: journalctl -u {svc} -n 50. Restart: sudo systemctl restart {svc}. If AppArmor: run apparmor-fix-agent and rebuild."
                await asyncio.to_thread(
                    _seed_rag,
                    "service_down",
                    f"Service {svc} ({zone}) state='{anomaly.get('state')}'",
                    f"Health spider detected during {zone} zone scan",
                    resolution,
                    ["service-down", zone, "health-spider"],
                )
                await asyncio.to_thread(
                    _push_memory_fact,
                    "service_down", zone,
                    f"Service {svc} is {anomaly.get('state', 'unknown')}.",
                    resolution,
                )
            await self._queue_prsi(anomaly)
            return True

        elif atype == "http_failure":
            # human_gate, severity=high (Service down from user perspective)
            try:
                push(
                    source="health-spider",
                    severity="high",
                    autonomy_boundary="human_gate",
                    title=f"HTTP Failure in zone {zone}",
                    detail=f"HTTP health check failed at {anomaly.get('url')}. Service state: {anomaly.get('service_state', 'unknown')}.",
                    proposed_action=f"Check service logs and restart if hung: journalctl -u {ZONES[zone].get('service', zone)} -n 50",
                    payload=anomaly
                )
            except Exception:
                pass
            key = f"http_failure:{zone}"
            if key not in self._known_issues:
                self._known_issues.add(key)
                resolution = f"Check service logs: journalctl -u {ZONES[zone].get('service', zone)} -n 50"
                await asyncio.to_thread(
                    _seed_rag,
                    "http_failure",
                    f"HTTP health check failed for zone '{zone}' at {anomaly.get('url')}",
                    f"Service state: {anomaly.get('service_state', 'unknown')}",
                    resolution,
                    ["http-failure", zone, "health-spider"],
                )
                await asyncio.to_thread(
                    _push_memory_fact,
                    "http_failure", zone,
                    f"HTTP check failed at {anomaly.get('url')} (service state: {anomaly.get('service_state', 'unknown')}).",
                    resolution,
                )
            return True

        elif atype == "dashboard_degraded":
            probe = anomaly.get("probe", "unknown")
            reason = anomaly.get("reason", "unknown")
            try:
                push(
                    source="health-spider",
                    severity="medium",
                    autonomy_boundary="human_gate",
                    title=f"Dashboard probe degraded: {probe}",
                    detail=f"{anomaly.get('url')} failed semantic health probe: {reason}",
                    proposed_action="Inspect dashboard endpoint response, AppArmor denials, and command-center-dashboard-api logs.",
                    payload=anomaly,
                )
            except Exception:
                pass
            key = f"dashboard_degraded:{probe}:{reason}"
            if key not in self._known_issues:
                self._known_issues.add(key)
                resolution = "Check command-center-dashboard-api logs and AppArmor denials; verify card endpoint JSON has available=true and healthy/pass status."
                await asyncio.to_thread(
                    _seed_rag,
                    "dashboard_degraded",
                    f"Dashboard probe '{probe}' degraded: {reason}",
                    f"Health spider deep probe {anomaly.get('url')}",
                    resolution,
                    ["dashboard", "health-spider", "degraded"],
                )
                await asyncio.to_thread(
                    _push_memory_fact,
                    "dashboard_degraded", zone,
                    f"Probe {probe} failed: {reason}.",
                    resolution,
                )
            return True
        elif atype == "systemd_failed_units":
            units = anomaly.get("units") or []
            unit_names = ", ".join(str(unit.get("unit", "unknown")) for unit in units[:8])
            try:
                push(
                    source="health-spider",
                    severity="high",
                    autonomy_boundary="human_gate",
                    title=f"Systemd failed units detected: {len(units)}",
                    detail=f"Failed units: {unit_names}",
                    proposed_action="Inspect with: systemctl --failed --no-pager && journalctl -u <unit> -n 80 --no-pager",
                    payload=anomaly,
                )
            except Exception:
                pass
            key = f"systemd_failed_units:{unit_names}"
            if key not in self._known_issues:
                self._known_issues.add(key)
                resolution = "Inspect failed units with systemctl --failed and journalctl; reset failed state only after root cause is understood or transient."
                await asyncio.to_thread(
                    _seed_rag,
                    "systemd_failed_units",
                    f"{len(units)} failed unit(s): {unit_names}",
                    "Health spider global systemd failed-unit probe",
                    resolution,
                    ["systemd", "failed-units", "health-spider"],
                )
                await asyncio.to_thread(
                    _push_memory_fact,
                    "systemd_failed_units", zone,
                    f"{len(units)} failed unit(s): {unit_names}.",
                    resolution,
                )
            return True
        return True

    async def _fix_apparmor(self, anomaly: Dict[str, Any]) -> str:
        """Invoke apparmor-fix-agent to commit rule fixes and notify via HANDOFF."""
        profile = anomaly["profile"]
        denials = anomaly["denials"]
        fix_agent = REPO_ROOT / "scripts" / "automation" / "apparmor-fix-agent.py"
        if not fix_agent.exists():
            logger.warning(f"apparmor-fix-agent.py not found: {fix_agent}")
            return "missing_agent"

        denial_json = json.dumps({"profile": profile, "denials": denials}).encode()
        logger.info(f"[{anomaly['zone']}] Running apparmor-fix-agent ({len(denials)} denials)")
        try:
            proc = await asyncio.create_subprocess_exec(
                sys.executable, str(fix_agent),
                "--profile", profile, "--input-json", "-",
                stdin=asyncio.subprocess.PIPE,
                stdout=asyncio.subprocess.PIPE,
                stderr=asyncio.subprocess.PIPE,
            )
            stdout, stderr = await asyncio.wait_for(proc.communicate(denial_json), timeout=90)
            if proc.returncode == 0:
                result = json.loads(stdout) if stdout.strip() else {}
                commit = result.get("commit_hash", "pending")
                rules = result.get("rules_added", [])
                logger.info(f"[{anomaly['zone']}] Fix staged (alert: {result.get('alert_id', 'unknown')})")
                
                # rebuild_required after fix is staged (even if not committed yet,
                # as nixos-rebuild will pick up the local file changes if run)
                try:
                    push(
                        source="health-spider",
                        severity="medium",
                        autonomy_boundary="rebuild_required",
                        title=f"Nix rebuild required for AppArmor fix ({profile})",
                        detail=f"apparmor-fix-agent staged {len(rules)} rules for {profile}. Nix file modified.",
                        proposed_action="Run: sudo nixos-rebuild switch --flake .#hyperd-ai-dev",
                        payload={"profile": profile, "rules_added": rules}
                    )
                except Exception:
                    pass
                
                _update_handoff(
                    f"**AppArmor fix staged** — profile `{profile}`  \n"
                    f"Rules added ({len(rules)}): {rules[:5]}  \n"
                    f"Denied paths: {[d['path'] for d in denials[:5]]}  \n"
                    f"⚠️  **Action required: `sudo nixos-rebuild switch --flake .#hyperd-ai-dev`**"
                )
                _emit_event("apparmor_fix_staged", {
                    "zone": anomaly["zone"], "profile": profile,
                    "rules_added": rules,
                })
                return "staged"
            elif proc.returncode == 2:
                logger.info(f"[{anomaly['zone']}] AppArmor: all paths already covered")
                return "covered"
            else:
                logger.error(f"[{anomaly['zone']}] fix-agent failed (rc={proc.returncode}): {stderr.decode()[:300]}")
                return "failed"
        except asyncio.TimeoutError:
            logger.error(f"[{anomaly['zone']}] apparmor-fix-agent timed out")
            return "timeout"
        except Exception as e:
            logger.error(f"[{anomaly['zone']}] fix-agent error: {e}")
            return "error"

    async def _queue_prsi(self, anomaly: Dict[str, Any]) -> None:
        orchestrator = REPO_ROOT / "scripts" / "automation" / "prsi-orchestrator.py"
        if not orchestrator.exists():
            return
        try:
            proc = await asyncio.create_subprocess_exec(
                sys.executable, str(orchestrator), "cycle",
                stdout=asyncio.subprocess.DEVNULL, stderr=asyncio.subprocess.DEVNULL,
            )
            await asyncio.wait_for(proc.wait(), timeout=30)
        except Exception as e:
            logger.debug(f"PRSI cycle error: {e}")

    async def run_once(self) -> int:
        """Single cycle — returns anomaly count."""
        total = 0
        failed_units = await asyncio.to_thread(_failed_systemd_units)
        if failed_units:
            logger.warning(f"[systemd] {len(failed_units)} failed unit(s): {', '.join(u['unit'] for u in failed_units[:8])}")
            anomaly = {
                "type": "systemd_failed_units",
                "zone": "systemd",
                "units": failed_units,
                "timestamp": time.time(),
            }
            if await self.handle_anomaly(anomaly):
                total += 1
        for zone in ZONES:
            try:
                anomalies = await self.sample_zone(zone)
                for a in anomalies:
                    if await self.handle_anomaly(a):
                        total += 1
            except Exception as e:
                logger.error(f"[{zone}] error: {e}")
        return total

    async def run(self):
        logger.info(f"Health Spider online — interval={self.interval}s, zones={list(ZONES)}")
        _emit_event("health_spider_started", {"zones": list(ZONES), "interval_s": self.interval})
        while True:
            t0 = time.time()
            n = await self.run_once()
            elapsed = round(time.time() - t0, 1)
            _emit_event("health_spider_cycle", {
                "zones_checked": len(ZONES), "anomalies": n, "cycle_seconds": elapsed,
            })
            logger.info(f"Cycle complete: {n} anomaly(ies) in {elapsed}s — sleeping {self.interval}s")
            await asyncio.sleep(self.interval)


