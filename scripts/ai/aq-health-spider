def _push_memory_fact(anomaly_type: str, zone: str, detail: str, resolution: str) -> None:
    """
    Push health observation to coordinator /api/memory/facts via loopback.
    No API key required — 127.0.0.1 requests use loopback-agent auth.
    Makes health history available to all agents via memory recall.
    """
    try:
        fact = (
            f"Health spider ({zone}): {anomaly_type}. {detail} "
            f"Resolution: {resolution}"
        )
        payload = json.dumps({
            "content": fact,
            "category": "system_health",
            "scope": f"health_spider_{zone}",
            "tags": ["health-spider", anomaly_type, zone],
            "confidence": 0.9,
            "source": "health-spider",
        }).encode()
        req = urllib.request.Request(
            f"{COORDINATOR_URL}/api/memory/facts",
            data=payload,
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=5) as r:
            r.read()
    except Exception as e:
        logger.debug(f"memory fact push failed: {e}")


def _first_existing(paths: List[Path]) -> Optional[Path]:
    for p in paths:
        try:
            if p.exists():
                return p
        except OSError:
            continue
    return None


def _count_pending_corrections() -> int:
    """failure_samples in the spool that still lack a correction (deduped by prompt||bad_output)."""
    sp = _first_existing(_TRAINING_SPOOL_PATHS)
    if sp is None:
        return 0
    corrected: set = set()
    pending: set = set()
    try:
        for line in sp.read_text(encoding="utf-8", errors="replace").splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                r = json.loads(line)
            except json.JSONDecodeError:
                continue
            if r.get("kind") != "failure_sample":
                continue
            sig = f"{r.get('prompt', '')}||{r.get('bad_output', '')}"
            if r.get("corrected_output"):
                corrected.add(sig)
            else:
                pending.add(sig)
    except OSError:
        return 0
    return len(pending - corrected)


def _read_training_results(path: Optional[Path], limit: int = 20) -> List[Dict[str, Any]]:
    if path is None:
        return []
    rows: List[Dict[str, Any]] = []
    try:
        for line in path.read_text(encoding="utf-8", errors="replace").splitlines()[-limit:]:
            line = line.strip()
            if not line:
                continue
            try:
                row = json.loads(line)
            except json.JSONDecodeError:
                continue
            if isinstance(row, dict) and row.get("pass_rate") is not None:
                rows.append(row)
    except OSError:
        return []
    return rows


def _loop_eval_regression(results: List[Dict[str, Any]]) -> Optional[Dict[str, Any]]:
    # Compare the last two REAL eval runs. Deferred / degraded_infra runs carry
    # pass_rate=None (model not evaluated — cold or slot-contended) and must be
    # excluded, or a contention run would either mask a real regression or, if
    # mis-scored, fake one. Prompt-5 fix: never let infra noise into the signal.
    real = [r for r in results
            if isinstance(r.get("pass_rate"), (int, float))
            and str(r.get("status") or "").lower() not in {"deferred", "degraded_infra"}]
    if len(real) < 2:
        return None
    previous = real[-2]
    latest = real[-1]
    try:
        previous_rate = float(previous.get("pass_rate"))
        latest_rate = float(latest.get("pass_rate"))
    except (TypeError, ValueError):
        return None
    drop = previous_rate - latest_rate
    if drop < _LOOP_REGRESSION_DROP:
        return None
    return {
        "type": "loop_eval_regression",
        "zone": "closed-loop",
        "detail": (
            f"training-loop pass_rate dropped from {previous_rate:.3f} to {latest_rate:.3f} "
            f"(drop {drop:.3f}, threshold {_LOOP_REGRESSION_DROP:.3f})"
        ),
        "previous_run": previous.get("run_id"),
        "latest_run": latest.get("run_id"),
        "previous_pass_rate": round(previous_rate, 3),
        "latest_pass_rate": round(latest_rate, 3),
        "drop": round(drop, 3),
        "timestamp": time.time(),
    }


def _activation_fallback_drift_check() -> List[Dict[str, Any]]:
    """Detect dormant primary paths silently falling back to degraded defaults."""
    anomalies: List[Dict[str, Any]] = []
    try:
        if not _QA_HARNESS_PATH.exists():
            anomalies.append({
                "type": "qa_fallback_default",
                "zone": "activation-drift",
                "detail": (
                    f"aq-qa Python harness bridge missing at {_QA_HARNESS_PATH}; "
                    "aq-qa will silently fall back to _aq-qa-bash"
                ),
                "harness_path": str(_QA_HARNESS_PATH),
                "timestamp": time.time(),
            })
    except OSError as exc:
        anomalies.append({
            "type": "qa_fallback_default",
            "zone": "activation-drift",
            "detail": f"aq-qa Python harness bridge could not be inspected: {exc}",
            "harness_path": str(_QA_HARNESS_PATH),
            "timestamp": time.time(),
        })
    return anomalies


def _closed_loop_check() -> List[Dict[str, Any]]:
    """Harness-level probe for the closed local-improvement loop — the measurement layer for the
    capture->correct->ingest->train pipeline. Advisory (detect + warn): a stale loop or a stalled
    teacher lane silently starves local-model improvement, so surface it even though nothing is 'down'.
    Best-effort: any read error yields no anomaly (never breaks a spider cycle)."""
    anomalies: List[Dict[str, Any]] = []
    now = time.time()

    # 1. Teacher lane reachable — no codex binary => corrections cannot be produced (loop can't learn).
    try:
        if not Path(_CODEX_BIN).exists():
            anomalies.append({
                "type": "loop_teacher_down", "zone": "closed-loop",
                "detail": f"codex teacher binary not found at {_CODEX_BIN}", "timestamp": now,
            })
    except OSError:
        pass

    # 2. Loop-run staleness — last training-loop result older than threshold (and never = advisory).
    results = _first_existing(_TRAINING_RESULTS_PATHS)
    try:
        # A 0-byte / record-less results file means the loop was wired but never COMPLETED a clean
        # run — treat that as "never ran", not as a fresh run (an empty file's mtime would otherwise
        # mask a loop that has produced nothing).
        has_result = results is not None and results.stat().st_size > 0
        if not has_result:
            anomalies.append({
                "type": "loop_never_ran", "zone": "closed-loop",
                "detail": "no completed training-loop result yet (results file missing or empty) — "
                          "the loop has not produced a clean run",
                "timestamp": now,
            })
        else:
            age_h = (now - results.stat().st_mtime) / 3600.0
            if age_h > _LOOP_STALE_H:
                anomalies.append({
                    "type": "loop_stalled", "zone": "closed-loop",
                    "detail": f"last training-loop result is {age_h:.1f}h old (>{_LOOP_STALE_H}h)",
                    "age_hours": round(age_h, 1), "timestamp": now,
                })
            regression = _loop_eval_regression(_read_training_results(results))
            if regression:
                anomalies.append(regression)
    except OSError:
        pass

    # 3. Correction backlog — pending failures piling up means the teacher step isn't keeping pace.
    backlog = _count_pending_corrections()
    if backlog > _CORRECTION_BACKLOG_MAX:
        anomalies.append({
            "type": "loop_correction_backlog", "zone": "closed-loop",
            "detail": f"{backlog} uncorrected failure sample(s) pending (>{_CORRECTION_BACKLOG_MAX})",
            "backlog": backlog, "timestamp": now,
        })

    anomalies.extend(_activation_fallback_drift_check())

    return anomalies


def _llama_slot_wedged_check() -> List[Dict[str, Any]]:
    """Detect an ORPHANED/wedged llama.cpp slot — the root cause behind cascading local-agent failures.
    On the single-slot APU, an abandoned generation (client timed out, but llama.cpp keeps prefilling)
    holds the only slot and starves ALL subsequent local dispatches (they fail with 'server silent',
    0 tool calls — victims, not culprits). CONSERVATIVE to avoid false-positives during a legitimate
    long generation: flags ONLY when the slot is_processing=True AND there is NO live local-agent
    process driving it AND a bounded completion probe is unresponsive."""
    base = LLAMA_URL.rstrip("/")
    # 1. Is the slot busy at all?
    try:
        with urllib.request.urlopen(f"{base}/slots", timeout=5) as r:
            slots = json.loads(r.read().decode())
        s0 = (slots if isinstance(slots, list) else [slots])[0] if slots else {}
        if not s0.get("is_processing"):
            return []
    except Exception:  # noqa: BLE001 — /slots may be disabled; can't assess
        return []
    # 2. Is a live local-agent process legitimately driving it? Then busy is EXPECTED, not wedged.
    try:
        out = subprocess.run(["pgrep", "-f", "agent_executor|aq-agent-loop"],
                             capture_output=True, text=True, timeout=5)
        if out.stdout.strip():
            return []
    except Exception:  # noqa: BLE001
        pass
    # 3. Busy with no live consumer → probe responsiveness. A healthy free slot answers in seconds;
    #    a wedged slot cannot admit the probe within the budget.
    try:
        body = json.dumps({
            "messages": [{"role": "user", "content": "ok"}],
            "max_tokens": 1, "chat_template_kwargs": {"enable_thinking": False},
        }).encode()
        req = urllib.request.Request(f"{base}/v1/chat/completions", data=body,
                                     headers={"Content-Type": "application/json"}, method="POST")
        with urllib.request.urlopen(req, timeout=int(os.environ.get("HS_SLOT_PROBE_TIMEOUT", "40"))) as r:
            r.read()
        return []  # responded → not wedged
    except Exception:  # noqa: BLE001
        return [{
            "type": "llama_slot_wedged", "zone": "llama-cpp",
            "detail": "llama.cpp slot is_processing=True with NO live local-agent consumer and an "
                      "unresponsive completion probe — orphaned/wedged slot starving all local work",
            "timestamp": time.time(),
        }]


