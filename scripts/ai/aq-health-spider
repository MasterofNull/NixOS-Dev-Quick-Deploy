class HealthSpider:
    def __init__(self, interval: int = 900):
        self.interval = interval
        self._apparmor_last: Dict[str, float] = {}
        self._known_issues: set = set()   # Dedup RAG seeding

    async def sample_zone(self, zone: str) -> List[Dict[str, Any]]:
        """Real health checks for one zone. Returns list of anomaly dicts."""
        cfg = ZONES[zone]
        anomalies: List[Dict[str, Any]] = []

        # 1. HTTP health check (fast, async)
        ok, ms = await asyncio.to_thread(_http_check, cfg["url"])
        if ok:
            logger.info(f"[{zone}] HTTP OK {ms}ms")
        else:
            logger.warning(f"[{zone}] HTTP FAILED {cfg['url']}")
            # 2. Service check only on HTTP failure (saves bandwidth)
            svc = cfg.get("service")
            state = await asyncio.to_thread(_service_check, svc) if svc else "unknown"
            if state not in ("active", "activating"):
                anomalies.append({
                    "type": "service_down", "zone": zone,
                    "service": svc, "state": state,
                    "timestamp": time.time(),
                })
            else:
                anomalies.append({
                    "type": "http_failure", "zone": zone,
                    "url": cfg["url"], "service_state": state,
                    "timestamp": time.time(),
                })

        # 1b. Semantic probes catch degraded dashboard cards that /api/health masks.
        for probe in cfg.get("probes", []):
            probe_ok, probe_ms, reason = await asyncio.to_thread(
                _json_probe,
                probe["url"],
                required_keys=probe.get("required_keys"),
                semantic_checks=probe.get("semantic_checks"),
            )
            if probe_ok:
                logger.info(f"[{zone}] probe {probe['name']} OK {probe_ms}ms")
                recovered = await asyncio.to_thread(
                    _resolve_recovered_dashboard_probe_alerts,
                    probe["name"],
                )
                if recovered:
                    logger.info(f"[{zone}] resolved {recovered} recovered alert(s) for probe {probe['name']}")
                continue
            logger.warning(f"[{zone}] probe {probe['name']} DEGRADED {probe['url']} ({reason})")
            anomalies.append({
                "type": "dashboard_degraded",
                "zone": zone,
                "probe": probe["name"],
                "url": probe["url"],
                "reason": reason,
                "timestamp": time.time(),
            })

        # 3. AppArmor denial scan (only zones with a profile)
        profile = cfg.get("apparmor_profile")
        if profile:
            since = self._apparmor_last.get(profile, time.time() - self.interval * 1.5)
            active_since = await asyncio.to_thread(
                _service_active_since_epoch,
                cfg.get("service"),
            )
            if active_since is not None:
                since = max(since, active_since)
            denials = await asyncio.to_thread(_apparmor_scan, profile, since)
            self._apparmor_last[profile] = time.time()
            if denials:
                logger.warning(f"[{zone}] AppArmor: {len(denials)} denial(s) → profile '{profile}'")
                anomalies.append({
                    "type": "apparmor_denial", "zone": zone,
                    "profile": profile, "denials": denials,
                    "timestamp": time.time(),
                })

        return anomalies

    async def handle_anomaly(self, anomaly: Dict[str, Any]) -> bool:
        """Handle anomaly and return True when it should count as unresolved."""
        atype, zone = anomaly["type"], anomaly["zone"]
        _emit_event(f"health_spider_{atype}", anomaly)

        if atype == "apparmor_denial":
            return await self._fix_apparmor(anomaly) != "covered"

        elif atype == "service_down":
            svc = anomaly.get("service", zone)
            # human_gate, severity=high
            try:
                push(
                    source="health-spider",
                    severity="high",
                    autonomy_boundary="human_gate",
                    title=f"Service {svc} is DOWN in zone {zone}",
                    detail=f"Service state: {anomaly.get('state', 'unknown')}. HTTP health check failed.",
                    proposed_action=f"Investigate and restart {svc} via systemctl.",
                    payload=anomaly
                )
            except Exception:
                pass
            key = f"service_down:{svc}"
            if key not in self._known_issues:
                self._known_issues.add(key)
                resolution = f"Check: journalctl -u {svc} -n 50. Restart: sudo systemctl restart {svc}. If AppArmor: run apparmor-fix-agent and rebuild."
                await asyncio.to_thread(
                    _seed_rag,
                    "service_down",
                    f"Service {svc} ({zone}) state='{anomaly.get('state')}'",
                    f"Health spider detected during {zone} zone scan",
                    resolution,
                    ["service-down", zone, "health-spider"],
                )
                await asyncio.to_thread(
                    _push_memory_fact,
                    "service_down", zone,
                    f"Service {svc} is {anomaly.get('state', 'unknown')}.",
                    resolution,
                )
            await self._queue_prsi(anomaly)
            return True

        elif atype == "http_failure":
            # human_gate, severity=high (Service down from user perspective)
            try:
                push(
                    source="health-spider",
                    severity="high",
                    autonomy_boundary="human_gate",
                    title=f"HTTP Failure in zone {zone}",
                    detail=f"HTTP health check failed at {anomaly.get('url')}. Service state: {anomaly.get('service_state', 'unknown')}.",
                    proposed_action=f"Check service logs and restart if hung: journalctl -u {ZONES[zone].get('service', zone)} -n 50",
                    payload=anomaly
                )
            except Exception:
                pass
            key = f"http_failure:{zone}"
            if key not in self._known_issues:
                self._known_issues.add(key)
                resolution = f"Check service logs: journalctl -u {ZONES[zone].get('service', zone)} -n 50"
                await asyncio.to_thread(
                    _seed_rag,
                    "http_failure",
                    f"HTTP health check failed for zone '{zone}' at {anomaly.get('url')}",
                    f"Service state: {anomaly.get('service_state', 'unknown')}",
                    resolution,
                    ["http-failure", zone, "health-spider"],
                )
                await asyncio.to_thread(
                    _push_memory_fact,
                    "http_failure", zone,
                    f"HTTP check failed at {anomaly.get('url')} (service state: {anomaly.get('service_state', 'unknown')}).",
                    resolution,
                )
            return True

        elif atype == "dashboard_degraded":
            probe = anomaly.get("probe", "unknown")
            reason = anomaly.get("reason", "unknown")
            try:
                push(
                    source="health-spider",
                    severity="medium",
                    autonomy_boundary="human_gate",
                    title=f"Dashboard probe degraded: {probe}",
                    detail=f"{anomaly.get('url')} failed semantic health probe: {reason}",
                    proposed_action="Inspect dashboard endpoint response, AppArmor denials, and command-center-dashboard-api logs.",
                    payload=anomaly,
                )
            except Exception:
                pass
            key = f"dashboard_degraded:{probe}:{reason}"
            if key not in self._known_issues:
                self._known_issues.add(key)
                resolution = "Check command-center-dashboard-api logs and AppArmor denials; verify card endpoint JSON has available=true and healthy/pass status."
                await asyncio.to_thread(
                    _seed_rag,
                    "dashboard_degraded",
                    f"Dashboard probe '{probe}' degraded: {reason}",
                    f"Health spider deep probe {anomaly.get('url')}",
                    resolution,
                    ["dashboard", "health-spider", "degraded"],
                )
                await asyncio.to_thread(
                    _push_memory_fact,
                    "dashboard_degraded", zone,
                    f"Probe {probe} failed: {reason}.",
                    resolution,
                )
            return True
        elif atype == "systemd_failed_units":
            units = anomaly.get("units") or []
            unit_names = ", ".join(str(unit.get("unit", "unknown")) for unit in units[:8])
            try:
                push(
                    source="health-spider",
                    severity="high",
                    autonomy_boundary="human_gate",
                    title=f"Systemd failed units detected: {len(units)}",
                    detail=f"Failed units: {unit_names}",
                    proposed_action="Inspect with: systemctl --failed --no-pager && journalctl -u <unit> -n 80 --no-pager",
                    payload=anomaly,
                )
            except Exception:
                pass
            key = f"systemd_failed_units:{unit_names}"
            if key not in self._known_issues:
                self._known_issues.add(key)
                resolution = "Inspect failed units with systemctl --failed and journalctl; reset failed state only after root cause is understood or transient."
                await asyncio.to_thread(
                    _seed_rag,
                    "systemd_failed_units",
                    f"{len(units)} failed unit(s): {unit_names}",
                    "Health spider global systemd failed-unit probe",
                    resolution,
                    ["systemd", "failed-units", "health-spider"],
                )
                await asyncio.to_thread(
                    _push_memory_fact,
                    "systemd_failed_units", zone,
                    f"{len(units)} failed unit(s): {unit_names}.",
                    resolution,
                )
            return True
        elif atype == "llama_slot_wedged":
            # Orphaned/wedged single slot — starves ALL local dispatch. High severity; the remediation
            # (restart llama-cpp) needs privilege, so route to the human gate with the concrete action.
            detail = anomaly.get("detail", atype)
            try:
                push(
                    source="health-spider",
                    severity="high",
                    autonomy_boundary="human_gate",
                    title="llama.cpp slot wedged (orphaned generation starving local work)",
                    detail=detail,
                    proposed_action="Free the slot: sudo systemctl restart llama-cpp . Root cause: an "
                                    "oversized prefill / abandoned generation holds the single APU slot. "
                                    "Prevention: LLAMA_MAX_PROMPT_CHARS guard in agent_executor + F2 slot scheduler.",
                    payload=anomaly,
                )
            except Exception:
                pass
            key = "llama_slot_wedged"
            if key not in self._known_issues:
                self._known_issues.add(key)
                await asyncio.to_thread(
                    _seed_rag, "llama_slot_wedged",
                    "llama.cpp single slot wedged by orphaned generation",
                    "Health spider slot-responsiveness probe (is_processing + no consumer + probe timeout)",
                    "Restart llama-cpp to free the slot. Prevent via prompt-size fail-fast guard "
                    "(LLAMA_MAX_PROMPT_CHARS) and the F2 slot scheduler/backpressure.",
                    ["llama-cpp", "wedged-slot", "local-inference", "health-spider"],
                )
                await asyncio.to_thread(
                    _push_memory_fact, "llama_slot_wedged", "llama-cpp", detail,
                    "sudo systemctl restart llama-cpp; add prompt-size guard.",
                )
            return True
        elif atype in ("loop_teacher_down", "loop_never_ran", "loop_stalled",
                       "loop_correction_backlog", "loop_eval_regression"):
            # Closed local-improvement loop advisories — detect + warn (the measurement layer the
            # operator flagged as missing). teacher_down is the most serious (loop can't learn at all).
            detail = anomaly.get("detail", atype)
            severity = "high" if atype in ("loop_teacher_down", "loop_eval_regression") else "medium"
            action = {
                "loop_teacher_down": "Verify codex login/binary (delegate-to-codex --status); the loop's correction step needs it.",
                "loop_never_ran": "Trigger a run: systemctl start ai-local-training-loop.service (or scripts/ai/aq-local-training-loop --resume).",
                "loop_stalled": "Check ai-local-training-loop.timer is active and the last run didn't error (training-loop-results.jsonl).",
                "loop_correction_backlog": "Run scripts/ai/aq-correct-failures --max 25 (codex teacher) to drain the backlog.",
                "loop_eval_regression": "Inspect the latest training-loop scores and hold LoRA promotion until the regression is explained.",
            }.get(atype, "Inspect the closed local-improvement loop telemetry.")
            try:
                push(
                    source="health-spider",
                    severity=severity,
                    autonomy_boundary="notify",
                    title=f"Closed-loop advisory: {atype}",
                    detail=detail,
                    proposed_action=action,
                    payload=anomaly,
                )
            except Exception:
                pass
            key = f"{atype}:{detail}"
            if key not in self._known_issues:
                self._known_issues.add(key)
                await asyncio.to_thread(
                    _push_memory_fact,
                    atype, "closed-loop", detail, action,
                )
            return True
        return True

    async def _fix_apparmor(self, anomaly: Dict[str, Any]) -> str:
        """Invoke apparmor-fix-agent to commit rule fixes and notify via HANDOFF."""
        profile = anomaly["profile"]
        denials = anomaly["denials"]
        fix_agent = REPO_ROOT / "scripts" / "automation" / "apparmor-fix-agent.py"
        if not fix_agent.exists():
            logger.warning(f"apparmor-fix-agent.py not found: {fix_agent}")
            return "missing_agent"

        denial_json = json.dumps({"profile": profile, "denials": denials}).encode()
        logger.info(f"[{anomaly['zone']}] Running apparmor-fix-agent ({len(denials)} denials)")
        try:
            proc = await asyncio.create_subprocess_exec(
                sys.executable, str(fix_agent),
                "--profile", profile, "--input-json", "-",
                stdin=asyncio.subprocess.PIPE,
                stdout=asyncio.subprocess.PIPE,
                stderr=asyncio.subprocess.PIPE,
            )
            stdout, stderr = await asyncio.wait_for(proc.communicate(denial_json), timeout=90)
            if proc.returncode == 0:
                result = json.loads(stdout) if stdout.strip() else {}
                commit = result.get("commit_hash", "pending")
                rules = result.get("rules_added", [])
                logger.info(f"[{anomaly['zone']}] Fix staged (alert: {result.get('alert_id', 'unknown')})")
                
                # rebuild_required after fix is staged (even if not committed yet,
                # as nixos-rebuild will pick up the local file changes if run)
                try:
                    push(
                        source="health-spider",
                        severity="medium",
                        autonomy_boundary="rebuild_required",
                        title=f"Nix rebuild required for AppArmor fix ({profile})",
                        detail=f"apparmor-fix-agent staged {len(rules)} rules for {profile}. Nix file modified.",
                        proposed_action="Run: sudo nixos-rebuild switch --flake .#hyperd-ai-dev",
                        payload={"profile": profile, "rules_added": rules}
                    )
                except Exception:
                    pass
                
                _update_handoff(
                    f"**AppArmor fix staged** — profile `{profile}`  \n"
                    f"Rules added ({len(rules)}): {rules[:5]}  \n"
                    f"Denied paths: {[d['path'] for d in denials[:5]]}  \n"
                    f"⚠️  **Action required: `sudo nixos-rebuild switch --flake .#hyperd-ai-dev`**"
                )
                _emit_event("apparmor_fix_staged", {
                    "zone": anomaly["zone"], "profile": profile,
                    "rules_added": rules,
                })
                return "staged"
            elif proc.returncode == 2:
                logger.info(f"[{anomaly['zone']}] AppArmor: all paths already covered")
                return "covered"
            else:
                logger.error(f"[{anomaly['zone']}] fix-agent failed (rc={proc.returncode}): {stderr.decode()[:300]}")
                return "failed"
        except asyncio.TimeoutError:
            logger.error(f"[{anomaly['zone']}] apparmor-fix-agent timed out")
            return "timeout"
        except Exception as e:
            logger.error(f"[{anomaly['zone']}] fix-agent error: {e}")
            return "error"

    async def _queue_prsi(self, anomaly: Dict[str, Any]) -> None:
        orchestrator = REPO_ROOT / "scripts" / "automation" / "prsi-orchestrator.py"
        if not orchestrator.exists():
            return
        try:
            proc = await asyncio.create_subprocess_exec(
                sys.executable, str(orchestrator), "cycle",
                stdout=asyncio.subprocess.DEVNULL, stderr=asyncio.subprocess.DEVNULL,
            )
            await asyncio.wait_for(proc.wait(), timeout=30)
        except Exception as e:
            logger.debug(f"PRSI cycle error: {e}")

    async def run_once(self) -> int:
        """Single cycle — returns anomaly count."""
        total = 0
        failed_units = await asyncio.to_thread(_failed_systemd_units)
        if failed_units:
            logger.warning(f"[systemd] {len(failed_units)} failed unit(s): {', '.join(u['unit'] for u in failed_units[:8])}")
            anomaly = {
                "type": "systemd_failed_units",
                "zone": "systemd",
                "units": failed_units,
                "timestamp": time.time(),
            }
            if await self.handle_anomaly(anomaly):
                total += 1
        for zone in ZONES:
            try:
                anomalies = await self.sample_zone(zone)
                for a in anomalies:
                    if await self.handle_anomaly(a):
                        total += 1
            except Exception as e:
                logger.error(f"[{zone}] error: {e}")
        # Harness-level: closed local-improvement loop (measurement layer, not a service zone).
        try:
            for a in await asyncio.to_thread(_closed_loop_check):
                if await self.handle_anomaly(a):
                    total += 1
        except Exception as e:
            logger.error(f"[closed-loop] error: {e}")
        # Harness-level: wedged llama.cpp slot (orphaned generation starving all local work).
        try:
            for a in await asyncio.to_thread(_llama_slot_wedged_check):
                if await self.handle_anomaly(a):
                    total += 1
        except Exception as e:
            logger.error(f"[llama-slot] error: {e}")
        return total

    async def run(self):
        logger.info(f"Health Spider online — interval={self.interval}s, zones={list(ZONES)}")
        _emit_event("health_spider_started", {"zones": list(ZONES), "interval_s": self.interval})
        while True:
            t0 = time.time()
            n = await self.run_once()
            elapsed = round(time.time() - t0, 1)
            _emit_event("health_spider_cycle", {
                "zones_checked": len(ZONES), "anomalies": n, "cycle_seconds": elapsed,
            })
            logger.info(f"Cycle complete: {n} anomaly(ies) in {elapsed}s — sleeping {self.interval}s")
            await asyncio.sleep(self.interval)


