#!/usr/bin/env bash
# delegate-to-gemini — Delegate a task to Gemini CLI (headless, persistent)
#
# Fixes:
#   - Correct headless flag: -p/--prompt  (NOT 'gemini print ...')
#   - Persistent output in .agents/delegation/outputs/ (survives session restarts)
#   - Task registry in .agents/delegation/registry.jsonl (survives eviction)
#
# Usage:
#   delegate-to-gemini --prompt "implement X in file Y"   # delegate in background
#   delegate-to-gemini --check <task-id>                  # read output
#   delegate-to-gemini --list                             # list all delegated tasks
#   delegate-to-gemini --status <task-id>                 # check running/done/failed
#
# Approval modes (--mode flag):
#   yolo       — approve all tool calls automatically, incl. run_shell_command (DEFAULT)
#   auto_edit  — auto-approve file edits only; run_shell_command NOT available in this mode
#
#   DEFAULT changed to yolo (2026-05-18): auto_edit restricts Gemini to read_file/grep_search/
#   replace only — any prompt telling Gemini to run aq-* or shell commands wastes a turn
#   with "Tool run_shell_command not found". Use --mode auto_edit explicitly when you want
#   to prevent all shell execution (pure read+edit tasks only).
#
#   NOTE: 'plan' mode is NOT supported by the current Gemini API tier — returns HTTP 400.
#
# Options:
#   --prompt TEXT      Task prompt to send to Gemini
#   --prompt-file FILE Read prompt from file
#   --mode MODE        Approval mode: auto_edit|yolo  [default: yolo]
#   --model MODEL      Gemini model override
#   --wait             Block until task completes (default: background)
#   --check ID         Print output of a completed task
#   --status ID        Show status of a task
#   --list             List all registered tasks
#   --help             Show this help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
DELEGATION_DIR="$REPO_ROOT/.agents/delegation"
OUTPUTS_DIR="$DELEGATION_DIR/outputs"
REGISTRY="$DELEGATION_DIR/registry.jsonl"
GEMINI_BIN="${GEMINI_BIN:-$HOME/.npm-global/bin/gemini}"

# Phase 173: minimum meaningful content bytes to treat a non-zero-exit run as partial-success.
# Raw byte threshold (200) is fooled by large error-only logs (stack traces, retry attempts).
# _gemini_meaningful_bytes() strips known header/warning/error lines before measuring.
GEMINI_MIN_CONTENT_BYTES=500

# Phase 56.1/56.7 — delegation audit bridge
# shellcheck disable=SC1091
source "${SCRIPT_DIR}/lib/audit-write.sh" 2>/dev/null || true
source "${SCRIPT_DIR}/lib/harness-grounding.sh" 2>/dev/null || true

# ── helpers ─────────────────────────────────────────────────────────────────

die()  { echo "ERROR: $*" >&2; exit 1; }
info() { echo "[delegate-to-gemini] $*"; }

# A2A action policy gate: authorize the approval MODE before launching gemini
# (config/agent-action-policy.json). Blocks invalid/kill-switched modes and — when the
# policy is hardened — privileged modes (yolo auto-approves run_shell_command) lacking
# authorization. Every decision is audited. Fails OPEN unless the evaluator returns an
# explicit BLOCK (rc 3), so a config problem never silently breaks delegation.
policy_gate_action() {
    local agent="$1" mode="$2" task_id="$3"
    local pol="$SCRIPT_DIR/lib/agent_action_policy.py"
    [[ -f "$pol" ]] || return 0
    local authorized="0"
    case "${A2A_ALLOW_PRIVILEGED:-0}" in 1|true|yes|on) authorized="1" ;; esac
    local verdict rc
    verdict="$(AQ_TASK_ID="$task_id" python3 "$pol" "$agent" "$mode" "$authorized" 2>/dev/null)"; rc=$?
    if [[ $rc -eq 3 ]]; then
        die "A2A action policy BLOCKED this delegation: ${verdict#BLOCK }
  Hardened privileged mode? Authorize with: export A2A_ALLOW_PRIVILEGED=1
  Policy: config/agent-action-policy.json | Audit: .agent/collaboration/a2a-audit.log"
    fi
}

# A2A outbound safeguard: scan the prompt for secrets BEFORE it leaves the harness for
# gemini (an external agent runtime = a data-exfiltration path). block=True: if a secret
# is found, refuse to dispatch and audit the finding (kind only, never the raw value).
# Fails OPEN if a2a_guard is unavailable. Env A2A_GUARD_BLOCK=0 -> audit-only.
guard_outbound_prompt() {
    local prompt="$1" task_id="$2" from_agent="${AQ_AGENT_ROLE:-claude}"
    local guard="$SCRIPT_DIR/lib/a2a_guard.py"
    [[ -f "$guard" ]] || return 0
    local block="True"; [[ "${A2A_GUARD_BLOCK:-1}" == "0" ]] && block="False"
    local verdict
    verdict="$(A2A_GUARD_TEXT="$prompt" python3 - "$guard" "$from_agent" "$task_id" "$block" <<'PY' 2>/dev/null
import os, sys
from importlib.machinery import SourceFileLoader
guard_path, from_agent, task_id, block = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4] == "True"
mod = SourceFileLoader("a2a_guard", guard_path).load_module()
res = mod.guard_outbound(os.environ.get("A2A_GUARD_TEXT", ""), from_agent=from_agent,
                         to_agent="gemini", task_id=task_id, block=block)
print("BLOCKED" if not res["ok"] else "OK", ",".join(f["kind"] for f in res["findings"]))
PY
)"
    if [[ "$verdict" == BLOCKED* ]]; then
        die "A2A outbound blocked — prompt contains secret-like content (${verdict#BLOCKED }).
  Refusing to send secrets to gemini (external runtime). Redact the prompt or set
  A2A_GUARD_BLOCK=0 to audit-only. Audit: .agent/collaboration/a2a-audit.log"
    fi
    [[ "$verdict" == OK\ ?* ]] && info "A2A guard: audited outbound (findings: ${verdict#OK })"
    return 0  # never fail the caller under `set -e` (clean prompt = non-matching [[ ]] above)
}

# A2A dispatch budget: rate/budget limit on external dispatches
# (config/agent-dispatch-budget.json) — counts recent dispatches per agent + globally from
# the shared registry and refuses when a rolling-window cap is exceeded, bounding runaway
# loops. Blocks only on an explicit BLOCK (rc 3); fails open otherwise.
# A2A_BUDGET_BYPASS=1 skips one call.
budget_gate_dispatch() {
    local agent="$1"
    local bud="$SCRIPT_DIR/lib/agent_dispatch_budget.py"
    [[ -f "$bud" ]] || return 0
    local verdict rc
    verdict="$(python3 "$bud" "$agent" 2>/dev/null)"; rc=$?
    if [[ $rc -eq 3 ]]; then
        die "A2A dispatch budget BLOCKED this delegation: ${verdict#BLOCK }
  Too many recent dispatches. Wait for the window to clear, or bypass one call with:
  export A2A_BUDGET_BYPASS=1  |  Policy: config/agent-dispatch-budget.json"
    fi
    [[ "$verdict" == WARN* ]] && info "A2A dispatch budget WARNING: ${verdict#WARN }"
    return 0  # never fail the caller under `set -e`
}

# Return byte count of lines that are NOT Gemini CLI headers, warnings, or network error lines.
# Used to distinguish "real content produced" from "error-only output" on non-zero exits.
_gemini_meaningful_bytes() {
    local file="$1"
    # Strip Gemini CLI warnings, retry messages, Node.js stack traces, and JS error
    # config dumps — all produced when the API call fails before the model responds.
    # Real model output never contains node_modules paths or googleapis.com URLs.
    grep -Ev \
        "^Warning:|^YOLO mode|^Attempt [0-9]+ failed\.|An unexpected critical|FetchError|ETIMED|EAI_AGAIN|ENOTFOUND|retrying with backoff|^\s+at |node_modules|googleapis\.com|GaxiosError|AbortSignal|errorRedactor|paramsSerializer|validateStatus|<<REDACTED|Symbol\(|'s-gaxios-error'\]|response: undefined|'Content-Type'|'User-Agent'|'x-goog-api-client'|^\s+[a-zA-Z_]+: [\"'{[]|^\s*[{}],?\s*$|type: 'system'|stop serving requests|migrate to Antigravity|gemini-cli-migration|unpaid tiers" \
        "$file" 2>/dev/null | wc -c || echo 0
}

require_gemini() {
    [[ -x "$GEMINI_BIN" ]] || die "Gemini CLI not found at $GEMINI_BIN
  Install: npm install -g @google/gemini-cli
  Or set:  export GEMINI_BIN=/path/to/gemini

  AUTH NOTE (2026-06-18): Google sunset individual OAuth access permanently.
  This script delegates via the @google/gemini-cli npm binary using API-key auth
  stored in ~/.gemini/gemini-credentials.json (NOT oauth-personal).
  ~/.gemini/settings.json must have auth.selectedType=gemini-api-key.

  If credentials are wiped: set GEMINI_API_KEY from https://aistudio.google.com/apikey
  and run 'gemini' once interactively to re-seed the credential store. Add the key to
  nix/hosts/hyperd/home-deploy-options.nix (gitignored) as home.sessionVariables.GEMINI_API_KEY.

  Antigravity CLI (pkgs.antigravity, now installed) is a VS Code IDE — NOT a CLI
  delegation tool. 'antigravity chat' opens a GUI window. Do not set GEMINI_BIN=antigravity.
  See: .agent/GEMINI.md §Auth Architecture and .agent/memory/issues-backlog.md"
}

# Return 0 if output file contains Gemini CLI sunset/quota-termination error patterns.
# "Resource has been exhausted" on onboardUser is how Google surfaces the sunset for
# individual accounts — it is NOT a transient quota limit, it is permanent.
_gemini_sunset_error() {
    local file="$1"
    grep -qE "Resource has been exhausted|onboardUser|migrate to Antigravity|stop serving requests" "$file" 2>/dev/null
}

ensure_gemini_rg() {
    # Gemini CLI uses a bundled ripgrep binary (rg-linux-x64), not the system rg.
    # The npm package does not ship the binary — symlink the system rg into the
    # expected vendor path so Gemini finds it instead of falling back to GrepTool.
    # GEMINI_BIN symlinks to bundle/gemini.js; vendor/ripgrep is a sibling of that dir.
    local _gemini_real; _gemini_real="$(realpath "$GEMINI_BIN" 2>/dev/null)" || return 0
    local _rg_bundle_dir; _rg_bundle_dir="$(dirname "$_gemini_real")/vendor/ripgrep"
    local _arch; _arch="$(uname -m)"
    [[ "$_arch" == "x86_64" ]] && _arch="x64"
    [[ "$_arch" == "aarch64" ]] && _arch="arm64"
    local _rg_bundle_path="${_rg_bundle_dir}/rg-linux-${_arch}"
    if [[ ! -x "$_rg_bundle_path" ]]; then
        local _system_rg; _system_rg="$(command -v rg 2>/dev/null || echo "/run/current-system/sw/bin/rg")"
        if [[ -x "$_system_rg" ]]; then
            mkdir -p "$_rg_bundle_dir"
            ln -sf "$_system_rg" "$_rg_bundle_path"
            info "Linked system rg → Gemini vendor bundle: $_rg_bundle_path"
        fi
    fi
}

ensure_dirs() {
    mkdir -p "$OUTPUTS_DIR"
    touch "$REGISTRY"
}

task_id() {
    # Format: gemini-YYYYMMDD-HHMMSS-XXXXXX
    # Use subshell with pipefail disabled — tr exits SIGPIPE when head closes the pipe,
    # which with set -o pipefail would wrongly trigger the '|| xxxxxx' fallback.
    local rand; rand="$(set +o pipefail; tr -dc 'a-z0-9' </dev/urandom 2>/dev/null | head -c6)" || rand="xxxxxx"
    echo "gemini-$(date +%Y%m%d-%H%M%S)-${rand}"
}

registry_append() {
    local id="$1" description="$2" output_file="$3" pid="${4:-}" role="${5:-implement}"
    local ts; ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    printf '{"id":"%s","agent":"gemini","role":"%s","description":%s,"output_file":"%s","pid":%s,"status":"running","tokens_in":null,"tokens_out":null,"created":"%s"}\n' \
        "$id" "$role" \
        "$(printf '%s' "$description" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))')" \
        "$output_file" \
        "${pid:-null}" \
        "$ts" >> "$REGISTRY"
}

registry_update_status() {
    local id="$1" new_status="$2"
    # Rewrite registry with updated status for matching id
    python3 - "$REGISTRY" "$id" "$new_status" <<'PYEOF'
import sys, json
registry_file, task_id, new_status = sys.argv[1], sys.argv[2], sys.argv[3]
lines = []
with open(registry_file) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            entry = json.loads(line)
            if entry.get("id") == task_id:
                entry["status"] = new_status
            lines.append(json.dumps(entry))
        except json.JSONDecodeError:
            lines.append(line)
with open(registry_file, "w") as f:
    f.write("\n".join(lines) + ("\n" if lines else ""))
PYEOF
}

check_pid_alive() {
    local pid="$1"
    [[ -n "$pid" ]] && [[ "$pid" != "null" ]] && kill -0 "$pid" 2>/dev/null
}

# ── subcommands ──────────────────────────────────────────────────────────────

cmd_list() {
    [[ -f "$REGISTRY" ]] || { info "No delegated tasks yet."; return; }
    printf "%-30s  %-10s  %-10s  %-10s  %6s  %6s  %s\n" "TASK ID" "STATUS" "AGENT" "ROLE" "TOK_IN" "TOK_OUT" "DESCRIPTION"
    printf "%-30s  %-10s  %-10s  %-10s  %6s  %6s  %s\n" "------------------------------" "----------" "----------" "----------" "------" "-------" "-----------"
    python3 - "$REGISTRY" <<'PYEOF'
import sys, json
with open(sys.argv[1]) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            e = json.loads(line)
            desc = e.get("description","")[:50]
            ti = str(e.get("tokens_in") or "-")
            to = str(e.get("tokens_out") or "-")
            print(f"{e['id']:<30}  {e.get('status','?'):<10}  {e.get('agent','?'):<10}  {e.get('role','?'):<10}  {ti:>6}  {to:>7}  {desc}")
        except Exception:
            pass
PYEOF
}

cmd_status() {
    local id="$1"
    [[ -f "$REGISTRY" ]] || die "No registry found at $REGISTRY"
    python3 - "$REGISTRY" "$id" <<'PYEOF'
import sys, json
registry_file, task_id = sys.argv[1], sys.argv[2]
found = False
with open(registry_file) as f:
    for line in f:
        line = line.strip()
        if not line: continue
        try:
            e = json.loads(line)
            if e.get("id") == task_id:
                found = True
                print(json.dumps(e, indent=2))
        except Exception:
            pass
if not found:
    print(f"Task not found: {task_id}", file=sys.stderr)
    sys.exit(1)
PYEOF

    # Live status: check if pid is still running
    local pid; pid=$(python3 - "$REGISTRY" "$id" <<'PYEOF'
import sys, json
registry_file, task_id = sys.argv[1], sys.argv[2]
with open(registry_file) as f:
    for line in f:
        line = line.strip()
        if not line: continue
        try:
            e = json.loads(line)
            if e.get("id") == task_id:
                print(e.get("pid",""))
        except Exception:
            pass
PYEOF
)
    if check_pid_alive "$pid"; then
        info "Process $pid is still running."
    else
        info "Process no longer running."
    fi
}

cmd_check() {
    local id="$1"
    local output_file; output_file=$(python3 - "$REGISTRY" "$id" <<'PYEOF'
import sys, json
registry_file, task_id = sys.argv[1], sys.argv[2]
with open(registry_file) as f:
    for line in f:
        line = line.strip()
        if not line: continue
        try:
            e = json.loads(line)
            if e.get("id") == task_id:
                print(e.get("output_file",""))
        except Exception:
            pass
PYEOF
)
    [[ -n "$output_file" ]] || die "Task not found in registry: $id"
    # Resolve relative paths
    [[ "$output_file" = /* ]] || output_file="$REPO_ROOT/$output_file"
    [[ -f "$output_file" ]] || die "Output file not found: $output_file (task may still be running)"
    local meaningful_bytes; meaningful_bytes="$(_gemini_meaningful_bytes "$output_file")"
    if [[ "$meaningful_bytes" -le "$GEMINI_MIN_CONTENT_BYTES" ]]; then
        echo "[delegate-to-gemini] WARN: output may be incomplete (${meaningful_bytes}B meaningful content — check for network errors below)" >&2
    fi
    cat "$output_file"
}

cmd_delegate() {
    local prompt="$1" mode="${2:-yolo}" model_flag="${3:-}" wait_mode="${4:-false}" role="${5:-implement}"

    require_gemini
    ensure_gemini_rg
    ensure_dirs

    local id; id="$(task_id)"
    # A2A safeguards: authorize the mode, scan the outbound prompt, check the dispatch budget.
    policy_gate_action gemini "$mode" "$id"
    guard_outbound_prompt "$prompt" "$id"
    budget_gate_dispatch gemini
    local output_file="$OUTPUTS_DIR/${id}.log"
    local rel_output=".agents/delegation/outputs/${id}.log"

    # Prepend the canonical harness grounding SSOT (config/local-agent-grounding.md)
    # so gemini receives the SAME facts as local/codex/antigravity.
    local grounding; grounding="$(harness_grounding gemini 2>/dev/null || true)"

    # Phase 33.5: prepend role tag and mandatory harness constraints to prompt.
    # CRITICAL: These rules are non-negotiable and override any conflicting instruction.
    local full_prompt="${grounding:+$grounding

}[ROLE: ${role}]

=== HARNESS CONSTRAINTS (NON-NEGOTIABLE — read GEMINI.md for full contract) ===
1. SCOPE LOCK: Work ONLY on what the task requests. No unsolicited refactors, cleanups, or
   adjacent features. One slice, one concern. If in doubt about scope, STOP and report.
2. PRD GATE: Write a brief plan (problem/goal/files/validation) to .agent/collaboration/PULSE.log
   BEFORE editing any file. Format: [ISO-timestamp] [gemini] [plan]: <scope> — <approach>
3. PORT POLICY: NEVER hardcode ports or URLs. Source of truth: nix/modules/core/options.nix.
   Python reads from env vars; shell uses \${PORT:-default}. Known ports: llama=8080,
   embed=8081, aidb=8002, coordinator=8003, switchboard=8085, dashboard=8889.
4. HARDWARE: GPU layers ceiling = 12 (Renoir APU). enable_thinking: false in ALL llama.cpp
   requests. Never suggest n_gpu_layers > 12.
5. LOGGING: switchboard.py uses print(..., file=sys.stderr) — there is NO logger object.
6. COMMIT DISCIPLINE: After work is done, list all modified files and validate with:
   python3 -m py_compile <py-files> && bash -n <sh-files>
   DO NOT commit — the orchestrator (Claude) reviews and commits.
7. SECURITY: No hardcoded secrets, tokens, or credentials. No injection patterns.
   Run py_compile on every Python file you touch before declaring work complete.
8. ATOMIC PULSE: Append one line to .agent/collaboration/PULSE.log after every file write:
   [ISO-timestamp] [gemini] [write]: <file> — <what changed>
9. ATOMIC RESUME: At every phase start and on task completion, update
   .agent/collaboration/RESUME.json with: current_objective, phase, todo_snapshot[],
   uncommitted_changes[], resume_hint. This is the compaction anchor for all agents.
=== END CONSTRAINTS ===

${prompt}"

    info "Delegating task: $id"
    info "Approval mode:   $mode"
    info "Role:            $role"
    info "Output file:     $output_file"

    # Build command — use -p for headless (NOT 'gemini print ...')
    # NO_COLOR=1 + TERM=dumb suppress "256-color not detected" and ANSI noise in log files
    # Inject /run/current-system/sw/bin so Gemini tool calls can find rg, fd, jq, etc.
    local _augmented_path="/run/current-system/sw/bin:${PATH}"
    local cmd=(env NO_COLOR=1 TERM=dumb "PATH=${_augmented_path}" "$GEMINI_BIN" "-p" "$full_prompt" "--approval-mode" "$mode")
    [[ -n "$model_flag" ]] && cmd+=("--model" "$model_flag")

    # Register before launching so the task is findable even if we die
    registry_append "$id" "$prompt" "$rel_output" "" "$role"
    # Persist dispatch to PENDING.json + HANDOFF.md — survives context summarization
    "$SCRIPT_DIR/lib/pending-update" add "$id" "gemini" "$rel_output" "${prompt:0:120}" 2>/dev/null || true
    audit_event_start "gemini" "$id" "${prompt:0:200}"

    if [[ "$wait_mode" == "true" ]]; then
        # Blocking mode: run in foreground, tee to output file
        info "Running in blocking mode..."
        "${cmd[@]}" 2>&1 | tee "$output_file"
        local exit_code="${PIPESTATUS[0]}"
        local meaningful_bytes; meaningful_bytes="$(_gemini_meaningful_bytes "$output_file")"
        if [[ "$exit_code" -eq 0 ]]; then
            registry_update_status "$id" "done"
            "$SCRIPT_DIR/lib/pending-update" "done" "$id" 2>/dev/null || true
            audit_event_end "gemini" "$id" "success" "0" "completed: ${prompt:0:100}" "$role"
            audit_save_session "gemini" "$id" "$prompt" "$output_file"
            info "Task $id completed successfully."
        elif [[ "$meaningful_bytes" -gt "$GEMINI_MIN_CONTENT_BYTES" ]]; then
            # Non-zero exit but model produced real content — treat as partial-success.
            registry_update_status "$id" "partial-success"
            "$SCRIPT_DIR/lib/pending-update" partial-success "$id" 2>/dev/null || true
            audit_event_end "gemini" "$id" "partial-success" "0" "partial-success exit=${exit_code}: ${prompt:0:100}" "$role"
            audit_save_session "gemini" "$id" "$prompt" "$output_file"
            info "Task $id partial-success (exit $exit_code, meaningful ${meaningful_bytes}B)."
        else
            registry_update_status "$id" "failed"
            "$SCRIPT_DIR/lib/pending-update" failed "$id" 2>/dev/null || true
            audit_event_end "gemini" "$id" "error" "0" "failed exit=${exit_code}: ${prompt:0:100}" "$role"
            audit_save_session "gemini" "$id" "$prompt" "$output_file"
            info "Task $id failed (exit $exit_code, meaningful ${meaningful_bytes}B — below ${GEMINI_MIN_CONTENT_BYTES}B threshold)."
            if _gemini_sunset_error "$output_file"; then
                info "SUNSET_ERROR: cloudcode-pa.googleapis.com/onboardUser rejected individual access (2026-06-18 sunset). This is PERMANENT, not a transient quota hit."
                info "  Bypass: export GEMINI_API_KEY=<key> from https://aistudio.google.com/apikey"
                info "  See: .agent/memory/issues-backlog.md (antigravity-cli-migration-pending)"
            fi
        fi
    else
        # Background mode: fully detach so it survives session eviction
        # Use printf '%q ' to safely quote each cmd element before embedding in bash -c string
        local cmd_q; cmd_q="$(printf '%q ' "${cmd[@]}")"
        local _coord_url="${HYBRID_COORDINATOR_URL:-http://127.0.0.1:8003}"
        local _prompt_brief; _prompt_brief="${prompt:0:100}"
        local _audit_helper; _audit_helper="$SCRIPT_DIR/lib/audit-post.sh"
        nohup bash -c "
            _start_ms=\$(date +%s%3N 2>/dev/null || echo 0)
            $cmd_q > \"$output_file\" 2>&1
            exit_code=\$?
            _end_ms=\$(date +%s%3N 2>/dev/null || echo 0)
            _lat=\$(( _end_ms - _start_ms ))
            if [[ \$exit_code -eq 0 ]]; then
                bash \"$_audit_helper\" \"$_coord_url\" task_completed gemini success \"\$_lat\" \"$id\" \"completed: $_prompt_brief\" \"$role\" \"$prompt\" \"$output_file\" || true
                python3 - \"$REGISTRY\" \"$id\" done <<'PYEOF'
import sys, json
rf, tid, ns = sys.argv[1], sys.argv[2], sys.argv[3]
lines = []
with open(rf) as f:
    for l in f:
        l = l.strip()
        if not l: continue
        try:
            e = json.loads(l)
            if e.get('id') == tid: e['status'] = ns
            lines.append(json.dumps(e))
        except: lines.append(l)
with open(rf, 'w') as f: f.write('\n'.join(lines) + '\n')
PYEOF
                \"$SCRIPT_DIR/lib/pending-update\" done \"$id\" 2>/dev/null || true
            else
                _meaningful_bytes=\$(grep -Ev '^Warning:|^YOLO mode|^Attempt [0-9]+ failed|An unexpected critical|FetchError|ETIMED|EAI_AGAIN|ENOTFOUND|retrying with backoff|^\s+at |node_modules|googleapis|GaxiosError|AbortSignal|errorRedactor|paramsSerializer|validateStatus|Symbol\(|response: undefined|^\s+[a-zA-Z_]+: |^\s+'\''[^'\'']+'\'': |^\s*[{}],*\s*$' \"$output_file\" 2>/dev/null | wc -c || echo 0)
                if [[ \$_meaningful_bytes -gt ${GEMINI_MIN_CONTENT_BYTES} ]]; then
                    bash \"$_audit_helper\" \"$_coord_url\" task_completed gemini partial-success \"\$_lat\" \"$id\" \"partial-success exit=\$exit_code meaningful=\${_meaningful_bytes}B: $_prompt_brief\" \"$role\" \"$prompt\" \"$output_file\" || true
                    python3 - \"$REGISTRY\" \"$id\" partial-success <<'PYEOF'
import sys, json
