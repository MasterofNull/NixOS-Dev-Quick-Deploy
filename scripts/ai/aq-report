def main() -> None:
    args = parse_args()
    window = _parse_since(args.since)
    now = datetime.now(tz=timezone.utc)
    since_dt = now - window
    since_label = args.since

    # Collect data (independent sources — order doesn't matter)
    audit_entries = read_tool_audit(since_dt)
    delegation_feedback_raw = read_delegation_feedback(since_dt)
    delegation_feedback = aggregate_delegation_feedback(delegation_feedback_raw)
    eval_rows = read_eval_scores(since_dt)
    gaps = read_query_gaps(since_dt, limit=10)
    gaps = [
        g for g in gaps
        if not _is_synthetic_gap(str(g.get("query_text", "")))
        and not _is_curated_stale_gap(str(g.get("query_text", "")))
    ]
    prompts = read_prompt_registry()

    # Analyse
    tool_stats = aggregate_tool_audit(audit_entries)
    recent_cutoff = now - timedelta(hours=1)
    recent_audit_entries = [
        e for e in audit_entries
        if (_entry_ts_utc(e) or datetime.min.replace(tzinfo=timezone.utc)) >= recent_cutoff
    ]
    recent_tool_stats = aggregate_tool_audit(recent_audit_entries)
    route = routing_split(audit_entries)
    recent_route = routing_split(recent_audit_entries)
    recent_route["window"] = "1h"
    routing_windows = routing_split_windows(audit_entries, now=now, report_since=since_dt)
    recent_retrieval_breadth = route_retrieval_breadth(recent_audit_entries)
    recent_retrieval_breadth["window"] = "1h"
    retrieval_breadth_windows = route_retrieval_breadth_windows(audit_entries, now=now, report_since=since_dt)
    recent_provider_fallbacks = route_provider_fallback_health(recent_audit_entries)
    recent_provider_fallbacks["window"] = "1h"
