        ),
        "windows": summaries,
    }


def _route_prompt_cache_hit_rate(entries: List[dict]) -> Dict[str, Any]:
    """Derive prompt-cache sample quality from route_search audit metadata."""
    samples: List[int] = []
    for entry in entries:
        if str(entry.get("tool_name", "")).strip().lower() != "route_search":
            continue
        metadata = entry.get("metadata") if isinstance(entry.get("metadata"), dict) else {}
        if metadata.get("generate_response") is not True:
            continue
        cached_tokens = metadata.get("prompt_cache_cached_tokens")
        if isinstance(cached_tokens, (int, float)):
            samples.append(int(cached_tokens))
    hits = sum(1 for value in samples if value > 0)
    misses = sum(1 for value in samples if value <= 0)
    total = hits + misses
    return {
        "hits": hits,
        "misses": misses,
        "sample_total": total,
        "hit_pct": round(100 * hits / total, 1) if total else None,
        "available": total > 0,
        "source": "route_prompt_cache_audit",
    }


def cache_hit_rate(audit_entries: Optional[List[dict]] = None) -> Dict[str, Any]:
    """Fetch embedding cache hit rate from Prometheus counters."""
    hits = prom_query("sum(embedding_cache_hits_total) or vector(0)")
    misses = prom_query("sum(embedding_cache_misses_total) or vector(0)")
    if hits is None and misses is None:
        # Fallback counter names (Phase 17.4.1)
        hits = prom_query("EMBEDDING_CACHE_HITS_total")
        misses = prom_query("EMBEDDING_CACHE_MISSES_total")
    h = hits or 0.0
    m = misses or 0.0
    total = h + m
    result = {
        "hits": int(h),
        "misses": int(m),
        "sample_total": int(total),
        "hit_pct": round(100 * h / total, 1) if total else None,
        "available": hits is not None or misses is not None,  # None only on connection error
        "source": "embedding_cache_prometheus",
    }
    if total == 0 and isinstance(audit_entries, list):
        audit_fallback = _route_prompt_cache_hit_rate(audit_entries)
        if audit_fallback.get("available"):
            return audit_fallback
    return result


def _get_last_prewarm_run(service: str) -> Dict[str, Any]:
    """Extract last cache prewarm run details from systemd journal."""
    try:
        # Get last 50 journal lines for the service
        result = subprocess.run(
            ["journalctl", "-u", service, "-n", "50", "--no-pager", "-o", "cat"],
            capture_output=True,
            text=True,
            timeout=5,
            check=False,
        )
        if result.returncode != 0:
            return {}

        lines = result.stdout.split("\n")

        # Parse seed-routing-traffic output
        # Looking for: "seed-routing-traffic: N OK, M FAIL"
        queries_ok = None
        queries_fail = None
        backend_seeded = False

        for line in reversed(lines):  # Most recent first
            if "seed-routing-traffic:" in line and "OK," in line and "FAIL" in line:
                # Parse "seed-routing-traffic: 8 OK, 0 FAIL"
                match = re.search(r"(\d+)\s+OK,\s+(\d+)\s+FAIL", line)
                if match:
                    queries_ok = int(match.group(1))
                    queries_fail = int(match.group(2))
            if "backend-selection seeded" in line:
                backend_seeded = True

        # Get last activation timestamp
        ts_result = subprocess.run(
            ["systemctl", "show", service, "--property=ActiveEnterTimestamp"],
            capture_output=True,
            text=True,
            timeout=5,
            check=False,
        )
        last_activation = None
        if ts_result.returncode == 0:
            # Parse "ActiveEnterTimestamp=Fri 2026-03-20 12:34:56 UTC"
            ts_line = ts_result.stdout.strip()
            if "=" in ts_line:
                ts_str = ts_line.split("=", 1)[1]
                if ts_str and ts_str != "n/a":
                    last_activation = ts_str

        result_data = {}
        if queries_ok is not None:
            result_data["last_run_success"] = queries_fail == 0
            result_data["last_run_queries_ok"] = queries_ok
            result_data["last_run_queries_fail"] = queries_fail
            result_data["last_run_backend_seeded"] = backend_seeded
        if last_activation:
            result_data["last_activation"] = last_activation

        return result_data
    except Exception:
        return {}


def cache_prewarm_status() -> Dict[str, Any]:
    """Inspect declarative cache-prewarm timer state for monitoring context."""
    timer = "ai-cache-prewarm.timer"
    service = "ai-cache-prewarm.service"
    try:
        enabled = subprocess.run(
            ["systemctl", "is-enabled", timer],
            capture_output=True,
            text=True,
            timeout=5,
            check=False,
        )
        active = subprocess.run(
            ["systemctl", "is-active", timer],
            capture_output=True,
            text=True,
            timeout=5,
            check=False,
        )
    except Exception:
        return {"available": False}

    # Check last service run from journal
    last_run_info = _get_last_prewarm_run(service)

    return {
        "available": True,
        "timer": timer,
        "service": service,
        "enabled": enabled.returncode == 0,
        "enabled_state": (enabled.stdout or enabled.stderr or "").strip() or "unknown",
        "active": active.returncode == 0,
        "active_state": (active.stdout or active.stderr or "").strip() or "unknown",
        **last_run_info,  # Add run details
    }


def eval_score_trend(rows: List[dict], entries: Optional[List[dict]] = None) -> Dict[str, Any]:
    """Compute eval score statistics over the window."""
    pcts: List[float] = []
    source = "scores_db"
    if rows:
        pcts = [float(r["pct_passed"]) for r in rows]
    elif entries:
        source = "tool_audit"
        for e in entries:
            if str(e.get("tool_name", "")).strip().lower() != "run_harness_eval":
                continue
            md = e.get("metadata") if isinstance(e.get("metadata"), dict) else {}
            score = md.get("harness_overall_score")
            if isinstance(score, (int, float)):
                pcts.append(round(float(score) * 100.0, 2))
    if not pcts:
        return {"available": False}
    return {
        "available": True,
        "source": source,
        "latest_pct": pcts[-1],
        "mean_pct": round(statistics.mean(pcts), 1),
        "min_pct": min(pcts),
        "max_pct": max(pcts),
        "trend": "rising" if len(pcts) >= 2 and pcts[-1] > pcts[0] else
                 "falling" if len(pcts) >= 2 and pcts[-1] < pcts[0] else "stable",
        "n_runs": len(pcts),
    }


def build_recommendations(
    tool_stats: Dict[str, dict],
    route: Dict[str, Any],
    cache: Dict[str, Any],
    eval_trend: Dict[str, Any],
    gaps: List[dict],
    route_latency_decomposition: Optional[Dict[str, Any]] = None,
    delegated_prompt_failures: Optional[Dict[str, Any]] = None,
    feedback_acceleration: Optional[Dict[str, Any]] = None,
    gap_remediation: Optional[Dict[str, Any]] = None,
    rag_posture_summary: Optional[Dict[str, Any]] = None,
    adoption: Optional[Dict[str, Any]] = None,
    intent_compliance: Optional[Dict[str, Any]] = None,
    security_auditor: Optional[Dict[str, Any]] = None,
    semantic_autorun: Optional[Dict[str, Any]] = None,
    tooling_quality: Optional[Dict[str, Any]] = None,
    hint_diversity_stats: Optional[Dict[str, Any]] = None,
    recent_hint_diversity_stats: Optional[Dict[str, Any]] = None,
    recent_tool_stats: Optional[Dict[str, dict]] = None,
    recent_semantic_autorun: Optional[Dict[str, Any]] = None,
    recent_provider_fallbacks: Optional[Dict[str, Any]] = None,
    recent_retrieval_breadth: Optional[Dict[str, Any]] = None,
    cache_prewarm: Optional[Dict[str, Any]] = None,
) -> List[str]:
    """Derive actionable workflow recommendations from measured data."""
    recs: List[str] = []
    ignored_flaky_tools = {
        t.strip().lower()
        for t in os.getenv("AQ_REPORT_FLAKY_TOOL_IGNORE", "run_sandboxed,shell_execute").split(",")
        if t.strip()
    }

    # Routing
    if route["available"]:
        if route["local_pct"] is not None and route["local_pct"] < 30:
            recs.append(
                f"Local routing is low ({route['local_pct']}%). "
                "Check `systemctl status ai-llama-cpp` and `llama.cpp` model load; "
                "run `scripts/testing/check-mcp-health.sh` to diagnose."
            )
    else:
        recs.append(
            "Routing metrics unavailable (Prometheus unreachable). "
            "Verify `systemctl status prometheus` and that ai-hybrid-coordinator exposes /metrics."
        )

    if route_latency_decomposition and route_latency_decomposition.get("available"):
        observed_p95 = route_latency_decomposition.get("overall_p95_ms")
        actionable_p95 = route_latency_decomposition.get("actionable_p95_ms")
        backend_valid_p95 = route_latency_decomposition.get("backend_valid_p95_ms")
        client_errors = int(route_latency_decomposition.get("client_error_count", 0) or 0)
        unclassified = int(route_latency_decomposition.get("backend_unclassified_count", 0) or 0)
        total_calls = int(route_latency_decomposition.get("total_calls", 0) or 0)
        if (
            observed_p95 is not None
            and actionable_p95 is not None
            and float(observed_p95) >= 2500.0
            and float(actionable_p95) + 500.0 < float(observed_p95)
            and client_errors > 0
        ):
            recs.append(
                f"Observed route_search p95 is inflated by invalid client requests "
                f"({_na(observed_p95, '.0f', 'ms')} observed vs {_na(actionable_p95, '.0f', 'ms')} actionable; "
                f"{client_errors}/{total_calls} requests were 4xx/client-error). "
                "Treat this as caller-contract noise before tuning retrieval or model routing."
            )
        if (
            actionable_p95 is not None
            and backend_valid_p95 is not None
            and float(actionable_p95) >= 2500.0
            and float(backend_valid_p95) + 500.0 < float(actionable_p95)
            and unclassified > 0
        ):
            recs.append(
                f"Actionable route_search latency is still inflated by backend-unclassified rows "
                f"({_na(actionable_p95, '.0f', 'ms')} actionable vs {_na(backend_valid_p95, '.0f', 'ms')} backend-valid; "
                f"{unclassified} rows missing explicit local/remote backend labels). "
                "Prefer fixing audit labeling before further routing-threshold tuning."
            )
        breakdown = route_latency_decomposition.get("breakdown") or []
        reasoning_lanes: List[Tuple[str, int, float]] = []
        for item in breakdown:
            if not isinstance(item, dict):
                continue
            label = str(item.get("label", "") or "").strip().lower()
            if label not in {"local_lane:reasoning", "synthesis_type:reasoning"}:
                continue
            try:
                calls = int(item.get("calls", 0) or 0)
            except (TypeError, ValueError):
                calls = 0
            try:
                p95_ms = float(item.get("p95_ms", 0.0) or 0.0)
            except (TypeError, ValueError):
                p95_ms = 0.0
            if calls <= 0 or p95_ms <= 0.0:
                continue
            reasoning_lanes.append((label, calls, p95_ms))
        if reasoning_lanes:
            reasoning_lanes.sort(key=lambda item: (-item[2], -item[1], item[0]))
            label, calls, p95_ms = reasoning_lanes[0]
            if calls >= 3 and p95_ms >= 8000.0:
                lane_note = "dedicated reasoning lane" if label == "local_lane:reasoning" else "reasoning synthesis path"
                recs.append(
                    f"Local reasoning synthesis remains the route_search tail ({lane_note} p95 {_na(p95_ms, '.0f', 'ms')} across {calls} calls). "
                    "Prefer lookup/format lanes for bounded tasks, keep reasoning prompts compact, and remeasure before changing retrieval breadth."
                )
        lane_default = next(
            (
                item for item in breakdown
                if isinstance(item, dict) and str(item.get("label", "") or "").strip().lower() == "local_lane:default"
            ),
            None,
        )
        lane_reasoning = next(
            (
                item for item in breakdown
                if isinstance(item, dict) and str(item.get("label", "") or "").strip().lower() == "local_lane:reasoning"
            ),
            None,
        )
        if lane_default and lane_reasoning:
            try:
                default_calls = int(lane_default.get("calls", 0) or 0)
                default_p95 = float(lane_default.get("p95_ms", 0.0) or 0.0)
                reasoning_calls = int(lane_reasoning.get("calls", 0) or 0)
                reasoning_p95 = float(lane_reasoning.get("p95_ms", 0.0) or 0.0)
            except (TypeError, ValueError):
                default_calls = 0
                default_p95 = 0.0
                reasoning_calls = 0
                reasoning_p95 = 0.0
            if (
                default_calls >= 2
                and reasoning_calls >= 3
                and default_p95 > 0.0
                and reasoning_p95 >= default_p95 + 3000.0
            ):
                recs.append(
                    f"Dedicated local reasoning is materially slower than the default local lane "
                    f"({_na(reasoning_p95, '.0f', 'ms')} vs {_na(default_p95, '.0f', 'ms')} p95). "
                    "Reserve the reasoning lane for continuation/deeper analyses and keep bounded explanations on the default local lane."
                )

    # Cache
    if cache["available"]:
        if _cache_recommendation_actionable(cache):
            recs.append(
                f"Embedding cache hit rate is low ({cache['hit_pct']}%). "
                "Consider pre-warming the cache by running common queries, "
                "or increase `AI_CACHE_MAX_SIZE` if memory allows."
            )
    else:
        recs.append(
            "Cache metrics unavailable. "
            "Ensure `embedding_cache.py` emits Prometheus counters and Prometheus scrapes the service."
        )

    # Cache prewarm
    if cache_prewarm and cache_prewarm.get("available") and cache_prewarm.get("last_run_success") is False:
        recs.append(
            f"Cache prewarm failed in last run "
            f"({cache_prewarm.get('last_run_queries_fail', 0)} failures). "
            "Check: journalctl -u ai-cache-prewarm.service -n 100"
        )

    if rag_posture_summary and rag_posture_summary.get("available"):
        rag_status = str(rag_posture_summary.get("status", "unknown") or "unknown")
        prewarm_candidates = rag_posture_summary.get("prewarm_candidates") or []
        prewarm_label = ", ".join(
            candidate.get("id", "")
            for candidate in prewarm_candidates
            if isinstance(candidate, dict) and str(candidate.get("id", "")).strip()
        )
        memory_share = rag_posture_summary.get("memory_recall_share_pct")
        memory_miss_pct = rag_posture_summary.get("memory_recall_miss_pct")
        if rag_status == "low_sample":
            suffix = f" Candidate prewarm prompts: {prewarm_label}." if prewarm_label else ""
            recs.append(
                "RAG cache is still in a low-sample warmup state. "
                "Prefer bounded local prewarm on recent retrieval patterns before changing cache sizing."
                + suffix
            )
        elif rag_status == "watch" and prewarm_label:
            recs.append(
                f"RAG retrieval is active but cache efficiency remains weak. "
                f"Prewarm recent low-cost patterns first: {prewarm_label}."
            )
        if memory_share is not None and float(memory_share) <= 15.0:
            if memory_miss_pct is not None and float(memory_miss_pct) >= 50.0:
                recs.append(
                    f"Memory recall misses are high ({memory_miss_pct}% of recent attempts). "
                    "Refresh stored milestone summaries or persist sharper task checkpoints before relying on broad route_search."
                )
            else:
                recs.append(
                    f"Memory recall usage is low ({memory_share}% of recent retrieval calls). "
                    "For ongoing repo/system tasks, prefer memory recall before broad route_search when prior context exists."
                )

    # Batch D — Cache and Retrieval Effectiveness
    # Add bounded prewarm heuristics for cheap recurring local queries
    if cache.get("available") and cache.get("hit_pct") is not None:
        cache_hit = float(cache["hit_pct"])
        if 40.0 <= cache_hit < 60.0:
            # Cache is warming but not yet optimal — recommend targeted prewarm
            prewarm_candidates = (rag_posture_summary or {}).get("prewarm_candidates") or []
            top_prewarm = None
            for c in prewarm_candidates:
                if isinstance(c, dict) and c.get("id"):
                    top_prewarm = c.get("id")
                    break
            if top_prewarm:
                recs.append(
                    f"Cache hit rate ({cache_hit:.1f}%) is approaching target. "
                    f"Run bounded prewarm for '{top_prewarm}' to push over 60% without broad seeding."
                )
        elif cache_hit >= 60.0:
            # Cache is healthy — recommend retrieval-first for local queries
            route_local = route.get("local_pct") if route.get("available") else None
            if route_local is not None and float(route_local) >= 80.0:
                recs.append(
                    f"Cache is healthy ({cache_hit:.1f}%) and local routing is strong ({float(route_local):.1f}%). "
                    "Prefer local-first retrieval for recurring queries; remote spend is unnecessary for cached patterns."
                )

    if recent_provider_fallbacks and recent_provider_fallbacks.get("available"):
        recovered_count = int(recent_provider_fallbacks.get("recovered_count", 0) or 0)
        if recovered_count > 0:
            status_counts = recent_provider_fallbacks.get("status_counts") or []
            status_text = _format_provider_fallback_statuses(status_counts) if status_counts else "4xx"
            provider_actions = recent_provider_fallbacks.get("actions") or []
            action_suffix = f" Next: {provider_actions[0]}." if provider_actions else ""
            recs.append(
                f"Recovered remote-provider fallbacks observed ({recovered_count} recent route_search calls; upstream {status_text}). "
                "Treat this as provider-budget or remote-routing pressure, not a local backend outage."
                + action_suffix
            )
    if recent_retrieval_breadth and recent_retrieval_breadth.get("available"):
        avg_collection_count = recent_retrieval_breadth.get("avg_collection_count")
        if avg_collection_count is not None and float(avg_collection_count) > 4.0:
            top_profiles = recent_retrieval_breadth.get("top_profiles") or []
            profile_note = f" Dominant profile: {top_profiles[0][0]}." if top_profiles else ""
            breadth_actions = recent_retrieval_breadth.get("actions") or []
            action_suffix = f" Next: {breadth_actions[0]}." if breadth_actions else ""
            recs.append(
                f"route_search is still scanning a broad collection set ({avg_collection_count} collections/call recent avg)."
                + profile_note
                + action_suffix
            )

    # Query gaps — check AIDB for existing docs before recommending import
    top_gaps = [
        g for g in gaps
        if g.get("occurrences", 1) >= 3
        and not _is_synthetic_gap(str(g.get("query_text", "")))
        and not _is_curated_stale_gap(str(g.get("query_text", "")))
    ]
    for g in top_gaps[:3]:
        topic = g["query_text"][:80].replace("\n", " ")
        occurrences = g.get("occurrences", "?")
        existing = _count_aidb_docs_for_topic(topic)
        if existing > 0:
            recs.append(
                f"Recurring gap ({occurrences}x): \"{topic}\". "
                f"Docs exist in AIDB ({existing} match{'es' if existing != 1 else ''}). "
                f"Verify Qdrant embedding with: scripts/ai/aq-qa 2. "
                f"Clear stale gap: psql $AIDB_DSN -c \"DELETE FROM query_gaps "
                f"WHERE query_text ILIKE '%{topic[:30]}%';\""
            )
        else:
            recs.append(
                f"Recurring unanswered query ({occurrences}x): \"{topic}\". "
                f"No matching docs in AIDB. "
                f"Import: scripts/ai/aq-knowledge-import.sh \"{topic[:40]}\""
            )

    # Eval trend
    if eval_trend.get("available") and eval_trend.get("trend") == "falling":
        source = str(eval_trend.get("source", "unknown") or "unknown")
        n_runs = int(eval_trend.get("n_runs", 0) or 0)
        sample_note = " Low sample window." if n_runs < 3 else ""
        recs.append(
            f"Eval score trending down (latest: {eval_trend['latest_pct']}%, "
            f"mean: {eval_trend['mean_pct']}%, runs: {n_runs}, source: {source})."
            f"{sample_note} Review recent prompt changes and run "
            "`scripts/automation/run-eval.sh --full --strategy eval-regression-check` to confirm."
        )

    # Hint adoption quality
    if adoption and adoption.get("available") and int(adoption.get("total", 0)) >= 5:
        pct = adoption.get("adoption_pct")
        if pct is not None and float(pct) < 60:
            recs.append(
                f"Hint adoption is low ({pct}% successful across {adoption['total']} injected tasks). "
                "Review hint matching quality and validate aider-wrapper acceptance paths."
            )
        tp_total = int(adoption.get("tooling_plan_total", 0) or 0)
        tp_pct = adoption.get("tooling_plan_success_pct")
        if tp_total >= 5 and tp_pct is not None and float(tp_pct) < 60:
            recs.append(
                f"Tooling-plan injected tasks underperform ({tp_pct}% success across {tp_total} runs). "
                "Review /workflow/plan relevance and tighten injected phase/tool selection."
            )

    # Intent contract coverage
    if intent_compliance and intent_compliance.get("available"):
        total_runs = int(intent_compliance.get("total_runs", 0) or 0)
        coverage = intent_compliance.get("contract_coverage_pct")
        if total_runs >= 3 and coverage is not None and float(coverage) < 90:
            missing_obj = int(intent_compliance.get("missing_contract_obj", 0) or 0)
            if missing_obj > 0:
                recs.append(
                    f"Workflow intent-contract coverage is low ({coverage}% over {total_runs} runs), "
                    f"including {missing_obj} run record(s) with no intent_contract object. "
                    "Backfill legacy workflow-sessions records and ensure /workflow/run/start always sends "
                    "intent_contract fields (user_intent, definition_of_done, depth_expectation, "
                    "spirit_constraints, no_early_exit_without)."
                )
            else:
                recs.append(
                    f"Workflow intent-contract coverage is low ({coverage}% over {total_runs} runs). "
                    "Ensure /workflow/run/start always includes intent_contract fields "
                    "(user_intent, definition_of_done, depth_expectation, spirit_constraints, no_early_exit_without)."
                )

    # Semantic tooling autorun quality
    if semantic_autorun and semantic_autorun.get("available"):
        route_calls = int(semantic_autorun.get("route_calls", 0) or 0)
        if route_calls >= 5:
            enabled_pct = semantic_autorun.get("autorun_enabled_pct")
            if enabled_pct is not None and float(enabled_pct) < 80:
                recs.append(
                    f"Semantic tooling autorun is inconsistently active ({enabled_pct}% across {route_calls} route calls). "
                    "Verify `AI_SEMANTIC_TOOLING_AUTORUN=true` in hybrid-coordinator runtime env."
                )
            blocked_total = int(semantic_autorun.get("tool_security_blocked_total", 0) or 0)
            blocked_pct = (100.0 * blocked_total / route_calls) if route_calls > 0 else 0.0
            if blocked_total >= 10 or blocked_pct >= 5.0:
                # Suppress stale 7d warning when recent traffic is clean.
                if recent_semantic_autorun and recent_semantic_autorun.get("available"):
                    r_calls = int(recent_semantic_autorun.get("route_calls", 0) or 0)
                    r_blocked = int(recent_semantic_autorun.get("tool_security_blocked_total", 0) or 0)
                    if r_calls >= 5 and r_blocked == 0:
                        pass
                    else:
                        blocked_tools = []
                        blocked_reasons = []
                        if security_auditor and security_auditor.get("available"):
                            blocked_tools = [
                                name for name, _count in (security_auditor.get("top_blocked_tools") or [])[:3]
                                if str(name).strip()
                            ]
                            blocked_reasons = [
                                name for name, _count in (security_auditor.get("top_block_reasons") or [])[:2]
                                if str(name).strip()
                            ]
                        blocked_suffix = f" Top blocked tools: {', '.join(blocked_tools)}." if blocked_tools else ""
                        reason_suffix = f" Top reasons: {', '.join(blocked_reasons)}." if blocked_reasons else ""
                        recs.append(
                            "Tool security auditor blocked one or more planned tools during autorun. "
                            "Review `runtime-tool-security-policy.json` and blocked tool metadata in tool-audit logs. "
                            f"Recent context: {_autorun_block_context(recent_semantic_autorun)}."
                            + blocked_suffix
                            + reason_suffix
                        )
                else:
                    blocked_tools = []
                    blocked_reasons = []
                    if security_auditor and security_auditor.get("available"):
                        blocked_tools = [
                            name for name, _count in (security_auditor.get("top_blocked_tools") or [])[:3]
                            if str(name).strip()
                        ]
                        blocked_reasons = [
                            name for name, _count in (security_auditor.get("top_block_reasons") or [])[:2]
                            if str(name).strip()
                        ]
                    blocked_suffix = f" Top blocked tools: {', '.join(blocked_tools)}." if blocked_tools else ""
                    reason_suffix = f" Top reasons: {', '.join(blocked_reasons)}." if blocked_reasons else ""
                    recs.append(
                        "Tool security auditor blocked one or more planned tools during autorun. "
                        "Review `runtime-tool-security-policy.json` and blocked tool metadata in tool-audit logs. "
                        f"Recent context: {_autorun_block_context(recent_semantic_autorun)}."
                        + blocked_suffix
                        + reason_suffix
                    )

    # Security auditor cache behavior
    if security_auditor and security_auditor.get("available"):
        events = int(security_auditor.get("events", 0) or 0)
        cache_hit_pct = security_auditor.get("cache_hit_pct")
        if events >= 10 and cache_hit_pct is not None and float(cache_hit_pct) < 50:
            recs.append(
                f"Security-auditor cache hit rate is low ({cache_hit_pct}% over {events} decisions). "
                "Consider increasing `AI_TOOL_SECURITY_CACHE_TTL_HOURS` to reduce repeated full audits."
            )

    if tooling_quality and tooling_quality.get("available"):
        plan_total = int(tooling_quality.get("plan_total", 0) or 0)
        baseline_total = int(tooling_quality.get("baseline_total", 0) or 0)
        plan_pct = tooling_quality.get("plan_success_pct")
        baseline_pct = tooling_quality.get("baseline_success_pct")
        if (
            plan_total >= 5
            and baseline_total >= 5
            and plan_pct is not None
            and baseline_pct is not None
            and float(plan_pct) + 5.0 < float(baseline_pct)
        ):
            recs.append(
                f"Tooling-plan injected tasks are under baseline ({plan_pct}% vs {baseline_pct}%). "
                "Refine /workflow/plan phase/tool selection and hint-plan alignment."
            )

    if hint_diversity_stats and hint_diversity_stats.get("available"):
        total_injections = int(hint_diversity_stats.get("total_injections", 0) or 0)
        dominant_share_pct = hint_diversity_stats.get("dominant_share_pct")
        unique_hints = int(hint_diversity_stats.get("unique_hints", 0) or 0)
        diversity_status = str(hint_diversity_stats.get("status", "")).strip().lower()
        recent_total = int((recent_hint_diversity_stats or {}).get("total_injections", 0) or 0)
        if total_injections >= 10 and recent_total >= 5 and (
            diversity_status == "concentrated"
            or unique_hints <= 1
            or (dominant_share_pct is not None and float(dominant_share_pct) >= 70)
        ):
            recs.append(
                "Hint diversity is overly concentrated. Add at least one data/tool-error/system-state hint path, "
                "and weight down over-repeated registry-only hints."
            )

    # Slow tools
    slow_tools = [
        (t, s) for t, s in tool_stats.items()
        if s["p95_ms"] > 5000 and s["calls"] >= 5
    ]
    for tool, stats in sorted(slow_tools, key=lambda x: -x[1]["p95_ms"])[:2]:
        fresh = recent_tool_stats.get(tool) if recent_tool_stats and tool in recent_tool_stats else None
        if fresh is None or int(fresh.get("calls", 0) or 0) == 0:
            continue
        if recent_tool_stats and tool in recent_tool_stats:
            if int(fresh.get("calls", 0) or 0) >= 1 and float(fresh.get("p95_ms", 0.0) or 0.0) <= 5000.0:
                continue
        if stats["p95_ms"] >= 300000:
            recs.append(
                f"Tool `{tool}` P95 latency is {stats['p95_ms']:.0f}ms — "
                "this looks like timeout/outlier behavior. Inspect raw tool-audit latency entries "
                f"and timeout settings before tuning caching/model size. Latency context: {_tool_latency_context(stats, fresh)}."
            )
        else:
            recs.append(
                f"Tool `{tool}` P95 latency is {stats['p95_ms']:.0f}ms — "
                f"consider caching, connection pooling, or model size reduction. Latency context: {_tool_latency_context(stats, fresh)}."
            )

    # Tool reliability
    flaky_tools = [
        (t, s) for t, s in tool_stats.items()
        if s["calls"] >= 3
        and s["success_pct"] < 80
        and t.lower() not in ignored_flaky_tools
    ]
    for tool, stats in sorted(flaky_tools, key=lambda x: x[1]["success_pct"])[:2]:
        fresh = recent_tool_stats.get(tool) if recent_tool_stats and tool in recent_tool_stats else None
        if fresh is None or int(fresh.get("calls", 0) or 0) == 0:
            continue
        if recent_tool_stats and tool in recent_tool_stats:
            if int(fresh.get("calls", 0) or 0) >= 1 and float(fresh.get("success_pct", 0.0) or 0.0) >= 90.0:
                continue
        if str(tool or "").strip().lower() == "workflow_run_start":
            accepted_reviews = int((intent_compliance or {}).get("accepted_reviews", 0) or 0)
            rejected_reviews = int((intent_compliance or {}).get("rejected_reviews", 0) or 0)
            pending_reviews = int((intent_compliance or {}).get("pending_reviews", 0) or 0)
            if accepted_reviews > 0 and rejected_reviews == 0 and pending_reviews == 0:
                recs.append(
                    f"Workflow start backend reliability reads low ({stats['success_pct']}% across {stats['calls']} valid calls), "
                    f"but reviewer-gated workflow runs are completing cleanly ({accepted_reviews} accepted review(s), no rejected or pending reviews). "
                    "Treat this as workflow contract/result-classification noise before changing retries or fallback behavior."
                )
                continue
        interpretation = _tool_reliability_interpretation(tool, stats, fresh)
        if not interpretation.get("active_incident", False):
            continue
        recs.append(
            f"Tool `{tool}` backend success rate is low ({stats['success_pct']}% across {stats['calls']} valid calls). "
            f"Reliability context: {interpretation.get('note') or _tool_reliability_context(stats, fresh)}. "
            "Tighten retries/timeouts or fallback behavior only if the failures are still active."
        )

    # Code-gen quality guidance (Phase 18 user goal: measure prompt efficiency for systems code gen)
    code_gen_tools = {t: s for t, s in tool_stats.items()
                     if any(kw in t.lower() for kw in ("aider", "code", "edit", "generate"))}
    for tool, stats in code_gen_tools.items():
        if stats["success_pct"] < 70:
            recs.append(
                f"Code-gen tool `{tool}` has low success rate ({stats['success_pct']}%). "
                "Try more specific file context (--file flags), smaller task scope per request, "
                "or a higher-tier model. See ai-stack/prompts/registry.yaml for vetted templates."
            )

    if delegated_prompt_failures and delegated_prompt_failures.get("available"):
        total_failures = int(delegated_prompt_failures.get("total_failures", 0) or 0)
        if total_failures > 0:
            top_failure_classes = delegated_prompt_failures.get("top_failure_classes") or []
            top_text = ", ".join(f"{name}={count}" for name, count in top_failure_classes[:3]) or "unknown"
            recs.append(
                f"Delegated OpenRouter prompt failures recorded ({total_failures} in-window; {top_text}). "
                "Treat these as local prompt-contract failures and tighten scope, output schema, and repo-grounding before retry."
            )
            salvageable_pct = delegated_prompt_failures.get("salvageable_pct")
            if salvageable_pct is not None and float(salvageable_pct) > 0:
                recs.append(
                    f"Delegated failure salvage rate is {_na(salvageable_pct, '.1f', '%')}. "
                    "Digest useful commands, paths, and excerpts from failed responses before spending more orchestration tokens."
                )

    if feedback_acceleration and feedback_acceleration.get("available"):
        feedback_status = str(feedback_acceleration.get("status", "unknown") or "unknown")
        if feedback_status == "active":
            recs.append(
                "Feedback acceleration pressure is active. "
                "Close the current delegated-failure or low-adoption loop before widening orchestration policy changes."
            )
        elif feedback_status == "watch" and int(feedback_acceleration.get("promotable_lessons", 0) or 0) > 0:
            recs.append(
                f"Feedback acceleration has {feedback_acceleration.get('promotable_lessons')} promotable lesson candidate(s). "
                "Review and materialize the top lesson before starting a new remediation branch."
            )

    if gap_remediation and gap_remediation.get("available"):
        candidate_count = int(gap_remediation.get("candidate_count", 0) or 0)
        if candidate_count > 0:
            top_strategies = ", ".join(
                f"{name}={count}" for name, count in (gap_remediation.get("top_strategies") or [])[:3]
            ) or "mixed"
            recs.append(
                f"Recurring capability gaps remain actionable ({candidate_count} candidate(s); {top_strategies}). "
                "Prefer the classified remediation strategy before importing generic docs or widening retrieval breadth."
            )

    if not recs:
        recs.append("No critical issues detected. System is operating within normal parameters.")

    return recs


def build_structured_actions(
    tool_stats: Dict[str, dict],
    route: Dict[str, Any],
    cache: Dict[str, Any],
    eval_trend: Dict[str, Any],
    gaps: List[dict],
    delegated_prompt_failures: Optional[Dict[str, Any]] = None,
    agent_lessons: Optional[Dict[str, Any]] = None,
    route_latency_decomposition: Optional[Dict[str, Any]] = None,
    historical_hint_watch: Optional[Dict[str, Any]] = None,
    gap_remediation: Optional[Dict[str, Any]] = None,
) -> List[dict]:
    """Machine-readable optimization actions for aq-optimizer."""
    actions: List[dict] = []

    timeout_gaps = [g for g in gaps if g.get("collection") == "inference_timeout"]
    timeout_count = sum(int(g.get("occurrences", 1)) for g in timeout_gaps)
    if timeout_count >= 3:
        actions.append({
            "type": "routing",
            "action": "prefer_remote",
            "reason": "inference_timeout_count=" + str(timeout_count),
            "safe": True,
            "confidence": min(1.0, timeout_count / 10),
            "env_overrides": {"DEFAULT_PROVIDER": "remote"},
            "services": ["ai-hybrid-coordinator", "ai-switchboard"],
        })

    if (route.get("available") and route.get("local_pct") is not None
            and float(route["local_pct"]) < 30):
        actions.append({
            "type": "routing",
            "action": "nudge_local_threshold_down",
            "reason": "local_pct_low=" + str(route["local_pct"]),
            "safe": True,
            "confidence": 0.65,
            "env_overrides": {
                "DEFAULT_PROVIDER": "local",
                "LOCAL_CONFIDENCE_THRESHOLD": "0.35",
            },
            "services": ["ai-hybrid-coordinator", "ai-switchboard"],
        })

    if (route.get("available") and route.get("local_pct") is not None
            and float(route["local_pct"]) > 70 and timeout_count == 0):
        actions.append({
            "type": "routing",
            "action": "prefer_local",
            "reason": "local_healthy_pct=" + str(route["local_pct"]),
            "safe": True,
            "confidence": 0.75,
            "env_overrides": {"DEFAULT_PROVIDER": "local"},
            "services": ["ai-hybrid-coordinator", "ai-switchboard"],
        })

    if route_latency_decomposition and route_latency_decomposition.get("available"):
        for item in route_latency_decomposition.get("breakdown") or []:
            if not isinstance(item, dict):
                continue
            label = str(item.get("label", "") or "").strip().lower()
            if label != "local_lane:reasoning":
                continue
            try:
                calls = int(item.get("calls", 0) or 0)
                p95_ms = float(item.get("p95_ms", 0.0) or 0.0)
            except (TypeError, ValueError):
                continue
            if calls >= 3 and p95_ms >= 8000.0:
                actions.append({
                    "type": "routing",
                    "action": "tune_local_reasoning_lane",
                    "reason": f"local_reasoning_lane_p95_ms={round(p95_ms, 1)} calls={calls}",
                    "safe": True,
                    "confidence": 0.72,
                    "notes": [
                        "Prefer lookup/format lanes for bounded synthesis before widening reasoning prompts.",
                        "Keep local reasoning context compact and remeasure route_search latency after one batch.",
                    ],
                    "services": ["ai-hybrid-coordinator"],
                })
                break

    if _cache_recommendation_actionable(cache):
        actions.append({
            "type": "maintenance",
            "action": "prewarm_cache",
            "reason": "cache_hit_pct_low=" + str(cache["hit_pct"]),
            "safe": True,
            "confidence": 0.7,
            "script": "seed-routing-traffic.sh",
            "script_args": ["--count", "8"],
        })

    if delegated_prompt_failures and delegated_prompt_failures.get("available"):
        total_failures = int(delegated_prompt_failures.get("total_failures", 0) or 0)
        top_failure_classes = delegated_prompt_failures.get("top_failure_classes") or []
        if total_failures >= 2 and top_failure_classes:
            reason = ",".join(f"{name}:{count}" for name, count in top_failure_classes[:3])
            actions.append({
                "type": "prompt",
                "action": "tighten_openrouter_delegation_contract",
                "reason": f"delegation_failures={reason}",
                "safe": False,
                "confidence": min(0.95, 0.45 + (total_failures / 10.0)),
                "topic": "openrouter_delegation_prompt_contract",
                "profiles": [name for name, _count in (delegated_prompt_failures.get("top_profiles") or [])[:3]],
                "evidence": delegated_prompt_failures.get("recent_examples") or [],
                "notes": [
                    "Treat each delegated rejection or unusable reply as a local prompt-contract failure.",
                    "Digest salvageable commands, file paths, and excerpts before retrying.",
                ],
            })

    if agent_lessons and agent_lessons.get("available"):
        promote_candidates = [
            item for item in (agent_lessons.get("candidates") or [])
            if (
                isinstance(item, dict)
                and str(item.get("state") or "") == "promote"
                and str(item.get("registry_state") or "pending_review") == "pending_review"
            )
        ]
        if promote_candidates:
            top = promote_candidates[0]
            actions.append({
                "type": "lesson",
                "action": "review_agent_lesson",
                "reason": f"{top.get('hint_id')}:{top.get('materialization')}:{top.get('event_count')}",
                "safe": True,
                "confidence": float(top.get("confidence", 0.0) or 0.0),
                "lesson_key": top.get("lesson_key"),
                "scope": top.get("scope"),
                "materialization": top.get("materialization"),
                "validation": "scripts/ai/aq-report --format json | jq '.agent_lessons'",
            })

    if historical_hint_watch and historical_hint_watch.get("available") and historical_hint_watch.get("has_items"):
        actions.append({
            "type": "hints",
            "action": "rotate_hint_alternates",
            "reason": (
                f"historical_hint_concentration={historical_hint_watch.get('dominant_hint_id')}:"
                f"{historical_hint_watch.get('dominant_share_pct')}"
            ),
            "safe": True,
            "confidence": 0.66,
            "dominant_hint_id": historical_hint_watch.get("dominant_hint_id"),
            "alternate_hint_ids": _historical_hint_alternate_ids(historical_hint_watch),
            "validation": "scripts/ai/aq-report --format json | jq '.historical_hint_watchlist'",
        })

    remediation_candidates = (gap_remediation or {}).get("candidates") or []
    for candidate in remediation_candidates[:3]:
        if not isinstance(candidate, dict):
            continue
        topic = str(candidate.get("topic", "") or "").strip()
        strategy = str(candidate.get("strategy", "import_knowledge") or "import_knowledge")
        if not topic:
            continue
        actions.append({
            "type": "gap_remediation",
            "action": "remediate_gap",
            "reason": (
                f"strategy={strategy} occurrences={candidate.get('occurrences', 0)} "
                f"reason={candidate.get('reason', 'unknown')}"
            ),
            "safe": not bool(candidate.get("requires_approval")),
            "confidence": min(1.0, int(candidate.get("occurrences", 1) or 1) / 5),
            "topic": topic[:80],
            "strategy": strategy,
            "estimated_effort": candidate.get("estimated_effort"),
            "requires_approval": bool(candidate.get("requires_approval")),
            "validation": "scripts/ai/aq-report --format json | jq '.gap_remediation'",
        })

    if eval_trend.get("available") and eval_trend.get("trend") == "falling":
        actions.append({
            "type": "eval",
            "action": "run_targeted_eval",
            "reason": "eval_score_falling latest=" + str(eval_trend.get("latest_pct")) + "%",
            "safe": True,
            "confidence": 0.9,
            "script": "scripts/automation/run-eval.sh",
            "script_args": ["--full", "--strategy", "eval-regression-check"],
            "source": str(eval_trend.get("source", "unknown") or "unknown"),
            "runs": int(eval_trend.get("n_runs", 0) or 0),
            "message": (
                "Eval trend falling: " + str(eval_trend.get("latest_pct")) + "% "
                "(mean " + str(eval_trend.get("mean_pct")) + "%). "
                "Run: scripts/automation/run-eval.sh --full --strategy eval-regression-check"
            ),
        })

    return actions


