                lines.append(f"  Patch reviews: accepted={patch_accepted} rejected={patch_rejected}")
            patch_agents = intent_compliance.get("patch_reviews_by_reviewed_agent", [])
            if patch_agents:
                lines.append(f"  Patch-reviewed agents: {', '.join(f'{agent}({count})' for agent, count in patch_agents[:3])}")
            accepted_task_classes = intent_compliance.get("accepted_task_classes", [])
            if accepted_task_classes:
                lines.append(f"  Accepted task classes: {', '.join(f'{task_class}({count})' for task_class, count in accepted_task_classes[:3])}")
            accepted_profiles = intent_compliance.get("accepted_by_reviewed_profile", [])
            if accepted_profiles:
                lines.append(f"  Accepted by reviewed profile: {', '.join(f'{profile}({count})' for profile, count in accepted_profiles[:3])}")
    else:
        lines.append("  Workflow session store unavailable.")
    lines.append("")

    lines += ["[ 12. Tool Security Auditor ]"]
    if security_auditor and security_auditor.get("available"):
        events = int(security_auditor.get("events", 0) or 0)
        if events == 0:
            lines.append("  No tool-security auditor decisions in this window.")
        else:
            lines += [
                f"  Decisions: {events}",
                f"  Approved: {security_auditor.get('approved', 0)}",
                f"  Blocked: {security_auditor.get('blocked', 0)}",
                f"  Cache hits: {security_auditor.get('cache_hits', 0)}  ({_na(security_auditor.get('cache_hit_pct'), '.1f', '%')})",
                f"  First-seen audits: {security_auditor.get('first_seen', 0)}",
            ]
    else:
        lines.append("  Tool-security auditor metrics unavailable.")
    lines.append("")

    lines += ["[ 13. Semantic Tooling Autorun ]"]
    if semantic_autorun and semantic_autorun.get("available"):
        route_calls = int(semantic_autorun.get("route_calls", 0) or 0)
        if route_calls == 0:
            lines.append("  No route_search traffic in this window.")
        else:
            lines += [
                f"  Route calls: {route_calls}",
                f"  Route calls with metadata: {semantic_autorun.get('with_metadata', 0)}",
                f"  Autorun enabled: {semantic_autorun.get('autorun_enabled_calls', 0)}"
                f"  ({_na(semantic_autorun.get('autorun_enabled_pct'), '.1f', '%')})",
                f"  Avg planned tools/call: {semantic_autorun.get('avg_planned_tools', 0.0)}",
                f"  Avg executed tools/call: {semantic_autorun.get('avg_executed_tools', 0.0)}",
                f"  Security blocks during autorun: {semantic_autorun.get('tool_security_blocked_total', 0)}",
            ]
    else:
        lines.append("  Semantic autorun metrics unavailable.")
    lines.append("")

    lines += ["[ 14. Hint Diversity ]"]
    if hint_diversity_stats and hint_diversity_stats.get("available"):
        total_injections = int(hint_diversity_stats.get("total_injections", 0) or 0)
        if total_injections == 0:
            lines.append("  No hint-injection activity in this window.")
        else:
            lines += [
                f"  Total injections: {total_injections}",
                f"  Unique hint IDs: {hint_diversity_stats.get('unique_hints', 0)}",
                f"  Dominant share: {_na(hint_diversity_stats.get('dominant_share_pct'), '.1f', '%')}",
                f"  Normalized entropy: {_na(hint_diversity_stats.get('normalized_entropy_pct'), '.1f', '%')}",
                f"  Effective hints: {_na(hint_diversity_stats.get('effective_hints'), '.2f')}",
                f"  Status: {hint_diversity_stats.get('status', 'unknown')}",
            ]
            if hint_diversity_stats.get("dominant_hint_id"):
                lines.append(f"  Dominant hint ID: {hint_diversity_stats.get('dominant_hint_id')}")
            if str(hint_diversity_stats.get("status", "")).lower() == "concentrated":
                lines.append("  Monitoring note: hint selection is concentrated; add alternative high-signal hints or stronger feedback rotation.")
            lines.append(f"  Recent context: {_hint_diversity_recent_context(recent_hint_diversity_stats)}")
    else:
        lines.append("  Hint-diversity metrics unavailable.")
    lines.append("")

    lines += [f"[ 14b. Historical Hint Watchlist ({(historical_hint_watch or {}).get('window', '7d')}) ]"]
    if not historical_hint_watch or not historical_hint_watch.get("has_items"):
        lines.append("  No historical hint concentration issues outside the recent window.")
    else:
        lines.append(
            f"  Dominant hint: {historical_hint_watch.get('dominant_hint_id')} "
            f"at {_na(historical_hint_watch.get('dominant_share_pct'), '.1f', '%')} "
            f"across {historical_hint_watch.get('total_injections', 0)} injections"
        )
        alternatives = historical_hint_watch.get("alternative_hints") or []
        if alternatives:
            alt_text = ", ".join(
                f"{item.get('hint_id')} ({item.get('count', 0)})"
                for item in alternatives[:2]
                if item.get("hint_id")
            )
            if alt_text:
                lines.append(f"  Candidate alternates: {alt_text}")
                lines.append("  Next action: rotate one alternate hint into the next steering batch before repeating the dominant hint.")
        lines.append("  Status: historical concentration only; diversify future high-signal hints before this becomes active again.")
    lines.append("")

    lines += ["[ 14c. Agent Lesson Promotion Candidates ]"]
    lesson_candidates = (agent_lessons or {}).get("candidates") or []
    lesson_registry = (agent_lessons or {}).get("registry") or {}
    if not lesson_candidates:
        lines.append("  No cross-agent lesson candidates met the promotion threshold in this window.")
    else:
        for item in lesson_candidates[:3]:
            lines.append(f"  {_format_agent_lesson_candidate(item)}")
            comments = item.get("comments") or []
            if comments:
                lines.append(f"    Example feedback: {comments[0]}")
    if lesson_registry.get("available"):
        counts = lesson_registry.get("counts") or {}
        lines.append(
            "  Registry: "
            f"pending={counts.get('pending_review', 0)} "
            f"promoted={counts.get('promoted', 0)} "
            f"avoided={counts.get('avoided', 0)} "
            f"rejected={counts.get('rejected', 0)}"
        )
    lines += ["", sep]
    return "\n".join(lines)


