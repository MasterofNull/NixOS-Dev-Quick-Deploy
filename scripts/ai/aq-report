                    lines.append(f"    {count:3d}x  {hid}")
            if tooling_quality and int(tooling_quality.get("total", 0) or 0) > 0:
                lines += [
                    f"  Aider task success (all): {tooling_quality.get('success', 0)}/{tooling_quality.get('total', 0)}"
                    f" ({_na(tooling_quality.get('success_pct'), '.1f', '%')})",
                    f"  Tooling-plan injected: {tooling_quality.get('plan_success', 0)}/{tooling_quality.get('plan_total', 0)}"
