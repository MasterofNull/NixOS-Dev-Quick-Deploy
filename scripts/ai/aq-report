def _task_tooling_from_hint_adoption(adoption: Optional[Dict[str, Any]]) -> Dict[str, Any]:
    if not isinstance(adoption, dict):
        return {"available": True, "total": 0}
    plan_total = int(adoption.get("tooling_plan_total", 0) or 0)
    plan_success = int(adoption.get("tooling_plan_success", 0) or 0)
    if plan_total <= 0:
        return {"available": True, "total": 0}
    return {
        "available": True,
        "source": "hint_adoption_fallback",
        "total": plan_total,
        "success": plan_success,
        "success_pct": round(100 * plan_success / plan_total, 1) if plan_total else None,
        "plan_total": plan_total,
        "plan_success": plan_success,
        "plan_success_pct": round(100 * plan_success / plan_total, 1) if plan_total else None,
        "baseline_total": 0,
        "baseline_success": 0,
        "baseline_success_pct": None,
    }


def task_tooling_quality(since: datetime, adoption: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
    """Read aider task audit and compare injected-plan success vs baseline."""
    task_path = _task_audit_path()
    if not task_path:
        return _task_tooling_from_hint_adoption(adoption)

    total = 0
    success = 0
    plan_total = 0
    plan_success = 0
    baseline_total = 0
    baseline_success = 0
    try:
        with task_path.open(encoding="utf-8", errors="replace") as fh:
            for line in fh:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                except json.JSONDecodeError:
                    continue
                ts_raw = entry.get("timestamp", "")
                try:
                    ts = datetime.fromisoformat(ts_raw.rstrip("Z")).replace(tzinfo=timezone.utc)
                    if ts < since:
                        continue
                except (ValueError, AttributeError):
                    continue
                total += 1
                ok = bool(entry.get("status") == "success")
                if ok:
                    success += 1
                if bool(entry.get("tooling_plan_injected", False)):
                    plan_total += 1
                    if ok:
                        plan_success += 1
                else:
                    baseline_total += 1
                    if ok:
                        baseline_success += 1
    except OSError:
        return _task_tooling_from_hint_adoption(adoption)

    if total == 0:
        return _task_tooling_from_hint_adoption(adoption)

    return {
        "available": True,
        "total": total,
        "success": success,
        "success_pct": round(100 * success / total, 1) if total else None,
        "plan_total": plan_total,
        "plan_success": plan_success,
        "plan_success_pct": round(100 * plan_success / plan_total, 1) if plan_total else None,
        "baseline_total": baseline_total,
        "baseline_success": baseline_success,
        "baseline_success_pct": round(100 * baseline_success / baseline_total, 1) if baseline_total else None,
    }


