def _normalize_gap_text(query_text: str) -> str:
    return re.sub(r"[^a-z0-9]+", " ", (query_text or "").strip().lower()).strip()


def _is_curated_stale_gap(query_text: str) -> bool:
    normalized = _normalize_gap_text(query_text)
    if not normalized:
        return True
    return any(pattern in normalized for pattern in _CURATED_STALE_GAP_PATTERNS)


def _count_aidb_docs_for_topic(topic: str) -> int:
    """Return count of imported_documents whose title matches the topic keyword."""
    host, port, db, user, password = _pg_creds()
    keyword = topic[:40].replace("'", "''")
    query = f"SELECT COUNT(*) FROM imported_documents WHERE title ILIKE '%{keyword}%';"
    dsn = f"postgresql://{user}:{password}@{host}:{port}/{db}"
    try:
        import psycopg  # type: ignore[import-untyped]
        conn = psycopg.connect(dsn, connect_timeout=3)
        cur = conn.execute(
            "SELECT COUNT(*) FROM imported_documents WHERE title ILIKE %s",
            (f"%{topic[:40]}%",),
        )
        count = cur.fetchone()[0]
        conn.close()
        return int(count)
    except ImportError:
        pass
    except Exception:
        return 0
    import subprocess
    try:
        result = subprocess.run(
            ["psql", dsn, "--tuples-only", "--no-align", "--command", query],
            capture_output=True, text=True, timeout=5,
        )
        line = result.stdout.strip()
        return int(line) if line.isdigit() else 0
    except Exception:
        return 0


def _cache_recommendation_actionable(cache: Dict[str, Any]) -> bool:
    if not cache.get("available"):
        return False
    hit_pct = cache.get("hit_pct")
    if hit_pct is None or float(hit_pct) >= 50:
        return False
    total = int(cache.get("hits", 0) or 0) + int(cache.get("misses", 0) or 0)
    return total >= 100


def hint_adoption(since: datetime) -> Dict[str, Any]:
    """Phase 19.3.4 — read hint-audit.jsonl and compute adoption stats.

    'Adoption' = the aider task that received an injected hint completed
    successfully (returncode 0 + at least one file modified).
    """
    hint_path = _hint_audit_path()
    if not hint_path:
        # File not yet written — normal on a fresh deploy; treat as zero activity
        return {"available": True, "total": 0, "accepted": 0, "adoption_pct": None, "top_hints": []}
    total = 0
    accepted = 0
    tooling_plan_total = 0
    tooling_plan_success = 0
    analysis_profile_total = 0
    analysis_profile_success = 0
    top_hints: Dict[str, int] = {}
    try:
        with hint_path.open(encoding="utf-8", errors="replace") as fh:
            for line in fh:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                except json.JSONDecodeError:
                    continue
                ts_raw = entry.get("timestamp", "")
                try:
                    ts = datetime.fromisoformat(ts_raw.rstrip("Z")).replace(tzinfo=timezone.utc)
                    if ts < since:
                        continue
                except (ValueError, AttributeError):
                    continue
                total += 1
                if entry.get("hint_accepted"):
                    accepted += 1
                if bool(entry.get("tooling_plan_injected", False)):
                    tooling_plan_total += 1
                    if entry.get("hint_accepted"):
                        tooling_plan_success += 1
                if bool(entry.get("analysis_only_profile", False)):
                    analysis_profile_total += 1
                    if entry.get("hint_accepted"):
                        analysis_profile_success += 1
                hid = entry.get("hint_id", "unknown")
                top_hints[hid] = top_hints.get(hid, 0) + 1
    except OSError:
        # File not yet created — normal on a fresh deploy; treat as zero activity
        return {"available": True, "total": 0, "accepted": 0, "adoption_pct": None, "top_hints": []}
    if total == 0:
        return {"available": True, "total": 0, "accepted": 0, "adoption_pct": None, "top_hints": []}
    sorted_hints = sorted(top_hints.items(), key=lambda x: -x[1])
    unique_hints = len(sorted_hints)
    dominant_hint_id = sorted_hints[0][0] if sorted_hints else None
    dominant_hint_count = int(sorted_hints[0][1]) if sorted_hints else 0
    dominant_share_pct = round(100 * dominant_hint_count / total, 1) if total else None
    entropy_bits = 0.0
    for _, count in sorted_hints:
        if count <= 0:
            continue
        prob = count / total
        entropy_bits += -prob * math.log2(prob)
    max_entropy_bits = math.log2(unique_hints) if unique_hints > 1 else 0.0
    normalized_entropy_pct = (
        round(100 * entropy_bits / max_entropy_bits, 1) if max_entropy_bits > 0 else (0.0 if unique_hints == 1 else None)
    )
    effective_hints = round(2 ** entropy_bits, 2) if total else None
    return {
        "available": True,
        "total": total,
        "accepted": accepted,
        "adoption_pct": round(100 * accepted / total, 1),
        "tooling_plan_total": tooling_plan_total,
        "tooling_plan_success": tooling_plan_success,
        "tooling_plan_success_pct": round(100 * tooling_plan_success / tooling_plan_total, 1) if tooling_plan_total else None,
        "analysis_profile_total": analysis_profile_total,
        "analysis_profile_success": analysis_profile_success,
        "analysis_profile_success_pct": round(100 * analysis_profile_success / analysis_profile_total, 1) if analysis_profile_total else None,
        "top_hints": sorted_hints[:5],
        "unique_hints": unique_hints,
        "dominant_hint_id": dominant_hint_id,
        "dominant_hint_count": dominant_hint_count,
        "dominant_share_pct": dominant_share_pct,
        "entropy_bits": round(entropy_bits, 3),
        "normalized_entropy_pct": normalized_entropy_pct,
        "effective_hints": effective_hints,
    }


def agent_lesson_candidates(since: datetime) -> Dict[str, Any]:
    """Promote repeated agent feedback into compact reusable lesson candidates."""
    if not HINT_FEEDBACK_PATH.exists():
        return {"available": True, "total_events": 0, "candidates": []}

    def _lesson_scope(hint_id: str, preferred_tags: List[str]) -> str:
        text = " ".join([hint_id] + list(preferred_tags or [])).lower()
        if any(token in text for token in ("plan", "orchestrat", "workflow", "intent")):
            return "planning_orchestration"
        if any(token in text for token in ("implement", "patch", "code", "refactor", "debug")):
            return "implementation"
        if any(token in text for token in ("review", "risk", "policy", "reasoning", "tradeoff")):
            return "review"
        if any(token in text for token in ("retrieval", "rag", "research", "route_search", "memory")):
            return "retrieval_research"
        if any(token in text for token in ("deploy", "systemd", "runtime", "service", "nixos", "remediate")):
            return "operational_remediation"
        return "general"

    def _lesson_materialization(direction: str, event_count: int, confidence: float, preferred_tools: List[str]) -> str:
        if direction == "avoid":
            return "reject_noise"
        if event_count >= 5 and confidence >= 0.75 and preferred_tools:
            return "skill_draft"
        if event_count >= 3 and confidence >= 0.6:
            return "quick_reference"
        return "hint_only"

    def _lesson_traceability(hint_id: str, agent: str, materialization: str) -> Dict[str, Any]:
        targets = ["hint"]
        if materialization in {"quick_reference", "skill_draft"}:
            targets.append("reference")
        if materialization == "skill_draft":
            targets.append("skill_registry")
        return {
            "source_type": "hint_feedback",
            "source_agent": agent,
            "source_hint_id": hint_id,
            "targets": targets,
        }

    grouped: Dict[Tuple[str, str], Dict[str, Any]] = {}
    total_events = 0
    try:
        with HINT_FEEDBACK_PATH.open(encoding="utf-8", errors="replace") as fh:
            for line in fh:
                line = line.strip()
                if not line:
                    continue
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError:
                    continue
                ts_raw = obj.get("timestamp", "")
                try:
                    ts = datetime.fromisoformat(str(ts_raw).rstrip("Z")).replace(tzinfo=timezone.utc)
                    if ts < since:
                        continue
                except (ValueError, TypeError, AttributeError):
                    continue
                hint_id = str(obj.get("hint_id", "") or "").strip()
                agent = str(obj.get("agent", "") or "unknown").strip().lower() or "unknown"
                if (
                    not hint_id
                    or agent in AGENT_LESSON_EXCLUDED_AGENTS
                    or any(hint_id.lower().startswith(prefix) for prefix in AGENT_LESSON_EXCLUDED_HINT_PREFIXES)
                ):
                    continue
                helpful_raw = obj.get("helpful")
                helpful = helpful_raw if isinstance(helpful_raw, bool) else None
                score_raw = obj.get("score")
                score_val: Optional[float] = None
                if score_raw is not None:
                    try:
                        score_val = float(score_raw)
                    except (TypeError, ValueError):
                        score_val = None
                comment = str(obj.get("comment", "") or "").strip()
                prefs = obj.get("agent_preferences", {})
                if not isinstance(prefs, dict):
                    prefs = {}
                row = grouped.setdefault((agent, hint_id), {
                    "agent": agent,
                    "hint_id": hint_id,
                    "positive": 0,
                    "negative": 0,
                    "comments": [],
                    "preferred_tools": [],
                    "preferred_tags": [],
                })
                total_events += 1
                if helpful is True or (score_val is not None and score_val > 0):
                    row["positive"] += 1
                elif helpful is False or (score_val is not None and score_val < 0):
                    row["negative"] += 1
                if comment and len(row["comments"]) < 2:
                    row["comments"].append(comment[:140])
                for key in ("preferred_tools", "preferred_tags"):
                    vals = prefs.get(key)
                    if isinstance(vals, list):
                        for item in vals:
                            text = str(item or "").strip().lower()
                            if text and text not in row[key]:
                                row[key].append(text[:48])
                                if len(row[key]) >= 3:
                                    break
        candidates: List[Dict[str, Any]] = []
        for row in grouped.values():
            positive = int(row["positive"])
            negative = int(row["negative"])
            total = positive + negative
            if total < 2:
                continue
            net = positive - negative
            if net >= 2:
                direction = "promote"
            elif net <= -2:
                direction = "avoid"
            else:
                continue
            confidence = round(abs(net) / total, 2)
            materialization = _lesson_materialization(direction, total, confidence, row["preferred_tools"])
            candidates.append({
                "agent": row["agent"],
                "hint_id": row["hint_id"],
                "direction": direction,
                "state": direction,
                "scope": _lesson_scope(str(row["hint_id"]), row["preferred_tags"]),
                "net_signal": net,
                "event_count": total,
                "evidence_count": total,
                "confidence": confidence,
                "materialization": materialization,
                "validation_link": "scripts/ai/aq-report --format json | jq '.agent_lessons'",
                "traceability": _lesson_traceability(str(row["hint_id"]), str(row["agent"]), materialization),
                "comments": row["comments"],
                "preferred_tools": row["preferred_tools"],
                "preferred_tags": row["preferred_tags"],
            })
        candidates.sort(key=lambda item: (-abs(int(item["net_signal"])), -int(item["event_count"]), item["hint_id"]))
        return {
            "available": True,
            "total_events": total_events,
            "candidates": candidates[:5],
        }
    except OSError:
        return {"available": True, "total_events": 0, "candidates": []}


def _agent_lesson_key(agent: str, hint_id: str, direction: str) -> str:
    return "::".join(
        [
            re.sub(r"[^a-z0-9]+", "-", str(agent or "").strip().lower()).strip("-") or "unknown",
            re.sub(r"[^a-z0-9]+", "-", str(hint_id or "").strip().lower()).strip("-") or "unknown",
            re.sub(r"[^a-z0-9]+", "-", str(direction or "").strip().lower()).strip("-") or "pending",
        ]
    )


def _default_agent_lesson_registry() -> Dict[str, Any]:
    return {
        "available": True,
        "path": str(AGENT_LESSON_REGISTRY_PATH),
        "entries": [],
        "counts": {
            "total": 0,
            "pending_review": 0,
            "promoted": 0,
            "avoided": 0,
            "rejected": 0,
        },
        "active_lessons": [],
    }


def _load_agent_lesson_registry() -> Dict[str, Any]:
    registry = _default_agent_lesson_registry()
    if not AGENT_LESSON_REGISTRY_PATH.exists():
        return registry
    try:
        data = json.loads(AGENT_LESSON_REGISTRY_PATH.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return registry
    if not isinstance(data, dict):
        return registry
    entries = data.get("entries")
    if isinstance(entries, list):
        registry["entries"] = [item for item in entries if isinstance(item, dict)]
    return registry


def _compute_agent_lesson_registry_summary(registry: Dict[str, Any]) -> Dict[str, Any]:
    entries = [item for item in (registry.get("entries") or []) if isinstance(item, dict)]
    counts = {
        "total": len(entries),
        "pending_review": 0,
        "promoted": 0,
        "avoided": 0,
        "rejected": 0,
    }
    active_lessons: List[Dict[str, Any]] = []
    for item in entries:
        state = str(item.get("state", "") or "").strip().lower()
        if state in counts:
            counts[state] += 1
        if state in {"promoted", "avoided"}:
            active_lessons.append({
                "lesson_key": item.get("lesson_key"),
                "agent": item.get("agent"),
                "hint_id": item.get("hint_id"),
                "state": state,
                "scope": item.get("scope"),
                "materialization": item.get("materialization"),
                "updated_at": item.get("updated_at"),
            })
    active_lessons.sort(
        key=lambda item: (
            str(item.get("state") or ""),
            str(item.get("agent") or ""),
            str(item.get("hint_id") or ""),
        )
    )
    registry["counts"] = counts
    registry["active_lessons"] = active_lessons[:10]
    registry["available"] = True
    registry["path"] = str(AGENT_LESSON_REGISTRY_PATH)
    return registry


def sync_agent_lesson_registry(agent_lessons: Dict[str, Any], now: Optional[datetime] = None) -> Dict[str, Any]:
    registry = _load_agent_lesson_registry()
    entries = [item for item in (registry.get("entries") or []) if isinstance(item, dict)]
    index: Dict[str, Dict[str, Any]] = {}
    for item in entries:
        lesson_key = str(item.get("lesson_key", "") or "").strip()
        if lesson_key:
            index[lesson_key] = item
    stamp = (now or datetime.now(tz=timezone.utc)).isoformat().replace("+00:00", "Z")
    changed = False
    for candidate in (agent_lessons.get("candidates") or []):
        if not isinstance(candidate, dict):
            continue
        lesson_key = _agent_lesson_key(
            str(candidate.get("agent", "") or ""),
            str(candidate.get("hint_id", "") or ""),
            str(candidate.get("direction", "") or ""),
        )
        existing = index.get(lesson_key)
        if existing is None:
            existing = {
                "lesson_key": lesson_key,
                "state": "pending_review",
                "first_seen_at": stamp,
            }
            entries.append(existing)
            index[lesson_key] = existing
            changed = True
        previous_snapshot = dict(existing)
        existing.update(
            {
                "lesson_key": lesson_key,
                "agent": candidate.get("agent"),
                "hint_id": candidate.get("hint_id"),
                "recommended_direction": candidate.get("direction"),
                "scope": candidate.get("scope"),
                "materialization": candidate.get("materialization"),
                "confidence": candidate.get("confidence"),
                "event_count": candidate.get("event_count"),
                "evidence_count": candidate.get("evidence_count"),
                "comments": candidate.get("comments") or [],
                "preferred_tools": candidate.get("preferred_tools") or [],
                "preferred_tags": candidate.get("preferred_tags") or [],
                "traceability": candidate.get("traceability") or {},
                "validation_link": candidate.get("validation_link"),
                "last_seen_at": stamp,
                "updated_at": stamp,
            }
        )
        if existing.get("state") not in {"pending_review", "promoted", "avoided", "rejected"}:
            existing["state"] = "pending_review"
        if existing != previous_snapshot:
            changed = True
        candidate["lesson_key"] = lesson_key
        candidate["registry_state"] = existing.get("state", "pending_review")
    entries.sort(
        key=lambda item: (
            str(item.get("state") or ""),
            str(item.get("agent") or ""),
            str(item.get("hint_id") or ""),
        )
    )
    registry["entries"] = entries
    registry = _compute_agent_lesson_registry_summary(registry)
    if changed or not AGENT_LESSON_REGISTRY_PATH.exists():
        try:
            AGENT_LESSON_REGISTRY_PATH.parent.mkdir(parents=True, exist_ok=True)
            AGENT_LESSON_REGISTRY_PATH.write_text(json.dumps(registry, indent=2) + "\n", encoding="utf-8")
        except OSError:
            registry["write_failed"] = True
    return registry


def hint_diversity(adoption: Optional[Dict[str, Any]]) -> Dict[str, Any]:
    """Compute concentration/diversity quality signals for injected hints."""
    if not adoption or not adoption.get("available"):
        return {"available": False}

    total = int(adoption.get("total", 0) or 0)
    if total == 0:
        return {
            "available": True,
            "total_injections": 0,
            "unique_hints": 0,
            "dominant_hint_id": None,
            "dominant_share_pct": None,
            "normalized_entropy_pct": None,
            "effective_hints": None,
            "status": "no_data",
        }

    unique_hints = int(adoption.get("unique_hints", 0) or 0)
    dominant_share_pct = adoption.get("dominant_share_pct")
    normalized_entropy_pct = adoption.get("normalized_entropy_pct")
    effective_hints = adoption.get("effective_hints")
    dominant_hint_id = adoption.get("dominant_hint_id")

    if total < 5:
        status = "low_sample"
    elif unique_hints <= 1:
        status = "monoculture"
    elif dominant_share_pct is not None and float(dominant_share_pct) >= 70:
        status = "highly_concentrated"
    elif dominant_share_pct is not None and float(dominant_share_pct) >= 50:
        status = "concentrated"
    elif (
        dominant_share_pct is not None
        and normalized_entropy_pct is not None
        and float(dominant_share_pct) < 50
        and float(normalized_entropy_pct) >= 60
    ):
        status = "balanced"
    elif normalized_entropy_pct is not None and float(normalized_entropy_pct) >= 75:
        status = "healthy"
    else:
        status = "mixed"

    return {
        "available": True,
        "total_injections": total,
        "unique_hints": unique_hints,
        "dominant_hint_id": dominant_hint_id,
        "dominant_share_pct": dominant_share_pct,
        "normalized_entropy_pct": normalized_entropy_pct,
        "effective_hints": effective_hints,
        "status": status,
    }


def _hint_diversity_recent_context(recent_hint_diversity: Optional[Dict[str, Any]]) -> str:
    if not recent_hint_diversity or not recent_hint_diversity.get("available"):
        return "Recent context unavailable."
    window = str(recent_hint_diversity.get("window", "1h") or "1h")
    total = int(recent_hint_diversity.get("total_injections", 0) or 0)
    if total <= 0:
        return f"no recent hint injections in the last {window}"
    status = str(recent_hint_diversity.get("status", "unknown") or "unknown")
    if status == "low_sample":
        return f"recent {window} hint diversity is low sample ({total} injection{'s' if total != 1 else ''})"
    dom = recent_hint_diversity.get("dominant_share_pct")
    if dom is None:
        return f"recent hint activity in the last {window}: status={status}"
    return f"recent {window} hint diversity is {status} (dominant share {float(dom):.1f}%)"


def _hint_adoption_recent_context(recent_hint_adoption: Optional[Dict[str, Any]]) -> str:
    if not recent_hint_adoption or not recent_hint_adoption.get("available"):
        return "Recent context unavailable."
    window = str(recent_hint_adoption.get("window", "1h") or "1h")
    total = int(recent_hint_adoption.get("total", 0) or 0)
    if total <= 0:
        return f"no recent hint-injected tasks in the last {window}"
    rate = recent_hint_adoption.get("adoption_pct")
    accepted = int(recent_hint_adoption.get("accepted", 0) or 0)
    return (
        f"recent {window} hint adoption is {_na(rate, '.1f', '%')} "
        f"across {accepted}/{total} hint-injected tasks"
    )


def historical_hint_watchlist(
    adoption: Optional[Dict[str, Any]],
    recent_hint_adoption: Optional[Dict[str, Any]],
    hint_diversity_stats: Optional[Dict[str, Any]],
    recent_hint_diversity_stats: Optional[Dict[str, Any]],
) -> Dict[str, Any]:
    """Summarize concentrated hint patterns that are visible historically but not recently active."""
    watch: Dict[str, Any] = {
        "available": True,
        "window": "7d",
        "has_items": False,
        "dominant_hint_id": None,
        "dominant_share_pct": None,
        "total_injections": 0,
        "alternative_hints": [],
    }
    if not adoption or not adoption.get("available"):
        return watch
    total = int(adoption.get("total", 0) or 0)
    recent_total = int((recent_hint_adoption or {}).get("total", 0) or 0)
    status = str((hint_diversity_stats or {}).get("status", "") or "").strip().lower()
    recent_status = str((recent_hint_diversity_stats or {}).get("status", "") or "").strip().lower()
    dominant_hint_id = adoption.get("dominant_hint_id")
    dominant_share_pct = adoption.get("dominant_share_pct")
    top_hints = adoption.get("top_hints") if isinstance(adoption.get("top_hints"), list) else []
    alternatives: List[Dict[str, Any]] = []
    for item in top_hints[1:3]:
        if not isinstance(item, (list, tuple)) or len(item) < 2:
            continue
        hint_id = str(item[0]).strip()
        count = int(item[1] or 0)
        if hint_id:
            alternatives.append({"hint_id": hint_id, "count": count})
    if total <= 0 or recent_total > 0:
        return watch
    if status not in {"concentrated", "narrow"} and recent_status not in {"no_data", ""}:
        return watch
    if dominant_share_pct is None or float(dominant_share_pct) < 50.0:
        return watch
    watch.update(
        {
            "has_items": True,
            "dominant_hint_id": dominant_hint_id,
            "dominant_share_pct": dominant_share_pct,
            "total_injections": total,
            "alternative_hints": alternatives,
        }
    )
    return watch


def _historical_hint_alternate_ids(historical_hint_watch: Optional[Dict[str, Any]]) -> List[str]:
    if not historical_hint_watch or not historical_hint_watch.get("has_items"):
        return []
    alternatives = historical_hint_watch.get("alternative_hints") or []
    return [
        str(item.get("hint_id", "")).strip()
        for item in alternatives[:2]
        if isinstance(item, dict) and str(item.get("hint_id", "")).strip()
    ]


def _format_agent_lesson_candidate(candidate: Dict[str, Any]) -> str:
    tools = candidate.get("preferred_tools") or []
    tool_suffix = f"; tools={','.join(str(t) for t in tools[:2])}" if tools else ""
    registry_state = str(candidate.get("registry_state", "") or "").strip()
    state_suffix = f"; registry={registry_state}" if registry_state else ""
    return (
        f"{candidate.get('agent')}:{candidate.get('direction')} {candidate.get('hint_id')} "
        f"(events={candidate.get('event_count')}, confidence={candidate.get('confidence')})"
        f"{tool_suffix}{state_suffix}"
    )


def _routing_recent_context(recent_route: Optional[Dict[str, Any]]) -> str:
    if not recent_route or not recent_route.get("available"):
        return "Recent context unavailable."
    window = str(recent_route.get("window", "1h") or "1h")
    local_n = int(recent_route.get("local_n", 0) or 0)
    remote_n = int(recent_route.get("remote_n", 0) or 0)
    total = local_n + remote_n
    if total <= 0:
        return f"no recent route_search traffic in the last {window}"
    return (
        f"recent {window} routing: local={local_n} remote={remote_n} "
        f"({_na(recent_route.get('local_pct'), '.1f', '%')} local)"
    )


def _cache_sample_context(cache: Optional[Dict[str, Any]]) -> Optional[str]:
    if not cache or not cache.get("available"):
        return None
    hits = int(cache.get("hits", 0) or 0)
    misses = int(cache.get("misses", 0) or 0)
    total = hits + misses
    if total == 0:
        return "no cache samples collected in this window"
    if total < 100:
        return f"low sample ({hits}/{total} hits)"
    return None


def _task_tooling_from_hint_adoption(adoption: Optional[Dict[str, Any]]) -> Dict[str, Any]:
    if not isinstance(adoption, dict):
        return {"available": True, "total": 0}
    plan_total = int(adoption.get("tooling_plan_total", 0) or 0)
    plan_success = int(adoption.get("tooling_plan_success", 0) or 0)
    if plan_total <= 0:
        return {"available": True, "total": 0}
    return {
        "available": True,
        "source": "hint_adoption_fallback",
        "total": plan_total,
        "success": plan_success,
        "success_pct": round(100 * plan_success / plan_total, 1) if plan_total else None,
        "plan_total": plan_total,
        "plan_success": plan_success,
        "plan_success_pct": round(100 * plan_success / plan_total, 1) if plan_total else None,
        "baseline_total": 0,
        "baseline_success": 0,
        "baseline_success_pct": None,
    }


def task_tooling_quality(since: datetime, adoption: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
    """Read aider task audit and compare injected-plan success vs baseline."""
    task_path = _task_audit_path()
    if not task_path:
        return _task_tooling_from_hint_adoption(adoption)

    total = 0
    success = 0
    plan_total = 0
    plan_success = 0
    baseline_total = 0
    baseline_success = 0
    try:
        with task_path.open(encoding="utf-8", errors="replace") as fh:
            for line in fh:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                except json.JSONDecodeError:
                    continue
                ts_raw = entry.get("timestamp", "")
                try:
                    ts = datetime.fromisoformat(ts_raw.rstrip("Z")).replace(tzinfo=timezone.utc)
                    if ts < since:
                        continue
                except (ValueError, AttributeError):
                    continue
                total += 1
                ok = bool(entry.get("status") == "success")
                if ok:
                    success += 1
                if bool(entry.get("tooling_plan_injected", False)):
                    plan_total += 1
                    if ok:
                        plan_success += 1
                else:
                    baseline_total += 1
                    if ok:
                        baseline_success += 1
    except OSError:
        return _task_tooling_from_hint_adoption(adoption)

    if total == 0:
        return _task_tooling_from_hint_adoption(adoption)

    return {
        "available": True,
        "total": total,
        "success": success,
        "success_pct": round(100 * success / total, 1) if total else None,
        "plan_total": plan_total,
        "plan_success": plan_success,
        "plan_success_pct": round(100 * plan_success / plan_total, 1) if plan_total else None,
        "baseline_total": baseline_total,
        "baseline_success": baseline_success,
        "baseline_success_pct": round(100 * baseline_success / baseline_total, 1) if baseline_total else None,
    }


