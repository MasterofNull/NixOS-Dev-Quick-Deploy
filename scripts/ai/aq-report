def read_tool_audit(since: datetime) -> List[dict]:
    """Read tool_audit.jsonl entries newer than `since`."""
    path = _tool_audit_path()
    if not path:
        return []
    entries = []
    try:
        with path.open(encoding="utf-8", errors="replace") as fh:
            for line in fh:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                except json.JSONDecodeError:
                    continue
                ts_raw = entry.get("timestamp", "")
                try:
                    ts = datetime.fromisoformat(ts_raw.rstrip("Z")).replace(tzinfo=timezone.utc)
                    if ts >= since:
                        entries.append(entry)
                except (ValueError, AttributeError):
                    continue
    except OSError:
        pass
    return entries


def read_delegation_feedback(since: datetime) -> Dict[str, Any]:
    path = _delegation_feedback_path()
    if not path:
        return {"available": False, "source": str(DELEGATION_FEEDBACK_PATH)}
    entries: List[Dict[str, Any]] = []
    try:
        with path.open(encoding="utf-8", errors="replace") as fh:
            for line in fh:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                except json.JSONDecodeError:
                    continue
                ts = _entry_ts_utc(entry)
                if ts is None or ts < since:
                    continue
                entries.append(entry)
    except OSError:
        return {"available": False, "source": str(path)}
    return {"available": True, "source": str(path), "entries": entries}


def aggregate_delegation_feedback(data: Dict[str, Any]) -> Dict[str, Any]:
    if not data.get("available"):
        return {"available": False, "source": data.get("source")}

    entries = data.get("entries") if isinstance(data.get("entries"), list) else []
    if not entries:
        return {
            "available": True,
            "source": data.get("source"),
            "total_failures": 0,
            "recovered_failures": 0,
            "salvageable_failures": 0,
            "top_failure_classes": [],
            "top_profiles": [],
            "recent_examples": [],
        }

    failure_counts: Dict[str, int] = {}
    profile_counts: Dict[str, int] = {}
    recovered = 0
    salvageable = 0
    examples: List[Dict[str, Any]] = []
    for entry in entries:
        if not isinstance(entry, dict):
            continue
        primary = str(entry.get("failure_class", "") or "").strip()
        if primary:
            failure_counts[primary] = failure_counts.get(primary, 0) + 1
        profile = str(entry.get("selected_profile", "") or "").strip()
        if profile:
            profile_counts[profile] = profile_counts.get(profile, 0) + 1
        if bool(entry.get("fallback_applied")):
            recovered += 1
        salvage = entry.get("salvage") if isinstance(entry.get("salvage"), dict) else {}
        if bool(salvage.get("has_useful_data")):
            salvageable += 1
        if len(examples) < 3:
            examples.append(
                {
                    "timestamp": entry.get("timestamp"),
                    "failure_class": primary,
                    "selected_profile": profile,
                    "failure_stage": entry.get("failure_stage"),
                    "task_excerpt": str(entry.get("task_excerpt", "") or "")[:140],
                    "response_preview": str(entry.get("response_preview", "") or "")[:180],
                    "improvement_actions": entry.get("improvement_actions") or [],
                    "salvage": salvage,
                }
            )

    return {
        "available": True,
        "source": data.get("source"),
        "total_failures": len(entries),
        "recovered_failures": recovered,
        "salvageable_failures": salvageable,
        "salvageable_pct": round(100 * salvageable / len(entries), 1) if entries else None,
        "top_failure_classes": sorted(failure_counts.items(), key=lambda item: (-item[1], item[0]))[:5],
        "top_profiles": sorted(profile_counts.items(), key=lambda item: (-item[1], item[0]))[:5],
        "recent_examples": examples,
    }


def delegated_prompt_failure_windows(
    data: Dict[str, Any],
    *,
    now: datetime,
    report_since: datetime,
) -> Dict[str, Any]:
    """Materialize comparable delegated prompt-failure windows."""
    entries = data.get("entries") if isinstance(data.get("entries"), list) else []
    windows = [
        ("1h", timedelta(hours=1)),
        ("24h", timedelta(hours=24)),
        ("7d", timedelta(days=7)),
    ]
    summaries: Dict[str, Any] = {}
    for label, delta in windows:
        cutoff = now - delta
        summaries[label] = aggregate_delegation_feedback(
            {
                "available": data.get("available", False),
                "source": data.get("source"),
                "entries": [
                    entry for entry in entries
                    if (_entry_ts_utc(entry) or datetime.min.replace(tzinfo=timezone.utc)) >= cutoff
                ],
            }
        )
        summaries[label]["partial_window"] = report_since > cutoff
    one_h = summaries.get("1h") if isinstance(summaries.get("1h"), dict) else {}
    twenty_four_h = summaries.get("24h") if isinstance(summaries.get("24h"), dict) else {}
    recent_failures = int(one_h.get("total_failures", 0) or 0)
    daily_failures = int(twenty_four_h.get("total_failures", 0) or 0)
    trend_status = "historical"
    trend_actions: List[str] = []
    trend_summary = ""
    if daily_failures <= 0 and recent_failures <= 0:
        trend_status = "healthy"
        trend_summary = "no delegated prompt failures recorded in the compared windows"
    elif daily_failures < 4:
        trend_status = "low_sample"
        trend_summary = "delegated prompt failure volume is too low for a stable trend"
    else:
        projected_daily = recent_failures * 24
        baseline = float(daily_failures)
        ratio = (projected_daily / baseline) if baseline > 0 else None
        if ratio is not None and ratio <= 0.5:
            trend_status = "improving"
            trend_summary = "recent delegated prompt failures are pacing below the 24h baseline"
        elif ratio is not None and ratio >= 1.25:
            trend_status = "worsening"
            trend_summary = "recent delegated prompt failures are pacing above the 24h baseline"
            trend_actions.append("tighten delegated task envelopes for the top failure classes before retrying the same task shape")
        else:
            trend_status = "steady"
            trend_summary = "delegated prompt failures are pacing close to the 24h baseline"
    return {
        "available": any(
            isinstance(summary, dict) and summary.get("available")
            for summary in summaries.values()
        ),
        "windows": summaries,
        "trend": {
            "status": trend_status,
            "summary": trend_summary,
            "actions": trend_actions,
        },
    }


def _gap_remediation_strategy(query_text: str) -> Dict[str, Any]:
    text = str(query_text or "").strip().lower()
    if not text:
        return {
            "strategy": "import_knowledge",
            "reason": "general_knowledge_gap",
            "estimated_effort": "low",
            "requires_approval": False,
        }
    if any(token in text for token in ("mcp", "api", "endpoint", "integration", "agent card", "json-rpc", "webhook")):
        return {
            "strategy": "create_integration",
            "reason": "integration_or_endpoint_gap",
            "estimated_effort": "high",
            "requires_approval": True,
        }
    if any(token in text for token in ("skill", "pattern", "playbook", "workflow", "orchestrat", "reviewer gate", "hint")):
        return {
            "strategy": "synthesize_skill",
            "reason": "workflow_or_skill_gap",
            "estimated_effort": "medium",
            "requires_approval": False,
        }
    if any(token in text for token in ("package", "install", "command not found", "binary", "cli", "tool missing")):
        return {
            "strategy": "install_package",
            "reason": "missing_tool_or_package_gap",
            "estimated_effort": "medium",
            "requires_approval": True,
        }
    if any(token in text for token in ("nixos", "home-manager", "home manager", "systemd", "module", "option", "tmpfiles", "credential.helper", "deploy", "switch")):
        return {
            "strategy": "extract_pattern",
            "reason": "operational_remediation_pattern_gap",
            "estimated_effort": "low",
            "requires_approval": False,
        }
    return {
        "strategy": "import_knowledge",
        "reason": "general_knowledge_gap",
        "estimated_effort": "low",
        "requires_approval": False,
    }


def gap_remediation_summary(gaps: List[dict]) -> Dict[str, Any]:
    candidates: List[Dict[str, Any]] = []
    strategy_counts: Dict[str, int] = {}
    for gap in gaps:
        if not isinstance(gap, dict):
            continue
        query_text = str(gap.get("query_text", "") or "").strip()
        if not query_text or _is_synthetic_gap(query_text) or _is_curated_stale_gap(query_text):
            continue
        occurrences = int(gap.get("occurrences", 1) or 1)
        if occurrences < 3:
            continue
        strategy_meta = _gap_remediation_strategy(query_text)
        strategy = str(strategy_meta.get("strategy") or "import_knowledge")
        strategy_counts[strategy] = strategy_counts.get(strategy, 0) + 1
        candidates.append(
            {
                "topic": query_text[:120],
                "occurrences": occurrences,
                "strategy": strategy,
                "reason": strategy_meta.get("reason"),
                "estimated_effort": strategy_meta.get("estimated_effort"),
                "requires_approval": bool(strategy_meta.get("requires_approval")),
            }
        )
    candidates.sort(key=lambda item: (-int(item.get("occurrences", 0)), str(item.get("topic", ""))))
    status = "healthy"
    if candidates:
        status = "active" if len(candidates) >= 3 else "watch"
    actions: List[str] = []
    if candidates:
        top = candidates[0]
        actions.append(
            f"Prioritize {top.get('strategy')} for '{top.get('topic')}' before importing broader low-signal docs."
        )
        if any(bool(item.get("requires_approval")) for item in candidates):
            actions.append("Approval-gated remediation candidates are present; keep package/integration changes out of unattended loops.")
    return {
        "available": True,
        "status": status,
        "candidate_count": len(candidates),
        "top_strategies": sorted(strategy_counts.items(), key=lambda item: (-item[1], item[0]))[:5],
        "candidates": candidates[:5],
        "actions": actions,
    }


def feedback_acceleration_summary(
    delegated_prompt_failures: Dict[str, Any],
    delegated_prompt_failure_windows: Dict[str, Any],
    adoption: Optional[Dict[str, Any]],
    recent_hint_adoption: Optional[Dict[str, Any]],
    agent_lessons: Optional[Dict[str, Any]],
) -> Dict[str, Any]:
    windows = delegated_prompt_failure_windows.get("windows") if isinstance(delegated_prompt_failure_windows, dict) else {}
    one_h = windows.get("1h") if isinstance(windows, dict) and isinstance(windows.get("1h"), dict) else {}
    recent_failures = int(one_h.get("total_failures", 0) or 0)
    trend = delegated_prompt_failure_windows.get("trend") if isinstance(delegated_prompt_failure_windows, dict) else {}
    trend_status = str((trend or {}).get("status", "historical") or "historical")
    total_feedback_failures = int((delegated_prompt_failures or {}).get("total_failures", 0) or 0)
    recent_hint_total = int((recent_hint_adoption or {}).get("total", 0) or 0)
    recent_hint_adoption_pct = (recent_hint_adoption or {}).get("adoption_pct")
    promote_candidates = [
        item for item in ((agent_lessons or {}).get("candidates") or [])
        if isinstance(item, dict) and str(item.get("state") or "") == "promote"
    ]
    status = "healthy"
    if total_feedback_failures <= 0 and recent_hint_total <= 0 and not promote_candidates:
        status = "low_sample"
    elif trend_status == "worsening" or recent_failures >= 2:
        status = "active"
    elif (
        recent_hint_total >= 5
        and recent_hint_adoption_pct is not None
        and float(recent_hint_adoption_pct) < 60.0
    ) or promote_candidates:
        status = "watch"
    actions: List[str] = []
    if recent_failures > 0:
        actions.append("Tighten delegated task envelopes and salvage reusable evidence before retrying recurring failure classes.")
    if recent_hint_total >= 5 and recent_hint_adoption_pct is not None and float(recent_hint_adoption_pct) < 60.0:
        actions.append("Improve hint quality or matching before increasing hint volume in the next batch.")
    if promote_candidates:
        top = promote_candidates[0]
        actions.append(f"Review promotable lesson {top.get('hint_id')} for {top.get('materialization')} materialization.")
    return {
        "available": True,
        "status": status,
        "trend": trend_status,
        "recent_failure_count": recent_failures,
        "total_failure_count": total_feedback_failures,
        "recent_hint_total": recent_hint_total,
        "recent_hint_adoption_pct": recent_hint_adoption_pct,
        "promotable_lessons": len(promote_candidates),
        "actions": actions,
    }


def remote_profile_utilization(entries: List[dict], *, window: str = "") -> Dict[str, Any]:
    """Summarize delegated remote profile usage from tool-audit metadata."""
    profile_counts: Dict[str, int] = {}
    runtime_counts: Dict[str, int] = {}
    requester_role_counts: Dict[str, int] = {}
    requesting_agent_counts: Dict[str, int] = {}
    handoff_by_role: Dict[str, int] = {}
    backend_reason_counts: Dict[str, int] = {}
    task_type_counts: Dict[str, int] = {}
    task_reason_counts: Dict[str, int] = {}
    response_max_token_counts: Dict[int, int] = {}
    fallback_applied = 0
    finalization_applied = 0
    handoff_requested = 0
    success_count = 0
    total = 0
    source = "delegate_audit"
    for entry in entries:
        if not isinstance(entry, dict):
            continue
        if str(entry.get("tool_name", "") or "").strip().lower() != "ai_coordinator_delegate":
            continue
        metadata = entry.get("metadata") if isinstance(entry.get("metadata"), dict) else {}
        profile = str(metadata.get("selected_profile", "") or "").strip()
        if not profile or not profile.startswith("remote-"):
            continue
        total += 1
        profile_counts[profile] = profile_counts.get(profile, 0) + 1
        runtime_id = str(metadata.get("selected_runtime_id", "") or "").strip()
        if runtime_id:
            runtime_counts[runtime_id] = runtime_counts.get(runtime_id, 0) + 1
        requester_role = str(metadata.get("requester_role", "") or "orchestrator").strip().lower()
        if requester_role:
            requester_role_counts[requester_role] = requester_role_counts.get(requester_role, 0) + 1
        requesting_agent = str(metadata.get("requesting_agent", "") or "").strip().lower()
        if requesting_agent:
            requesting_agent_counts[requesting_agent] = requesting_agent_counts.get(requesting_agent, 0) + 1
        if bool(metadata.get("fallback_applied")):
            fallback_applied += 1
        if bool(metadata.get("delegation_finalization_applied")):
            finalization_applied += 1
        if bool(metadata.get("delegation_handoff_requested")):
            handoff_requested += 1
            if requester_role:
                handoff_by_role[requester_role] = handoff_by_role.get(requester_role, 0) + 1
        if str(entry.get("outcome", "") or "").strip().lower() in {"ok", "success"}:
            success_count += 1
    if total <= 0:
        for entry in entries:
            if not isinstance(entry, dict):
                continue
            if str(entry.get("tool_name", "") or "").strip().lower() != "route_search":
                continue
            metadata = entry.get("metadata") if isinstance(entry.get("metadata"), dict) else {}
            if str(metadata.get("backend", "") or "").strip().lower() != "remote":
                continue
            if metadata.get("generate_response") is not True:
                continue
            total += 1
            success = str(entry.get("outcome", "") or "").strip().lower() in {"ok", "success"}
            if success:
                success_count += 1
            profile_counts["remote-reasoning"] = profile_counts.get("remote-reasoning", 0) + 1
            backend_reason = str(metadata.get("backend_reason_class", "") or "").strip()
            if backend_reason:
                backend_reason_counts[backend_reason] = backend_reason_counts.get(backend_reason, 0) + 1
            task_type = str(metadata.get("task_complexity_type", "") or "").strip()
            if task_type:
                task_type_counts[task_type] = task_type_counts.get(task_type, 0) + 1
            task_reason = str(metadata.get("task_complexity_reason", "") or "").strip()
            if task_reason:
                task_reason_counts[task_reason] = task_reason_counts.get(task_reason, 0) + 1
            response_max_tokens = metadata.get("response_max_tokens")
            if isinstance(response_max_tokens, int) and response_max_tokens > 0:
                response_max_token_counts[response_max_tokens] = response_max_token_counts.get(response_max_tokens, 0) + 1
            source = "route_search_audit_fallback"
    if total <= 0:
        return {"available": False, "window": window}
    return {
        "available": True,
        "source": source,
        "window": window,
        "total_calls": total,
        "success_count": success_count,
        "success_pct": round(100 * success_count / total, 1) if total else None,
        "fallback_applied": fallback_applied,
        "finalization_applied": finalization_applied,
        "handoff_requested": handoff_requested,
        "handoff_pct": round(100 * handoff_requested / total, 1) if total else None,
        "top_profiles": sorted(profile_counts.items(), key=lambda item: (-item[1], item[0]))[:5],
        "top_runtime_ids": sorted(runtime_counts.items(), key=lambda item: (-item[1], item[0]))[:5],
        "top_requester_roles": sorted(requester_role_counts.items(), key=lambda item: (-item[1], item[0]))[:5],
        "top_requesting_agents": sorted(requesting_agent_counts.items(), key=lambda item: (-item[1], item[0]))[:5],
        "handoff_by_requester_role": sorted(handoff_by_role.items(), key=lambda item: (-item[1], item[0]))[:5],
        "top_backend_reason_classes": sorted(backend_reason_counts.items(), key=lambda item: (-item[1], item[0]))[:5],
        "top_task_complexity_types": sorted(task_type_counts.items(), key=lambda item: (-item[1], item[0]))[:5],
        "top_task_complexity_reasons": sorted(task_reason_counts.items(), key=lambda item: (-item[1], item[0]))[:5],
        "top_response_max_tokens": sorted(response_max_token_counts.items(), key=lambda item: (-item[1], item[0]))[:5],
    }


