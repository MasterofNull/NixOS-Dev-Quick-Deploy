def aidb_import(content: str, week_label: str) -> bool:
    """POST the report to AIDB as a searchable document."""
    aidb_key = os.getenv("AIDB_API_KEY", "").strip()
    if not aidb_key:
        key_file = os.getenv("AIDB_API_KEY_FILE", "/run/secrets/aidb_api_key")
        p = Path(key_file)
        if p.exists():
            try:
                aidb_key = p.read_text(encoding="utf-8").strip()
            except OSError:
                aidb_key = ""

    headers = {"Content-Type": "application/json"}
    if aidb_key:
        headers["X-API-Key"] = aidb_key

    docs_payload = json.dumps({
        "project": "aq-report",
        "relative_path": f"weekly/{week_label}.md",
        "title": f"AI Stack Weekly Report ({week_label})",
        "content_type": "text/markdown",
        "content": content,
        "status": "approved",
        "source_trust_level": "generated",
    }).encode("utf-8")
    legacy_payload = json.dumps({
        "text": content,
        "metadata": {
            "type": "weekly_report",
            "week": week_label,
            "source": "aq-report",
        },
    }).encode("utf-8")

    attempts = [
        (f"{AIDB_URL}/documents", docs_payload),
        (f"{AIDB_URL}/import", legacy_payload),
    ]
    last_exc: Optional[Exception] = None
    for url, payload in attempts:
        try:
            req = urllib.request.Request(
                url,
                data=payload,
                headers=headers,
                method="POST",
            )
            with urllib.request.urlopen(req, timeout=15) as resp:
                if resp.status < 300:
                    return True
        except Exception as exc:
            last_exc = exc
            continue
    print(f"[aq-report] AIDB import failed: {last_exc}", file=sys.stderr)
    return False


