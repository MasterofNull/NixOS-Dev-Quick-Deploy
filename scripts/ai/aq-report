            if client_error_count:
                noise_parts.append(f"{client_error_count} invalid client requests")
            if backend_unclassified_count:
                noise_parts.append(f"{backend_unclassified_count} backend-unclassified actionable rows")
            lines.append(f"  Noise context: {', '.join(noise_parts)}")
        breakdown = route_latency_decomposition.get("breakdown") or []
        for item in breakdown[:5]:
            lines.append(
                f"    {item['label']}: calls {item['calls']},"
                f" p50 {_na(item.get('p50_ms'), '.0f', 'ms')},"
                f" p95 {_na(item.get('p95_ms'), '.0f', 'ms')},"
                f" success {_na(item.get('success_pct'), '.1f', '%')}"
            )
    lines.append("")

    lines += [f"[ 8b. Retrieval Breadth ({retrieval_breadth.get('window', '1h')}) ]"]
    avg_collection_count = retrieval_breadth.get("avg_collection_count")
    if avg_collection_count is None:
        lines.append("  No route_search retrieval-breadth metadata in this window.")
    else:
        lines.append(f"  Avg collections/call: {_na(avg_collection_count, '.2f')}")
        top_profiles = retrieval_breadth.get("top_profiles") or []
        if top_profiles:
            labels = ", ".join(f"{name}({count})" for name, count in top_profiles[:3])
            lines.append(f"  Active profiles: {labels}")
        diagnosis = retrieval_breadth.get("diagnosis")
        actions = retrieval_breadth.get("actions") or []
        if diagnosis:
            lines.append(f"  Retrieval breadth diagnosis: {diagnosis}")
        if actions:
            lines.append(f"  Retrieval breadth remediation: {'; '.join(str(action) for action in actions)}")
    lines.append("")

    lines += ["[ 8bb. Retrieval Breadth Trends ]"]
    breadth_windows = retrieval_breadth_windows.get("windows") if isinstance(retrieval_breadth_windows, dict) else {}
    if not breadth_windows:
        lines.append("  No multi-window retrieval-breadth data available.")
    else:
        for label in ("1h", "24h", "7d"):
            summary = breadth_windows.get(label) if isinstance(breadth_windows, dict) else None
            if not isinstance(summary, dict) or int(summary.get("route_calls", 0) or 0) <= 0:
                lines.append(f"  {label}: no route_search retrieval-breadth data recorded")
                continue
            avg = summary.get("avg_collection_count")
            top_profiles = summary.get("top_profiles") or []
            top_profile = top_profiles[0][0] if top_profiles else "n/a"
            partial = " (partial)" if summary.get("partial_window") else ""
            lines.append(
                f"  {label}{partial}: avg collections/call {_na(avg, '.2f')}, top profile {top_profile}"
            )
    lines.append("")

    lines += [f"[ 8c. Provider Fallback Recovery ({provider_fallbacks.get('window', '1h')}) ]"]
    recovered_count = int(provider_fallbacks.get("recovered_count", 0) or 0)
    if recovered_count <= 0:
        lines.append("  No recovered remote-provider fallback events in this window.")
    else:
        lines.append(
            f"  Recovered local fallbacks: {recovered_count}"
            f" ({_na(provider_fallbacks.get('recovered_pct'), '.1f', '%')} of route_search calls)"
        )
        status_counts = provider_fallbacks.get("status_counts") or []
        if status_counts:
            lines.append(f"  Upstream status mix: {_format_provider_fallback_statuses(status_counts)}")
        diagnosis = provider_fallbacks.get("diagnosis")
        actions = provider_fallbacks.get("actions") or []
        if diagnosis:
            lines.append(f"  Provider fallback diagnosis: {diagnosis}")
        if actions:
            lines.append(f"  Provider fallback remediation: {'; '.join(str(action) for action in actions)}")
        lines.append("  These are tracked separately from backend failures because the request recovered locally.")
    lines.append("")

    lines += [f"[ 8d. Historical Watchlist ({historical_watch.get('window', '7d')}) ]"]
    if not historical_watch.get("has_items"):
        lines.append("  No background watchlist items outside the recent window.")
    else:
        slow_tools = historical_watch.get("slow_tools") or []
        flaky_tools = historical_watch.get("flaky_tools") or []
        if slow_tools:
            lines.append("  Slow tools outside the recent window:")
            for item in slow_tools[:3]:
                lines.append(
                    f"    {item['tool']}: 7d p95 {_na(item.get('p95_ms'), '.0f', 'ms')} across {item['calls']} calls"
                )
        if flaky_tools:
            lines.append("  Reliability watchlist outside the recent window:")
            for item in flaky_tools[:3]:
                lines.append(
                    f"    {item['tool']}: {_backend_reliability_summary(item, window_label='7d', recent=False)}"
                )
                note = str(item.get("reliability_note", "") or "").strip()
                if note:
                    lines.append(f"      note: {note}")
    lines.append("")

    lines += ["[ 9. Workflow Recommendations ]"]
    for i, rec in enumerate(recs, 1):
        # Wrap at ~72 chars
        words = rec.split()
        cur_line = f"  {i}. "
        indent = "     "
        for word in words:
            if len(cur_line) + len(word) + 1 > 72 and len(cur_line) > len(indent):
                lines.append(cur_line)
                cur_line = indent + word
            else:
                cur_line = cur_line + (" " if len(cur_line) > len(indent) else "") + word
        lines.append(cur_line)
    lines.append("")

    lines += ["[ 10. Hint Adoption (aq-hints → aider-wrapper) ]"]
    if adoption and adoption.get("available"):
        if adoption["total"] == 0:
            lines.append("  No hint-injected aider tasks in this window.")
        else:
            lines += [
                f"  Injected: {adoption['total']}   Successful: {adoption['accepted']}"
                f"   Rate: {_na(adoption['adoption_pct'], '.1f', '%')}",
            ]
            if int(adoption.get("tooling_plan_total", 0) or 0) > 0:
                lines.append(
                    f"  Tooling-plan success: {adoption.get('tooling_plan_success', 0)}"
                    f"/{adoption.get('tooling_plan_total', 0)}"
                    f"   ({_na(adoption.get('tooling_plan_success_pct'), '.1f', '%')})"
                )
            if adoption.get("top_hints"):
                lines.append("  Top hints:")
