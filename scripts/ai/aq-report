def route_search_latency_decomposition(entries: List[dict], *, window: str = "") -> Dict[str, Any]:
    """Break route_search latency into backend and recovery classes."""
    route_events: List[Dict[str, Any]] = []
    for entry in entries:
        if str(entry.get("tool_name", "")).strip().lower() != "route_search":
            continue
        if str(entry.get("service", "")).strip().lower() == "hybrid-coordinator-tool-security":
            continue
        route_events.append(entry)
    if not route_events:
        return {"available": False, "window": window}

    groups: Dict[str, Dict[str, Any]] = {}

    def _bucket(name: str) -> Dict[str, Any]:
        bucket = groups.get(name)
        if bucket is None:
            bucket = {"calls": 0, "latencies": [], "success": 0, "errors": 0}
            groups[name] = bucket
        return bucket

    overall_latencies: List[float] = []
    actionable_latencies: List[float] = []
    backend_valid_latencies: List[float] = []
    synthesis_latencies: List[float] = []
    retrieval_only_latencies: List[float] = []
    client_error_count = 0
    backend_unclassified_count = 0
    for entry in route_events:
        metadata = entry.get("metadata") if isinstance(entry.get("metadata"), dict) else {}
        latency = entry.get("latency_ms")
        latency_value = float(latency or 0.0)
        overall_latencies.append(latency_value)
        outcome = str(entry.get("outcome", "") or "").strip().lower()
        backend = str(metadata.get("backend", "") or "unknown").strip().lower() or "unknown"
        fallback_reason = str(metadata.get("fallback_reason", "") or "").strip().lower()
        status_code = metadata.get("http_status")
        generate_response = metadata.get("generate_response")
        task_complexity_type = str(metadata.get("task_complexity_type", "") or "").strip().lower()
        local_inference_lane = str(metadata.get("local_inference_lane", "") or "").strip().lower()
        local_inference_lane_reason = str(metadata.get("local_inference_lane_reason", "") or "").strip().lower()
        is_client_error = outcome == "client_error" or (isinstance(status_code, int) and 400 <= status_code < 500)
        is_actionable = not is_client_error
        if is_client_error:
            client_error_count += 1
        else:
            actionable_latencies.append(latency_value)
            if backend in {"local", "remote"}:
                backend_valid_latencies.append(latency_value)
            else:
                backend_unclassified_count += 1
            if generate_response is True:
                synthesis_latencies.append(latency_value)
            elif generate_response is False:
                retrieval_only_latencies.append(latency_value)
        classes = [f"backend:{backend}"]
        if generate_response is True:
            classes.append("request:synthesis")
            if task_complexity_type:
                classes.append(f"synthesis_type:{task_complexity_type}")
            if local_inference_lane:
                classes.append(f"local_lane:{local_inference_lane}")
            if local_inference_lane_reason:
                classes.append(f"local_lane_reason:{local_inference_lane_reason}")
        elif generate_response is False:
            classes.append("request:retrieval_only")
        if fallback_reason == "remote_4xx_local_fallback":
            classes.append("fallback:remote_4xx_local_fallback")
        if isinstance(status_code, int):
            if 400 <= status_code < 500:
                classes.append("status:4xx")
            elif status_code >= 500:
                classes.append("status:5xx")
        if outcome in {"ok", "success"}:
            classes.append("outcome:success")
        elif outcome:
            classes.append("outcome:error")
        for label in classes:
            bucket = _bucket(label)
            bucket["calls"] += 1
            bucket["latencies"].append(latency_value)
            if outcome in {"ok", "success"}:
                bucket["success"] += 1
            else:
                bucket["errors"] += 1

    breakdown = []
    for label, bucket in groups.items():
        latencies = bucket.pop("latencies")
        calls = int(bucket.get("calls", 0) or 0)
        breakdown.append(
            {
                "label": label,
                "calls": calls,
                "p50_ms": _percentile(latencies, 50),
                "p95_ms": _percentile(latencies, 95),
                "success_pct": round(100 * int(bucket.get("success", 0) or 0) / calls, 1) if calls else None,
                "error_count": int(bucket.get("errors", 0) or 0),
            }
        )
    breakdown.sort(key=lambda item: (-int(item.get("calls", 0) or 0), str(item.get("label", ""))))
    return {
        "available": True,
        "window": window,
        "total_calls": len(route_events),
        "overall_p50_ms": _percentile(overall_latencies, 50),
        "overall_p95_ms": _percentile(overall_latencies, 95),
        "actionable_calls": len(actionable_latencies),
        "actionable_p50_ms": _percentile(actionable_latencies, 50),
        "actionable_p95_ms": _percentile(actionable_latencies, 95),
        "backend_valid_calls": len(backend_valid_latencies),
        "backend_valid_p50_ms": _percentile(backend_valid_latencies, 50),
        "backend_valid_p95_ms": _percentile(backend_valid_latencies, 95),
        "synthesis_calls": len(synthesis_latencies),
        "synthesis_p50_ms": _percentile(synthesis_latencies, 50),
        "synthesis_p95_ms": _percentile(synthesis_latencies, 95),
        "retrieval_only_calls": len(retrieval_only_latencies),
        "retrieval_only_p50_ms": _percentile(retrieval_only_latencies, 50),
        "retrieval_only_p95_ms": _percentile(retrieval_only_latencies, 95),
        "client_error_count": client_error_count,
        "backend_unclassified_count": backend_unclassified_count,
        "breakdown": breakdown[:12],
    }


def _entry_ts_utc(entry: Dict[str, Any]) -> Optional[datetime]:
    raw = str(entry.get("timestamp", "") or "").strip()
    if not raw:
        return None
    try:
        return datetime.fromisoformat(raw.rstrip("Z")).replace(tzinfo=timezone.utc)
    except ValueError:
        return None


def _score_ts_utc(raw: Any) -> Optional[datetime]:
    """Parse eval score timestamps across legacy and ISO8601 formats."""
    text = str(raw or "").strip()
    if not text:
        return None
    parse_attempts = (
        lambda v: datetime.fromisoformat(v.rstrip("Z")),
        lambda v: datetime.strptime(v, "%Y%m%dT%H%M%SZ"),
    )
    for parser in parse_attempts:
        try:
            parsed = parser(text)
            if parsed.tzinfo is None:
                parsed = parsed.replace(tzinfo=timezone.utc)
            else:
                parsed = parsed.astimezone(timezone.utc)
            return parsed
        except ValueError:
            continue
    return None


def read_eval_scores(since: datetime) -> List[dict]:
    """Read eval_scores rows from scores.sqlite."""
    if not EVAL_SCORES_DB.exists():
        return []
    try:
        conn = sqlite3.connect(str(EVAL_SCORES_DB))
        conn.row_factory = sqlite3.Row
        # strategy_tag column added in Phase 18.2.1; use IFNULL for older DBs
        cur = conn.execute(
            "SELECT timestamp, config, passed, total, pct_passed, threshold, "
            "IFNULL(strategy_tag, '') AS strategy_tag "
            "FROM eval_scores",
        )
        rows = [dict(r) for r in cur.fetchall()]
        conn.close()
        filtered_rows = []
        for row in rows:
            parsed = _score_ts_utc(row.get("timestamp"))
            if parsed is None or parsed < since:
                continue
            row["_parsed_ts"] = parsed
            filtered_rows.append(row)
        filtered_rows.sort(key=lambda r: r["_parsed_ts"])
        for row in filtered_rows:
            row.pop("_parsed_ts", None)
        return filtered_rows
    except (sqlite3.Error, OSError):
        return []


def strategy_leaderboard(rows: List[dict]) -> List[dict]:
    """Group eval rows by strategy_tag and compute mean pct_passed per tag."""
    from collections import defaultdict
    buckets: Dict[str, List[int]] = defaultdict(list)
    for r in rows:
        tag = r.get("strategy_tag") or "untagged"
        buckets[tag].append(r["pct_passed"])
    board = [
        {"tag": tag, "mean_pct": round(sum(v) / len(v), 1), "runs": len(v)}
        for tag, v in buckets.items()
    ]
    return sorted(board, key=lambda x: -x["mean_pct"])


def read_prompt_registry() -> List[dict]:
    """Load ai-stack/prompts/registry.yaml; return list of prompt entries."""
    registry_path = Path(
        os.getenv("REGISTRY_PATH",
                  str(Path(__file__).parent.parent.parent / "ai-stack/prompts/registry.yaml"))
    )
    if not registry_path.exists():
        return []

    def _minimal_prompt_registry_fallback(path: Path) -> List[dict]:
        prompts: List[dict] = []
        current: Optional[Dict[str, Any]] = None
        for raw_line in path.read_text(encoding="utf-8").splitlines():
            line = raw_line.rstrip()
            stripped = line.strip()
            if not stripped or stripped.startswith("#"):
                continue
            if stripped.startswith("- id:"):
                if current and current.get("id"):
                    prompts.append(current)
                current = {"id": stripped.split(":", 1)[1].strip()}
                continue
            if current is None:
                continue
            if stripped.startswith("name:"):
                current["name"] = stripped.split(":", 1)[1].strip()
                continue
            if stripped.startswith("mean_score:"):
                value = stripped.split(":", 1)[1].strip()
                try:
                    current["mean_score"] = float(value)
                except ValueError:
                    current["mean_score"] = None
        if current and current.get("id"):
            prompts.append(current)
        return prompts

    try:
        import yaml  # type: ignore[import-untyped]
        with registry_path.open(encoding="utf-8") as fh:
            data = yaml.safe_load(fh)
        return data.get("prompts", []) if data else []
    except Exception:
        try:
            return _minimal_prompt_registry_fallback(registry_path)
        except Exception:
            return []


def prom_query(metric: str) -> Optional[float]:
    """Fetch an instant Prometheus metric value (scalar or single series)."""
    url = f"{PROMETHEUS_URL}/api/v1/query?" + urllib.parse.urlencode({"query": metric})
    try:
        req = urllib.request.Request(url, headers={"Accept": "application/json"})
        with urllib.request.urlopen(req, timeout=5) as resp:
            data = json.loads(resp.read())
        results = data.get("data", {}).get("result", [])
        if not results:
            return None
        return float(results[0]["value"][1])
    except Exception:
        return None


def prom_query_range(metric: str, start: datetime, step: str = "1h") -> List[Tuple[float, float]]:
    """Fetch a Prometheus range query. Returns [(unix_ts, value), ...]."""
    end_ts = datetime.now(tz=timezone.utc).timestamp()
    start_ts = start.timestamp()
    url = f"{PROMETHEUS_URL}/api/v1/query_range?" + urllib.parse.urlencode({
        "query": metric,
        "start": start_ts,
        "end": end_ts,
        "step": step,
    })
    try:
        req = urllib.request.Request(url, headers={"Accept": "application/json"})
        with urllib.request.urlopen(req, timeout=10) as resp:
            data = json.loads(resp.read())
        results = data.get("data", {}).get("result", [])
        if not results:
            return []
        return [(float(v[0]), float(v[1])) for v in results[0].get("values", [])]
    except Exception:
        return []


def read_llama_benchmark_runs(since: datetime) -> Dict[str, Any]:
    if not LLAMA_BENCHMARK_RUNS_DIR.is_dir():
        return {"available": False, "source": str(LLAMA_BENCHMARK_RUNS_DIR)}

    runs: List[Dict[str, Any]] = []
    for path in sorted(LLAMA_BENCHMARK_RUNS_DIR.glob("*.json")):
        try:
            payload = json.loads(path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            continue
        if not isinstance(payload, dict):
            continue
        ts = _score_ts_utc(payload.get("saved_at")) or datetime.fromtimestamp(path.stat().st_mtime, tz=timezone.utc)
        if ts < since:
            continue
        payload["_saved_ts"] = ts
        payload["_path"] = str(path)
        runs.append(payload)

    runs.sort(key=lambda item: item.get("_saved_ts", datetime.min.replace(tzinfo=timezone.utc)), reverse=True)
    return {"available": True, "source": str(LLAMA_BENCHMARK_RUNS_DIR), "runs": runs}


def summarize_llama_benchmark_runs(data: Dict[str, Any]) -> Dict[str, Any]:
    if not data.get("available"):
        return {"available": False, "source": data.get("source")}

    runs = data.get("runs") if isinstance(data.get("runs"), list) else []
    if not runs:
        return {
            "available": True,
            "source": data.get("source"),
            "total_runs": 0,
            "quality_passed_runs": 0,
            "latest_run": None,
            "best_latency_run": None,
            "best_tps_run": None,
        }

    valid_runs = [run for run in runs if isinstance(run, dict) and isinstance(run.get("summary"), dict)]
    quality_passed = [
        run for run in valid_runs
        if bool((run.get("summary") or {}).get("all_quality_checks_passed"))
    ]

    def _latency_key(run: Dict[str, Any]) -> float:
        summary = run.get("summary") or {}
        return float(summary.get("avg_warm_latency_s") or 1e12)

    def _tps_key(run: Dict[str, Any]) -> float:
        summary = run.get("summary") or {}
        return float(summary.get("avg_completion_tokens_per_second") or -1.0)

    pool = quality_passed or valid_runs
    best_latency = min(pool, key=_latency_key) if pool else None
    best_tps = max(pool, key=_tps_key) if pool else None
    latest = runs[0]

    def _compact(run: Optional[Dict[str, Any]]) -> Optional[Dict[str, Any]]:
        if not run:
            return None
        summary = run.get("summary") or {}
        resources = run.get("resource_observations") or {}
        return {
            "run_id": run.get("run_id"),
            "target_model": run.get("target_model"),
            "target_ctx_size": run.get("target_ctx_size"),
            "saved_at": run.get("saved_at") or str(run.get("_saved_ts") or ""),
            "avg_warm_latency_s": summary.get("avg_warm_latency_s"),
            "avg_completion_tokens_per_second": summary.get("avg_completion_tokens_per_second"),
            "all_quality_checks_passed": summary.get("all_quality_checks_passed"),
            "peak_rss_mb": resources.get("peak_rss_mb"),
            "avg_gpu_busy_percent": resources.get("avg_gpu_busy_percent"),
            "path": run.get("saved_path") or run.get("_path"),
        }

    return {
        "available": True,
        "source": data.get("source"),
        "total_runs": len(runs),
        "quality_passed_runs": len(quality_passed),
        "latest_run": _compact(latest),
        "best_latency_run": _compact(best_latency),
        "best_tps_run": _compact(best_tps),
    }


def _pg_creds() -> tuple[str, int, str, str, str]:
    """Return (host, port, db, user, password) with sensible defaults."""
    host = os.getenv("POSTGRES_HOST", "127.0.0.1")
    port = int(os.getenv("POSTGRES_PORT", "5432"))
    db = os.getenv("POSTGRES_DB", "aidb")
    user = os.getenv("POSTGRES_USER", "aidb")
    password = os.getenv("POSTGRES_PASSWORD", "")
    if not password:
        secret = Path("/run/secrets/postgres_password")
        if secret.exists():
            password = secret.read_text().strip()
    return host, port, db, user, password


def read_query_gaps(since: datetime, limit: int = 10) -> List[dict]:
    """Fetch top repeated query gaps from Postgres.

    Tries psycopg first (available in service envs), then falls back to
    the psql CLI which is always present on this NixOS system.
    """
    host, port, db, user, password = _pg_creds()
    dsn = f"postgresql://{user}:{password}@{host}:{port}/{db}"
    query = (
        "SELECT query_text, score, collection, COUNT(*) AS occurrences "
        "FROM query_gaps "
        f"WHERE created_at >= '{since.isoformat()}' "
        "GROUP BY query_text, score, collection "
        "ORDER BY occurrences DESC, score ASC "
        f"LIMIT {limit};"
    )

    # ── psycopg path (fast, available inside systemd service environments) ──
    try:
        import psycopg  # type: ignore[import-untyped]
        conn = psycopg.connect(dsn, connect_timeout=5)
        cur = conn.execute(
            "SELECT query_text, score, collection, COUNT(*) AS occurrences "
            "FROM query_gaps WHERE created_at >= %s "
            "GROUP BY query_text, score, collection "
            "ORDER BY occurrences DESC, score ASC LIMIT %s",
            (since, limit),
        )
        rows = [dict(r._mapping) for r in cur.fetchall()]
        conn.close()
        return rows
    except ImportError:
        pass
    except Exception:
        return []

    # ── psql subprocess path (shell invocations where psycopg is absent) ──
    import subprocess, csv, io
    try:
        result = subprocess.run(
            ["psql", dsn, "--tuples-only", "--no-align",
             "--field-separator=\t", "--command", query],
            capture_output=True, text=True, timeout=10,
        )
        if result.returncode != 0:
            return []
        rows = []
        for line in csv.reader(io.StringIO(result.stdout), delimiter="\t"):
            if len(line) < 4:
                continue
            rows.append({
                "query_text": line[0],
                "score": float(line[1]) if line[1] else None,
                "collection": line[2],
                "occurrences": int(line[3]),
            })
        return rows
    except Exception:
        return []


def read_workflow_sessions(since: datetime) -> Dict[str, Any]:
    """Summarise workflow run intent-contract compliance from persisted sessions."""
    path = WORKFLOW_SESSIONS_PATH
    if not path.exists():
        return {"available": False, "source": str(path)}
    try:
        raw = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {"available": False, "source": str(path)}

    if not isinstance(raw, dict):
        return {"available": False, "source": str(path)}

    since_ts = int(since.timestamp())
    sessions = []
    for _sid, sess in raw.items():
        if not isinstance(sess, dict):
            continue
        created = int(sess.get("created_at", 0) or 0)
        updated = int(sess.get("updated_at", 0) or 0)
        if max(created, updated) < since_ts:
            continue
        sessions.append(sess)

    total = len(sessions)
    if total == 0:
        return {
            "available": True,
            "source": str(path),
            "total_runs": 0,
            "with_contract": 0,
            "missing_contract": 0,
            "contract_coverage_pct": None,
            "depth_distribution": {},
            "top_blueprints": [],
        }

    with_contract = 0
    missing_contract = 0
    missing_contract_obj = 0
    depth_counts: Dict[str, int] = {}
    blueprint_counts: Dict[str, int] = {}
    review_gate_required = 0
    accepted_reviews = 0
    rejected_reviews = 0
    pending_reviews = 0
    sessions_with_reviews = 0
    requester_role_counts: Dict[str, int] = {}
    accepted_by_requester_role: Dict[str, int] = {}
    rejected_by_requester_role: Dict[str, int] = {}
    reviewer_counts: Dict[str, int] = {}
    accepted_blueprint_counts: Dict[str, int] = {}
    rejected_blueprint_counts: Dict[str, int] = {}
    review_type_counts: Dict[str, int] = {}
    accepted_patch_reviews = 0
    rejected_patch_reviews = 0
    patch_reviewed_agent_counts: Dict[str, int] = {}
    accepted_task_class_counts: Dict[str, int] = {}
    rejected_task_class_counts: Dict[str, int] = {}
    accepted_by_reviewed_profile: Dict[str, int] = {}
    rejected_by_reviewed_profile: Dict[str, int] = {}
    for sess in sessions:
        contract = sess.get("intent_contract")
        has_contract = (
            isinstance(contract, dict)
            and bool(str(contract.get("user_intent", "")).strip())
            and bool(str(contract.get("definition_of_done", "")).strip())
            and str(contract.get("depth_expectation", "")).strip().lower() in {"minimum", "standard", "deep"}
            and isinstance(contract.get("spirit_constraints"), list)
            and len([x for x in contract.get("spirit_constraints", []) if str(x).strip()]) > 0
            and isinstance(contract.get("no_early_exit_without"), list)
            and len([x for x in contract.get("no_early_exit_without", []) if str(x).strip()]) > 0
        )
        if has_contract:
            with_contract += 1
            depth = str(contract.get("depth_expectation", "unknown")).strip().lower() or "unknown"
            depth_counts[depth] = depth_counts.get(depth, 0) + 1
        else:
            missing_contract += 1
            if not isinstance(contract, dict):
                missing_contract_obj += 1
        bp = str(sess.get("blueprint_id", "") or "").strip()
        if bp:
            blueprint_counts[bp] = blueprint_counts.get(bp, 0) + 1
        orchestration = sess.get("orchestration")
        requester_role = ""
        if isinstance(orchestration, dict):
            requester_role = str(orchestration.get("requester_role", "") or "").strip().lower()
            if requester_role:
                requester_role_counts[requester_role] = requester_role_counts.get(requester_role, 0) + 1
        reviewer_gate = sess.get("reviewer_gate")
        if isinstance(reviewer_gate, dict):
            if bool(reviewer_gate.get("required", False)):
                review_gate_required += 1
            status = str(reviewer_gate.get("status", "") or "").strip().lower()
            history = reviewer_gate.get("history", [])
            if isinstance(history, list) and history:
                sessions_with_reviews += 1
            last_review = reviewer_gate.get("last_review")
            review_type = "acceptance"
            artifact_kind = ""
            task_class = bp.lower().replace("-", "_") if bp else ""
            reviewed_agent = ""
            reviewed_profile = ""
            if isinstance(last_review, dict):
                reviewer = str(last_review.get("reviewer", "") or "").strip().lower()
                if reviewer:
                    reviewer_counts[reviewer] = reviewer_counts.get(reviewer, 0) + 1
                review_type = str(last_review.get("review_type", "") or "acceptance").strip().lower()
                if review_type:
                    review_type_counts[review_type] = review_type_counts.get(review_type, 0) + 1
                artifact_kind = str(last_review.get("artifact_kind", "") or "").strip().lower()
                task_class = str(last_review.get("task_class", "") or task_class).strip().lower()
                reviewed_agent = str(last_review.get("reviewed_agent", "") or "").strip().lower()
                reviewed_profile = str(last_review.get("reviewed_profile", "") or "").strip().lower()
            if status == "accepted":
                accepted_reviews += 1
                if requester_role:
                    accepted_by_requester_role[requester_role] = accepted_by_requester_role.get(requester_role, 0) + 1
                if bp:
                    accepted_blueprint_counts[bp] = accepted_blueprint_counts.get(bp, 0) + 1
                if task_class:
                    accepted_task_class_counts[task_class] = accepted_task_class_counts.get(task_class, 0) + 1
                if reviewed_profile:
                    accepted_by_reviewed_profile[reviewed_profile] = accepted_by_reviewed_profile.get(reviewed_profile, 0) + 1
                if review_type == "patch_review" or artifact_kind == "patch":
                    accepted_patch_reviews += 1
                    if reviewed_agent:
                        patch_reviewed_agent_counts[reviewed_agent] = patch_reviewed_agent_counts.get(reviewed_agent, 0) + 1
            elif status == "rejected":
                rejected_reviews += 1
                if requester_role:
                    rejected_by_requester_role[requester_role] = rejected_by_requester_role.get(requester_role, 0) + 1
                if bp:
                    rejected_blueprint_counts[bp] = rejected_blueprint_counts.get(bp, 0) + 1
                if task_class:
                    rejected_task_class_counts[task_class] = rejected_task_class_counts.get(task_class, 0) + 1
                if reviewed_profile:
                    rejected_by_reviewed_profile[reviewed_profile] = rejected_by_reviewed_profile.get(reviewed_profile, 0) + 1
                if review_type == "patch_review" or artifact_kind == "patch":
                    rejected_patch_reviews += 1
                    if reviewed_agent:
                        patch_reviewed_agent_counts[reviewed_agent] = patch_reviewed_agent_counts.get(reviewed_agent, 0) + 1
            elif status == "pending_review":
                pending_reviews += 1

    top_blueprints = sorted(blueprint_counts.items(), key=lambda x: -x[1])[:5]
    return {
        "available": True,
        "source": str(path),
        "total_runs": total,
        "with_contract": with_contract,
        "missing_contract": missing_contract,
        "missing_contract_obj": missing_contract_obj,
        "contract_coverage_pct": round((with_contract / total) * 100.0, 1) if total else None,
        "depth_distribution": depth_counts,
        "top_blueprints": top_blueprints,
        "reviewer_gate_required_runs": review_gate_required,
        "sessions_with_reviews": sessions_with_reviews,
        "accepted_reviews": accepted_reviews,
        "rejected_reviews": rejected_reviews,
        "pending_reviews": pending_reviews,
        "top_requester_roles": sorted(requester_role_counts.items(), key=lambda x: (-x[1], x[0]))[:5],
        "accepted_by_requester_role": sorted(accepted_by_requester_role.items(), key=lambda x: (-x[1], x[0]))[:5],
        "rejected_by_requester_role": sorted(rejected_by_requester_role.items(), key=lambda x: (-x[1], x[0]))[:5],
        "top_reviewers": sorted(reviewer_counts.items(), key=lambda x: (-x[1], x[0]))[:5],
        "top_review_types": sorted(review_type_counts.items(), key=lambda x: (-x[1], x[0]))[:5],
        "accepted_blueprints": sorted(accepted_blueprint_counts.items(), key=lambda x: (-x[1], x[0]))[:5],
        "rejected_blueprints": sorted(rejected_blueprint_counts.items(), key=lambda x: (-x[1], x[0]))[:5],
        "accepted_patch_reviews": accepted_patch_reviews,
        "rejected_patch_reviews": rejected_patch_reviews,
        "patch_reviews_by_reviewed_agent": sorted(patch_reviewed_agent_counts.items(), key=lambda x: (-x[1], x[0]))[:5],
        "accepted_task_classes": sorted(accepted_task_class_counts.items(), key=lambda x: (-x[1], x[0]))[:5],
        "rejected_task_classes": sorted(rejected_task_class_counts.items(), key=lambda x: (-x[1], x[0]))[:5],
        "accepted_by_reviewed_profile": sorted(accepted_by_reviewed_profile.items(), key=lambda x: (-x[1], x[0]))[:5],
        "rejected_by_reviewed_profile": sorted(rejected_by_reviewed_profile.items(), key=lambda x: (-x[1], x[0]))[:5],
    }


def _is_synthetic_gap(query_text: str) -> bool:
    text = (query_text or "").strip().lower()
    if not text:
        return True
    # Ignore local probe/test prompts and command-like diagnostics that should
    # not become knowledge-import recommendations.
    if text in {"test", "nix", "ping", "health"}:
        return True
    synthetic_prefixes = (
        "analysis only task ",
        "analysis only:",
        "analysis task ",
        "analyze docs/",
        "please analyze and summarize docs/",
        "analyze and summarize docs/",
        "read docs/",
        "read and summarize docs/",
        "summarize docs/",
        "summarize file ",
        "summarize the file ",
        "analyze file ",
        "nixos-rag-test-probe-unique-sentinel",
        "fetch http://127.0.0.1",
        "fetch https://127.0.0.1",
        "fetch http://localhost",
        "curl http://127.0.0.1",
        "curl http://localhost",
        "get http://127.0.0.1",
        "get http://localhost",
    )
    return text.startswith(synthetic_prefixes)


