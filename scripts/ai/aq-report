def _na(val: Optional[float], fmt: str = ".1f", suffix: str = "") -> str:
    if val is None:
        return "n/a"
    return f"{val:{fmt}}{suffix}"


def _tool_reliability_context(stats: Dict[str, Any], fresh: Optional[Dict[str, Any]] = None) -> str:
    parts: List[str] = []
    server_errors = int(stats.get("error_count", 0) or 0)
    client_errors = int(stats.get("client_error_count", 0) or 0)
    if server_errors:
        parts.append(f"{server_errors} backend failures")
    if client_errors:
        parts.append(f"{client_errors} invalid client requests excluded")
    if fresh is None or int(fresh.get("calls", 0) or 0) == 0:
        parts.append("no recent calls in the last hour")
    else:
        parts.append(
            f"last hour backend OK%={_na(fresh.get('success_pct'), '.1f', '%')} across {int(fresh.get('calls', 0) or 0)} valid calls"
        )
    return "; ".join(parts)


def _backend_reliability_summary(item: Dict[str, Any], *, window_label: str, recent: bool) -> str:
    calls = int(item.get("calls", 0) or 0)
    ok_pct = _na(item.get("success_pct"), '.1f', '%')
    client_errors = int(item.get("client_error_count", 0) or 0)
    period = "recent valid calls" if recent else "valid calls"
    prefix = f"{window_label} " if window_label else ""
    text = f"{prefix}backend OK {ok_pct} across {calls} {period}"
    if client_errors:
        text += f" (+{client_errors} invalid client requests)"
    text += f" (server={item.get('error_count', 0)})"
    return text


def _tool_latency_context(stats: Dict[str, Any], fresh: Optional[Dict[str, Any]] = None) -> str:
    if fresh is None or int(fresh.get("calls", 0) or 0) == 0:
        return "no recent calls in the last hour"
    return (
        f"last hour p95={_na(fresh.get('p95_ms'), '.0f', 'ms')} across "
        f"{int(fresh.get('calls', 0) or 0)} calls"
    )


def _autorun_block_context(recent_semantic_autorun: Optional[Dict[str, Any]] = None) -> str:
    if not recent_semantic_autorun or not recent_semantic_autorun.get("available"):
        return "recent autorun state unavailable"
    recent_calls = int(recent_semantic_autorun.get("route_calls", 0) or 0)
    recent_blocked = int(recent_semantic_autorun.get("tool_security_blocked_total", 0) or 0)
    if recent_calls == 0:
        return "no recent autorun traffic in the last hour"
    if recent_blocked == 0:
        return f"last hour clean across {recent_calls} autorun calls"
    return f"last hour blocked {recent_blocked} tool actions across {recent_calls} autorun calls"


def _format_retrieval_mix(mix: Optional[Dict[str, Any]]) -> str:
    if not mix:
        return "n/a"
    parts: List[str] = []
    for key in ("route_search", "tree_search", "recall_agent_memory"):
        value = int(mix.get(key, 0) or 0)
        if value > 0:
            parts.append(f"{key}={value}")
    return ", ".join(parts) if parts else "none"


def rag_posture(
    tool_stats: Dict[str, dict],
    recent_tool_stats: Dict[str, dict],
    cache: Dict[str, Any],
    gaps: List[dict],
) -> Dict[str, Any]:
    """Summarize retrieval/RAG posture from live traffic, cache posture, and actionable gaps."""
    retrieval_tools = ("route_search", "tree_search", "recall_agent_memory")
    recent_mix = {
        name: int((recent_tool_stats.get(name) or {}).get("calls", 0) or 0)
        for name in retrieval_tools
    }
    total_mix = {
        name: int((tool_stats.get(name) or {}).get("calls", 0) or 0)
        for name in retrieval_tools
    }
    recent_calls = sum(recent_mix.values())
    total_calls = sum(total_mix.values())
    actionable_gaps = [
        g for g in gaps
        if int(g.get("occurrences", 1) or 0) >= 3
        and not _is_synthetic_gap(str(g.get("query_text", "")))
        and not _is_curated_stale_gap(str(g.get("query_text", "")))
    ]
    status = "healthy"
    reasons: List[str] = []
    cache_context = _cache_sample_context(cache) if cache.get("available") else None
    if recent_calls == 0:
        status = "historical"
        reasons.append("no recent retrieval traffic")
    if actionable_gaps:
        status = "watch"
        reasons.append(f"{len(actionable_gaps)} actionable gaps")
    if cache.get("available"):
        total_cache = int(cache.get("hits", 0) or 0) + int(cache.get("misses", 0) or 0)
        hit_pct = cache.get("hit_pct")
        if status != "watch" and recent_calls > 0 and total_cache < 20:
            status = "low_sample"
            reasons.append(f"cache sample still warming ({total_cache} samples)")
        if total_cache >= 20 and hit_pct is not None and float(hit_pct) < 20.0:
            status = "watch"
            reasons.append(f"cache hit rate {_na(hit_pct, '.1f', '%')}")
    dominant_recent = max(recent_mix.items(), key=lambda item: item[1])[0] if recent_calls > 0 else None
    dominant_total = max(total_mix.items(), key=lambda item: item[1])[0] if total_calls > 0 else None
    return {
        "available": True,
        "status": status,
        "recent_retrieval_calls": recent_calls,
        "total_retrieval_calls": total_calls,
        "actionable_gap_count": len(actionable_gaps),
        "cache_hit_pct": cache.get("hit_pct") if cache.get("available") else None,
        "cache_context": cache_context,
        "retrieval_mix": {
            "recent": recent_mix,
            "total": total_mix,
            "dominant_recent": dominant_recent,
            "dominant_total": dominant_total,
        },
        "reasons": reasons,
    }


def recent_health_snapshot(recent_tool_stats: Dict[str, dict]) -> Dict[str, Any]:
    """Summarize active issues in the recent monitoring window."""
    snapshot: Dict[str, Any] = {
        "available": True,
        "window": "1h",
        "slow_tools": [],
        "flaky_tools": [],
    }
    ignored_flaky_tools = {
        t.strip().lower()
        for t in os.getenv("AQ_REPORT_FLAKY_TOOL_IGNORE", "run_sandboxed,shell_execute").split(",")
        if t.strip()
    }
    for tool, stats in sorted(recent_tool_stats.items(), key=lambda item: (-item[1]["calls"], item[0])):
        calls = int(stats.get("calls", 0) or 0)
        if calls <= 0:
            continue
        if float(stats.get("p95_ms", 0.0) or 0.0) > 5000.0:
            snapshot["slow_tools"].append(
                {
                    "tool": tool,
                    "calls": calls,
                    "p95_ms": round(float(stats.get("p95_ms", 0.0) or 0.0), 1),
                }
            )
        if tool.lower() not in ignored_flaky_tools and float(stats.get("success_pct", 0.0) or 0.0) < 90.0:
            snapshot["flaky_tools"].append(
                {
                    "tool": tool,
                    "calls": calls,
                    "success_pct": round(float(stats.get("success_pct", 0.0) or 0.0), 1),
                    "error_count": int(stats.get("error_count", 0) or 0),
                    "client_error_count": int(stats.get("client_error_count", 0) or 0),
                }
            )
    snapshot["healthy"] = not snapshot["slow_tools"] and not snapshot["flaky_tools"]
    return snapshot


def historical_watchlist(tool_stats: Dict[str, dict], recent_tool_stats: Dict[str, dict]) -> Dict[str, Any]:
    """Summarize longer-window issues that are not active in the recent window."""
    watch: Dict[str, Any] = {
        "available": True,
        "window": "7d",
        "slow_tools": [],
        "flaky_tools": [],
    }
    ignored_flaky_tools = {
        t.strip().lower()
        for t in os.getenv("AQ_REPORT_FLAKY_TOOL_IGNORE", "run_sandboxed,shell_execute").split(",")
        if t.strip()
    }
    for tool, stats in sorted(tool_stats.items(), key=lambda item: (-item[1]["calls"], item[0])):
        fresh = recent_tool_stats.get(tool) if recent_tool_stats and tool in recent_tool_stats else None
        if fresh is not None and int(fresh.get("calls", 0) or 0) > 0:
            continue
        calls = int(stats.get("calls", 0) or 0)
        if calls <= 0:
            continue
        if float(stats.get("p95_ms", 0.0) or 0.0) > 5000.0:
            watch["slow_tools"].append({
                "tool": tool,
                "calls": calls,
                "p95_ms": round(float(stats.get("p95_ms", 0.0) or 0.0), 1),
            })
        if tool.lower() not in ignored_flaky_tools and float(stats.get("success_pct", 0.0) or 0.0) < 90.0:
            watch["flaky_tools"].append({
                "tool": tool,
                "calls": calls,
                "success_pct": round(float(stats.get("success_pct", 0.0) or 0.0), 1),
                "error_count": int(stats.get("error_count", 0) or 0),
                "client_error_count": int(stats.get("client_error_count", 0) or 0),
            })
    watch["has_items"] = bool(watch["slow_tools"] or watch["flaky_tools"])
    return watch


