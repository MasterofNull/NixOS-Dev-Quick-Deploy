                local_pct = summary.get("local_pct")
                remote_pct = 100 - local_pct if local_pct is not None else None
                partial = " (partial)" if summary.get("partial_window") else ""
                lines.append(
                    f"  {label}{partial}: local {summary.get('local_n', 0)}"
