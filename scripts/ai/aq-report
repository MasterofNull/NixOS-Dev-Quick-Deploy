def read_tool_audit(since: datetime) -> List[dict]:
    """Read tool_audit.jsonl entries newer than `since`."""
    path = _tool_audit_path()
    if not path:
        return []
    entries = []
    try:
        with path.open(encoding="utf-8", errors="replace") as fh:
            for line in fh:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                except json.JSONDecodeError:
                    continue
                ts_raw = entry.get("timestamp", "")
                try:
                    ts = datetime.fromisoformat(ts_raw.rstrip("Z")).replace(tzinfo=timezone.utc)
                    if ts >= since:
                        entries.append(entry)
                except (ValueError, AttributeError):
                    continue
    except OSError:
        pass
    return entries


def _entry_ts_utc(entry: Dict[str, Any]) -> Optional[datetime]:
    raw = str(entry.get("timestamp", "") or "").strip()
    if not raw:
        return None
    try:
        return datetime.fromisoformat(raw.rstrip("Z")).replace(tzinfo=timezone.utc)
    except ValueError:
        return None


def _score_ts_utc(raw: Any) -> Optional[datetime]:
    """Parse eval score timestamps across legacy and ISO8601 formats."""
    text = str(raw or "").strip()
    if not text:
        return None
    parse_attempts = (
        lambda v: datetime.fromisoformat(v.rstrip("Z")),
        lambda v: datetime.strptime(v, "%Y%m%dT%H%M%SZ"),
    )
    for parser in parse_attempts:
        try:
            parsed = parser(text)
            if parsed.tzinfo is None:
                parsed = parsed.replace(tzinfo=timezone.utc)
            else:
                parsed = parsed.astimezone(timezone.utc)
            return parsed
        except ValueError:
            continue
    return None


def read_eval_scores(since: datetime) -> List[dict]:
    """Read eval_scores rows from scores.sqlite."""
    if not EVAL_SCORES_DB.exists():
        return []
    try:
        conn = sqlite3.connect(str(EVAL_SCORES_DB))
        conn.row_factory = sqlite3.Row
        # strategy_tag column added in Phase 18.2.1; use IFNULL for older DBs
        cur = conn.execute(
            "SELECT timestamp, config, passed, total, pct_passed, threshold, "
            "IFNULL(strategy_tag, '') AS strategy_tag "
            "FROM eval_scores",
        )
        rows = [dict(r) for r in cur.fetchall()]
        conn.close()
        filtered_rows = []
        for row in rows:
            parsed = _score_ts_utc(row.get("timestamp"))
            if parsed is None or parsed < since:
                continue
            row["_parsed_ts"] = parsed
            filtered_rows.append(row)
        filtered_rows.sort(key=lambda r: r["_parsed_ts"])
        for row in filtered_rows:
            row.pop("_parsed_ts", None)
        return filtered_rows
    except (sqlite3.Error, OSError):
        return []


def strategy_leaderboard(rows: List[dict]) -> List[dict]:
    """Group eval rows by strategy_tag and compute mean pct_passed per tag."""
    from collections import defaultdict
    buckets: Dict[str, List[int]] = defaultdict(list)
    for r in rows:
        tag = r.get("strategy_tag") or "untagged"
        buckets[tag].append(r["pct_passed"])
    board = [
        {"tag": tag, "mean_pct": round(sum(v) / len(v), 1), "runs": len(v)}
        for tag, v in buckets.items()
    ]
    return sorted(board, key=lambda x: -x["mean_pct"])


def read_prompt_registry() -> List[dict]:
    """Load ai-stack/prompts/registry.yaml; return list of prompt entries."""
    registry_path = Path(
        os.getenv("REGISTRY_PATH",
                  str(Path(__file__).parent.parent.parent / "ai-stack/prompts/registry.yaml"))
    )
    if not registry_path.exists():
        return []
    try:
        import yaml  # type: ignore[import-untyped]
        with registry_path.open(encoding="utf-8") as fh:
            data = yaml.safe_load(fh)
        return data.get("prompts", []) if data else []
    except Exception:
