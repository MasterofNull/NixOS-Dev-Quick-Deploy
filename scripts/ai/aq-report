            review_required = int(intent_compliance.get("reviewer_gate_required_runs", 0) or 0)
            reviewed = int(intent_compliance.get("sessions_with_reviews", 0) or 0)
            accepted = int(intent_compliance.get("accepted_reviews", 0) or 0)
            rejected = int(intent_compliance.get("rejected_reviews", 0) or 0)
            pending = int(intent_compliance.get("pending_reviews", 0) or 0)
