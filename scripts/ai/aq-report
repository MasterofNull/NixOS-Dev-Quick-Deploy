            if t.strip()
        }
        visible_tool_rows = [
            (tool, stats)
            for tool, stats in sorted(tool_stats.items(), key=lambda x: -x[1]["calls"])
            if tool.lower() not in ignored_flaky_tools
        ]
        suppressed_tool_rows = [
            (tool, stats)
            for tool, stats in sorted(tool_stats.items(), key=lambda x: -x[1]["calls"])
            if tool.lower() in ignored_flaky_tools
        ]
        lines.append(f"  {'Tool':<30} {'Valid':>6} {'P50ms':>7} {'P95ms':>7} {'OK%':>6} {'Err':>5} {'4xx':>5}")
        lines.append(f"  {'─'*30} {'─'*6} {'─'*7} {'─'*7} {'─'*6} {'─'*5} {'─'*5}")
        for tool, s in visible_tool_rows:
            lines.append(
                f"  {tool:<30} {s['calls']:>6} {s['p50_ms']:>7.0f} {s['p95_ms']:>7.0f} {s['success_pct']:>5.1f}% {int(s.get('error_count', 0) or 0):>5} {int(s.get('client_error_count', 0) or 0):>5}"
            )
        if not visible_tool_rows:
            lines.append("  (all observed tools are currently in the flaky-ignore list)")
        if suppressed_tool_rows:
            suppressed_names = ", ".join(t for t, _ in suppressed_tool_rows[:4])
            lines.append(f"  Suppressed noisy tools: {suppressed_names}")
        total_client_errors = sum(int(s.get("client_error_count", 0) or 0) for s in tool_stats.values())
        total_unknown = sum(int(s.get("unknown_count", 0) or 0) for s in tool_stats.values())
        if total_client_errors or total_unknown:
            lines.append("  Valid counts backend-attributable calls only; invalid client requests are shown in 4xx.")
        if total_client_errors:
            lines.append(f"  Ignored client-side 4xx rows: {total_client_errors}")
        if total_unknown:
            lines.append(f"  Ignored ambiguous audit rows: {total_unknown}")
    else:
        lines.append("  No tool audit data.")
    lines.append("")

    lines += ["[ 2. Routing Split ]"]
