def _na(val: Optional[float], fmt: str = ".1f", suffix: str = "") -> str:
    if val is None:
        return "n/a"
    return f"{val:{fmt}}{suffix}"


def _tool_reliability_context(stats: Dict[str, Any], fresh: Optional[Dict[str, Any]] = None) -> str:
    parts: List[str] = []
    server_errors = int(stats.get("error_count", 0) or 0)
    client_errors = int(stats.get("client_error_count", 0) or 0)
    if server_errors:
        parts.append(f"{server_errors} backend failures")
    if client_errors:
        parts.append(f"{client_errors} invalid client requests excluded")
    if fresh is None or int(fresh.get("calls", 0) or 0) == 0:
        parts.append("no recent calls in the last hour")
    else:
        parts.append(
            f"last hour backend OK%={_na(fresh.get('success_pct'), '.1f', '%')} across {int(fresh.get('calls', 0) or 0)} valid calls"
        )
    return "; ".join(parts)


def _tool_reliability_interpretation(
    tool: str,
    stats: Dict[str, Any],
    fresh: Optional[Dict[str, Any]] = None,
    *,
    historical_only: bool = False,
) -> Dict[str, Any]:
    """Classify whether reliability noise is active backend failure or caller/background debt."""
    tool_name = str(tool or "").strip().lower()
    server_errors = int(stats.get("error_count", 0) or 0)
    client_errors = int(stats.get("client_error_count", 0) or 0)
    fresh_server_errors = int((fresh or {}).get("error_count", 0) or 0)
    fresh_client_errors = int((fresh or {}).get("client_error_count", 0) or 0)

    if tool_name == "store_agent_memory":
        if fresh is not None and fresh_server_errors == 0 and fresh_client_errors > 0:
            return {
                "status": "caller_input_only",
                "active_incident": False,
                "note": (
                    f"recent caller-side validation noise only ({fresh_client_errors} invalid memory-write attempts); "
                    "backend writes are healthy"
                ),
            }
        if fresh is not None and fresh_server_errors > 0:
            return {
                "status": "active_backend_failures",
                "active_incident": True,
                "note": (
                    f"recent backend memory-write failures remain active ({fresh_server_errors} failures in the last hour)"
                ),
            }
        if historical_only and server_errors > 0:
            return {
                "status": "historical_backend_debt",
                "active_incident": False,
                "note": (
                    f"historical backend memory-write debt remains visible ({server_errors} backend failures), "
                    "but no recent calls are active in the last hour"
                ),
            }
        if server_errors > 0 and fresh is not None and fresh_server_errors == 0:
            return {
                "status": "historical_backend_debt",
                "active_incident": False,
                "note": (
                    f"historical backend memory-write failures exist ({server_errors}), "
                    "but recent backend writes are healthy"
                ),
            }
    return {
        "status": "active_backend_failures" if server_errors > 0 else "healthy",
        "active_incident": server_errors > 0,
        "note": _tool_reliability_context(stats, fresh),
    }


def _backend_reliability_summary(item: Dict[str, Any], *, window_label: str, recent: bool) -> str:
    calls = int(item.get("calls", 0) or 0)
    ok_pct = _na(item.get("success_pct"), '.1f', '%')
    client_errors = int(item.get("client_error_count", 0) or 0)
    recovered_fallbacks = int(item.get("recovered_fallback_count", 0) or 0)
    provider_recovered = int(item.get("provider_recovered_count", 0) or 0)
    period = "recent valid calls" if recent else "valid calls"
    prefix = f"{window_label} " if window_label else ""
    text = f"{prefix}backend OK {ok_pct} across {calls} {period}"
    if client_errors:
        text += f" (+{client_errors} invalid client requests)"
    text += f" (server={item.get('error_count', 0)})"
    if recovered_fallbacks:
        text += f" (recovered-fallbacks={recovered_fallbacks})"
    if provider_recovered and provider_recovered != recovered_fallbacks:
        text += f" (provider-recovered={provider_recovered})"
    return text


def _tool_latency_context(stats: Dict[str, Any], fresh: Optional[Dict[str, Any]] = None) -> str:
    if fresh is None or int(fresh.get("calls", 0) or 0) == 0:
        return "no recent calls in the last hour"
    return (
        f"last hour p95={_na(fresh.get('p95_ms'), '.0f', 'ms')} across "
        f"{int(fresh.get('calls', 0) or 0)} calls"
    )


def _autorun_block_context(recent_semantic_autorun: Optional[Dict[str, Any]] = None) -> str:
    if not recent_semantic_autorun or not recent_semantic_autorun.get("available"):
        return "recent autorun state unavailable"
    recent_calls = int(recent_semantic_autorun.get("route_calls", 0) or 0)
    recent_blocked = int(recent_semantic_autorun.get("tool_security_blocked_total", 0) or 0)
    if recent_calls == 0:
        return "no recent autorun traffic in the last hour"
    if recent_blocked == 0:
        return f"last hour clean across {recent_calls} autorun calls"
    return f"last hour blocked {recent_blocked} tool actions across {recent_calls} autorun calls"


def _format_retrieval_mix(mix: Optional[Dict[str, Any]]) -> str:
    if not mix:
        return "n/a"
    parts: List[str] = []
    for key in ("route_search", "tree_search", "recall_agent_memory"):
        value = int(mix.get(key, 0) or 0)
        if value > 0:
            parts.append(f"{key}={value}")
    return ", ".join(parts) if parts else "none"


def _rag_prewarm_candidates(
    top_prompts: List[dict],
    recent_mix: Dict[str, int],
    cache: Optional[Dict[str, Any]] = None,
    route_latency: Optional[Dict[str, Any]] = None,
    retrieval_breadth: Optional[Dict[str, Any]] = None,
    memory_recall_diagnosis: Optional[str] = None,
) -> List[Dict[str, str]]:
    candidates: List[Dict[str, str]] = []
    if not top_prompts:
        return candidates
    cache = cache if isinstance(cache, dict) else {}
    route_latency = route_latency if isinstance(route_latency, dict) else {}
    retrieval_breadth = retrieval_breadth if isinstance(retrieval_breadth, dict) else {}
    route_p95 = route_latency.get("backend_valid_p95_ms")
    if route_p95 is None:
        route_p95 = route_latency.get("actionable_p95_ms")
    if route_p95 is None:
        route_p95 = route_latency.get("p95_ms")
    if route_p95 is None:
        route_p95 = route_latency.get("overall_p95_ms")
    cache_hit_pct = cache.get("hit_pct")
    breadth_avg = retrieval_breadth.get("avg_collection_count")

    scored_candidates: List[Dict[str, Any]] = []
    fallback_candidates: List[Dict[str, Any]] = []
    for idx, prompt in enumerate(top_prompts):
        pid = str(prompt.get("id", "") or "").strip()
        if not pid:
            continue
        name = str(prompt.get("name", "") or "").strip()
        prompt_score = float(prompt.get("mean_score", 0.0) or 0.0)
        family = None
        if "route_search" in pid:
            family = "route_search"
        elif "memory_recall" in pid:
            family = "memory_recall"
        elif "gap" in pid or "query_expansion" in pid:
            family = "gap"
        if family is None:
            fallback_candidates.append(
                {
                    "id": pid,
                    "name": name,
                    "score": int(round(prompt_score * 100)),
                    "reason": "top prompt fallback",
                    "_rank": idx,
                }
            )
            continue
        score = int(round(prompt_score * 100))
        reasons: List[str] = []
        if family == "route_search":
            if route_p95 is not None and float(route_p95) >= 2500.0:
                score += 60
                reasons.append("high route_search latency")
            if cache_hit_pct is not None and float(cache_hit_pct) < 60.0:
                score += 45
                reasons.append("weak semantic cache hit rate")
            if int(recent_mix.get("route_search", 0) or 0) > 0:
                score += 30
                reasons.append("recent route_search usage")
        if family == "memory_recall":
            if memory_recall_diagnosis == "unused":
                score += 55
                reasons.append("memory recall underused")
            elif memory_recall_diagnosis == "weak":
                score += 20
                reasons.append("memory recall quality needs refresh")
            if int(recent_mix.get("recall_agent_memory", 0) or 0) > 0:
                score += 20
                reasons.append("recent memory recall usage")
        if family == "gap":
            if breadth_avg is not None and float(breadth_avg) > 2.5:
                score += 35
                reasons.append("retrieval breadth remains high")
            if int(recent_mix.get("tree_search", 0) or 0) > 0:
                score += 20
                reasons.append("recent gap detection usage")
        scored_candidates.append(
            {
                "id": pid,
                "name": name,
                "score": score,
                "reason": reasons[0] if reasons else "top prompt family match",
                "_rank": idx,
            }
        )

    for candidate in sorted(scored_candidates, key=lambda item: (-int(item["score"]), int(item["_rank"]))):
        item = {
            "id": str(candidate.get("id", "")),
            "name": str(candidate.get("name", "")),
            "score": int(candidate.get("score", 0) or 0),
            "reason": str(candidate.get("reason", "")),
        }
        if item not in candidates:
            candidates.append(item)
    if not candidates:
        for candidate in sorted(fallback_candidates, key=lambda item: (-int(item["score"]), int(item["_rank"]))):
            item = {
                "id": str(candidate.get("id", "")),
                "name": str(candidate.get("name", "")),
                "score": int(candidate.get("score", 0) or 0),
                "reason": str(candidate.get("reason", "")),
            }
            if item not in candidates:
                candidates.append(item)
    return candidates[:3]


def _memory_recall_quality(entries: List[dict]) -> Dict[str, Any]:
    attempts = 0
    misses = 0
    for entry in entries:
        if str(entry.get("tool_name", "")).strip().lower() != "recall_agent_memory":
            continue
        metadata = entry.get("metadata") if isinstance(entry.get("metadata"), dict) else {}
        attempts += 1
        if bool(metadata.get("memory_recall_miss")):
            misses += 1
    return {
        "attempts": attempts,
        "misses": misses,
        "miss_pct": round(100.0 * misses / attempts, 1) if attempts else None,
    }


def rag_posture(
    tool_stats: Dict[str, dict],
    recent_tool_stats: Dict[str, dict],
    recent_audit_entries: List[dict],
    cache: Dict[str, Any],
    gaps: List[dict],
    top_prompts: Optional[List[dict]] = None,
    route_latency: Optional[Dict[str, Any]] = None,
    retrieval_breadth: Optional[Dict[str, Any]] = None,
) -> Dict[str, Any]:
    """Summarize retrieval/RAG posture from live traffic, cache posture, and actionable gaps."""
    retrieval_tools = ("route_search", "tree_search", "recall_agent_memory")
    recent_mix = {
        name: int((recent_tool_stats.get(name) or {}).get("calls", 0) or 0)
        for name in retrieval_tools
    }
    total_mix = {
        name: int((tool_stats.get(name) or {}).get("calls", 0) or 0)
        for name in retrieval_tools
    }
    recent_calls = sum(recent_mix.values())
    total_calls = sum(total_mix.values())
    actionable_gaps = [
        g for g in gaps
        if int(g.get("occurrences", 1) or 0) >= 3
        and not _is_synthetic_gap(str(g.get("query_text", "")))
        and not _is_curated_stale_gap(str(g.get("query_text", "")))
    ]
    status = "healthy"
    reasons: List[str] = []
    cache_context = _cache_sample_context(cache) if cache.get("available") else None
    cache_sample_total = int(cache.get("sample_total", 0) or 0)
    cache_hit_pct = cache.get("hit_pct") if cache.get("available") else None
    if recent_calls == 0:
        status = "historical"
        reasons.append("no recent retrieval traffic")
    if actionable_gaps:
        status = "watch"
        reasons.append(f"{len(actionable_gaps)} actionable gaps")
    if cache.get("available"):
        total_cache = cache_sample_total or (int(cache.get("hits", 0) or 0) + int(cache.get("misses", 0) or 0))
        hit_pct = cache.get("hit_pct")
        if status != "watch" and recent_calls > 0 and total_cache < 50:
            status = "low_sample"
            reasons.append(f"cache sample still warming ({total_cache} samples)")
            cache_hit_pct = None
        if total_cache >= 50 and hit_pct is not None and float(hit_pct) < 20.0:
            status = "watch"
            reasons.append(f"cache hit rate {_na(hit_pct, '.1f', '%')}")
    dominant_recent = max(recent_mix.items(), key=lambda item: item[1])[0] if recent_calls > 0 else None
    dominant_total = max(total_mix.items(), key=lambda item: item[1])[0] if total_calls > 0 else None
    route_recent = int(recent_mix.get("route_search", 0) or 0)
    memory_recent = int(recent_mix.get("recall_agent_memory", 0) or 0)
    tree_recent = int(recent_mix.get("tree_search", 0) or 0)
    recall_quality = _memory_recall_quality(recent_audit_entries)
    recall_miss_pct = recall_quality.get("miss_pct")
    memory_recall_diagnosis = "healthy"
    memory_recall_actions: List[str] = []
    if route_recent >= 12 and memory_recent <= max(2, int(route_recent * 0.15)):
        memory_recall_diagnosis = "unused"
        reasons.append("memory recall is lightly used relative to route_search")
        memory_recall_actions.append(
            "recall prior context before broad route_search on continuation and long-horizon repo tasks"
        )
    if recall_miss_pct is not None and float(recall_miss_pct) >= 50.0:
        memory_recall_diagnosis = "weak"
        reasons.append(f"memory recall misses are high ({_na(recall_miss_pct, '.1f', '%')})")
        memory_recall_actions = [
            "persist sharper milestone summaries or recent task checkpoints before relying on recall"
        ]
    elif recent_calls == 0:
        memory_recall_diagnosis = "historical"
    prewarm_candidates = _rag_prewarm_candidates(
        top_prompts or [],
        recent_mix,
        cache=cache,
        route_latency=route_latency,
        retrieval_breadth=retrieval_breadth,
        memory_recall_diagnosis=memory_recall_diagnosis,
    )
    return {
        "available": True,
        "status": status,
        "recent_retrieval_calls": recent_calls,
        "total_retrieval_calls": total_calls,
        "actionable_gap_count": len(actionable_gaps),
        "cache_hit_pct": cache_hit_pct,
        "cache_sample_total": cache_sample_total if cache.get("available") else 0,
        "cache_context": cache_context,
        "retrieval_mix": {
            "recent": recent_mix,
            "total": total_mix,
            "dominant_recent": dominant_recent,
            "dominant_total": dominant_total,
        },
        "memory_recall_share_pct": round(100.0 * memory_recent / recent_calls, 1) if recent_calls else None,
        "memory_recall_attempts": int(recall_quality.get("attempts", 0) or 0),
        "memory_recall_misses": int(recall_quality.get("misses", 0) or 0),
        "memory_recall_miss_pct": recall_miss_pct,
        "memory_recall_diagnosis": memory_recall_diagnosis,
        "memory_recall_actions": memory_recall_actions,
        "tree_search_share_pct": round(100.0 * tree_recent / recent_calls, 1) if recent_calls else None,
        "prewarm_candidates": prewarm_candidates,
        "reasons": reasons,
    }


def recent_health_snapshot(
    recent_tool_stats: Dict[str, dict],
    recent_provider_fallbacks: Optional[Dict[str, Any]] = None,
) -> Dict[str, Any]:
    """Summarize active issues in the recent monitoring window."""
    snapshot: Dict[str, Any] = {
        "available": True,
        "window": "1h",
        "slow_tools": [],
        "flaky_tools": [],
    }
    ignored_flaky_tools = {
        t.strip().lower()
        for t in os.getenv("AQ_REPORT_FLAKY_TOOL_IGNORE", "run_sandboxed,shell_execute").split(",")
        if t.strip()
    }
    for tool, stats in sorted(recent_tool_stats.items(), key=lambda item: (-item[1]["calls"], item[0])):
        calls = int(stats.get("calls", 0) or 0)
        if calls <= 0:
            continue
        if float(stats.get("p95_ms", 0.0) or 0.0) > 5000.0:
            snapshot["slow_tools"].append(
                {
                    "tool": tool,
                    "calls": calls,
                    "p95_ms": round(float(stats.get("p95_ms", 0.0) or 0.0), 1),
                }
            )
        if tool.lower() not in ignored_flaky_tools and float(stats.get("success_pct", 0.0) or 0.0) < 90.0:
            interpretation = _tool_reliability_interpretation(tool, stats, stats)
            item = {
                "tool": tool,
                "calls": calls,
                "success_pct": round(float(stats.get("success_pct", 0.0) or 0.0), 1),
                "error_count": int(stats.get("error_count", 0) or 0),
                "client_error_count": int(stats.get("client_error_count", 0) or 0),
                "recovered_fallback_count": int(stats.get("recovered_fallback_count", 0) or 0),
                "active_incident": bool(interpretation.get("active_incident", False)),
                "reliability_status": str(interpretation.get("status", "")),
                "reliability_note": str(interpretation.get("note", "")),
            }
            if tool == "route_search" and recent_provider_fallbacks and recent_provider_fallbacks.get("available"):
                item["provider_recovered_count"] = int(recent_provider_fallbacks.get("recovered_count", 0) or 0)
            snapshot["flaky_tools"].append(item)
    snapshot["healthy"] = not snapshot["slow_tools"] and not snapshot["flaky_tools"]
    return snapshot


def historical_watchlist(tool_stats: Dict[str, dict], recent_tool_stats: Dict[str, dict]) -> Dict[str, Any]:
    """Summarize longer-window issues that are not active in the recent window."""
    watch: Dict[str, Any] = {
        "available": True,
        "window": "7d",
        "slow_tools": [],
        "flaky_tools": [],
    }
    ignored_flaky_tools = {
        t.strip().lower()
        for t in os.getenv("AQ_REPORT_FLAKY_TOOL_IGNORE", "run_sandboxed,shell_execute").split(",")
        if t.strip()
    }
    for tool, stats in sorted(tool_stats.items(), key=lambda item: (-item[1]["calls"], item[0])):
        fresh = recent_tool_stats.get(tool) if recent_tool_stats and tool in recent_tool_stats else None
        if fresh is not None and int(fresh.get("calls", 0) or 0) > 0:
            continue
        calls = int(stats.get("calls", 0) or 0)
        if calls <= 0:
            continue
        if float(stats.get("p95_ms", 0.0) or 0.0) > 5000.0:
            watch["slow_tools"].append({
                "tool": tool,
                "calls": calls,
                "p95_ms": round(float(stats.get("p95_ms", 0.0) or 0.0), 1),
            })
        if tool.lower() not in ignored_flaky_tools and float(stats.get("success_pct", 0.0) or 0.0) < 90.0:
            interpretation = _tool_reliability_interpretation(tool, stats, fresh, historical_only=True)
            watch["flaky_tools"].append({
                "tool": tool,
                "calls": calls,
                "success_pct": round(float(stats.get("success_pct", 0.0) or 0.0), 1),
                "error_count": int(stats.get("error_count", 0) or 0),
                "client_error_count": int(stats.get("client_error_count", 0) or 0),
                "recovered_fallback_count": int(stats.get("recovered_fallback_count", 0) or 0),
                "active_incident": bool(interpretation.get("active_incident", False)),
                "reliability_status": str(interpretation.get("status", "")),
                "reliability_note": str(interpretation.get("note", "")),
            })
    watch["has_items"] = bool(watch["slow_tools"] or watch["flaky_tools"])
    return watch


def _format_provider_fallback_statuses(status_counts: List[Tuple[int, int]]) -> str:
    labels = [f"{status}={count}" for status, count in status_counts[:3]]
    return ", ".join(labels)


def format_md(
    since_label: str,
    tool_stats: Dict[str, dict],
    route: Dict[str, Any],
    recent_route: Dict[str, Any],
    routing_windows: Dict[str, Any],
    cache: Dict[str, Any],
    cache_prewarm: Dict[str, Any],
    eval_trend: Dict[str, Any],
    leaderboard: List[dict],
    top_prompts: List[dict],
    gaps: List[dict],
    rag_posture_summary: Dict[str, Any],
    recent_health: Dict[str, Any],
    continue_editor: Dict[str, Any],
    continue_editor_windows: Dict[str, Any],
    shared_skill_registry: Dict[str, Any],
    delegated_prompt_failures: Dict[str, Any],
    delegated_prompt_failure_windows: Dict[str, Any],
    remote_profile_summary: Dict[str, Any],
    remote_profile_windows: Dict[str, Any],
    route_latency_decomposition: Dict[str, Any],
    retrieval_breadth: Dict[str, Any],
    retrieval_breadth_windows: Dict[str, Any],
    provider_fallbacks: Dict[str, Any],
    historical_watch: Dict[str, Any],
    recs: List[str],
    adoption: Optional[Dict[str, Any]] = None,
    recent_hint_adoption: Optional[Dict[str, Any]] = None,
    intent_compliance: Optional[Dict[str, Any]] = None,
    security_auditor: Optional[Dict[str, Any]] = None,
    semantic_autorun: Optional[Dict[str, Any]] = None,
    tooling_quality: Optional[Dict[str, Any]] = None,
    hint_diversity_stats: Optional[Dict[str, Any]] = None,
    recent_hint_diversity_stats: Optional[Dict[str, Any]] = None,
    historical_hint_watch: Optional[Dict[str, Any]] = None,
    agent_lessons: Optional[Dict[str, Any]] = None,
    feedback_acceleration: Optional[Dict[str, Any]] = None,
    gap_remediation: Optional[Dict[str, Any]] = None,
    llama_benchmark_summary: Optional[Dict[str, Any]] = None,
) -> str:
    lines = [
        f"# AI Stack Performance Report — last {since_label}",
        f"*Generated: {datetime.now(tz=timezone.utc).strftime('%Y-%m-%d %H:%M UTC')}*",
        "",
    ]

    # 1. Tool performance
    lines += ["## 1. Tool Call Performance", ""]
    if tool_stats:
        lines += [
            "| Tool | Valid | P50 ms | P95 ms | Success % | Err | 4xx |",
            "|------|------:|-------:|-------:|----------:|----:|----:|",
        ]
        for tool, s in sorted(tool_stats.items(), key=lambda x: -x[1]["calls"]):
            lines.append(
                f"| `{tool}` | {s['calls']} | {s['p50_ms']:.0f} | {s['p95_ms']:.0f} | {s['success_pct']} | {int(s.get('error_count', 0) or 0)} | {int(s.get('client_error_count', 0) or 0)} |"
            )
        total_client_errors = sum(int(s.get("client_error_count", 0) or 0) for s in tool_stats.values())
        total_unknown = sum(int(s.get("unknown_count", 0) or 0) for s in tool_stats.values())
        if total_client_errors or total_unknown:
            lines.append("")
            lines.append("Monitoring notes:")
            lines.append("- `Valid` counts backend-attributable calls only; invalid client requests are shown in `4xx`.")
            if total_client_errors:
                lines.append(f"- Ignored client-side 4xx rows: **{total_client_errors}**")
            if total_unknown:
                lines.append(f"- Ignored ambiguous audit rows without final outcome: **{total_unknown}**")
    else:
        lines.append("*No tool audit entries found for this window.*")
    lines.append("")

    # 2. Routing split
    lines += ["## 2. Routing Split", ""]
    if route["available"]:
        lines += [
            f"- Local requests: **{route['local_n']}** ({_na(route['local_pct'], '.1f', '%')})",
            f"- Remote requests: **{route['remote_n']}** ({_na(100 - route['local_pct'] if route['local_pct'] is not None else None, '.1f', '%')})",
        ]
        if route.get("fallback_used"):
            lines.append(
                f"- Backend split metric missing; observed **{route['query_ok_n']}** successful `/query` requests."
            )
        lines.append(f"- Recent context: {_routing_recent_context(recent_route)}")
        route_windows = routing_windows.get("windows") if isinstance(routing_windows, dict) else {}
        if route_windows:
            for label in ("1h", "24h", "7d"):
                summary = route_windows.get(label) if isinstance(route_windows, dict) else None
                if not isinstance(summary, dict) or not summary.get("available"):
                    lines.append(f"- {label}: routing history unavailable")
                    continue
                local_pct = summary.get("local_pct")
                remote_pct = 100 - local_pct if local_pct is not None else None
                partial = " (partial)" if summary.get("partial_window") else ""
                lines.append(
                    f"- {label}{partial}: local **{summary.get('local_n', 0)}**"
                    f" ({_na(local_pct, '.1f', '%')}), remote **{summary.get('remote_n', 0)}**"
                    f" ({_na(remote_pct, '.1f', '%')})"
                )
    else:
        lines.append("*Prometheus unreachable — routing metrics unavailable.*")
    lines.append("")

    # 3. Cache hit rate
    lines += ["## 3. Semantic Cache", ""]
    if cache["available"]:
        lines += [
            f"- Hits: **{cache['hits']}**, Misses: **{cache['misses']}**",
            f"- Hit rate: **{_na(cache['hit_pct'], '.1f', '%')}**",
        ]
        cache_context = _cache_sample_context(cache)
        if cache_context:
            lines.append(f"- Context: {cache_context}")
        if cache_prewarm.get("available"):
            lines.append(
                f"- Cache prewarm timer: **{cache_prewarm.get('enabled_state', 'unknown')}** / "
                f"active **{cache_prewarm.get('active_state', 'unknown')}**"
            )
            # Show last run status
            if cache_prewarm.get("last_run_queries_ok") is not None:
                ok = cache_prewarm.get("last_run_queries_ok", 0)
                fail = cache_prewarm.get("last_run_queries_fail", 0)
                success_icon = "✅" if fail == 0 else "⚠️"
                lines.append(
                    f"- Last prewarm run: **{ok} OK, {fail} FAIL** {success_icon}"
                )
                if cache_prewarm.get("last_activation"):
                    lines.append(f"  - Last activation: {cache_prewarm['last_activation']}")
    else:
        lines.append("*Cache metrics unavailable.*")
    lines.append("")

    # 4. Eval score trend
    lines += ["## 4. Eval Score Trend", ""]
    if eval_trend.get("available"):
        lines += [
            f"- Runs in window: {eval_trend['n_runs']}",
            f"- Latest: **{eval_trend['latest_pct']}%**  |  Mean: {eval_trend['mean_pct']}%"
            f"  |  Range: {eval_trend['min_pct']}–{eval_trend['max_pct']}%",
            f"- Trend: **{eval_trend['trend']}**",
        ]
    else:
        lines.append("*No eval runs found for this window.*")
    lines.append("")

    # 5. Strategy Leaderboard (18.2.2)
    lines += ["## 5. Strategy Leaderboard", ""]
    visible = [r for r in leaderboard if r["tag"] != "untagged"]
    if len(visible) >= 2:
        lines += [
            "| Rank | Strategy | Mean % | Runs |",
            "|-----:|----------|-------:|-----:|",
        ]
        for i, r in enumerate(visible[:5], 1):
            lines.append(f"| {i} | `{r['tag']}` | {r['mean_pct']} | {r['runs']} |")
        lines.append("")
        lines.append(f"*Run `scripts/automation/run-eval.sh --strategy <name>` to tag a new variant.*")
    else:
        lines.append("*No tagged strategy runs yet. Use `--strategy LABEL` with run-eval.sh.*")
    lines.append("")

    # 6. Recommended Prompts (18.3.3)
    lines += ["## 6. Recommended Prompts", ""]
    if top_prompts:
        for p in top_prompts:
            lines.append(
                f"- **{p['name']}** (`{p['id']}`) — score {p['mean_score']:.1%}  \n"
                f"  {p.get('description', '').strip()[:120]}"
            )
    else:
        lines.append("*Run `scripts/ai/aq-prompt-eval` to score prompts in registry.yaml.*")
    lines.append("")

    # 7. Query gaps
    lines += ["## 7. Top Query Gaps", ""]
    if gaps:
        lines += [
            "| # | Query | Score | Collection | Occurrences |",
            "|---|-------|------:|-----------|------------:|",
        ]
        for i, g in enumerate(gaps[:10], 1):
            q = str(g.get("query_text", ""))[:60].replace("|", "\\|")
            lines.append(
                f"| {i} | {q} | {g.get('score', 0):.2f} | {g.get('collection', '')} | {g.get('occurrences', 1)} |"
            )
        lines += [
            "",
            "*Import suggestion: `aidb import --query \"<query text>\"` to pull relevant docs.*",
        ]
    else:
        lines.append("*No query gaps found (Postgres unreachable or table empty).*")
    lines.append("")

    # 8. Recent health snapshot
    lines += ["## 7b. RAG Posture", ""]
    if rag_posture_summary.get("available"):
        lines += [
            f"- Status: **{rag_posture_summary.get('status', 'unknown')}**",
            f"- Recent retrieval calls: **{rag_posture_summary.get('recent_retrieval_calls', 0)}**",
            f"- Actionable gaps: **{rag_posture_summary.get('actionable_gap_count', 0)}**",
        ]
        recent_mix = ((rag_posture_summary.get("retrieval_mix") or {}).get("recent") or {})
        if recent_mix:
            lines.append(f"- Recent retrieval mix: {_format_retrieval_mix(recent_mix)}")
        memory_share = rag_posture_summary.get("memory_recall_share_pct")
        memory_miss_pct = rag_posture_summary.get("memory_recall_miss_pct")
        memory_diagnosis = rag_posture_summary.get("memory_recall_diagnosis")
        memory_actions = rag_posture_summary.get("memory_recall_actions") or []
        if memory_share is not None:
            lines.append(f"- Memory recall share: **{_na(memory_share, '.1f', '%')}**")
        if memory_miss_pct is not None:
            lines.append(f"- Memory recall miss rate: **{_na(memory_miss_pct, '.1f', '%')}**")
        if memory_diagnosis:
            lines.append(f"- Memory recall diagnosis: **{memory_diagnosis}**")
        if memory_actions:
            lines.append(f"- Memory recall remediation: {'; '.join(str(action) for action in memory_actions)}")
        if rag_posture_summary.get("cache_hit_pct") is not None:
            lines.append(f"- Cache hit rate: **{_na(rag_posture_summary.get('cache_hit_pct'), '.1f', '%')}**")
        cache_context = rag_posture_summary.get("cache_context")
        if cache_context:
            lines.append(f"- Cache context: {cache_context}")
        prewarm_candidates = rag_posture_summary.get("prewarm_candidates") or []
        if prewarm_candidates:
            labels = [
                f"`{candidate.get('id')}`"
                for candidate in prewarm_candidates
                if isinstance(candidate, dict) and str(candidate.get("id", "")).strip()
            ]
            if labels:
                lines.append(f"- Candidate prewarm prompts: {', '.join(labels)}")
        reasons = rag_posture_summary.get("reasons") or []
        if reasons:
            lines.append(f"- Notes: {', '.join(str(r) for r in reasons)}")
    else:
        lines.append("*RAG posture unavailable.*")
    lines.append("")

    lines += ["## 7c. Feedback Acceleration", ""]
    if feedback_acceleration and feedback_acceleration.get("available"):
        lines += [
            f"- Status: **{feedback_acceleration.get('status', 'unknown')}**",
            f"- Failure trend: **{feedback_acceleration.get('trend', 'unknown')}**",
            f"- Recent delegated failures: **{feedback_acceleration.get('recent_failure_count', 0)}**",
            f"- Promotable lessons: **{feedback_acceleration.get('promotable_lessons', 0)}**",
        ]
        actions = feedback_acceleration.get("actions") or []
        if actions:
            lines.append(f"- Next: {actions[0]}")
    else:
        lines.append("*Feedback acceleration unavailable.*")
    lines.append("")

    lines += ["## 7d. Gap Remediation", ""]
    if gap_remediation and gap_remediation.get("available"):
        lines += [
            f"- Status: **{gap_remediation.get('status', 'unknown')}**",
            f"- Candidate count: **{gap_remediation.get('candidate_count', 0)}**",
        ]
        top_strategies = gap_remediation.get("top_strategies") or []
        if top_strategies:
            lines.append("- Top strategies: " + ", ".join(f"`{name}` ({count})" for name, count in top_strategies[:3]))
        candidates = gap_remediation.get("candidates") or []
        if candidates:
            top = candidates[0]
            lines.append(
                f"- Top candidate: `{top.get('strategy')}` for **{top.get('topic')}** ({top.get('occurrences')}x)"
            )
    else:
        lines.append("*Gap remediation unavailable.*")
    lines.append("")

    lines += [f"## 8. Recent Health Snapshot ({recent_health.get('window', '1h')})", ""]
    if recent_health.get("healthy"):
        lines.append("*No active slow or flaky tools in the recent window.*")
    else:
        slow_tools = recent_health.get("slow_tools") or []
        flaky_tools = recent_health.get("flaky_tools") or []
        if slow_tools:
            lines.append("- Slow tools still active:")
            for item in slow_tools[:3]:
                lines.append(
                    f"  - `{item['tool']}` — p95 {item['p95_ms']:.0f}ms across {item['calls']} recent calls"
                )
        if flaky_tools:
            lines.append("- Reliability issues still active:")
            for item in flaky_tools[:3]:
                lines.append(
                    f"  - `{item['tool']}` — {_backend_reliability_summary(item, window_label='', recent=True).lstrip()}"
                )
                note = str(item.get("reliability_note", "") or "").strip()
                if note:
                    lines.append(f"    - Interpretation: {note}")
    lines.append("")

    lines += ["## 8a. Continue/Editor Health", ""]
    if not continue_editor.get("available"):
        lines.append("*Continue/editor health unavailable.*")
    elif continue_editor.get("healthy"):
        lines.append(
            f"- Healthy: **yes** ({continue_editor.get('passed_n', 0)}/{continue_editor.get('total_checks', 0)} checks passed)"
        )
    else:
        lines.append(
            f"- Healthy: **no** ({continue_editor.get('failed_n', 0)} failing check(s) out of {continue_editor.get('total_checks', 0)})"
        )
        for item in (continue_editor.get("checks") or []):
            if item.get("status") == "FAIL":
                lines.append(f"  - `{item.get('id')}` — {item.get('description')}")
        failure_categories = continue_editor.get("failure_categories") or []
        if failure_categories:
            rendered = ", ".join(f"{name}({count})" for name, count in failure_categories)
            lines.append(f"- Failure categories: {rendered}")
    window_map = continue_editor_windows.get("windows") if isinstance(continue_editor_windows, dict) else {}
    if window_map:
        for label in ("1h", "24h", "7d"):
            summary = window_map.get(label)
            if not isinstance(summary, dict) or not summary.get("available"):
                lines.append(f"- {label}: no Continue/editor history recorded")
                continue
            partial = " (partial)" if summary.get("partial_window") else ""
            lines.append(
                f"- {label}{partial}: healthy **{_na(summary.get('healthy_pct'), '.1f', '%')}**"
                f" across {summary.get('samples', 0)} snapshot(s); latest failures "
                f"{summary.get('latest_failed_n', 0)}/{summary.get('latest_total_checks', 0)}"
            )
            latest_failure_categories = summary.get("latest_failure_categories") or []
            if latest_failure_categories and not summary.get("latest_healthy"):
                rendered = ", ".join(f"{name}({count})" for name, count in latest_failure_categories)
                lines.append(f"  latest failure categories: {rendered}")
    lines.append("")

    lines += ["## 8ab. Shared Skill Registry", ""]
    if not shared_skill_registry.get("available"):
        lines.append("*Shared skill registry unavailable.*")
    elif shared_skill_registry.get("healthy"):
        lines.append(
            f"- Healthy: **yes** ({shared_skill_registry.get('approved_skill_count', 0)}/{shared_skill_registry.get('local_skill_count', 0)} shared skills visible in AIDB)"
        )
    else:
        lines.append(
            f"- Healthy: **no** ({len(shared_skill_registry.get('missing_in_aidb') or [])} missing, {len(shared_skill_registry.get('path_mismatches') or [])} mismatched)"
        )
        missing = shared_skill_registry.get("missing_in_aidb") or []
        if missing:
            lines.append(f"- Missing in AIDB: {', '.join(f'`{slug}`' for slug in missing[:8])}")
        mismatches = shared_skill_registry.get("path_mismatches") or []
        for item in mismatches[:3]:
            lines.append(f"  - `{item.get('slug')}` path drift: `{item.get('aidb_source_path')}`")
    lines.append("")

    lines += ["## 8ac. Llama Benchmark Runs", ""]
    if not llama_benchmark_summary or not llama_benchmark_summary.get("available"):
        lines.append("*Saved llama benchmark runs unavailable.*")
    elif int(llama_benchmark_summary.get("total_runs", 0) or 0) == 0:
        lines.append("*No saved llama benchmark runs in this window.*")
    else:
        lines.append(
            f"- Saved runs: **{llama_benchmark_summary.get('total_runs', 0)}**"
            f" ({llama_benchmark_summary.get('quality_passed_runs', 0)} with all quality checks passing)"
        )
        latest_run = llama_benchmark_summary.get("latest_run") or {}
        if latest_run:
            lines.append(
                f"- Latest: `{latest_run.get('run_id')}` — {latest_run.get('target_model')} @ {latest_run.get('target_ctx_size')} ctx "
                f"(warm { _na(latest_run.get('avg_warm_latency_s'), '.3f', 's') }, "
                f"{ _na(latest_run.get('avg_completion_tokens_per_second'), '.2f', ' tok/s') })"
            )
        best_latency = llama_benchmark_summary.get("best_latency_run") or {}
        if best_latency:
            lines.append(
                f"- Best latency: `{best_latency.get('run_id')}` — warm { _na(best_latency.get('avg_warm_latency_s'), '.3f', 's') }"
            )
        best_tps = llama_benchmark_summary.get("best_tps_run") or {}
        if best_tps:
            lines.append(
                f"- Best throughput: `{best_tps.get('run_id')}` — { _na(best_tps.get('avg_completion_tokens_per_second'), '.2f', ' tok/s') }"
            )
    lines.append("")

    lines += ["## 8aa. Delegated Prompt Failures", ""]
    if not delegated_prompt_failures.get("available"):
        lines.append("*Delegated prompt failure telemetry unavailable.*")
    elif int(delegated_prompt_failures.get("total_failures", 0) or 0) == 0:
        lines.append("*No delegated prompt failures recorded in this window.*")
    else:
        lines.append(f"- Failures: **{delegated_prompt_failures.get('total_failures', 0)}**")
        lines.append(f"- Salvageable: **{delegated_prompt_failures.get('salvageable_failures', 0)}** ({_na(delegated_prompt_failures.get('salvageable_pct'), '.1f', '%')})")
        lines.append(f"- Recovered via fallback: **{delegated_prompt_failures.get('recovered_failures', 0)}**")
        top_classes = delegated_prompt_failures.get("top_failure_classes") or []
        if top_classes:
            lines.append(f"- Top failure classes: {', '.join(f'`{name}` ({count})' for name, count in top_classes[:3])}")
    failure_windows = delegated_prompt_failure_windows.get("windows") if isinstance(delegated_prompt_failure_windows, dict) else {}
    if isinstance(failure_windows, dict):
        twenty_four = failure_windows.get("24h") if isinstance(failure_windows.get("24h"), dict) else {}
        seven_day = failure_windows.get("7d") if isinstance(failure_windows.get("7d"), dict) else {}
        if twenty_four.get("available") or seven_day.get("available"):
            lines.append(
                "- Failure trend: "
                f"24h={int(twenty_four.get('total_failures', 0) or 0)}"
                f" ({_na(twenty_four.get('salvageable_pct'), '.1f', '%')} salvageable), "
                f"7d={int(seven_day.get('total_failures', 0) or 0)}"
                f" ({_na(seven_day.get('salvageable_pct'), '.1f', '%')} salvageable)"
            )
    failure_trend = delegated_prompt_failure_windows.get("trend") if isinstance(delegated_prompt_failure_windows, dict) else {}
    if isinstance(failure_trend, dict) and failure_trend.get("status"):
        lines.append(f"- Failure trend status: **{failure_trend.get('status')}**")
        if failure_trend.get("summary"):
            lines.append(f"- Failure trend note: {failure_trend.get('summary')}")
        actions = failure_trend.get("actions") or []
        if actions:
            lines.append(f"- Failure trend remediation: {'; '.join(str(action) for action in actions)}")
    lines.append("")

    lines += [f"## 8aaa. Remote Profile Utilization ({remote_profile_summary.get('window', since_label)})", ""]
    if not remote_profile_summary.get("available"):
        lines.append("*No delegated remote profile usage recorded in this window.*")
    else:
        lines.append(f"- Calls: **{remote_profile_summary.get('total_calls', 0)}**")
        lines.append(f"- Success: **{_na(remote_profile_summary.get('success_pct'), '.1f', '%')}**")
        lines.append(f"- Fallback applied: **{remote_profile_summary.get('fallback_applied', 0)}**")
        lines.append(f"- Finalization applied: **{remote_profile_summary.get('finalization_applied', 0)}**")
        lines.append(
            f"- Coordinator handoff requested: **{remote_profile_summary.get('handoff_requested', 0)}**"
            f" ({_na(remote_profile_summary.get('handoff_pct'), '.1f', '%')})"
        )
        top_profiles = remote_profile_summary.get("top_profiles") or []
        if top_profiles:
            lines.append(f"- Top profiles: {', '.join(f'`{name}` ({count})' for name, count in top_profiles[:3])}")
        top_reason_classes = remote_profile_summary.get("top_backend_reason_classes") or []
        if top_reason_classes:
            lines.append(
                f"- Backend reasons: {', '.join(f'`{name}` ({count})' for name, count in top_reason_classes[:3])}"
            )
        top_task_types = remote_profile_summary.get("top_task_complexity_types") or []
        if top_task_types:
            lines.append(
                f"- Task types: {', '.join(f'`{name}` ({count})' for name, count in top_task_types[:3])}"
            )
        top_task_reasons = remote_profile_summary.get("top_task_complexity_reasons") or []
        if top_task_reasons:
            lines.append(
                f"- Task reasons: {', '.join(f'`{name}` ({count})' for name, count in top_task_reasons[:3])}"
            )
        top_response_max_tokens = remote_profile_summary.get("top_response_max_tokens") or []
        if top_response_max_tokens:
            lines.append(
                f"- Response token budgets: {', '.join(f'`{name}` ({count})' for name, count in top_response_max_tokens[:3])}"
            )
        top_roles = remote_profile_summary.get("top_requester_roles") or []
        if top_roles:
            lines.append(f"- Requester roles: {', '.join(f'`{name}` ({count})' for name, count in top_roles[:3])}")
        handoff_roles = remote_profile_summary.get("handoff_by_requester_role") or []
        if handoff_roles:
            lines.append(f"- Handoff by requester role: {', '.join(f'`{name}` ({count})' for name, count in handoff_roles[:3])}")
    lines.append("")

    lines += ["## 8aaab. Remote Profile Trends", ""]
    profile_windows = remote_profile_windows.get("windows") if isinstance(remote_profile_windows, dict) else {}
    if not profile_windows:
        lines.append("*No multi-window delegated remote-profile data available.*")
    else:
        for label in ("1h", "24h", "7d"):
            summary = profile_windows.get(label) if isinstance(profile_windows, dict) else None
            if not isinstance(summary, dict) or not summary.get("available"):
                lines.append(f"- {label}: no delegated remote profile usage recorded")
                continue
            top_profiles = summary.get("top_profiles") or []
            top_profile = top_profiles[0][0] if top_profiles else "n/a"
            partial = " (partial)" if summary.get("partial_window") else ""
            lines.append(
                f"- {label}{partial}: **{summary.get('total_calls', 0)}** calls,"
                f" success **{_na(summary.get('success_pct'), '.1f', '%')}**,"
                f" top profile `{top_profile}`"
            )
    lines.append("")

    lines += [f"## 8aaac. Route Search Latency Decomposition ({route_latency_decomposition.get('window', since_label)})", ""]
    if not route_latency_decomposition.get("available"):
        lines.append("*No route_search latency decomposition data available in this window.*")
    else:
        lines.append(
            f"- Overall p50/p95: **{_na(route_latency_decomposition.get('overall_p50_ms'), '.0f', 'ms')}** / "
            f"**{_na(route_latency_decomposition.get('overall_p95_ms'), '.0f', 'ms')}**"
        )
        if route_latency_decomposition.get("actionable_calls"):
            lines.append(
                f"- Actionable p50/p95: **{_na(route_latency_decomposition.get('actionable_p50_ms'), '.0f', 'ms')}** / "
                f"**{_na(route_latency_decomposition.get('actionable_p95_ms'), '.0f', 'ms')}**"
                f" across **{int(route_latency_decomposition.get('actionable_calls', 0) or 0)}** non-4xx calls"
            )
        if route_latency_decomposition.get("backend_valid_calls"):
            lines.append(
                f"- Backend-valid p50/p95: **{_na(route_latency_decomposition.get('backend_valid_p50_ms'), '.0f', 'ms')}** / "
                f"**{_na(route_latency_decomposition.get('backend_valid_p95_ms'), '.0f', 'ms')}**"
                f" across **{int(route_latency_decomposition.get('backend_valid_calls', 0) or 0)}** local/remote-labeled calls"
            )
        client_error_count = int(route_latency_decomposition.get("client_error_count", 0) or 0)
        backend_unclassified_count = int(route_latency_decomposition.get("backend_unclassified_count", 0) or 0)
        if client_error_count or backend_unclassified_count:
            noise_parts: List[str] = []
            if client_error_count:
                noise_parts.append(f"{client_error_count} invalid client requests")
            if backend_unclassified_count:
                noise_parts.append(f"{backend_unclassified_count} backend-unclassified actionable rows")
            lines.append(f"- Noise context: {', '.join(noise_parts)}")
        breakdown = route_latency_decomposition.get("breakdown") or []
        if breakdown:
            lines.append("- Breakdown:")
            for item in breakdown[:5]:
                lines.append(
                    f"  - `{item['label']}` — calls {item['calls']},"
                    f" p50 {_na(item.get('p50_ms'), '.0f', 'ms')},"
                    f" p95 {_na(item.get('p95_ms'), '.0f', 'ms')},"
                    f" success {_na(item.get('success_pct'), '.1f', '%')}"
                )
    lines.append("")

    lines += [f"## 8b. Retrieval Breadth ({retrieval_breadth.get('window', '1h')})", ""]
    avg_collection_count = retrieval_breadth.get("avg_collection_count")
    if avg_collection_count is None:
        lines.append("*No route_search retrieval-breadth metadata in this window.*")
    else:
        lines.append(f"- Avg collections/call: **{_na(avg_collection_count, '.2f')}**")
        top_profiles = retrieval_breadth.get("top_profiles") or []
        if top_profiles:
            labels = ", ".join(f"`{name}` ({count})" for name, count in top_profiles[:3])
            lines.append(f"- Active profiles: {labels}")
        diagnosis = retrieval_breadth.get("diagnosis")
        actions = retrieval_breadth.get("actions") or []
        if diagnosis:
            lines.append(f"- Retrieval breadth diagnosis: **{diagnosis}**")
        if actions:
            lines.append(f"- Retrieval breadth remediation: {'; '.join(str(action) for action in actions)}")
    lines.append("")

    lines += ["## 8bb. Retrieval Breadth Trends", ""]
    breadth_windows = retrieval_breadth_windows.get("windows") if isinstance(retrieval_breadth_windows, dict) else {}
    if not breadth_windows:
        lines.append("*No multi-window retrieval-breadth data available.*")
    else:
        for label in ("1h", "24h", "7d"):
            summary = breadth_windows.get(label) if isinstance(breadth_windows, dict) else None
            if not isinstance(summary, dict) or int(summary.get("route_calls", 0) or 0) <= 0:
                lines.append(f"- {label}: no route_search retrieval-breadth data recorded")
                continue
            avg = summary.get("avg_collection_count")
            top_profiles = summary.get("top_profiles") or []
            top_profile = top_profiles[0][0] if top_profiles else "n/a"
            partial = " (partial)" if summary.get("partial_window") else ""
            lines.append(
                f"- {label}{partial}: avg collections/call **{_na(avg, '.2f')}**,"
                f" top profile `{top_profile}`"
            )
    lines.append("")

    lines += [f"## 8c. Provider Fallback Recovery ({provider_fallbacks.get('window', '1h')})", ""]
    recovered_count = int(provider_fallbacks.get("recovered_count", 0) or 0)
    if recovered_count <= 0:
        lines.append("*No recovered remote-provider fallback events in this window.*")
    else:
        lines.append(
            f"- Recovered local fallbacks: **{recovered_count}**"
            f" ({_na(provider_fallbacks.get('recovered_pct'), '.1f', '%')} of route_search calls)"
        )
        status_counts = provider_fallbacks.get("status_counts") or []
        if status_counts:
            lines.append(f"- Upstream status mix: {_format_provider_fallback_statuses(status_counts)}")
        diagnosis = provider_fallbacks.get("diagnosis")
        actions = provider_fallbacks.get("actions") or []
        if diagnosis:
            lines.append(f"- Provider fallback diagnosis: **{diagnosis}**")
        if actions:
            lines.append(f"- Provider fallback remediation: {'; '.join(str(action) for action in actions)}")
        lines.append("- These are tracked separately from backend failures because the user-visible request recovered locally.")
    lines.append("")

    # 8c. Historical watchlist
    lines += [f"## 8d. Historical Watchlist ({historical_watch.get('window', '7d')})", ""]
    if not historical_watch.get("has_items"):
        lines.append("*No background watchlist items outside the recent window.*")
    else:
        slow_tools = historical_watch.get("slow_tools") or []
        flaky_tools = historical_watch.get("flaky_tools") or []
        if slow_tools:
            lines.append("- Slow tools outside the recent window:")
            for item in slow_tools[:3]:
                lines.append(
                    f"  - `{item['tool']}` — 7d p95 {item['p95_ms']:.0f}ms across {item['calls']} calls"
                )
        if flaky_tools:
            lines.append("- Reliability watchlist outside the recent window:")
            for item in flaky_tools[:3]:
                lines.append(
                    f"  - `{item['tool']}` — {_backend_reliability_summary(item, window_label='7d', recent=False)}"
                )
                note = str(item.get("reliability_note", "") or "").strip()
                if note:
                    lines.append(f"    - Interpretation: {note}")
    lines.append("")

    # 9. Recommendations
    lines += ["## 9. Workflow Recommendations", ""]
    for i, rec in enumerate(recs, 1):
        lines.append(f"{i}. {rec}")
    lines.append("")

    # 10. Hint Adoption (Phase 19.3.4)
    lines += ["## 10. Hint Adoption (aq-hints → aider-wrapper)", ""]
    if adoption and adoption.get("available"):
        if adoption["total"] == 0:
            lines.append("*No hint-injected aider tasks in this window.*")
        else:
            lines += [
                f"- Tasks with hint injection: **{adoption['total']}**",
                f"- Successful completions: **{adoption['accepted']}**",
                f"- Adoption rate: **{_na(adoption['adoption_pct'], '.1f', '%')}**",
            ]
            if int(adoption.get("tooling_plan_total", 0) or 0) > 0:
                lines.append(
                    f"- Tooling-plan injected success: **{adoption.get('tooling_plan_success', 0)}"
                    f"/{adoption.get('tooling_plan_total', 0)}**"
                    f" ({_na(adoption.get('tooling_plan_success_pct'), '.1f', '%')})"
                )
            if adoption.get("top_hints"):
                lines += ["", "Top hints by injection frequency:", ""]
                lines += [
                    "| Hint ID | Injections |",
                    "|---------|----------:|",
                ]
                for hid, count in adoption["top_hints"]:
                    lines.append(f"| `{hid}` | {count} |")
            if tooling_quality and int(tooling_quality.get("total", 0) or 0) > 0:
                lines += [
                    "",
                    f"- Aider task success (all): **{tooling_quality.get('success', 0)}/{tooling_quality.get('total', 0)}** ({_na(tooling_quality.get('success_pct'), '.1f', '%')})",
                    f"- Tooling-plan injected: **{tooling_quality.get('plan_success', 0)}/{tooling_quality.get('plan_total', 0)}** ({_na(tooling_quality.get('plan_success_pct'), '.1f', '%')})",
                    f"- Non-injected baseline: **{tooling_quality.get('baseline_success', 0)}/{tooling_quality.get('baseline_total', 0)}** ({_na(tooling_quality.get('baseline_success_pct'), '.1f', '%')})",
                ]
            lines.append(f"- Recent context: {_hint_adoption_recent_context(recent_hint_adoption)}")
    else:
        lines.append("*Hint audit unavailable — ensure AI_HINTS_ENABLED=true in aider-wrapper.*")
    lines.append("")

    # 11. Intent-contract compliance
    lines += ["## 11. Intent Contract Compliance", ""]
    if intent_compliance and intent_compliance.get("available"):
        total = int(intent_compliance.get("total_runs", 0) or 0)
        if total == 0:
            lines.append("*No workflow runs in this window.*")
        else:
            lines += [
                f"- Workflow runs: **{total}**",
                f"- With valid contract: **{intent_compliance.get('with_contract', 0)}**",
                f"- Coverage: **{_na(intent_compliance.get('contract_coverage_pct'), '.1f', '%')}**",
            ]
            depth = intent_compliance.get("depth_distribution", {})
            if isinstance(depth, dict) and depth:
                items = ", ".join(f"{k}:{v}" for k, v in sorted(depth.items(), key=lambda x: (-x[1], x[0])))
                lines.append(f"- Depth distribution: {items}")
            top_bp = intent_compliance.get("top_blueprints", [])
            if top_bp:
                lines += ["", "Top blueprints by runs:"]
                for bp, n in top_bp:
                    lines.append(f"- `{bp}`: {n}")
            review_required = int(intent_compliance.get("reviewer_gate_required_runs", 0) or 0)
            reviewed = int(intent_compliance.get("sessions_with_reviews", 0) or 0)
            accepted = int(intent_compliance.get("accepted_reviews", 0) or 0)
            rejected = int(intent_compliance.get("rejected_reviews", 0) or 0)
            pending = int(intent_compliance.get("pending_reviews", 0) or 0)
            lines.append(
                f"- Reviewer gate: required={review_required} reviewed={reviewed} accepted={accepted} rejected={rejected} pending={pending}"
            )
            top_roles = intent_compliance.get("top_requester_roles", [])
            if top_roles:
                lines.append(f"- Requester roles: {', '.join(f'`{role}` ({count})' for role, count in top_roles[:3])}")
            accepted_roles = intent_compliance.get("accepted_by_requester_role", [])
            if accepted_roles:
                lines.append(f"- Accepted by requester role: {', '.join(f'`{role}` ({count})' for role, count in accepted_roles[:3])}")
            reviewers = intent_compliance.get("top_reviewers", [])
            if reviewers:
                lines.append(f"- Reviewers: {', '.join(f'`{reviewer}` ({count})' for reviewer, count in reviewers[:3])}")
            review_types = intent_compliance.get("top_review_types", [])
            if review_types:
                lines.append(f"- Review types: {', '.join(f'`{review_type}` ({count})' for review_type, count in review_types[:3])}")
            accepted_blueprints = intent_compliance.get("accepted_blueprints", [])
            if accepted_blueprints:
                lines.append(f"- Accepted blueprints: {', '.join(f'`{bp}` ({count})' for bp, count in accepted_blueprints[:3])}")
            patch_accepted = int(intent_compliance.get("accepted_patch_reviews", 0) or 0)
            patch_rejected = int(intent_compliance.get("rejected_patch_reviews", 0) or 0)
            if patch_accepted or patch_rejected:
                lines.append(f"- Patch reviews: accepted={patch_accepted} rejected={patch_rejected}")
            patch_agents = intent_compliance.get("patch_reviews_by_reviewed_agent", [])
            if patch_agents:
                lines.append(f"- Patch-reviewed agents: {', '.join(f'`{agent}` ({count})' for agent, count in patch_agents[:3])}")
            accepted_task_classes = intent_compliance.get("accepted_task_classes", [])
            if accepted_task_classes:
                lines.append(f"- Accepted task classes: {', '.join(f'`{task_class}` ({count})' for task_class, count in accepted_task_classes[:3])}")
            accepted_profiles = intent_compliance.get("accepted_by_reviewed_profile", [])
            if accepted_profiles:
                lines.append(f"- Accepted by reviewed profile: {', '.join(f'`{profile}` ({count})' for profile, count in accepted_profiles[:3])}")
    else:
        lines.append("*Workflow session store unavailable.*")
    lines.append("")

    # 12. Security auditor
    lines += ["## 12. Tool Security Auditor", ""]
    if security_auditor and security_auditor.get("available"):
        events = int(security_auditor.get("events", 0) or 0)
        if events == 0:
            lines.append("*No tool-security auditor decisions observed in this window.*")
        else:
            lines += [
                f"- Decisions: **{events}**",
                f"- Approved: **{security_auditor.get('approved', 0)}**",
                f"- Blocked: **{security_auditor.get('blocked', 0)}**",
                f"- Cache hits: **{security_auditor.get('cache_hits', 0)}** ({_na(security_auditor.get('cache_hit_pct'), '.1f', '%')})",
                f"- First-seen audits: **{security_auditor.get('first_seen', 0)}**",
            ]
    else:
        lines.append("*Tool-security auditor metrics unavailable.*")
    lines.append("")

    # 13. Semantic autorun
    lines += ["## 13. Semantic Tooling Autorun", ""]
    if semantic_autorun and semantic_autorun.get("available"):
        route_calls = int(semantic_autorun.get("route_calls", 0) or 0)
        if route_calls == 0:
            lines.append("*No `/query` route_search traffic in this window.*")
        else:
            lines += [
                f"- Route calls: **{route_calls}**",
                f"- Route calls with metadata: **{semantic_autorun.get('with_metadata', 0)}**",
                f"- Autorun enabled: **{semantic_autorun.get('autorun_enabled_calls', 0)}** ({_na(semantic_autorun.get('autorun_enabled_pct'), '.1f', '%')})",
                f"- Avg planned tools/call: **{semantic_autorun.get('avg_planned_tools', 0.0)}**",
                f"- Avg executed tools/call: **{semantic_autorun.get('avg_executed_tools', 0.0)}**",
                f"- Security blocks during autorun: **{semantic_autorun.get('tool_security_blocked_total', 0)}**",
            ]
    else:
        lines.append("*Semantic autorun metrics unavailable.*")
    lines.append("")

    # 14. Hint Diversity
    lines += ["## 14. Hint Diversity", ""]
    if hint_diversity_stats and hint_diversity_stats.get("available"):
        total_injections = int(hint_diversity_stats.get("total_injections", 0) or 0)
        if total_injections == 0:
            lines.append("*No hint-injection activity in this window.*")
        else:
            lines += [
                f"- Total injections: **{total_injections}**",
                f"- Unique hint IDs: **{hint_diversity_stats.get('unique_hints', 0)}**",
                f"- Dominant hint share: **{_na(hint_diversity_stats.get('dominant_share_pct'), '.1f', '%')}**",
                f"- Normalized entropy: **{_na(hint_diversity_stats.get('normalized_entropy_pct'), '.1f', '%')}**",
                f"- Effective hints (entropy-based): **{_na(hint_diversity_stats.get('effective_hints'), '.2f')}**",
                f"- Status: **{hint_diversity_stats.get('status', 'unknown')}**",
            ]
            if hint_diversity_stats.get("dominant_hint_id"):
                lines.append(f"- Dominant hint ID: `{hint_diversity_stats.get('dominant_hint_id')}`")
            if str(hint_diversity_stats.get("status", "")).lower() == "concentrated":
                lines.append("- Monitoring note: hint selection is concentrated; prefer adding alternative high-signal hints or stronger feedback diversity.")
            lines.append(f"- Recent context: {_hint_diversity_recent_context(recent_hint_diversity_stats)}")
    else:
        lines.append("*Hint-diversity metrics unavailable.*")
    lines.append("")

    lines += [f"## 14b. Historical Hint Watchlist ({(historical_hint_watch or {}).get('window', '7d')})", ""]
    if not historical_hint_watch or not historical_hint_watch.get("has_items"):
        lines.append("*No historical hint concentration issues outside the recent window.*")
    else:
        lines.append(
            f"- Dominant hint: `{historical_hint_watch.get('dominant_hint_id')}`"
            f" at **{_na(historical_hint_watch.get('dominant_share_pct'), '.1f', '%')}**"
            f" across **{historical_hint_watch.get('total_injections', 0)}** injections"
        )
        alternatives = historical_hint_watch.get("alternative_hints") or []
        if alternatives:
            alt_text = ", ".join(
                f"`{item.get('hint_id')}` ({item.get('count', 0)})"
                for item in alternatives[:2]
                if item.get("hint_id")
            )
            if alt_text:
                lines.append(f"- Candidate alternates: {alt_text}")
                lines.append("- Next action: rotate one of the alternate hints into the next steering batch before repeating the dominant hint.")
        lines.append("- Status: historical concentration only; diversify future high-signal hints before this becomes active again.")
    lines.append("")

    lines += ["## 14c. Agent Lesson Promotion Candidates", ""]
    lesson_candidates = (agent_lessons or {}).get("candidates") or []
    lesson_registry = (agent_lessons or {}).get("registry") or {}
    if not lesson_candidates:
        lines.append("*No cross-agent lesson candidates met the promotion threshold in this window.*")
    else:
        for item in lesson_candidates[:3]:
            lines.append(f"- `{_format_agent_lesson_candidate(item)}`")
            comments = item.get("comments") or []
            if comments:
                lines.append(f"  - Example feedback: {comments[0]}")
    if lesson_registry.get("available"):
        counts = lesson_registry.get("counts") or {}
        lines.append(
            f"- `registry pending={counts.get('pending_review', 0)} promoted={counts.get('promoted', 0)} avoided={counts.get('avoided', 0)} rejected={counts.get('rejected', 0)}`"
        )
    lines.append("")

    return "\n".join(lines)


def format_text(
    since_label: str,
    tool_stats: Dict[str, dict],
    route: Dict[str, Any],
    recent_route: Dict[str, Any],
    routing_windows: Dict[str, Any],
    cache: Dict[str, Any],
    cache_prewarm: Dict[str, Any],
    eval_trend: Dict[str, Any],
    leaderboard: List[dict],
    top_prompts: List[dict],
    gaps: List[dict],
    rag_posture_summary: Dict[str, Any],
    recent_health: Dict[str, Any],
    continue_editor: Dict[str, Any],
    continue_editor_windows: Dict[str, Any],
    shared_skill_registry: Dict[str, Any],
    delegated_prompt_failures: Dict[str, Any],
    delegated_prompt_failure_windows: Dict[str, Any],
    remote_profile_summary: Dict[str, Any],
    remote_profile_windows: Dict[str, Any],
    route_latency_decomposition: Dict[str, Any],
    retrieval_breadth: Dict[str, Any],
    retrieval_breadth_windows: Dict[str, Any],
    provider_fallbacks: Dict[str, Any],
    historical_watch: Dict[str, Any],
    recs: List[str],
    adoption: Optional[Dict[str, Any]] = None,
    recent_hint_adoption: Optional[Dict[str, Any]] = None,
    intent_compliance: Optional[Dict[str, Any]] = None,
    security_auditor: Optional[Dict[str, Any]] = None,
    semantic_autorun: Optional[Dict[str, Any]] = None,
    tooling_quality: Optional[Dict[str, Any]] = None,
    hint_diversity_stats: Optional[Dict[str, Any]] = None,
    recent_hint_diversity_stats: Optional[Dict[str, Any]] = None,
    historical_hint_watch: Optional[Dict[str, Any]] = None,
    agent_lessons: Optional[Dict[str, Any]] = None,
