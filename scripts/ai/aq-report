def continue_editor_health() -> Dict[str, Any]:
    """Summarise Continue/editor health from aq-qa Phase 0 checks 0.5.*."""
    if not AQ_QA_SCRIPT.exists():
        return {"available": False, "source": str(AQ_QA_SCRIPT)}
    timeout_seconds = int(os.getenv("AQ_REPORT_CONTINUE_EDITOR_TIMEOUT_SECONDS", "75"))
    try:
        result = subprocess.run(
            [str(AQ_QA_SCRIPT), "0", "--json"],
            capture_output=True,
            text=True,
            timeout=timeout_seconds,
            check=False,
        )
    except subprocess.TimeoutExpired as exc:
        fallback = _continue_editor_health_from_history()
        if fallback:
            fallback["source"] = str(AQ_QA_SCRIPT)
            fallback["fallback_source"] = str(CONTINUE_EDITOR_HISTORY_PATH)
            fallback["warning"] = f"aq-qa timed out after {timeout_seconds}s; using latest persisted snapshot"
            fallback["error"] = str(exc)
            return fallback
        return {"available": False, "source": str(AQ_QA_SCRIPT), "error": str(exc)}
    except Exception as exc:
        return {"available": False, "source": str(AQ_QA_SCRIPT), "error": str(exc)}

    raw = (result.stdout or "").strip()
    if not raw:
        return {
            "available": False,
            "source": str(AQ_QA_SCRIPT),
            "error": (result.stderr or "").strip() or f"aq-qa exited {result.returncode}",
        }

    try:
        data = json.loads(raw)
    except json.JSONDecodeError as exc:
        return {"available": False, "source": str(AQ_QA_SCRIPT), "error": f"invalid json: {exc}"}

    labels = {
        "0.5.1": "Continue CLI help works",
        "0.5.2": "Continue config targets continue-local via switchboard",
        "0.5.3": "VSCodium has Continue extension installed",
        "0.5.4": "continue-local switchboard smoke",
        "0.5.5": "continue-local trims oversized dense prompts",
        "0.5.6": "Continue/editor prompt to feedback smoke",
    }
    failure_category_map = {
        "0.5.1": "cli_runtime",
        "0.5.2": "config_generation",
        "0.5.3": "editor_extension",
        "0.5.4": "switchboard_routing",
        "0.5.5": "context_window_trimming",
        "0.5.6": "agent_flow",
    }
    checks: List[Dict[str, Any]] = []
    for item in data.get("tests") or []:
        check_id = str(item.get("id", "") or "").strip()
        if not check_id.startswith("0.5."):
            continue
        status = str(item.get("status", "UNKNOWN") or "UNKNOWN").upper()
        checks.append(
            {
                "id": check_id,
                "description": str(item.get("description") or item.get("name") or labels.get(check_id, check_id)),
                "status": status,
                "failure_category": failure_category_map.get(check_id, "unknown"),
            }
        )
    if not checks:
        return {
            "available": False,
            "source": str(AQ_QA_SCRIPT),
            "error": "continue/editor phase-0 checks not found",
        }

    passed_n = sum(1 for item in checks if item.get("status") == "PASS")
    failed = [item for item in checks if item.get("status") == "FAIL"]
    skipped_n = sum(1 for item in checks if item.get("status") == "SKIP")
    failure_categories = sorted(
        Counter(item.get("failure_category", "unknown") for item in failed if item.get("failure_category")).items(),
        key=lambda entry: (-entry[1], entry[0]),
    )
    return {
        "available": True,
        "source": str(AQ_QA_SCRIPT),
        "healthy": len(failed) == 0,
        "total_checks": len(checks),
        "passed_n": passed_n,
        "failed_n": len(failed),
        "skipped_n": skipped_n,
        "checks": checks,
        "failure_categories": failure_categories,
        "top_failure_category": failure_categories[0][0] if failure_categories else None,
    }


def _continue_editor_health_from_history() -> Optional[Dict[str, Any]]:
    """Use the latest persisted Continue/editor snapshot when aq-qa is temporarily unavailable."""
    if not CONTINUE_EDITOR_HISTORY_PATH.exists():
        return None
    latest: Optional[Dict[str, Any]] = None
    try:
        with CONTINUE_EDITOR_HISTORY_PATH.open("r", encoding="utf-8") as handle:
            for line in handle:
                line = line.strip()
                if not line:
                    continue
                try:
                    item = json.loads(line)
                except json.JSONDecodeError:
                    continue
                ts = _entry_ts_utc(item)
                if ts is None:
                    continue
                item["_ts"] = ts
                if latest is None or ts >= latest["_ts"]:
                    latest = item
    except OSError:
        return None
    if latest is None:
        return None
    failure_categories = latest.get("failure_categories") or []
    return {
        "available": True,
        "source": str(CONTINUE_EDITOR_HISTORY_PATH),
        "healthy": bool(latest.get("healthy", False)),
        "total_checks": int(latest.get("total_checks", 0) or 0),
        "passed_n": int(latest.get("passed_n", 0) or 0),
        "failed_n": int(latest.get("failed_n", 0) or 0),
        "skipped_n": int(latest.get("skipped_n", 0) or 0),
        "checks": [],
        "failure_categories": failure_categories,
        "top_failure_category": failure_categories[0][0] if failure_categories else None,
        "history_timestamp": latest["_ts"].isoformat().replace("+00:00", "Z"),
    }


def append_continue_editor_snapshot(snapshot: Dict[str, Any], *, timestamp: datetime) -> None:
    if not snapshot.get("available"):
        return
    record = {
        "timestamp": timestamp.isoformat().replace("+00:00", "Z"),
        "healthy": bool(snapshot.get("healthy")),
        "total_checks": int(snapshot.get("total_checks", 0) or 0),
        "passed_n": int(snapshot.get("passed_n", 0) or 0),
        "failed_n": int(snapshot.get("failed_n", 0) or 0),
        "skipped_n": int(snapshot.get("skipped_n", 0) or 0),
        "failure_categories": snapshot.get("failure_categories") or [],
    }
    try:
        last_record = None
        if CONTINUE_EDITOR_HISTORY_PATH.exists():
            with CONTINUE_EDITOR_HISTORY_PATH.open("r", encoding="utf-8") as handle:
                for line in handle:
                    if line.strip():
                        last_record = line
        if last_record:
            try:
                if json.loads(last_record) == record:
                    return
            except json.JSONDecodeError:
                pass
        CONTINUE_EDITOR_HISTORY_PATH.parent.mkdir(parents=True, exist_ok=True)
        with CONTINUE_EDITOR_HISTORY_PATH.open("a", encoding="utf-8") as handle:
            handle.write(json.dumps(record) + "\n")
    except OSError:
        return


def continue_editor_windows(*, now: datetime, report_since: datetime) -> Dict[str, Any]:
    windows = [
        ("1h", timedelta(hours=1)),
        ("24h", timedelta(hours=24)),
        ("7d", timedelta(days=7)),
    ]
    if not CONTINUE_EDITOR_HISTORY_PATH.exists():
        return {"available": False, "source": str(CONTINUE_EDITOR_HISTORY_PATH), "windows": {}}
    records: List[Dict[str, Any]] = []
    try:
        with CONTINUE_EDITOR_HISTORY_PATH.open("r", encoding="utf-8") as handle:
            for line in handle:
                line = line.strip()
                if not line:
                    continue
                try:
                    item = json.loads(line)
                except json.JSONDecodeError:
                    continue
                ts = _entry_ts_utc(item)
                if ts is None:
                    continue
                item["_ts"] = ts
                records.append(item)
    except OSError:
        return {"available": False, "source": str(CONTINUE_EDITOR_HISTORY_PATH), "windows": {}}

    summaries: Dict[str, Any] = {}
    for label, delta in windows:
        cutoff = now - delta
        sample = [item for item in records if item["_ts"] >= cutoff]
        if not sample:
            summaries[label] = {
                "available": False,
                "window": label,
                "partial_window": report_since > cutoff,
                "samples": 0,
            }
            continue
        latest = max(sample, key=lambda item: item["_ts"])
        healthy_n = sum(1 for item in sample if bool(item.get("healthy")))
        summaries[label] = {
            "available": True,
            "window": label,
            "partial_window": report_since > cutoff,
            "samples": len(sample),
            "healthy_samples": healthy_n,
            "healthy_pct": round(100 * healthy_n / len(sample), 1),
            "latest_healthy": bool(latest.get("healthy")),
            "latest_failed_n": int(latest.get("failed_n", 0) or 0),
            "latest_total_checks": int(latest.get("total_checks", 0) or 0),
            "latest_failure_categories": latest.get("failure_categories") or [],
        }
    return {"available": True, "source": str(CONTINUE_EDITOR_HISTORY_PATH), "windows": summaries}


def shared_skill_registry_health() -> Dict[str, Any]:
    local_paths = sorted(LOCAL_SHARED_SKILLS_DIR.glob("*/SKILL.md")) if LOCAL_SHARED_SKILLS_DIR.is_dir() else []
    expected_records = [
        {
            "slug": path.parent.name,
            "source_path": str(path.relative_to(Path(__file__).resolve().parents[2])),
        }
        for path in local_paths
        if path.parent.name.strip()
    ]
    if EXTERNAL_SHARED_SKILLS_MANIFEST.is_file():
        try:
            payload = json.loads(EXTERNAL_SHARED_SKILLS_MANIFEST.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            payload = {}
        for item in payload.get("skills") or []:
            if not isinstance(item, dict) or item.get("enabled", True) is False:
                continue
            source_path = str(item.get("source_path", "") or "").strip()
            slug = str(item.get("slug", "") or "").strip()
            if source_path and slug:
                expected_records.append({"slug": slug, "source_path": source_path})
    local_slugs = sorted(item["slug"] for item in expected_records)
    try:
        request = urllib.request.Request(
            f"{AIDB_URL.rstrip('/')}/skills?{urllib.parse.urlencode({'include_pending': 'true', '_': str(time.time_ns())})}",
            headers={"Accept": "application/json"},
        )
        with urllib.request.urlopen(request, timeout=10) as response:
            payload = json.loads(response.read().decode("utf-8"))
    except Exception as exc:
        return {
            "available": False,
            "source": f"{AIDB_URL.rstrip('/')}/skills",
            "local_skill_count": len(local_paths),
            "expected_skill_count": len(expected_records),
            "local_slugs": local_slugs,
            "error": str(exc),
        }

    approved = [
        item for item in (payload if isinstance(payload, list) else [])
        if isinstance(item, dict) and str(item.get("status", "")).strip().lower() == "approved"
    ]
    approved_map_by_path = {
        str(item.get("source_path", "")).strip(): item
        for item in approved
        if isinstance(item, dict) and str(item.get("source_path", "")).strip()
    }
    approved_slugs = sorted(
        str(item.get("slug", "")).strip()
        for item in approved
        if isinstance(item, dict) and str(item.get("slug", "")).strip()
    )
    approved_map = {
        str(item.get("slug", "")).strip(): item
        for item in approved
        if isinstance(item, dict) and str(item.get("slug", "")).strip()
    }
    path_mismatches = []
    for item in expected_records:
        slug = item["slug"]
        remote = approved_map.get(slug)
        if not remote:
            continue
        remote_path = str(remote.get("source_path", "") or "").strip()
        rel_path = item["source_path"]
        if remote_path and remote_path != rel_path and remote_path in approved_map_by_path:
            path_mismatches.append(
                {
                    "slug": slug,
                    "local_source_path": rel_path,
                    "aidb_source_path": remote_path,
                }
            )

    local_paths_set = {item["source_path"] for item in expected_records}
    missing_in_aidb = [item["slug"] for item in expected_records if item["source_path"] not in approved_map_by_path]
    extra_in_aidb = [
        str(item.get("slug", "")).strip()
        for item in approved
        if isinstance(item, dict) and str(item.get("source_path", "")).strip() not in local_paths_set
    ]
    return {
        "available": True,
        "source": f"{AIDB_URL.rstrip('/')}/skills",
        "local_skill_count": len(local_paths),
        "expected_skill_count": len(expected_records),
        "approved_skill_count": len(approved_slugs),
        "missing_in_aidb": missing_in_aidb,
        "extra_in_aidb": extra_in_aidb[:10],
        "path_mismatches": path_mismatches[:10],
        "healthy": len(missing_in_aidb) == 0 and len(path_mismatches) == 0,
    }


def _hint_audit_path() -> Optional[Path]:
    """Resolve hint-audit path with fallback to active tool-audit directory."""
    env_hint = os.getenv("HINT_AUDIT_LOG_PATH")
    if env_hint:
        p = Path(env_hint)
        try:
            if p.exists():
                return p
        except PermissionError:
            pass
    candidates = [
        HINT_AUDIT_PATH,
        TOOL_AUDIT_PATH.parent / "hint-audit.jsonl",
        AUDIT_FALLBACK_PATH.parent / "hint-audit.jsonl",
