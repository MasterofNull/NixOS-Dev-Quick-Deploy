def main() -> None:
    args = parse_args()
    window = _parse_since(args.since)
    since_dt = datetime.now(tz=timezone.utc) - window
    since_label = args.since

    # Collect data (independent sources — order doesn't matter)
    audit_entries = read_tool_audit(since_dt)
    eval_rows = read_eval_scores(since_dt)
    gaps = read_query_gaps(since_dt, limit=10)
    gaps = [
        g for g in gaps
        if not _is_synthetic_gap(str(g.get("query_text", "")))
        and not _is_curated_stale_gap(str(g.get("query_text", "")))
    ]
    prompts = read_prompt_registry()

    # Analyse
    tool_stats = aggregate_tool_audit(audit_entries)
    recent_cutoff = datetime.now(tz=timezone.utc) - timedelta(hours=1)
    recent_audit_entries = [
        e for e in audit_entries
        if (_entry_ts_utc(e) or datetime.min.replace(tzinfo=timezone.utc)) >= recent_cutoff
    ]
    recent_tool_stats = aggregate_tool_audit(recent_audit_entries)
    route = routing_split(audit_entries)
    recent_route = routing_split(recent_audit_entries)
    recent_route["window"] = "1h"
    cache = cache_hit_rate()
    cache_prewarm = cache_prewarm_status()
    eval_trend = eval_score_trend(eval_rows, audit_entries)
    adoption = hint_adoption(since_dt)  # Phase 19.3.4
    tooling_quality = task_tooling_quality(since_dt, adoption)
    intent_compliance = read_workflow_sessions(since_dt)
    security_auditor = security_auditor_health(audit_entries)
    semantic_autorun = semantic_autorun_health(audit_entries)
    recent_semantic_autorun = semantic_autorun_health(recent_audit_entries)
    recent_health = recent_health_snapshot(recent_tool_stats)
    historical_health_watch = historical_watchlist(tool_stats, recent_tool_stats)
    rag_posture_summary = rag_posture(tool_stats, recent_tool_stats, cache, gaps)
    hint_diversity_stats = hint_diversity(adoption)
    recent_hint_adoption = hint_adoption(recent_cutoff)
    recent_hint_adoption["window"] = "1h"
    recent_hint_diversity_stats = hint_diversity(recent_hint_adoption)
    recent_hint_diversity_stats["window"] = "1h"
    historical_hint_watch = historical_hint_watchlist(
        adoption,
        recent_hint_adoption,
        hint_diversity_stats,
        recent_hint_diversity_stats,
    )
    leaderboard = strategy_leaderboard(eval_rows)
    top_prompts = sorted(
        [p for p in prompts if isinstance(p.get("mean_score"), float) and p["mean_score"] > 0],
        key=lambda x: -x["mean_score"],
    )[:3]
    recs = build_recommendations(
        tool_stats,
        route,
        cache,
        eval_trend,
        gaps,
        adoption,
        intent_compliance,
        security_auditor,
        semantic_autorun,
        tooling_quality,
        hint_diversity_stats,
        recent_hint_diversity_stats,
        recent_tool_stats,
        recent_semantic_autorun,
    )
    structured_actions = build_structured_actions(tool_stats, route, cache, eval_trend, gaps)

    # Render
    fmt_args = (
        since_label,
        tool_stats,
        route,
        recent_route,
        cache,
        cache_prewarm,
        eval_trend,
        leaderboard,
        top_prompts,
        gaps,
        rag_posture_summary,
        recent_health,
        historical_health_watch,
        recs,
        adoption,
        recent_hint_adoption,
        intent_compliance,
        security_auditor,
        semantic_autorun,
        tooling_quality,
        hint_diversity_stats,
        recent_hint_diversity_stats,
        historical_hint_watch,
    )
    if args.fmt == "md":
        output = format_md(*fmt_args)
    elif args.fmt == "json":
        output = format_json(*fmt_args, structured_actions=structured_actions)
    else:
        output = format_text(*fmt_args)

    print(output)

    # Optional AIDB import
    if args.aidb_import:
        week_label = (datetime.now(tz=timezone.utc) - timedelta(days=3)).strftime("W%W-%Y")
        ok = aidb_import(output, week_label)
        if ok:
            print(f"\n[aq-report] Report imported to AIDB (week={week_label})", file=sys.stderr)
        # failure already printed by aidb_import()


if __name__ == "__main__":
    main()
