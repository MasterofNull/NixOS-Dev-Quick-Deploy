            review_types = intent_compliance.get("top_review_types", [])
            if review_types:
                lines.append(f"  Review types: {', '.join(f'{review_type}({count})' for review_type, count in review_types[:3])}")
            accepted_blueprints = intent_compliance.get("accepted_blueprints", [])
            if accepted_blueprints:
                lines.append(f"  Accepted blueprints: {', '.join(f'{bp}({count})' for bp, count in accepted_blueprints[:3])}")
            patch_accepted = int(intent_compliance.get("accepted_patch_reviews", 0) or 0)
            patch_rejected = int(intent_compliance.get("rejected_patch_reviews", 0) or 0)
