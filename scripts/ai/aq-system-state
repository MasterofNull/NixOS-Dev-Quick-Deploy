#!/usr/bin/env python3
"""
aq-system-state — System Intelligence Hub snapshot (Phase 115.1)

Synthesises service health, git metadata, validation status, error patterns,
data topology, agent coordination state, and performance summary into a single
refreshable JSON artifact + human-readable summary.

Usage:
  aq-system-state                    Write artifact + print summary
  aq-system-state --fmt json         Print JSON only (also writes artifact)
  aq-system-state --fmt text         Print human-readable summary (also writes artifact)
  aq-system-state --diff             Show delta from previous artifact
  aq-system-state --domain DOMAIN    Focus on one domain:
                                       git | services | validation | errors |
                                       attention | data | agent | performance

Environment:
  SYSTEM_STATE_ARTIFACT_PATH   Output path (default: /var/lib/ai-stack/hybrid/telemetry/latest-system-state.json)
  QDRANT_URL                   Qdrant base URL (default: http://127.0.0.1:6333)
  POSTGRES_DSN                 PostgreSQL DSN
  POSTGRES_HOST / _PORT / _DB / _USER / _PASSWORD
  HYBRID_COORDINATOR_URL       Coordinator URL (default: http://127.0.0.1:8003)
  REPO_ROOT                    Repo root (default: script's grandparent dir)
"""

