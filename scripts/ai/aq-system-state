def collect_git() -> Dict[str, Any]:
    branch = _run(["git", "-C", str(REPO_ROOT), "rev-parse", "--abbrev-ref", "HEAD"])
    log_raw = _run(
        ["git", "-C", str(REPO_ROOT), "log", "--oneline", "-10", "--format=%H|%s|%ai|%an"]
    )
    commits = []
    for line in log_raw.splitlines():
        parts = line.split("|", 3)
        if len(parts) == 4:
            commits.append({"hash": parts[0][:12], "message": parts[1], "date": parts[2], "author": parts[3]})
    status_raw = _run(["git", "-C", str(REPO_ROOT), "status", "--short"])
    uncommitted = [l.strip() for l in status_raw.splitlines() if l.strip()]
    ahead = _run(["git", "-C", str(REPO_ROOT), "rev-list", "--count", "HEAD@{u}..HEAD"])
    churn_raw = _run(
        ["git", "-C", str(REPO_ROOT), "log", "--since=7 days ago", "--name-only", "--format="]
    )
    churn: Dict[str, int] = {}
    for line in churn_raw.splitlines():
        line = line.strip()
        if line:
            churn[line] = churn.get(line, 0) + 1
    churn_hotspots = sorted(churn.items(), key=lambda x: -x[1])[:10]
    return {
        "branch": branch or "unknown",
        "commits_ahead_upstream": int(ahead) if ahead.isdigit() else None,
        "recent_commits": commits,
        "uncommitted_files": uncommitted,
        "churn_hotspots_7d": [{"file": f, "changes": c} for f, c in churn_hotspots],
    }


def collect_services() -> List[Dict[str, Any]]:
    results = []
    for svc in _AI_SERVICES:
        name = f"{svc}.service"
        show = _run(["systemctl", "show", name, "--property=ActiveState,SubState,ExecMainStartTimestamp,MainPID,NRestarts"])
        props: Dict[str, str] = {}
        for line in show.splitlines():
            if "=" in line:
                k, v = line.split("=", 1)
                props[k] = v
        active = props.get("ActiveState", "unknown")
        sub = props.get("SubState", "unknown")
        pid = props.get("MainPID", "0")
        restarts = props.get("NRestarts", "0")
        start_ts = props.get("ExecMainStartTimestamp", "")
        results.append({
            "name": svc,
            "status": active,
            "sub_state": sub,
            "pid": int(pid) if pid.isdigit() else None,
            "restarts": int(restarts) if restarts.isdigit() else 0,
            "active_since": start_ts or None,
        })
    return results


def collect_validation() -> Dict[str, Any]:
    registry_path = REPO_ROOT / "config" / "validation-check-registry.json"
    try:
        registry = json.loads(registry_path.read_text())
        checks = registry.get("checks", [])
        total = len(checks)
        enabled = sum(1 for c in checks if c.get("enabled", True))
    except Exception:
        total = 0
        enabled = 0
        checks = []

    # Read latest focused-CI JSON artifact if available
    focused_path = Path(os.getenv("FOCUSED_CI_JSON", "/tmp/focused-ci-latest.json"))
    focused_summary: Dict[str, Any] = {"available": False}
    if focused_path.exists():
        try:
            focused_data = json.loads(focused_path.read_text())
            results = focused_data if isinstance(focused_data, list) else focused_data.get("checks", [])
            passed = sum(1 for r in results if r.get("status") == "pass")
            failed = sum(1 for r in results if r.get("status") == "fail")
            generated = focused_data.get("generated_at") if isinstance(focused_data, dict) else None
            focused_summary = {
                "available": True,
                "checks_ran": len(results),
                "passed": passed,
                "failed": failed,
                "generated_at": generated,
                "top_failures": [r.get("check_id") for r in results if r.get("status") == "fail"][:5],
            }
        except Exception:
            pass

    # Read aq-qa results if available
    qa_results_path = Path(os.getenv("AQ_QA_RESULTS_PATH", "/var/lib/ai-stack/hybrid/telemetry/aq-qa-results.json"))
    qa_summary: Dict[str, Any] = {"available": False}
    if qa_results_path.exists():
        try:
            qa_data = json.loads(qa_results_path.read_text())
            qa_summary = {
                "available": True,
                "passed": qa_data.get("passed", 0),
                "failed": qa_data.get("failed", 0),
                "total": qa_data.get("total", 0),
                "generated_at": qa_data.get("generated_at"),
            }
        except Exception:
            pass

    return {
        "registry_checks_total": total,
        "registry_checks_enabled": enabled,
        "focused_ci": focused_summary,
        "aq_qa": qa_summary,
    }


def collect_errors() -> List[Dict[str, Any]]:
    since_ts = (_NOW - timedelta(hours=1)).strftime("%Y-%m-%d %H:%M:%S")
    logs = _run(
        ["journalctl", "--since", since_ts, "-p", "err..warning", "--no-pager",
         "-u", "ai-hybrid-coordinator", "-u", "ai-ralph-wiggum", "-u", "ai-aidb",
         "-u", "ai-switchboard", "--output=short-monotonic"],
        timeout=15,
    )
    error_counts: Dict[str, Dict[str, Any]] = {}
    for line in logs.splitlines():
        line_lower = line.lower()
        svc = "coordinator" if "hybrid-coord" in line else \
              "ralph" if "ralph" in line else \
              "aidb" if "aidb" in line else \
              "switchboard" if "switchboard" in line else "system"
        err_type = "unknown"
        if "500" in line or "backend_500" in line_lower:
            err_type = "backend_500"
        elif "timeout" in line_lower or "504" in line:
            err_type = "timeout"
        elif "apparmor" in line_lower or "denied" in line_lower:
            err_type = "apparmor_denial"
        elif "connection refused" in line_lower or "connect" in line_lower:
            err_type = "connection_refused"
        elif "exception" in line_lower or "traceback" in line_lower:
            err_type = "python_exception"
        elif "error" in line_lower:
            err_type = "general_error"
        else:
            continue
        key = f"{svc}:{err_type}"
        if key not in error_counts:
            error_counts[key] = {"service": svc, "type": err_type, "count": 0, "last_line": ""}
        error_counts[key]["count"] += 1
        error_counts[key]["last_line"] = line[:120]
    return sorted(error_counts.values(), key=lambda x: -x["count"])[:10]


def collect_attention() -> Dict[str, Any]:
    attn_path = REPO_ROOT / ".agents" / "attention" / "ATTENTION.json"
    archive_path = REPO_ROOT / ".agents" / "attention" / "ATTENTION_ARCHIVE.jsonl"
    # Phase 117.4 — fallback mirror written by attention_queue.py from the calling
    # process (ai-hybrid or hyperd). Used when live REPO_ROOT is DAC-blocked (mode 700).
    mirror_path = Path(
        os.getenv("ATTENTION_MIRROR_PATH", "/var/lib/ai-stack/hybrid/telemetry/attention-snapshot.json")
    )

    pending = 0
    pending_items: List[str] = []
    if attn_path.exists():
        try:
            d = json.loads(attn_path.read_text())
            alerts = d.get("alerts") or d.get("items") or []
            pending_alerts = [a for a in alerts if a.get("status") == "pending"]
            pending = len(pending_alerts)
            pending_items = [(a.get("title") or a.get("message", "?"))[:60] for a in pending_alerts[:5]]
        except Exception:
            pass
    elif mirror_path.exists():
        try:
            snap = json.loads(mirror_path.read_text())
            pending = snap.get("pending_human_gate", 0)
            pending_items = snap.get("pending_items") or []
        except Exception:
            pass

    recent_auto_ok = 0
    if archive_path.exists():
        cutoff = (_NOW - timedelta(hours=24)).isoformat()
        try:
            with archive_path.open() as f:
                for line in f:
                    line = line.strip()
                    if not line:
                        continue
                    try:
                        ev = json.loads(line)
                        if ev.get("autonomy_boundary") == "auto_ok" and ev.get("created_at", "") >= cutoff:
                            recent_auto_ok += 1
                    except Exception:
                        pass
        except Exception:
            pass

    return {
        "pending_human_gate": pending,
        "pending_items": pending_items,
        "recent_auto_ok_24h": recent_auto_ok,
    }


def collect_data_topology() -> Dict[str, Any]:
    # Qdrant collections
    qdrant_result = _http_get(f"{QDRANT_URL}/collections")
    qdrant_collections = []
    if qdrant_result:
        for col in (qdrant_result.get("result", {}).get("collections") or []):
            name = col.get("name", "?")
            info = _http_get(f"{QDRANT_URL}/collections/{name}")
            pts = 0
            if info:
                pts = (info.get("result", {}).get("points_count") or
                       info.get("result", {}).get("indexed_vectors_count") or 0)
            qdrant_collections.append({"name": name, "point_count": pts})

    # PostgreSQL tables
    pg_tables = []
    rows = _pg_query(
        "SELECT relname AS table_name, n_live_tup AS row_count "
        "FROM pg_stat_user_tables ORDER BY n_live_tup DESC LIMIT 15"
    )
    for r in rows:
        pg_tables.append({"table": r.get("table_name"), "rows": r.get("row_count")})

    # Redis INFO
    redis_info: Dict[str, Any] = {"available": False}
    try:
        import subprocess
        redis_host = os.getenv("REDIS_HOST", "127.0.0.1")
        redis_port = os.getenv("REDIS_PORT", os.getenv("MCP_REDIS_PORT", "6380"))
        info_raw = subprocess.run(
            ["redis-cli", "-h", redis_host, "-p", redis_port, "INFO", "memory", "keyspace"],
            capture_output=True, text=True, timeout=5,
        ).stdout
        mem_line = next((l for l in info_raw.splitlines() if l.startswith("used_memory_human:")), "")
        mem = mem_line.split(":", 1)[-1].strip() if mem_line else "unknown"
        keys_line = next((l for l in info_raw.splitlines() if l.startswith("db")), "")
        key_count = 0
        if keys_line:
            import re
            m = re.search(r"keys=(\d+)", keys_line)
            key_count = int(m.group(1)) if m else 0
        redis_info = {"available": True, "used_memory_human": mem, "key_count": key_count}
    except Exception:
        pass

    return {
        "qdrant": qdrant_collections,
        "postgres": pg_tables,
        "redis": redis_info,
    }


def collect_agent_state() -> Dict[str, Any]:
    resume_path = REPO_ROOT / ".agent" / "collaboration" / "RESUME.json"
    handoff_path = REPO_ROOT / ".agent" / "collaboration" / "HANDOFF.md"
    pending_path = REPO_ROOT / ".agent" / "collaboration" / "PENDING.json"
    # Phase 117.4 — fallback mirror written by aq-session-start at session start.
    # Used when live REPO_ROOT is DAC-blocked (mode 700 on /home/hyperd/).
    mirror_path = Path("/var/lib/ai-stack/hybrid/telemetry/agent-resume.json")

    objective = None
    phase = None
    open_tasks: List[str] = []
    resume_source = resume_path if resume_path.exists() else (mirror_path if mirror_path.exists() else None)
    if resume_source is not None:
        try:
            r = json.loads(resume_source.read_text())
            objective = r.get("current_objective")
            phase = r.get("phase")
            open_tasks = [t for t in (r.get("todo_snapshot") or []) if not t.startswith("DONE")][:5]
        except Exception:
            pass

    handoff_snippet = None
    if handoff_path.exists():
        try:
            lines = handoff_path.read_text().splitlines()[:50]
            handoff_snippet = "\n".join(lines)
        except Exception:
            pass

    pending_count = 0
    if pending_path.exists():
        try:
            d = json.loads(pending_path.read_text())
            tasks = d.get("tasks") or []
            pending_count = sum(1 for t in tasks if t.get("status") not in ("done", "accepted", "cancelled"))
        except Exception:
            pass

    return {
        "current_objective": objective,
        "phase": phase,
        "open_tasks": open_tasks,
        "pending_delegations": pending_count,
        "handoff_snippet": handoff_snippet,
    }


def collect_performance() -> Dict[str, Any]:
    aq_report_path = Path(
        os.getenv("AQ_REPORT_LATEST_JSON", "/var/lib/ai-stack/hybrid/telemetry/latest-aq-report.json")
    )
    if not aq_report_path.exists():
        return {"available": False, "reason": "aq-report artifact not found"}

    try:
        report = json.loads(aq_report_path.read_text())
    except Exception as exc:
        return {"available": False, "reason": str(exc)}

    generated_at = report.get("generated_at", "")
    stale = False
    if generated_at:
        try:
            gen_dt = datetime.fromisoformat(generated_at.replace("Z", "+00:00"))
            stale = (_NOW - gen_dt).total_seconds() > 7 * 86400
        except Exception:
            pass

    sc = report.get("effectiveness_scorecard") or {}
    routing = report.get("routing") or {}
    cache = report.get("cache") or {}
    ut = report.get("useful_tokens") or {}

    return {
        "available": True,
        "stale": stale,
        "report_generated_at": generated_at,
        "scorecard_status": sc.get("overall_status"),
        "completion_reliability": (sc.get("completion_reliability") or {}).get("delegation_success_rate"),
        "local_routing_pct": routing.get("local_pct") or routing.get("local_routing_pct"),
        "cache_hit_pct": cache.get("hit_pct"),
        "useful_token_ratio": ut.get("useful_ratio"),
        "waste_buckets": ut.get("waste_buckets"),
    }


