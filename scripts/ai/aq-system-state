def build_snapshot(domains: Optional[List[str]] = None) -> Dict[str, Any]:
    all_domains = domains or ["git", "services", "validation", "errors", "attention", "data", "agent", "performance"]
    snap: Dict[str, Any] = {
        "generated_at": _NOW.isoformat(),
        "freshness_seconds": 0,
        "domains_collected": all_domains,
    }
    collectors = {
        "git": collect_git,
        "services": collect_services,
        "validation": collect_validation,
        "errors": collect_errors,
        "attention": collect_attention,
        "data": collect_data_topology,
        "agent": collect_agent_state,
        "performance": collect_performance,
    }
    for domain in all_domains:
        fn = collectors.get(domain)
        if fn:
            try:
                snap[domain] = fn()
            except Exception as exc:
                snap[domain] = {"_error": str(exc)}
    snap["freshness_seconds"] = 0  # just generated
    return snap


def persist_artifact(snap: Dict[str, Any]) -> None:
    """Write artifact atomically (.tmp → rename). Uses fcntl exclusive lock to
    prevent concurrent writers from producing corrupted output."""
    try:
        ARTIFACT_PATH.parent.mkdir(parents=True, exist_ok=True)
        lock_fh = open(LOCK_PATH, "w")
        try:
            fcntl.flock(lock_fh, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            print("[aq-system-state] INFO: refresh already in progress, skipping write", file=sys.stderr)
            lock_fh.close()
            return
        try:
            tmp = ARTIFACT_PATH.with_suffix(".tmp")
            tmp.write_text(json.dumps(snap, indent=2, default=str), encoding="utf-8")
            tmp.replace(ARTIFACT_PATH)
        finally:
            fcntl.flock(lock_fh, fcntl.LOCK_UN)
            lock_fh.close()
    except Exception as exc:
        print(f"[aq-system-state] WARN: could not write artifact: {exc}", file=sys.stderr)


def format_summary(snap: Dict[str, Any]) -> str:
    sep = "─" * 60
    lines = [
        sep,
        f"  SYSTEM STATE SNAPSHOT",
        f"  Generated: {snap.get('generated_at', '')[:19].replace('T', ' ')} UTC",
        sep,
        "",
    ]

    # Services
    svcs = snap.get("services") or []
    if svcs:
        active = sum(1 for s in svcs if s.get("status") == "active")
        failed = [s["name"] for s in svcs if s.get("status") in ("failed", "inactive") and s.get("sub_state") != "dead"]
        restarted = [s["name"] for s in svcs if (s.get("restarts") or 0) > 0]
        lines += ["[ Services ]"]
        lines.append(f"  Active: {active}/{len(svcs)}   Failed: {len(failed)}   With restarts: {len(restarted)}")
        for f in failed[:3]:
            lines.append(f"  ✗ {f}")
        if restarted:
            lines.append(f"  Restarts: {', '.join(restarted[:3])}")
        lines.append("")

    # Git
    git = snap.get("git") or {}
    if git:
        lines += ["[ Git ]"]
        branch = git.get("branch", "?")
        uncommitted = len(git.get("uncommitted_files") or [])
        ahead = git.get("commits_ahead_upstream")
        hotspots = git.get("churn_hotspots_7d") or []
        ahead_str = f"   Ahead: {ahead}" if ahead else ""
        lines.append(f"  Branch: {branch}   Uncommitted: {uncommitted}{ahead_str}")
        if git.get("recent_commits"):
            last = git["recent_commits"][0]
            lines.append(f"  Latest: {last['hash']} {last['message'][:60]}")
        if hotspots:
            lines.append(f"  Churn hotspots (7d): {hotspots[0]['file']} ({hotspots[0]['changes']}x)")
        lines.append("")

    # Validation
    val = snap.get("validation") or {}
    if val:
        lines += ["[ Validation ]"]
        total = val.get("registry_checks_total", 0)
        enabled = val.get("registry_checks_enabled", 0)
        qa = val.get("aq_qa") or {}
        fci = val.get("focused_ci") or {}
        lines.append(f"  Registry: {enabled}/{total} enabled")
        if qa.get("available"):
            lines.append(f"  aq-qa: {qa.get('passed', 0)}/{qa.get('total', 0)} pass")
        if fci.get("available"):
            p, f = fci.get("passed", 0), fci.get("failed", 0)
            lines.append(f"  Focused CI: {p} pass, {f} fail")
            for fail_id in (fci.get("top_failures") or [])[:3]:
                lines.append(f"    ✗ {fail_id}")
        lines.append("")

    # Errors
    errors = snap.get("errors") or []
    if errors:
        lines += ["[ Recent Errors (1h) ]"]
        for e in errors[:5]:
            lines.append(f"  {e['service']} / {e['type']}: {e['count']}x")
        lines.append("")

    # Data topology
    data = snap.get("data") or {}
    if data:
        lines += ["[ Data Topology ]"]
        qdrant = data.get("qdrant") or []
        pg = data.get("postgres") or []
        redis = data.get("redis") or {}
        if qdrant:
            lines.append(f"  Qdrant: {len(qdrant)} collections — " + ", ".join(f"{c['name']}({c['point_count']})" for c in qdrant[:5]))
        if pg:
            lines.append(f"  PostgreSQL: {len(pg)} tables — " + ", ".join(f"{r['table']}({r['rows']})" for r in pg[:5]))
        if redis.get("available"):
            lines.append(f"  Redis: {redis.get('used_memory_human', '?')}   keys: {redis.get('key_count', '?')}")
        lines.append("")

    # Agent state
    agent = snap.get("agent") or {}
    if agent and agent.get("current_objective"):
        lines += ["[ Agent State ]"]
        lines.append(f"  Objective: {agent['current_objective'][:80]}")
        lines.append(f"  Phase: {agent.get('phase', '?')}")
        open_tasks = agent.get("open_tasks") or []
        if open_tasks:
            lines.append(f"  Open tasks: {len(open_tasks)}")
        pending = agent.get("pending_delegations", 0)
        if pending:
            lines.append(f"  Pending delegations: {pending}")
        lines.append("")

    # Performance
    perf = snap.get("performance") or {}
    if perf.get("available"):
        lines += ["[ Performance ]"]
        stale_note = " (STALE)" if perf.get("stale") else ""
        lines.append(f"  Scorecard: {perf.get('scorecard_status', '?')}{stale_note}")
        rel = perf.get("completion_reliability")
        ratio = perf.get("useful_token_ratio")
        local = perf.get("local_routing_pct")
        cache = perf.get("cache_hit_pct")
        if rel is not None:
            lines.append(f"  Delegation success: {rel:.1%}   Useful token ratio: {ratio:.1%}" if ratio is not None else f"  Delegation success: {rel:.1%}")
        if local is not None:
            lines.append(f"  Local routing: {local:.1f}%   Cache hit: {cache:.1f}%" if cache is not None else f"  Local routing: {local:.1f}%")
        lines.append("")

    # Attention
    attn = snap.get("attention") or {}
    pending_gate = attn.get("pending_human_gate", 0)
    auto_ok = attn.get("recent_auto_ok_24h", 0)
    if pending_gate or auto_ok:
        lines += ["[ Attention Queue ]"]
        lines.append(f"  Pending human gate: {pending_gate}   Auto-OK (24h): {auto_ok}")
        for item in (attn.get("pending_items") or [])[:3]:
            lines.append(f"  → {item}")
        lines.append("")

    lines.append(f"  Artifact: {ARTIFACT_PATH}")
    lines.append(sep)
    return "\n".join(lines)


def format_diff(current: Dict[str, Any], previous: Dict[str, Any]) -> str:
    lines = ["=== SYSTEM STATE DELTA ===", ""]

    def _flat(obj: Any, prefix: str = "") -> Dict[str, Any]:
        out: Dict[str, Any] = {}
        if isinstance(obj, dict):
            for k, v in obj.items():
                out.update(_flat(v, f"{prefix}.{k}" if prefix else k))
        elif isinstance(obj, list):
            out[prefix] = f"[{len(obj)} items]"
        else:
            out[prefix] = obj
        return out

    cur_flat = _flat(current)
    prev_flat = _flat(previous)
    all_keys = set(cur_flat) | set(prev_flat)
    changed = []
    for k in sorted(all_keys):
        cv = cur_flat.get(k)
        pv = prev_flat.get(k)
        if cv != pv:
            changed.append((k, pv, cv))

    if not changed:
        lines.append("  No changes detected.")
    else:
        for k, old, new in changed[:30]:
            lines.append(f"  {k}")
            lines.append(f"    before: {str(old)[:80]}")
            lines.append(f"    after:  {str(new)[:80]}")
    return "\n".join(lines)


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def main() -> None:
    parser = argparse.ArgumentParser(description="aq-system-state — system intelligence snapshot")
    parser.add_argument("--fmt", choices=["text", "json", "summary"], default="summary",
                        help="Output format (default: summary)")
    parser.add_argument("--diff", action="store_true", help="Show delta from previous artifact")
    parser.add_argument("--domain", help="Collect only this domain (git|services|validation|errors|attention|data|agent|performance)")
    parser.add_argument("--no-persist", action="store_true", help="Do not write artifact to disk")
    args = parser.parse_args()

    domains = [args.domain] if args.domain else None
    snap = build_snapshot(domains)

    # Diff mode
    if args.diff and ARTIFACT_PATH.exists() and not args.domain:
        try:
            prev = json.loads(ARTIFACT_PATH.read_text())
            print(format_diff(snap, prev))
        except Exception:
            pass

    # Persist
    if not args.no_persist and not args.domain:
        persist_artifact(snap)

    # Output
    if args.fmt == "json":
        print(json.dumps(snap, indent=2, default=str))
    else:
        print(format_summary(snap))


if __name__ == "__main__":
    main()
