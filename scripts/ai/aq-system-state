_NOW = datetime.now(tz=timezone.utc)


def _run(cmd: List[str], timeout: int = 10) -> str:
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return r.stdout.strip()
    except Exception:
        return ""


def _http_get(url: str, timeout: int = 5) -> Optional[Dict[str, Any]]:
    try:
        with urllib.request.urlopen(url, timeout=timeout) as resp:
            return json.loads(resp.read().decode("utf-8"))
    except Exception:
        return None


def _pg_dsn() -> str:
    dsn = os.getenv("POSTGRES_DSN", "")
    if dsn:
        return dsn
    host = os.getenv("POSTGRES_HOST", "127.0.0.1")
    port = os.getenv("POSTGRES_PORT", "5432")
    db = os.getenv("POSTGRES_DB", os.getenv("AIDB_PG_DB", "aidb"))
    user = os.getenv("POSTGRES_USER", os.getenv("AIDB_PG_USER", "aidb"))
    pw = os.getenv("POSTGRES_PASSWORD", os.getenv("AIDB_PG_PASSWORD", ""))
    return f"host={host} port={port} dbname={db} user={user} password={pw} connect_timeout=5"


def _pg_query(sql: str, params: tuple = ()) -> List[Dict[str, Any]]:
    try:
        import psycopg  # type: ignore
        conn = psycopg.connect(_pg_dsn(), connect_timeout=5)
        cur = conn.execute(sql, params)
        cols = [d.name for d in cur.description]
        rows = [dict(zip(cols, r)) for r in cur.fetchall()]
        conn.close()
        return rows
    except Exception:
        return []


