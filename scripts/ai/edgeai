#!/usr/bin/env bash
# edgeai — MAEAH CLI facade over the normalized edge harness APIs.
# Repo-local v0 focuses on stable JSON API surfaces and graceful offline output.
set -euo pipefail

VERSION="0.1.0"
COORDINATOR_URL="${EDGEAI_COORDINATOR_URL:-${HYBRID_COORDINATOR_URL:-http://127.0.0.1:8003}}"
DASHBOARD_URL="${EDGEAI_DASHBOARD_URL:-${DASHBOARD_URL:-http://127.0.0.1:8889}}"
API_KEY="${EDGEAI_API_KEY:-${HYBRID_COORDINATOR_API_KEY:-}}"
API_KEY_FILE="${EDGEAI_API_KEY_FILE:-${HYBRID_API_KEY_FILE:-/run/secrets/hybrid_coordinator_api_key}}"
if [[ -z "$API_KEY" && -r "$API_KEY_FILE" ]]; then
  API_KEY="$(tr -d '[:space:]' < "$API_KEY_FILE")"
fi
TIMEOUT="${EDGEAI_TIMEOUT_SECONDS:-5}"

usage() {
  cat <<'EOF'
edgeai — Multi-Agent Edge AI Harness CLI

Usage:
  edgeai --version
  edgeai doctor [--json]
  edgeai models list [--json]
  edgeai models add --id ID --name NAME --repo REPO --file FILE [options]
  edgeai models delete <model-id>
  edgeai models download <model-id>
  edgeai models promote <model-id>
  edgeai models rollback <model-id>
  edgeai models reset <model-id>
  edgeai chat [--model MODEL] [--json] <prompt...>
  edgeai contracts check [--json]
  edgeai a2a card validate [--json]
  edgeai mcp tools list [--json]
  edgeai traces tail [--last N] [--json]

Environment:
  EDGEAI_COORDINATOR_URL   default http://127.0.0.1:8003
  EDGEAI_DASHBOARD_URL     default http://127.0.0.1:8889
  EDGEAI_API_KEY           admin API key; falls back to HYBRID_COORDINATOR_API_KEY
  EDGEAI_API_KEY_FILE      default /run/secrets/hybrid_coordinator_api_key
  EDGEAI_TIMEOUT_SECONDS   default 5
EOF
}

json_escape() {
  python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))'
}

_emit_error_json() {
  local component="$1" detail="$2"
  python3 - "$component" "$detail" <<'PY'
import json, sys
print(json.dumps({"ok": False, "component": sys.argv[1], "error": sys.argv[2]}, sort_keys=True))
PY
}

curl_json() {
  local method="$1" url="$2" body="${3:-}"
  local -a args=(curl -fsS --max-time "$TIMEOUT" -X "$method" -H 'Accept: application/json')
  if [[ -n "$API_KEY" ]]; then
    args+=(-H "X-API-Key: $API_KEY")
  fi
  if [[ "$method" != "GET" ]]; then
    args+=(-H 'Content-Type: application/json')
    args+=(-H 'X-Dashboard-Internal: 1')
    args+=(-d "${body:-{}}")
  fi
  args+=("$url")
  "${args[@]}"
}

print_json_or_cat() {
  if command -v jq >/dev/null 2>&1; then jq .; else cat; fi
}

cmd_doctor() {
  local json=0
  [[ "${1:-}" == "--json" ]] && json=1
  python3 - "$COORDINATOR_URL" "$DASHBOARD_URL" "$TIMEOUT" "$json" <<'PY'
import json, sys, urllib.request, urllib.error
coord, dash, timeout, json_mode = sys.argv[1], sys.argv[2], float(sys.argv[3]), sys.argv[4] == "1"
checks = []
def probe(name, url):
    try:
        with urllib.request.urlopen(url, timeout=timeout) as r:
            checks.append({"name": name, "url": url, "ok": 200 <= r.status < 500, "status": r.status})
    except Exception as exc:
        checks.append({"name": name, "url": url, "ok": False, "error": str(exc)[:180]})
probe("coordinator_health", coord.rstrip("/") + "/health")
probe("agent_card", coord.rstrip("/") + "/.well-known/agent.json")
probe("dashboard_health", dash.rstrip("/") + "/api/health")
result = {"ok": all(c.get("ok") for c in checks), "checks": checks}
if json_mode:
    print(json.dumps(result, sort_keys=True))
else:
    for c in checks:
        status = "OK" if c.get("ok") else "FAIL"
        detail = c.get("status", c.get("error", ""))
        print(f"{status:4} {c['name']} {detail}")
    raise SystemExit(0 if result["ok"] else 1)
PY
}

_models_usage() {
  cat >&2 <<'EOF'
usage: edgeai models list [--json]
       edgeai models add --id ID --name NAME --repo REPO --file FILE [--params TEXT] [--context-size N] [--ram-gb N] [--quant-tier TIER] [--type TYPE] [--hardware-targets CSV] [--sha256 HEX] [--description TEXT]
       edgeai models add --from-json PATH
       edgeai models delete <model-id>
       edgeai models download|promote|rollback|reset <model-id>
EOF
}

_build_model_add_body() {
  python3 - "$@" <<'PY'
import json, sys
args = sys.argv[1:]
body = {}
from_json = None
i = 0
while i < len(args):
    key = args[i]
    if key == "--from-json":
        if i + 1 >= len(args):
            raise SystemExit("missing value for --from-json")
        from_json = args[i + 1]; i += 2; continue
    if key not in {"--id", "--name", "--repo", "--file", "--params", "--context-size", "--ram-gb", "--quant-tier", "--type", "--hardware-targets", "--sha256", "--description"}:
        raise SystemExit(f"unknown add option: {key}")
    if i + 1 >= len(args):
        raise SystemExit(f"missing value for {key}")
    val = args[i + 1]
    field = key[2:].replace("-", "_")
    if field == "context_size":
        val = int(val)
    elif field == "ram_gb":
        field = "ram_estimate_gb"
        val = float(val)
    elif field == "hardware_targets":
        val = [x.strip() for x in val.split(",") if x.strip()]
    body[field] = val
    i += 2
if from_json:
    if body:
        raise SystemExit("--from-json cannot be combined with field flags")
    with open(from_json, "r", encoding="utf-8") as f:
        body = json.load(f)
missing = [k for k in ("id", "name", "repo", "file") if not str(body.get(k, "")).strip()]
if missing:
    raise SystemExit("missing required add fields: " + ", ".join(missing))
print(json.dumps(body, sort_keys=True))
PY
}

cmd_models() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    list)
      local json=0; [[ "${1:-}" == "--json" ]] && json=1
      local out
      if out="$(curl_json GET "$DASHBOARD_URL/admin/v1/models" 2>/dev/null)"; then
        if [[ "$json" -eq 1 ]]; then printf '%s\n' "$out"; else printf '%s\n' "$out" | print_json_or_cat; fi
      elif out="$(curl_json GET "$DASHBOARD_URL/api/models" 2>/dev/null)"; then
        if [[ "$json" -eq 1 ]]; then printf '%s\n' "$out"; else printf '%s\n' "$out" | print_json_or_cat; fi
      else
        _emit_error_json models "model catalog unavailable at $DASHBOARD_URL"; return 1
      fi
      ;;
    add)
      local body out
      if ! body="$(_build_model_add_body "$@")"; then return 2; fi
      if out="$(curl_json POST "$DASHBOARD_URL/admin/v1/models" "$body" 2>/dev/null)"; then
        printf '%s\n' "$out" | print_json_or_cat
      else
        _emit_error_json models "model add endpoint unavailable at $DASHBOARD_URL"; return 1
      fi
      ;;
    delete)
      local model_id="${1:-}"; [[ -n "$model_id" ]] || { echo "model id required" >&2; return 2; }
      local out
      if out="$(curl_json DELETE "$DASHBOARD_URL/admin/v1/models/${model_id}" '{}' 2>/dev/null)"; then
        printf '%s\n' "$out" | print_json_or_cat
      else
        _emit_error_json models "model delete endpoint unavailable at $DASHBOARD_URL"; return 1
      fi
      ;;
    download|promote|rollback|reset)
      local model_id="${1:-}"; [[ -n "$model_id" ]] || { echo "model id required" >&2; return 2; }
      local out
      if out="$(curl_json POST "$DASHBOARD_URL/admin/v1/models/${model_id}/${sub}" '{}' 2>/dev/null)"; then
        printf '%s\n' "$out" | print_json_or_cat
      else
        _emit_error_json models "model ${sub} endpoint unavailable at $DASHBOARD_URL"; return 1
      fi
      ;;
    *) _models_usage; return 2 ;;
  esac
}

cmd_chat() {
  local model="${EDGEAI_DEFAULT_MODEL:-local}" json=0
  local -a prompt_parts=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --model) model="${2:-}"; shift 2 ;;
      --json) json=1; shift ;;
      --) shift; prompt_parts+=("$@"); break ;;
      *) prompt_parts+=("$1"); shift ;;
    esac
  done
  local prompt="${prompt_parts[*]:-}"
  [[ -n "$prompt" ]] || { echo "prompt required" >&2; return 2; }
  local body
  body="$(python3 - "$model" "$prompt" <<'PY'
import json, sys
print(json.dumps({"model": sys.argv[1], "input": sys.argv[2]}))
PY
)"
  local out status tmp attempt
  # LLM inference can take 90-300s on local hardware. Do not use curl -f here:
  # local admission control returns structured 503 JSON that callers need to see.
  local chat_timeout="${EDGEAI_CHAT_TIMEOUT_SECONDS:-300}"
  tmp="$(mktemp)"
  trap 'rm -f "${tmp:-}"' RETURN
  for attempt in 1 2 3; do
    local -a args=(curl -sS --max-time "$chat_timeout" -o "$tmp" -w '%{http_code}' -X POST -H 'Accept: application/json')
    if [[ -n "$API_KEY" ]]; then
      args+=(-H "X-API-Key: $API_KEY")
    fi
    args+=(-H 'Content-Type: application/json' -H 'X-Dashboard-Internal: 1' -d "$body" "$COORDINATOR_URL/v1/responses")
    status="$("${args[@]}" 2>/dev/null || printf '000')"
    out="$(cat "$tmp" 2>/dev/null || true)"
    if [[ "$status" =~ ^2 ]]; then
      break
    fi
    if [[ "$out" == *'local_slot_busy'* && "$attempt" != 3 ]]; then
      sleep "${EDGEAI_CHAT_RETRY_AFTER_SECONDS:-30}"
      continue
    fi
    if [[ -n "$out" ]]; then
      printf '%s\n' "$out"
    else
      _emit_error_json chat "responses endpoint unavailable at $COORDINATOR_URL (http_status=$status)"
    fi
    return 1
  done
  if [[ "$json" -eq 1 ]]; then
    printf '%s\n' "$out"
  else
    printf '%s\n' "$out" | python3 -c 'import json,sys; d=json.load(sys.stdin); print(d.get("output_text") or json.dumps(d, indent=2))'
  fi
}


cmd_contracts() {
  [[ "${1:-}" == "check" ]] || { echo "usage: edgeai contracts check [--json]" >&2; return 2; }
  shift || true
  local json=0
  [[ "${1:-}" == "--json" ]] && json=1
  local root
  root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
  python3 - "$root" "$json" <<'PY'
import json, subprocess, sys, time
root = sys.argv[1]
json_mode = sys.argv[2] == "1"
checks = [
    ["python3", "scripts/testing/test-maeah-api-surface-contract.py"],
    ["python3", "scripts/testing/test-maeah-contract-artifacts.py"],
    ["python3", "scripts/testing/test-maeah-model-registry-schema.py"],
    ["python3", "scripts/testing/test-maeah-live-runbook-contract.py"],
    ["bash", "scripts/testing/maeah-live-auth-smoke.sh", "--plan-json"],
]
results = []
for argv in checks:
    started = time.time()
    proc = subprocess.run(argv, cwd=root, text=True, capture_output=True)
    results.append({
        "command": " ".join(argv),
        "ok": proc.returncode == 0,
        "returncode": proc.returncode,
        "duration_s": round(time.time() - started, 3),
        "stdout": proc.stdout.strip()[-2000:],
        "stderr": proc.stderr.strip()[-2000:],
    })
summary = {"ok": all(r["ok"] for r in results), "checks": results}
if json_mode:
    print(json.dumps(summary, sort_keys=True))
else:
    for r in results:
        print(("PASS" if r["ok"] else "FAIL") + " " + r["command"])
        if not r["ok"]:
            detail = r["stderr"] or r["stdout"]
            if detail:
                print(detail)
raise SystemExit(0 if summary["ok"] else 1)
PY
}

cmd_a2a() {
  [[ "${1:-}" == "card" && "${2:-}" == "validate" ]] || { echo "usage: edgeai a2a card validate [--json]" >&2; return 2; }
  local json=0; [[ "${3:-}" == "--json" ]] && json=1
  local out
  if ! out="$(curl_json GET "$COORDINATOR_URL/.well-known/agent.json" 2>/dev/null)"; then
    _emit_error_json a2a "agent card unavailable at $COORDINATOR_URL"; return 1
  fi
  python3 - "$json" "$out" <<'PY'
import json, sys
json_mode = sys.argv[1] == "1"
try:
    card = json.loads(sys.argv[2])
except Exception as exc:
    result = {"ok": False, "error": f"invalid json: {exc}"}
else:
    missing = [k for k in ("name", "protocolVersion", "capabilities") if k not in card]
    endpoint_present = bool(card.get("url") or card.get("endpoint"))
    if not endpoint_present:
        missing.append("url|endpoint")
    result = {"ok": not missing, "missing": missing, "signed": bool(card.get("proof")), "name": card.get("name"), "protocolVersion": card.get("protocolVersion")}
if json_mode:
    print(json.dumps(result, sort_keys=True))
else:
    print("OK" if result.get("ok") else "FAIL", json.dumps(result, sort_keys=True))
raise SystemExit(0 if result.get("ok") else 1)
PY
}

cmd_mcp() {
  [[ "${1:-}" == "tools" && "${2:-}" == "list" ]] || { echo "usage: edgeai mcp tools list [--json]" >&2; return 2; }
  local json=0; [[ "${3:-}" == "--json" ]] && json=1
  local out
  if out="$(curl_json GET "$COORDINATOR_URL/tools/catalog" 2>/dev/null)"; then
    if [[ "$json" -eq 1 ]]; then printf '%s\n' "$out"; else printf '%s\n' "$out" | print_json_or_cat; fi
  else
    _emit_error_json mcp "tool catalog unavailable at $COORDINATOR_URL"; return 1
  fi
}

cmd_traces() {
  [[ "${1:-}" == "tail" ]] || { echo "usage: edgeai traces tail [--last N] [--json]" >&2; return 2; }
  shift || true
  local last=1 json=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --last) last="${2:-1}"; shift 2 ;;
      --json) json=1; shift ;;
      *) echo "unknown traces option: $1" >&2; return 2 ;;
    esac
  done
  local out
  if out="$(curl_json GET "$COORDINATOR_URL/api/traces?limit=$last" 2>/dev/null)"; then
    if [[ "$json" -eq 1 ]]; then printf '%s\n' "$out"; else printf '%s\n' "$out" | print_json_or_cat; fi
  else
    _emit_error_json traces "trace endpoint unavailable at $COORDINATOR_URL"; return 1
  fi
}

main() {
  case "${1:-}" in
    --version) echo "edgeai $VERSION" ;;
    -h|--help|help|"") usage ;;
    doctor) shift; cmd_doctor "$@" ;;
    models) shift; cmd_models "$@" ;;
    chat) shift; cmd_chat "$@" ;;
    contracts) shift; cmd_contracts "$@" ;;
    a2a) shift; cmd_a2a "$@" ;;
    mcp) shift; cmd_mcp "$@" ;;
    traces) shift; cmd_traces "$@" ;;
    *) echo "unknown command: $1" >&2; usage >&2; return 2 ;;
  esac
}

main "$@"
