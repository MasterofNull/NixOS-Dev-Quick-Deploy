#!/usr/bin/env python3
"""Inspect and reconcile the durable multi-agent delegation registry."""
from __future__ import annotations

import argparse
import json
import os
import sys
from pathlib import Path
from datetime import datetime, timezone

ROOT = Path(__file__).resolve().parents[2]
DEFAULT_REGISTRY = ROOT / ".agents" / "delegation" / "registry.jsonl"
LIB = ROOT / "scripts" / "ai" / "lib"
sys.path.insert(0, str(LIB))

from task_registry import TaskRegistry  # noqa: E402


def _pid_alive(pid: object) -> bool:
    if pid in (None, "", "null"):
        return False
    try:
        value = int(pid)
    except (TypeError, ValueError):
        return False
    try:
        os.kill(value, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


def _load(path: Path) -> tuple[list[str], list[dict]]:
    comments: list[str] = []
    entries: list[dict] = []
    if not path.exists():
        return comments, entries
    for raw in path.read_text().splitlines():
        line = raw.strip()
        if not line:
            continue
        if line.startswith("#"):
            comments.append(raw)
            continue
        try:
            entries.append(json.loads(line))
        except json.JSONDecodeError:
            comments.append(raw)
    return comments, entries


def _write(path: Path, comments: list[str], entries: list[dict]) -> None:
    lines = list(comments)
    lines.extend(json.dumps(e, separators=(",", ":"), ensure_ascii=False) for e in entries)
    path.write_text("\n".join(lines) + ("\n" if lines else ""))


def reconcile(path: Path, dry_run: bool) -> int:
    if path == DEFAULT_REGISTRY:
        registry = TaskRegistry(path.parent, repo_root=ROOT)
        result = registry.repair_stale(apply=not dry_run)
        print(json.dumps({"registry": str(path), **result, "dry_run": dry_run}, indent=2))
        return 0
    comments, entries = _load(path)
    now = datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")
    changed = 0
    for entry in entries:
        if entry.get("status") != "running":
            continue
        pid = entry.get("pid")
        if _pid_alive(pid):
            continue
        entry["status"] = "stale"
        entry["stale_since"] = now
        entry["stale_reason"] = "registry said running, but pid is missing or no longer alive"
        changed += 1
    if changed and not dry_run:
        _write(path, comments, entries)
    print(json.dumps({"registry": str(path), "stale_marked": changed, "dry_run": dry_run}, indent=2))
    return 0


def list_entries(path: Path, status: str | None) -> int:
    if path == DEFAULT_REGISTRY:
        registry = TaskRegistry(path.parent, repo_root=ROOT)
        entries = [registry._with_inferred_status(e) for e in registry.list_all()]
        for entry in entries:
            if status and entry.get("status") != status:
                continue
            print(f"{entry.get('id','?'):<32} {entry.get('status','?'):<8} {entry.get('agent','?'):<12} {entry.get('role','?'):<10} {str(entry.get('pid')):<8} {entry.get('description','')[:72]}")
        return 0
    _, entries = _load(path)
    for entry in entries:
        if status and entry.get("status") != status:
            continue
        print(f"{entry.get('id','?'):<32} {entry.get('status','?'):<8} {entry.get('agent','?'):<12} {entry.get('role','?'):<10} {str(entry.get('pid')):<8} {entry.get('description','')[:72]}")
    return 0


def _m2a_registry(path: Path) -> "TaskRegistry":
    reg_dir = path.parent if path.suffix else path
    return TaskRegistry(reg_dir, repo_root=ROOT)


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--registry", type=Path, default=DEFAULT_REGISTRY)
    sub = parser.add_subparsers(dest="cmd", required=True)

    r = sub.add_parser("reconcile", help="mark dead running entries as stale")
    r.add_argument("--dry-run", action="store_true")
    l = sub.add_parser("list", help="list registry entries")
    l.add_argument("--status")

    # ── M2A dormant operations — machine JSON only ───────────────────────────
    b = sub.add_parser(
        "begin",
        help="[M2A dormant] write a new queued M2A task record",
    )
    b.add_argument("task_id")
    b.add_argument("--lane", required=True)
    b.add_argument("--role", required=True)
    b.add_argument("--access", required=True)
    b.add_argument("--task-class", dest="task_class", required=True)
    b.add_argument("--artifact", dest="artifact_expectation", required=True)

    ap = sub.add_parser(
        "attach-process",
        help="[M2A dormant] attach PID+start-time to a queued record",
    )
    ap.add_argument("task_id")
    ap.add_argument("--pid", type=int, required=True)
    ap.add_argument("--start-time", dest="pid_start_time", type=int, required=True)
    ap.add_argument("--expected-revision", dest="expected_revision", type=int, default=None)

    tr = sub.add_parser(
        "transition",
        help="[M2A dormant] apply a state transition to a M2A record",
    )
    tr.add_argument("task_id")
    tr.add_argument("--to-status", dest="to_status", required=True)
    tr.add_argument("--terminal-reason", dest="terminal_reason", default=None)
    tr.add_argument("--expected-revision", dest="expected_revision", type=int, default=None)

    sh = sub.add_parser("show", help="[M2A dormant] show a single M2A record")
    sh.add_argument("task_id")

    sub.add_parser("reconcile-m2a", help="[M2A dormant] reconcile dead-PID active M2A records")

    args = parser.parse_args()

    if args.cmd == "reconcile":
        return reconcile(args.registry, args.dry_run)
    if args.cmd == "list":
        return list_entries(args.registry, args.status)

    from task_registry import RegistryError  # noqa: E402
    reg = _m2a_registry(args.registry)

    if args.cmd == "begin":
        try:
            result = reg.begin(
                args.task_id, args.lane, args.role, args.access,
                args.task_class, args.artifact_expectation,
            )
            print(json.dumps({"ok": True, "record": result}, indent=2))
            return 0
        except RegistryError as exc:
            print(json.dumps({"ok": False, "error": str(exc)}), file=sys.stderr)
            return 1

    if args.cmd == "attach-process":
        try:
            result = reg.attach_process(
                args.task_id, args.pid, args.pid_start_time, args.expected_revision,
            )
            print(json.dumps({"ok": True, "record": result}, indent=2))
            return 0
        except RegistryError as exc:
            print(json.dumps({"ok": False, "error": str(exc)}), file=sys.stderr)
            return 1

    if args.cmd == "transition":
        try:
            result = reg.transition_m2a(
                args.task_id, args.to_status, args.terminal_reason, args.expected_revision,
            )
            print(json.dumps({"ok": True, "record": result}, indent=2))
            return 0
        except RegistryError as exc:
            print(json.dumps({"ok": False, "error": str(exc)}), file=sys.stderr)
            return 1

    if args.cmd == "show":
        result = reg.lookup_m2a_compatible(args.task_id)
        _EXIT = {
            None: 0,
            "registry_task_not_found": 3,
            "registry_target_legacy_oversized": 4,
            "registry_task_id_invalid": 2,
        }
        # Exit 5 means the source was read but cannot be trusted. Exit 6 is
        # reserved for access/read availability, never integrity ambiguity.
        _UNAVAIL = frozenset({"registry_read_open_failed", "registry_source_unavailable"})
        error_code = result.get("error_code")
        if result["ok"]:
            print(json.dumps(result, indent=2))
            return 0
        code = _EXIT.get(error_code, 6 if error_code in _UNAVAIL else 5)
        print(json.dumps(result, indent=2), file=sys.stderr)
        return code

    if args.cmd == "reconcile-m2a":
        try:
            result = reg.reconcile_m2a()
            print(json.dumps({"ok": True, **result}, indent=2))
            return 0
        except RegistryError as exc:
            print(json.dumps({"ok": False, "error": str(exc)}), file=sys.stderr)
            return 1

    return 2


if __name__ == "__main__":
    raise SystemExit(main())
