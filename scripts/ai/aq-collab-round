#!/usr/bin/env python3
"""aq-collab-round — agentic fan-out engine for flat-collaborative rounds.

Codifies the multi-agent round that was previously orchestrated by hand: fan a task out to ALL
agents, each writing to its OWN per-agent file (no lost-write race), then poll/collect. First cut
of the epic's "round driver" (epic-flat-collaborative-factory, stages 2-4).

Full logic + data-exposure map: docs/operations/collab-workflow-exposure.md.

Auth model (NO API keys — governing, feedback-no-api-keys-oauth-only):
  - codex  : headless CLI, codex's own login (remote OpenAI). Prompt scanned/audited outbound.
  - local  : delegate-to-local → on-host APU. NOTHING leaves the host. Never skipped: dispatched
             with the task INLINED (so it doesn't burn turns reading) + a generous timeout; the
             round stays OPEN for its late contribution.
  - antigravity : the Google Antigravity IDE (real Gemini) authenticated by its OWN OAuth, which we
             NEVER touch. We do NOT call a headless key-based lane (that would fall back to local
             Qwen). Instead we DROP a task file into a watched inbox; the IDE agent (configured to
             watch it) responds by writing the per-agent file. No credentials cross the boundary.
             The old delegate-to-gemini / gemini npm CLI is DEAD — never dispatched.

Usage:
  aq-collab-round open   --round <name> --task "<prompt>" [--target <path>] [--local-timeout 5400] [--dry-run]
  aq-collab-round status --round <name>
  aq-collab-round collect --round <name>   # poll + auto-extract local's verdict from its output log
"""
from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import shutil
import time
from datetime import datetime, timezone
from pathlib import Path

REPO = Path(__file__).resolve().parents[2]
PLANS = REPO / ".agents" / "plans"
SCRIPTS = REPO / "scripts" / "ai"
OUTPUTS = REPO / ".agents" / "delegation" / "outputs"
# Watched inbox — the Antigravity IDE agent (its own OAuth) polls this dir and responds.
ANTIGRAVITY_INBOX = REPO / ".agent" / "collaboration" / "antigravity-inbox"
# Lanes that receive a live dispatch. antigravity is a file-drop (inbox), not a process dispatch.
PROCESS_AGENTS = ["codex", "local"]
ALL_AGENTS = ["claude", "codex", "local", "antigravity"]
LEGACY_ROUND_ALIASES = {
    "usability-parity-v2": "usability-parity",
}

# ── F1.5: round.json state-machine integration (NON-BREAKING) ─────────────────
# The typed round primitive (F1.1-F1.4: scripts/ai/lib/round_{state,contribution,aggregate}.py).
# aq-collab-round writes/reads round.json ALONGSIDE the legacy per-agent markdown. If the lib is
# unavailable or any typed step fails, we degrade to the legacy markdown-only behavior — the CLI is
# never worse than before. The typed path is strictly additive and READ-ONLY on <agent>.md.
_LIB = SCRIPTS / "lib"
if str(_LIB) not in sys.path:
    sys.path.insert(0, str(_LIB))
try:
    import round_state as _rstate
    import round_contribution as _rcontrib
    import round_aggregate as _raggr
    _LIB_OK = True
except Exception:  # noqa: BLE001 — a missing/broken lib must not break the legacy CLI
    _LIB_OK = False


def _write_manifest(rd: Path, name: str, task: str, target: str) -> None:
    """F1.5: write round.json (state DISPATCHED) beside the per-agent files. Best-effort; never raises."""
    if not _LIB_OK:
        return
    try:
        m = _rstate.RoundManifest(
            round_id=name, state=_rstate.RoundState.CREATED,
            task=_rstate.RoundTask(prompt=task, target=target or "", scope_files=[]),
            opened_at=_rstate.utc_iso(),
            quorum_policy=_rstate.QuorumPolicy(min_lanes=2, required_agents=[],
                                               timeout_seconds=None, deadline=None),
            lanes=[], consensus_hash=None, aggregate_path=None, aggregate_hash=None, locked_at=None)
        for agent in ALL_AGENTS:
            _raggr.register_lane(m, agent, "reviewer", task)
        m = _rstate.transition(m, _rstate.RoundState.DISPATCHED, "aq-collab-round")
        _rstate.save(m, rd / "round.json")
    except Exception:  # noqa: BLE001
        pass


def _typed_consensus(rd: Path, name: str) -> str | None:
    """F1.5: read-only typed aggregation over whatever contributions are present. Returns a one-line
    printable summary, or None if the lib is unavailable or anything fails. NEVER mutates <agent>.md
    (uses the read-only extract_contribution); persists round.json only when it already exists (round-
    owned, derived)."""
    if not _LIB_OK:
        return None
    try:
        rjson = rd / "round.json"
        if rjson.exists():
            m = _rstate.load(rjson)
        else:  # legacy round — synthesize an in-memory manifest, never written for legacy dirs
            m = _rstate.RoundManifest(
                round_id=name, state=_rstate.RoundState.CREATED,
                task=_rstate.RoundTask(prompt="(legacy)", target="", scope_files=[]),
                opened_at=_rstate.utc_iso(),
                quorum_policy=_rstate.QuorumPolicy(min_lanes=2, required_agents=[],
                                                   timeout_seconds=None, deadline=None),
                lanes=[], consensus_hash=None, aggregate_path=None, aggregate_hash=None, locked_at=None)
            for agent in ALL_AGENTS:
                _raggr.register_lane(m, agent, "reviewer", "(legacy)")
            m = _rstate.transition(m, _rstate.RoundState.DISPATCHED, "aq-collab-round")
        try:
            disp = json.loads((rd / ".round-dispatch.json").read_text()).get("dispatch", {})
        except Exception:  # noqa: BLE001
            disp = {}
        contribs = {}
        for agent in ALL_AGENTS:
            if not (rd / f"{agent}.md").exists() and agent not in disp:
                continue
            tid = str(disp.get(agent, ""))
            log = OUTPUTS / f"{tid}.log" if tid and not tid.startswith(("inbox", "error", "running")) else None
            c, _note = _rcontrib.extract_contribution(agent, rd, log if (log and log.exists()) else None)
            if c is not None:
                contribs[agent] = c
        if not contribs:
            return None
        if m.state == _rstate.RoundState.DISPATCHED:
            m = _rstate.transition(m, _rstate.RoundState.CONTRIBUTING, "aq-collab-round")
        if m.state == _rstate.RoundState.CONTRIBUTING:
            m = _rstate.transition(m, _rstate.RoundState.COLLECTED, "aq-collab-round")
        for lane in m.lanes:  # F1.5: reflect landed contributions so quorum_met is accurate
            if lane.agent in contribs:
                lane.status = _rstate.LaneStatus.submitted
        if m.state == _rstate.RoundState.COLLECTED:
            m = _raggr.aggregate(m, contribs)
        if rjson.exists():
            _rstate.save(m, rjson)  # round-owned derived file; legacy dirs are never written
        tally: dict[str, int] = {}
        for c in contribs.values():
            tally[c.verdict.value] = tally.get(c.verdict.value, 0) + 1
        return (f"typed consensus: state={m.state.value} verdicts={tally} "
                f"conflicts={len(m.conflicts)} hash={(m.consensus_hash or '—')[:12]}")
    except Exception:  # noqa: BLE001 — typed path is additive; never break collect
        return None


def _round_dir(name: str) -> Path:
    return PLANS / name


def _now() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def _readme(name: str, task: str, target: str) -> str:
    return f"""# Collaborative Round — {name}

Opened: {_now()}
Target artifact (if a review round): {target or '(none — fresh drafting round)'}

## Task
{task}

## Protocol
Each agent writes its OWN file here — `codex.md`, `local.md`, `antigravity.md`, `claude.md`.
NEVER append to a shared file. The orchestrator aggregates into `AGGREGATE.md`.
- local[Qwen] runs long — the round stays OPEN for it; never skipped.
- antigravity (Antigravity IDE, real Gemini via its OWN OAuth) picks up the task from the inbox
  `{ANTIGRAVITY_INBOX.relative_to(REPO)}/{name}.md` and writes `antigravity.md`. No API keys.
"""


def _write_prompt(rd: Path, name: str, task: str, target: str) -> Path:
    # INLINE the target artifact (do not make agents READ a file). local[Qwen] chunk-reads a
    # --target file and burns its whole run on re-reading (observed: it never designs). Inlining
    # (capped) makes every lane — especially local — see the artifact directly. Live finding from
    # the f1 round.
    target_block = ""
    if target:
        try:
            tp = Path(target) if Path(target).is_absolute() else (REPO / target)
            content = tp.read_text(encoding="utf-8")
            target_block = (f"=== REVIEW ARTIFACT ({target}) — INLINED; do NOT read the file ===\n"
                            f"{content[:12000]}\n=== END ARTIFACT ===\n\n")
        except OSError:
            target_block = f"Review artifact: {target} (read it).\n"
    prompt = (f"COLLABORATIVE ROUND '{name}'.\n{target_block}"
              f"TASK:\n{task}\n\n"
              f"Write your contribution to YOUR OWN file ONLY: "
              f".agents/plans/{name}/<AGENT>.md (<AGENT> = codex | local | antigravity). "
              f"Do NOT edit any shared file. Do NOT read the artifact file (it is inlined above). "
              f"Be decisive and concise.")
    pf = rd / ".round-prompt.txt"
    pf.write_text(prompt)
    return pf


def _dispatch_process(agent: str, prompt_file: Path, local_timeout: int) -> str:
    """Fire a live process dispatch (codex/local), background. Returns the task id (or error)."""
    try:
        if agent == "codex":
            cmd = ["bash", str(SCRIPTS / "delegate-to-codex"), "--mode", "edit",
                   "--prompt-file", str(prompt_file)]
            env = os.environ
        else:  # local — never-skip: agent-mode, inlined, generous timeout, async
            cmd = ["bash", str(SCRIPTS / "delegate-to-local"), "--mode", "agent", "--role",
                   "reviewer", "--timeout", str(local_timeout), "--prompt-file", str(prompt_file)]
            env = {**os.environ, "AQ_AGENT_ROLE": "reviewer"}
        out = subprocess.run(cmd, capture_output=True, text=True, timeout=30, env=env).stdout
        return (out.strip().splitlines() or ["?"])[-1]
    except subprocess.TimeoutExpired:
        return "running-async"
    except Exception as e:  # noqa: BLE001 — one lane failing must not abort the fan-out
        return f"error:{e}"


def _drop_antigravity(name: str, prompt_file: Path) -> str:
    """No-key antigravity lane: drop a task file into the IDE-watched inbox.

    Secondary/notification only. The inbox has historically piled up unconsumed
    (the IDE was never wired to poll it), so the RELIABLE lane is the headless
    switchboard dispatch below. This drop remains for a human working in the IDE.
    """
    ANTIGRAVITY_INBOX.mkdir(parents=True, exist_ok=True)
    inbox = ANTIGRAVITY_INBOX / f"{name}.md"
    inbox.write_text(f"# A2A task for antigravity — round '{name}'\n\n"
                     f"Dropped: {_now()}\n\n"
                     f"Respond by writing `.agents/plans/{name}/antigravity.md`.\n\n"
                     f"{prompt_file.read_text()}\n")
    return f"inbox:{inbox.relative_to(REPO)}"


# The consumption signal is deletion: the IDE (or a bridge) removes a task file
# once it acts on it. We track the LAST drop so liveness keys off whether THAT
# specific file was consumed — not on the presence of unrelated old backlog
# (which created a self-reinforcing UNAVAILABLE loop: stale files -> unavailable
# -> drop another -> more stale files. Diagnosis credited to the antigravity
# lane itself, relayed 2026-07-09).
_ANTIGRAVITY_STATE = ANTIGRAVITY_INBOX / ".lane-state.json"
_ANTIGRAVITY_CONSUME_WINDOW_S = 900  # 15 min to consume a drop before "not watching"


def _archive_stale_inbox(keep: "set[str]") -> int:
    """Move consumed-window-exceeded task files (except `keep`) to the archive.

    Stops the monotonic backlog growth that poisoned the liveness signal.
    Rule 12: archive, never delete.
    """
    if not ANTIGRAVITY_INBOX.exists():
        return 0
    now = time.time()
    archive_dir = REPO / ".agent" / "archive" / f"antigravity-inbox-{datetime.now(timezone.utc):%Y%m%d}"
    moved = 0
    for p in ANTIGRAVITY_INBOX.glob("*.md"):
        if p.name in keep:
            continue
        if now - p.stat().st_mtime > _ANTIGRAVITY_CONSUME_WINDOW_S:
            archive_dir.mkdir(parents=True, exist_ok=True)
            shutil.move(str(p), str(archive_dir / p.name))
            moved += 1
    return moved


def _antigravity_inbox_live() -> "tuple[bool, str]":
    """Liveness by per-drop CONSUMPTION, not backlog presence.

    Live iff the last dropped task file was consumed (deleted) within the
    window. Unrelated old files no longer poison the signal (they are archived
    on open). If we have no prior drop to judge, we report 'unproven' as a
    soft state (attempt the lane) rather than a hard dead.
    """
    try:
        proc_live = False
        try:
            proc_live = subprocess.run(
                ["pgrep", "-fa", "antigravity"], capture_output=True, text=True, timeout=5
            ).returncode == 0
        except Exception:
            proc_live = False
        if not ANTIGRAVITY_INBOX.exists():
            return False, "inbox dir missing"

        last_drop = None
        try:
            last_drop = json.loads(_ANTIGRAVITY_STATE.read_text()).get("last_drop")
        except Exception:
            last_drop = None

        if not last_drop:
            return proc_live, ("no prior drop to judge — attempting lane"
                               + ("" if proc_live else "; Antigravity IDE not running"))

        prev = ANTIGRAVITY_INBOX / last_drop["name"]
        age = time.time() - last_drop["ts"]
        if not prev.exists():
            return True, "IDE consumed the previous task file (lane live)"
        if age > _ANTIGRAVITY_CONSUME_WINDOW_S:
            return False, (f"previous drop '{last_drop['name']}' unconsumed after "
                           f"{int(age/60)}min — "
                           f"{'IDE running but no inbox-watch workflow' if proc_live else 'IDE not running'}")
        return proc_live, f"previous drop pending consumption ({int(age)}s)"
    except Exception as e:  # noqa: BLE001
        return False, f"liveness check error: {e}"


def _dispatch_antigravity(name: str, prompt_file: Path) -> str:
    """Antigravity lane (no-key IDE/OAuth inbox), self-cleaning + consumption-based."""
    archived = _archive_stale_inbox(keep={f"{name}.md"})
    live, why = _antigravity_inbox_live()          # judge BEFORE this drop
    marker = _drop_antigravity(name, prompt_file)
    try:
        _ANTIGRAVITY_STATE.write_text(json.dumps(
            {"last_drop": {"name": f"{name}.md", "ts": time.time()}}))
    except Exception:
        pass
    arch = f" (archived {archived} stale)" if archived else ""
    if live:
        return f"{marker} (IDE consuming — {why}){arch}"
    return f"{marker} UNAVAILABLE: {why}{arch}"


def cmd_open(args) -> int:
    rd = _round_dir(args.round)
    if args.dry_run:
        print(f"[dry-run] would open '{args.round}' at {rd}")
        print(f"[dry-run] dispatch: codex(edit), local(agent,{args.local_timeout}s,inlined,never-skip)")
        print(f"[dry-run] antigravity: file-drop to {ANTIGRAVITY_INBOX.relative_to(REPO)}/{args.round}.md (no keys)")
        print(f"[dry-run] claude: orchestrator writes {args.round}/claude.md + aggregates")
        return 0
    rd.mkdir(parents=True, exist_ok=True)
    (rd / "README.md").write_text(_readme(args.round, args.task, args.target or ""))
    pf = _write_prompt(rd, args.round, args.task, args.target or "")

    dispatch = {}
    print(f"[aq-collab-round] opened '{args.round}' at {rd.relative_to(REPO)}")
    for agent in PROCESS_AGENTS:
        tid = _dispatch_process(agent, pf, args.local_timeout)
        dispatch[agent] = tid
        print(f"  {agent}: dispatched {tid}")
    # Antigravity: no-key IDE/OAuth inbox lane with honest liveness reporting.
    # (Headless switchboard->Gemini is intentionally refused by the no-keys
    #  policy guard, so the IDE inbox is the only sanctioned transport.)
    dispatch["antigravity"] = _dispatch_antigravity(args.round, pf)
    _ag_state = dispatch["antigravity"]
    print(f"  antigravity: {_ag_state}")
    if "UNAVAILABLE" in _ag_state:
        print(f"  ⚠ antigravity lane will not respond until the Antigravity IDE is wired to watch "
              f"{ANTIGRAVITY_INBOX.relative_to(REPO)}/ — round will aggregate without it.")
    print(f"  claude: orchestrator writes {args.round}/claude.md + aggregates")
    (rd / ".round-dispatch.json").write_text(json.dumps(
        {"opened": _now(), "dispatch": dispatch}, indent=2))
    _write_manifest(rd, args.round, args.task, args.target or "")  # F1.5: round.json (best-effort)
    if (rd / "round.json").exists():
        print(f"  round.json: written (state=DISPATCHED)")
    print(f"\n  poll:    aq-collab-round status  --round {args.round}")
    print(f"  collect: aq-collab-round collect --round {args.round}   (auto-extracts local verdict)")
    return 0


def _extract_local_verdict(rd: Path) -> str:
    """If local wrote no local.md but its dispatch log has a completed result, record it. Local
    often emits the verdict as TEXT (0 tool calls) — capture it so its contribution is never lost."""
    lf = rd / "local.md"
    if lf.exists():
        return "present"
    try:
        disp = json.loads((rd / ".round-dispatch.json").read_text()).get("dispatch", {})
    except Exception:
        return "no-dispatch-record"
    tid = disp.get("local", "")
    if not tid or tid.startswith(("error", "running")):
        return "local-not-dispatched-or-running"
    log = OUTPUTS / f"{tid}.log"
    if not log.exists():
        return "local-log-missing"
    try:
        d = json.loads(log.read_text())
    except Exception:
        return "local-running-or-unparsed"
    if d.get("status") != "completed":
        return f"local-{d.get('status','running')}"
    result = d.get("result")
    text = result if isinstance(result, str) else json.dumps(result)
    if not text:
        return "local-completed-empty"
    lf.write_text(f"# local[Qwen] — round contribution (auto-extracted)\n\n"
                  f"_From dispatch `{tid}` (produced text, {len(d.get('tool_calls') or [])} tool "
                  f"calls; orchestrator recorded)._\n\n{text.strip()}\n")
    return "extracted"


def _legacy_round_alias(name: str) -> str | None:
    return LEGACY_ROUND_ALIASES.get(name)


def _repair_antigravity_misplaced_output(rd: Path, name: str) -> str:
    """Recover Antigravity output written to a known superseded round path.

    The IDE lane is file-drop/OAuth only, so the common failure mode is a stale
    prompt instructing the IDE to write to an older round directory. Copy only
    known aliases and only when the active round output is absent.
    """
    target = rd / "antigravity.md"
    if target.exists():
        return "present"
    alias = _legacy_round_alias(name)
    if not alias:
        return "no-legacy-alias"
    legacy = PLANS / alias / "antigravity.md"
    if not legacy.exists():
        return "legacy-missing"
    target.parent.mkdir(parents=True, exist_ok=True)
    shutil.copyfile(legacy, target)
    with target.open("a", encoding="utf-8") as fh:
        fh.write(
            "\n\n<!-- recovered-by: aq-collab-round; "
            f"source=.agents/plans/{alias}/antigravity.md; "
            "reason=legacy-output-path -->\n"
        )
    return f"recovered-from:{alias}"


def _validate_antigravity_contribution(rd: Path) -> list[str]:
    """Return non-fatal review warnings for known Antigravity proposal mistakes."""
    path = rd / "antigravity.md"
    if not path.exists():
        return []
    text = path.read_text(encoding="utf-8", errors="replace")
    warnings = []
    required = [
        "# Verdict",
        "# Evidence Read",
        "# Expert-Team Findings",
        "# Ranked Parity Gaps",
        "# Proposed UX Architecture",
        "# Slice Plan",
        "# Validation Matrix",
        "# Risk Register",
        "# First Slice Recommendation",
        "# Open Questions",
    ]
    missing = [h for h in required if h not in text]
    if missing:
        warnings.append("antigravity-missing-headings:" + ",".join(missing))
    stale_path_lines = [
        line for line in text.splitlines()
        if ".agents/plans/usability-parity/" in line
        and ("write" in line.lower() or "output" in line.lower())
    ]
    if stale_path_lines:
        warnings.append("antigravity-mentions-superseded-output-path")
    forbidden = ["Google AI Studio", "active billing quota", "SOPS secret keys"]
    if any(term in text for term in forbidden):
        warnings.append("antigravity-provider-language-needs-no-key-review")
    gap_section = text.split("# Ranked Parity Gaps", 1)[-1].split("# Proposed UX Architecture", 1)[0]
    ranked_rows = 0
    for line in gap_section.splitlines():
        cells = [cell.strip() for cell in line.strip().strip("|").split("|")]
        if cells and cells[0].isdigit():
            ranked_rows += 1
    numbered = sum(
        1
        for line in gap_section.splitlines()
        if any(line.lstrip().startswith(f"{i}.") for i in range(1, 11))
    )
    if max(ranked_rows, numbered) < 10:
        warnings.append("antigravity-ranked-gaps-fewer-than-10")
    return warnings


def cmd_status(args, do_extract: bool = False) -> int:
    rd = _round_dir(args.round)
    if not rd.exists():
        print(f"no round '{args.round}' at {rd}", file=sys.stderr)
        return 1
    if do_extract:
        r = _extract_local_verdict(rd)
        print(f"[collect] local verdict: {r}")
        ar = _repair_antigravity_misplaced_output(rd, args.round)
        if ar != "present":
            print(f"[collect] antigravity output: {ar}")
    print(f"[aq-collab-round] {args.round}")
    for agent in ALL_AGENTS:
        f = rd / f"{agent}.md"
        print(f"  {agent:12} " + (f"✅ {f.stat().st_size}B" if f.exists() else "⏳ pending"))
    try:
        out = subprocess.run(["pgrep", "-af", "delegate-to|aq-agent-loop|codex exec"],
                             capture_output=True, text=True, timeout=5).stdout
        print(f"  active dispatch procs: {sum(1 for l in out.splitlines() if 'aq-collab-round' not in l and 'pgrep' not in l)}")
    except Exception:
        pass
    have = [a for a in ALL_AGENTS if (rd / f"{a}.md").exists()]
    print(f"  landed: {len(have)}/4 — {', '.join(have) or 'none'}")
    if do_extract:  # F1.5: collect/aggregate print the typed consensus (additive; None-safe)
        for warning in _validate_antigravity_contribution(rd):
            print(f"  warning: {warning}")
        tc = _typed_consensus(rd, args.round)
        if tc:
            print(f"  {tc}")
    return 0


def main() -> int:
    ap = argparse.ArgumentParser(prog="aq-collab-round", description=__doc__)
    sub = ap.add_subparsers(dest="cmd", required=True)
    o = sub.add_parser("open", help="fan a task out to all agents")
    o.add_argument("--round", required=True); o.add_argument("--task", required=True)
    o.add_argument("--target"); o.add_argument("--local-timeout", type=int, default=5400)
    o.add_argument("--dry-run", action="store_true"); o.set_defaults(fn=cmd_open)
    s = sub.add_parser("status", help="poll contributions"); s.add_argument("--round", required=True)
    s.set_defaults(fn=lambda a: cmd_status(a, do_extract=False))
    c = sub.add_parser("collect", help="poll + auto-extract local's verdict from its log")
    c.add_argument("--round", required=True); c.set_defaults(fn=lambda a: cmd_status(a, do_extract=True))
    g = sub.add_parser("aggregate", help="F1.5: typed aggregation over round.json (read-only on <agent>.md)")
    g.add_argument("--round", required=True); g.set_defaults(fn=lambda a: cmd_status(a, do_extract=True))
    args = ap.parse_args()
    return args.fn(args)


if __name__ == "__main__":
    sys.exit(main())
