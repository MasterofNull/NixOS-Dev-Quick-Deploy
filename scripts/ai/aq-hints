#!/usr/bin/env python3
"""
aq-hints — Agent-agnostic workflow hint CLI (Phase 19.1.2)

Surfaces ranked hints from registry.yaml prompt scores, query gaps, and
CLAUDE.md workflow rules. Consumed by any agent over stdout:

  Human terminal:    aq-hints "conflicting nixos" --format=text
  Claude Code:       aq-hints "systemd service" --format=json --agent=claude
  Codex/Qwen pipe:   aq-hints "aider task" --format=json --agent=codex
  aider-wrapper:     aq-hints "..." --format=json --agent=aider
  Continue.dev:      aq-hints "..." --format=json --agent=continue
  Shell complete:    aq-hints --format=shell-complete

Falls back to REST GET /hints?q= on HYBRID_URL if local engine is unavailable.

Usage:
  aq-hints [QUERY] [--format=json|text|shell-complete]
           [--context=EXT] [--max=N] [--agent=TYPE]

Environment:
  REGISTRY_PATH        Override path to registry.yaml
  TOOL_AUDIT_LOG_PATH  Override tool-audit.jsonl path
  HYBRID_URL           Hybrid coordinator base URL (REST fallback)
"""

from __future__ import annotations

import argparse
import json
import os
import sys
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path
from typing import Any, Dict, List, Optional

# ---------------------------------------------------------------------------
# Engine import — local first, REST fallback
# ---------------------------------------------------------------------------

# Resolve symlinks so local-bin wrappers (e.g. ~/.local/bin/aq-hints -> repo script)
# still compute the correct repository root.
_REPO_ROOT = Path(__file__).resolve().parent.parent.parent
_ENGINE_DIR = _REPO_ROOT / "ai-stack/mcp-servers/hybrid-coordinator"

if str(_ENGINE_DIR) not in sys.path and _ENGINE_DIR.exists():
    sys.path.insert(0, str(_ENGINE_DIR))

try:
    from hints_engine import HintsEngine  # type: ignore[import]
    _ENGINE_AVAILABLE = True
except ImportError:
    _ENGINE_AVAILABLE = False

HYBRID_URL = os.getenv(
    "HYBRID_URL",
    f"http://{os.getenv('SERVICE_HOST', '127.0.0.1')}:{os.getenv('HYBRID_COORDINATOR_PORT', '8003')}",
).rstrip("/")


def _load_hybrid_api_key() -> str:
    key = os.getenv("HYBRID_API_KEY", "").strip()
    if key:
        return key
    key_file = os.getenv("HYBRID_API_KEY_FILE", "/run/secrets/hybrid_coordinator_api_key")
    try:
        return Path(key_file).read_text(encoding="utf-8").strip()
    except Exception:
        return ""


def _fetch_agent_status() -> Optional[Dict[str, Any]]:
    """Fetch remote agent pool status from /agent-status endpoint."""
    url = f"{HYBRID_URL}/agent-status"
    try:
        headers = {"Accept": "application/json"}
        api_key = _load_hybrid_api_key()
        if api_key:
            headers["X-API-Key"] = api_key
        req = urllib.request.Request(url, headers=headers)
        with urllib.request.urlopen(req, timeout=3) as resp:
            return json.loads(resp.read())
    except Exception:
        return None


def _format_agent_status_summary(status: Dict[str, Any]) -> str:
    """Format agent status into a human-readable summary."""
    lines = []
    pool_status = status.get("pool_status", "unknown")
    total = status.get("total_agents", 0)
    available = status.get("available_agents", 0)
    free = status.get("free_agents_available", 0)

    lines.append(f"\n  Agent Pool Status: {pool_status}")
    lines.append(f"    Total agents: {total} | Available: {available} | Free tier: {free}")

    agents = status.get("agents", [])
    rate_limited = [a for a in agents if a.get("is_rate_limited")]
    unavailable = [a for a in agents if not a.get("is_available") and not a.get("is_rate_limited")]

    if rate_limited:
        lines.append(f"    Rate-limited agents: {len(rate_limited)}")
        for agent in rate_limited[:3]:  # Show top 3
            eta = agent.get("eta_available_minutes")
            eta_str = f" (ETA: {eta} min)" if eta else " (ETA: unknown)"
            lines.append(f"      - {agent.get('name', agent.get('agent_id'))}{eta_str}")

    if unavailable:
        lines.append(f"    Unavailable agents: {len(unavailable)}")
        for agent in unavailable[:3]:  # Show top 3
            lines.append(f"      - {agent.get('name', agent.get('agent_id'))}: {agent.get('status', 'unknown')}")

    if rate_limited or unavailable:
        lines.append("")
        lines.append("  Action: Wait for rate limits to reset or use available agents.")

    return "\n".join(lines)


def _format_error_with_agent_status(result: Dict[str, Any], status: Dict[str, Any]) -> str:
    """Format error message with agent status context."""
    http_status = result.get("http_status", 0)
    error = result.get("error", "Unknown error")

    if http_status == 429:
        retry_after = result.get("retry_after", "")
        base_msg = f"Rate limited (HTTP 429). {error}"
        if retry_after:
            base_msg += f" Retry after: {retry_after}s."
        base_msg += _format_agent_status_summary(status)
        return base_msg
    elif http_status == 503:
        base_msg = f"Service unavailable (HTTP 503). {error}"
        base_msg += _format_agent_status_summary(status)
        return base_msg
    else:
        base_msg = f"{error}"
        base_msg += _format_agent_status_summary(status)
        return base_msg


# ---------------------------------------------------------------------------
# Arg parsing
# ---------------------------------------------------------------------------


def _parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(
        description="Ranked AI workflow hints for any agent",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p.add_argument("query", nargs="?", default="", help="Task description or partial query")
    p.add_argument(
        "--format", dest="fmt", default="text",
        choices=["json", "text", "shell-complete"],
        help="Output format (default: text)",
    )
    p.add_argument(
        "--context", default="",
        help="File extension or domain filter (e.g. .nix, .py, nixos, rag, aider, systemd)",
    )
    p.add_argument("--max", type=int, default=4, help="Max hints to return (default: 4)")
    p.add_argument(
        "--agent", default="human",
        choices=["human", "claude", "codex", "qwen", "aider", "continue"],
        help="Agent type — adjusts output verbosity and augments inject fields",
    )
    p.add_argument(
        "--debug-meta",
        action="store_true",
        help="Include verbose hint/debug metadata in JSON output",
    )
    # Phase 10.3 — Token-efficient hint delivery
    p.add_argument(
        "--compact",
        action="store_true",
        help="Use compact hint format for minimal token footprint",
    )
    p.add_argument(
        "--max-tokens", type=int, default=0,
        help="Cap total hint tokens (0 = unlimited, e.g. 200 for tight budget)",
    )
    p.add_argument(
        "--escalate",
        action="store_true",
        help="Request expanded context - suspends token limits for deep dives",
    )
    return p.parse_args()


# ---------------------------------------------------------------------------
# Data retrieval
# ---------------------------------------------------------------------------


def _fetch_local(
    query: str, context: str, max_hints: int, agent: str, debug_meta: bool,
    compact: bool = False, max_tokens: int = 0, escalate: bool = False
) -> Optional[Dict[str, Any]]:
    if not _ENGINE_AVAILABLE:
        return None
    try:
        engine = HintsEngine()
        return engine.rank_as_dict(
            query,
            context=context,
            max_hints=max_hints,
            agent_type=agent,
            include_debug_metadata=debug_meta,
            max_hint_tokens=max_tokens,
            compact_mode=compact,
            force_escalation=escalate,
        )
    except Exception:
        return None


def _fetch_rest(
    query: str, context: str, max_hints: int, agent: str, debug_meta: bool,
    compact: bool = False, max_tokens: int = 0, escalate: bool = False
) -> Optional[Dict[str, Any]]:
    params = urllib.parse.urlencode({
        "q": query, "context": context, "max": max_hints, "agent": agent,
        "debug": "1" if debug_meta else "0",
        "compact": "1" if compact else "0",
        "max_tokens": str(max_tokens),
        "escalate": "1" if escalate else "0",
    })
    url = f"{HYBRID_URL}/hints?{params}"
    try:
        headers = {"Accept": "application/json"}
        api_key = _load_hybrid_api_key()
        if api_key:
            headers["X-API-Key"] = api_key
        req = urllib.request.Request(url, headers=headers)
        with urllib.request.urlopen(req, timeout=5) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as exc:
        # Phase 20.1: Capture HTTP errors (429 rate limit, 503 unavailable, etc.)
        error_body = ""
        try:
            error_body = exc.read().decode("utf-8", errors="replace")
        except Exception:
            pass
        return {
            "status": "error",
            "hints": [],
            "query": query,
            "agent_type": agent,
            "http_status": exc.code,
            "error": f"harness HTTP {exc.code}: {exc.reason}",
            "error_detail": error_body[:500] if error_body else "",
            "retry_after": exc.headers.get("Retry-After", ""),
        }
    except Exception:
        return None


def get_hints(
    query: str, context: str, max_hints: int, agent: str, debug_meta: bool,
    compact: bool = False, max_tokens: int = 0, escalate: bool = False
) -> Dict[str, Any]:
    result = (
        _fetch_local(query, context, max_hints, agent, debug_meta, compact, max_tokens, escalate)
        or _fetch_rest(query, context, max_hints, agent, debug_meta, compact, max_tokens, escalate)
    )
    if result is None:
        # Phase 20.1: Try to fetch agent status for better error messages
        agent_status = _fetch_agent_status()

        # Graceful degradation: return offline marker instead of hard-failing.
        # Agents should proceed locally when harness is unreachable.
        offline = {
            "status": "offline",
            "hints": [],
            "query": query,
            "agent_type": agent,
            "inject_prefix": "HARNESS UNREACHABLE — proceed with local execution, retry before commit.",
            "offline_notice": (
                f"Local engine: {'OK' if _ENGINE_AVAILABLE else 'MISSING'}; "
                f"REST fallback: {HYBRID_URL}/hints (unreachable). "
                "Proceed locally and retry before commit."
            ),
        }

        # Phase 20.1: Add agent status if available
        if agent_status:
            offline["agent_status"] = agent_status
            offline["offline_notice"] += _format_agent_status_summary(agent_status)

        print(
            "WARN: Harness unreachable — returning offline mode.",
            file=sys.stderr,
        )
        print(
            f"  Local engine: {'OK' if _ENGINE_AVAILABLE else 'MISSING'}\n"
            f"  REST fallback: {HYBRID_URL}/hints (ensure hybrid-coordinator is running)",
            file=sys.stderr,
        )
        return offline

    # Phase 20.1: If result has error status (e.g., 429 rate limit), add agent status context
    if result.get("status") == "error" and result.get("http_status"):
        agent_status = _fetch_agent_status()
        if agent_status:
            result["agent_status"] = agent_status
            result["error_message"] = _format_error_with_agent_status(result, agent_status)

    return result


# ---------------------------------------------------------------------------
# Agent-type augmentation
# ---------------------------------------------------------------------------

_ANSI_RESET = "\033[0m"
_ANSI_BOLD  = "\033[1m"
_ANSI_CYAN  = "\033[36m"
_ANSI_GREEN = "\033[32m"
_ANSI_DIM   = "\033[2m"
_USE_COLOR  = sys.stdout.isatty()


def _c(code: str, text: str) -> str:
    return f"{code}{text}{_ANSI_RESET}" if _USE_COLOR else text


def _augment_for_agent(result: Dict[str, Any], agent: str, debug_meta: bool = False) -> Dict[str, Any]:
    result.setdefault("feedback_contract", {
        "endpoint": "/hints/feedback",
        "required_any_of": ["helpful", "score"],
        "required": ["hint_id"],
    })
    hints = result.get("hints", [])
    if not hints:
        return result
    top = hints[0]
    snippet = top.get("snippet", "")[:150]

    if agent in ("claude", "codex", "qwen"):
        result["inject_prefix"] = snippet
        result["agent_note"] = (
            f"Prepend inject_prefix to your next prompt for context-aware steering. "
            f"Top hint: {top.get('title')} (score {top.get('score', 0):.0%})"
        )
    elif agent == "aider":
        result["aider_message_prefix"] = f"CONTEXT (from aq-hints): {snippet}"
        result["agent_note"] = "Prepend aider_message_prefix to your --message argument."
    elif agent == "continue":
        # Reformat as a Continue.dev context item
        text_lines = [f"# AI Stack Hints for: {result.get('query', '')}\n"]
        for i, h in enumerate(hints, 1):
            block = (
                f"{i}. [{h['type']}] {h['title']} ({h.get('score', 0):.0%})\n"
                f"   {h.get('snippet', '')[:100]}\n"
            )
            if debug_meta and h.get("reason"):
                block += f"   Reason: {h.get('reason', '')}\n"
            text_lines.append(block)
        result["continue_context"] = {
            "name": "aq-hints",
            "description": "AI Stack workflow hints",
            "content": "\n".join(text_lines),
        }
    return result


# ---------------------------------------------------------------------------
# Formatters
# ---------------------------------------------------------------------------

_TYPE_ICONS = {
    "prompt_template": "📋",
    "gap_topic":       "🔍",
    "workflow_rule":   "📌",
    "runtime_signal":  "🧭",
    "prompt_coaching": "🧠",
    "tool_warning":    "⚠️ ",
}


def _format_json(result: Dict[str, Any]) -> str:
    return json.dumps(result, indent=2, default=str)


def _format_text(result: Dict[str, Any], agent: str, debug_meta: bool = False) -> str:
    hints = result.get("hints", [])
    query = result.get("query", "")
    coaching = result.get("prompt_coaching", {})
    sep = "─" * 54

    # aider gets a machine-readable prefix line first
    if agent == "aider" and "aider_message_prefix" in result:
        print(result["aider_message_prefix"])

    lines = [
        _c(_ANSI_BOLD, f"\n── AI Stack Hints {'─' * 34}"),
    ]
    if query:
        query_line = f"  Query: {_c(_ANSI_CYAN, repr(query))}"
        if agent != "human":
            query_line += f"   Agent: {agent}"
        lines.append(query_line)
    lines.append("")

    # Phase 20.1: Display error with agent status if present
    if result.get("status") == "error" and result.get("error_message"):
        lines.append(_c("\033[1;31m", "  ERROR:"))
        lines.append(f"    {result['error_message']}")
        lines.append("")
    elif result.get("status") == "error":
        error = result.get("error", "Unknown error")
        http_status = result.get("http_status", 0)
        if http_status:
            lines.append(_c("\033[1;31m", f"  HTTP Error {http_status}:"))
            lines.append(f"    {error}")
            retry_after = result.get("retry_after", "")
            if retry_after:
                lines.append(f"    Retry-After: {retry_after}s")
        else:
            lines.append(_c("\033[1;31m", "  Error:"))
            lines.append(f"    {error}")
        lines.append("")

    if not hints:
        lines.append("  No hints found. Run `scripts/ai/aq-prompt-eval` to score registry prompts,")
        lines.append("  or check that the hybrid-coordinator is running for gap data.")
        lines.append("")
    else:
        for i, h in enumerate(hints, 1):
            icon = _TYPE_ICONS.get(h.get("type", ""), "•")
            score_pct = f"{h.get('score', 0):.0%}"
            lines.append(
                f"  {i}. {_c(_ANSI_GREEN, icon + ' ' + h.get('title', ''))}  "
                f"({_c(_ANSI_BOLD, score_pct)})"
            )
            tags = h.get("tags", [])
            if tags:
                lines.append(f"     Tags: {_c(_ANSI_DIM, ', '.join(tags))}")
            snippet = h.get("snippet", "")[:100]
            if snippet:
                lines.append(f"     → {snippet}{'…' if len(h.get('snippet','')) > 100 else ''}")
            reason = h.get("reason", "")
            if debug_meta and reason:
                lines.append(f"     {_c(_ANSI_DIM, 'Reason: ' + reason)}")
            lines.append("")

    if "inject_prefix" in result:
        lines.append(_c(_ANSI_DIM, f"  inject_prefix: {result['inject_prefix'][:80]}…"))
        lines.append("")

    if isinstance(coaching, dict) and coaching:
        coaching_score = int(round(float(coaching.get("score", 0.0)) * 100))
        lines.append(_c(_ANSI_BOLD, "  Prompt Coaching"))
        lines.append(
            f"     Score: {_c(_ANSI_BOLD, str(coaching_score) + '%')}"
            f"   Recommended agent: {_c(_ANSI_GREEN, str(coaching.get('recommended_agent', 'codex')))}"
        )
        token_discipline = coaching.get("token_discipline", {})
        if isinstance(token_discipline, dict) and token_discipline:
            spend_tier = str(token_discipline.get("spend_tier", "lean"))
            recommended_budget = str(token_discipline.get("recommended_input_budget", ""))
            lines.append(
                "     Token plan: "
                + f"{_c(_ANSI_BOLD, spend_tier)}"
                + (f" (~{recommended_budget} input tokens max)" if recommended_budget else "")
            )
            rationale = str(token_discipline.get("rationale", "") or "")
            if rationale:
                lines.append(f"     Budget fit: {rationale}")
        missing = coaching.get("missing_fields", [])
        if isinstance(missing, list) and missing:
            missing_items = [str(item) for item in missing if str(item).strip()]
            compact_missing = ", ".join(missing_items[:3])
            extra_missing = len(missing_items) - 3
            if extra_missing > 0:
                compact_missing += f" (+{extra_missing} more)"
            lines.append(f"     Missing: {compact_missing}")
        rationale = str(coaching.get("recommended_agent_rationale", "") or "")
        if rationale:
            lines.append(f"     Agent fit: {rationale}")
        suggested_prompt = str(coaching.get("suggested_prompt", "") or "")
        if suggested_prompt:
            lines.append(f"     Suggested prompt: {suggested_prompt[:140]}{'…' if len(suggested_prompt) > 140 else ''}")
        lines.append("")

    # Phase 20.1: Display agent status if present
    agent_status = result.get("agent_status")
    if agent_status and isinstance(agent_status, dict):
        lines.append(_c(_ANSI_BOLD, "  Remote Agent Status"))
        pool = agent_status.get("pool_status", "unknown")
        total = agent_status.get("total_agents", 0)
        available = agent_status.get("available_agents", 0)
        free = agent_status.get("free_agents_available", 0)
        lines.append(f"    Pool: {_c(_ANSI_GREEN if pool == 'ok' else '\033[1;31m', pool)}")
        lines.append(f"    Total: {total} | Available: {available} | Free: {free}")

        agents = agent_status.get("agents", [])
        rate_limited = [a for a in agents if a.get("is_rate_limited")]
        if rate_limited:
            lines.append(f"    Rate-limited: {len(rate_limited)} agent(s)")
            for ag in rate_limited[:3]:
                eta = ag.get("eta_available_minutes")
                eta_str = f" (~{eta} min)" if eta else ""
                lines.append(f"      - {ag.get('name', ag.get('agent_id'))}{eta_str}")
        lines.append("")

    lines.append(_c(_ANSI_BOLD, sep))
    return "\n".join(lines)


def _format_shell_complete(result: Dict[str, Any]) -> str:
    """One candidate per line for compgen — no color, no headers."""
    candidates: List[str] = []
    for h in result.get("hints", []):
        title_slug = h.get("title", "").lower().replace(" ", "-")
        if title_slug:
            candidates.append(title_slug)
        for tag in h.get("tags", []):
            if tag not in candidates:
                candidates.append(tag)
    return "\n".join(candidates)


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------


def main() -> None:
    args = _parse_args()
    result = get_hints(
        args.query, args.context, args.max, args.agent, args.debug_meta,
        compact=args.compact, max_tokens=args.max_tokens, escalate=args.escalate
    )
    result = _augment_for_agent(result, args.agent, args.debug_meta)

    if args.fmt == "json":
        print(_format_json(result))
    elif args.fmt == "shell-complete":
        output = _format_shell_complete(result)
        if output:
            print(output)
    else:
        print(_format_text(result, args.agent, args.debug_meta))

    # Exit code 2 for offline mode — scripts can detect but don't hard-fail
    if result.get("status") == "offline":
        sys.exit(2)


if __name__ == "__main__":
    main()
