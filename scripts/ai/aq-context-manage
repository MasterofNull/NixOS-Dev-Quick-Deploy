#!/usr/bin/env python3
"""
Context Memory Management CLI - Monitor and manage context lifecycle.

Usage:
    aq-context-manage stats          # Show context memory statistics
    aq-context-manage check          # Check if compaction should trigger
    aq-context-manage plan           # Generate compaction plan
    aq-context-manage compact        # Trigger compaction (requires confirmation)
    aq-context-manage update         # Update lifecycle states

Part of Context Rot and Recall system.
"""

import argparse
import json
import os
import subprocess
import sys
import urllib.error
import urllib.request
from pathlib import Path

# Add context_memory to path
sys.path.insert(0, str(Path(__file__).parent.parent.parent / "ai-stack" / "context_memory"))

from context_manager import ContextMemoryManager


AQ_MEMORY_SCRIPT = Path(__file__).with_name("aq-memory")
DEFAULT_DASHBOARD_URL = "http://127.0.0.1:8889"

SUMMARY_TYPE_LABELS = {
    "decision": "decisions",
    "fact": "facts",
    "advice": "next_steps",
    "discovery": "open_questions",
    "event": "events",
}


def format_bytes(bytes_count: int) -> str:
    """Format bytes as human-readable string."""
    for unit in ['B', 'KB', 'MB', 'GB']:
        if bytes_count < 1024.0:
            return f"{bytes_count:.1f}{unit}"
        bytes_count /= 1024.0
    return f"{bytes_count:.1f}TB"


def _fetch_clm_status() -> dict | None:
    """Best-effort live CLM status from the dashboard proxy."""
    if os.getenv("AQ_CONTEXT_MANAGE_SKIP_CLM", "").lower() in {"1", "true", "yes"}:
        return None

    status_file = os.getenv("AQ_CONTEXT_MANAGE_CLM_STATUS_FILE")
    if status_file:
        try:
            return json.loads(Path(status_file).read_text(encoding="utf-8"))
        except Exception as exc:
            return {"available": False, "error": str(exc)}

    base_url = os.getenv("DASHBOARD_URL", DEFAULT_DASHBOARD_URL).rstrip("/")
    if base_url.endswith("/api"):
        url = f"{base_url}/context/lifecycle/status"
    else:
        url = f"{base_url}/api/context/lifecycle/status"
    try:
        with urllib.request.urlopen(url, timeout=2.0) as response:
            return json.loads(response.read().decode("utf-8"))
    except (OSError, urllib.error.URLError, json.JSONDecodeError) as exc:
        return {"available": False, "error": str(exc)}


def _clm_trigger_reason(status: dict | None) -> str | None:
    if not status or status.get("available") is False:
        return None
    pressure = float(status.get("pressure_pct") or 0)
    thresholds = status.get("thresholds") or {}
    high_threshold = float(thresholds.get("hot_pressure_pct") or 85.0)
    suspended = bool(status.get("compaction_suspended"))
    thermal = str(status.get("thermal_tier") or "unknown")
    if pressure >= high_threshold and suspended:
        return f"CLM hot pressure {pressure:.1f}% >= {high_threshold:.1f}% and compaction suspended by thermal tier {thermal}"
    if pressure >= high_threshold:
        return f"CLM hot pressure {pressure:.1f}% >= {high_threshold:.1f}%"
    if suspended:
        return f"CLM compaction suspended by thermal tier {thermal}"
    return None


def cmd_stats(manager: ContextMemoryManager, json_output: bool = False):
    """Show context memory statistics."""
    stats = manager.get_stats()

    if json_output:
        print(json.dumps(stats, indent=2))
        return

    print("Context Memory Statistics")
    print("=" * 60)
    print(f"Total Contexts: {stats['total_contexts']}")
    print(f"Total Tokens: {stats['total_tokens']:,} / {stats['window_limit']:,}")
    print(f"Window Usage: {stats['window_usage_percent']:.1f}%")
    print(f"Stale Ratio: {stats['stale_ratio']:.1%}")
    print()

    print("Lifecycle Distribution:")
    for state, count in sorted(stats['lifecycle_distribution'].items()):
        print(f"  {state:12} {count:6} contexts")
    print()

    print("Average Importance by Lifecycle:")
    for state, avg_imp in sorted(stats['average_importance_by_lifecycle'].items()):
        print(f"  {state:12} {avg_imp:.3f}")


def cmd_check(manager: ContextMemoryManager, json_output: bool = False):
    """Check if compaction should be triggered."""
    should_trigger, reason = manager.should_trigger_compaction()
    clm_status = _fetch_clm_status()
    clm_reason = _clm_trigger_reason(clm_status)
    if clm_reason:
        should_trigger = True
        reason = clm_reason

    if json_output:
        print(json.dumps({
            "should_trigger": should_trigger,
            "reason": reason,
            "stats": manager.get_stats(),
            "clm_status": clm_status,
        }, indent=2))
        return

    print("Compaction Trigger Check")
    print("=" * 60)
    print(f"Should Trigger: {should_trigger}")
    print(f"Reason: {reason}")
    if clm_status:
        print()
        print("Live CLM:")
        if clm_status.get("available") is False:
            print(f"  unavailable: {clm_status.get('error') or 'unknown'}")
        else:
            print(f"  pressure: {float(clm_status.get('pressure_pct') or 0):.1f}%")
            print(f"  thermal:  {clm_status.get('thermal_tier') or 'unknown'}")
            print(f"  suspended: {bool(clm_status.get('compaction_suspended'))}")
    print()

    if should_trigger:
        print("⚠️  COMPACTION RECOMMENDED")
        print()
        print("Run 'aq-context-manage plan' to see compaction plan")
        print("Run 'aq-context-manage compact' to trigger compaction")
        sys.exit(1)  # Exit with error code to signal compaction needed
    else:
        print("✓ No compaction needed")
        sys.exit(0)


def cmd_plan(manager: ContextMemoryManager, json_output: bool = False):
    """Generate compaction plan."""
    plan = manager.get_compaction_plan()

    if json_output:
        # Don't output full content in JSON
        plan_summary = {
            "stats": plan["stats"],
            "keep_full_ids": [ctx["id"] for ctx in plan["keep_full"]],
            "summarize_ids": [ctx["id"] for ctx in plan["summarize"]],
            "archive_ids": [ctx["id"] for ctx in plan["archive"]],
        }
        print(json.dumps(plan_summary, indent=2))
        return

    print("Compaction Plan")
    print("=" * 60)
    print()
    print(f"Keep Full:   {plan['stats']['keep_full_count']:6} contexts")
    print(f"Summarize:   {plan['stats']['summarize_count']:6} contexts")
    print(f"Archive:     {plan['stats']['archive_count']:6} contexts")
    print(f"Budget Left: {plan['stats']['budget_remaining']:6.0f} tokens")
    print()

    if plan['keep_full']:
        print("Top 5 contexts to keep:")
        for ctx in plan['keep_full'][:5]:
            print(f"  [{ctx['id'][:8]}] {ctx['context_type']:15} (importance={ctx['importance_score']:.2f}, {ctx['lifecycle_state']})")
    print()

    if plan['summarize']:
        print("Top 5 contexts to summarize:")
        for ctx in plan['summarize'][:5]:
            print(f"  [{ctx['id'][:8]}] {ctx['context_type']:15} (importance={ctx['importance_score']:.2f}, {ctx['lifecycle_state']})")
    print()

    if plan['archive']:
        print(f"Contexts to archive: {len(plan['archive'])}")
        print("Top 5:")
        for ctx in plan['archive'][:5]:
            print(f"  [{ctx['id'][:8]}] {ctx['context_type']:15} (importance={ctx['importance_score']:.2f}, {ctx['lifecycle_state']})")


def cmd_update(manager: ContextMemoryManager, json_output: bool = False):
    """Update lifecycle states for all contexts."""
    import asyncio

    async def update_async():
        updated = await manager.update_all_lifecycle_states()
        return updated

    updated = asyncio.run(update_async())

    if json_output:
        print(json.dumps({"updated_count": updated}, indent=2))
        return

    print(f"Updated lifecycle states for {updated} contexts")


def cmd_compact(manager: ContextMemoryManager, force: bool = False):
    """Trigger compaction (placeholder - requires conversation compaction integration)."""
    should_trigger, reason = manager.should_trigger_compaction()

    if not should_trigger and not force:
        print("Compaction not recommended at this time.")
        print(f"Reason: {reason}")
        print()
        print("Use --force to trigger anyway")
        return

    print("Compaction Trigger")
    print("=" * 60)
    print()
    print("⚠️  WARNING: This will trigger conversation compaction in Claude Code.")
    print()
    print("This is a MANUAL trigger point. Compaction will be initiated by")
    print("the conversation context, not this script.")
    print()

    if not force:
        confirm = input("Trigger compaction? [y/N]: ")
        if confirm.lower() != 'y':
            print("Cancelled.")
            return

    # Show plan before compaction
    plan = manager.get_compaction_plan()
    print()
    print(f"Plan: Keep {plan['stats']['keep_full_count']}, "
          f"Summarize {plan['stats']['summarize_count']}, "
          f"Archive {plan['stats']['archive_count']}")
    print()
    print("✓ Ready for compaction")
    print()
    print("TO TRIGGER COMPACTION:")
    print("  1. Note current context state in this conversation")
    print("  2. Ask Claude to summarize and compact the conversation")
    print("  3. Context will be preserved according to importance scores")
    print()


def _checkpoint_entries(args) -> list[tuple[str, str, list[str]]]:
    entries: list[tuple[str, str, list[str]]] = []
    for item in args.fact or []:
        entries.append((item, "fact", ["checkpoint", "fact"]))
    for item in args.decision or []:
        entries.append((item, "decision", ["checkpoint", "decision"]))
    for item in args.next_step or []:
        entries.append((item, "advice", ["checkpoint", "next-step"]))
    for item in args.open_question or []:
        entries.append((item, "discovery", ["checkpoint", "open-question"]))
    return entries


def _run_memory_json(command: list[str]) -> list[dict] | dict:
    result = subprocess.run(command, capture_output=True, text=True, check=False)
    if result.returncode != 0:
        raise SystemExit((result.stderr or result.stdout or "aq-memory command failed").strip())
    try:
        payload = json.loads((result.stdout or "").strip() or "[]")
    except json.JSONDecodeError as exc:
        raise SystemExit(f"unable to parse aq-memory output: {exc}") from exc
    return payload


def _fact_preview(fact: dict) -> dict:
    return {
        "fact_id": fact.get("fact_id"),
        "type": fact.get("type"),
        "content": fact.get("content"),
        "created_at": fact.get("created_at"),
        "tags": fact.get("tags") or [],
        "source": fact.get("source"),
    }


def _build_summary_payload(args) -> dict:
    resume_query = args.resume_query or args.task
    search_payload = _run_memory_json([
        sys.executable,
        str(AQ_MEMORY_SCRIPT),
        "--storage",
        args.memory_storage,
        "--json",
        "search",
        resume_query,
        "--project",
        args.project,
        "--tags",
        "checkpoint,resume",
        "--limit",
        str(args.limit),
    ])
    list_payload = _run_memory_json([
        sys.executable,
        str(AQ_MEMORY_SCRIPT),
        "--storage",
        args.memory_storage,
        "--json",
        "list",
        "--project",
        args.project,
        "--topic",
        args.topic,
        "--limit",
        str(args.limit),
    ])

    matched_items = search_payload if isinstance(search_payload, list) else []
    recent_items = list_payload if isinstance(list_payload, list) else []

    combined: list[dict] = []
    seen: set[str] = set()
    for fact in matched_items + recent_items:
        fact_id = str(fact.get("fact_id") or "")
        if not fact_id or fact_id in seen:
            continue
        tags = set(fact.get("tags") or [])
        if "checkpoint" not in tags and str(fact.get("source") or "") != "aq-context-manage":
            continue
        combined.append(fact)
        seen.add(fact_id)

    sections: dict[str, list[dict]] = {label: [] for label in SUMMARY_TYPE_LABELS.values()}
    for fact in combined:
        bucket = SUMMARY_TYPE_LABELS.get(str(fact.get("type") or ""), "facts")
        sections.setdefault(bucket, []).append(_fact_preview(fact))

    summary_lines: list[str] = []
    latest_event = sections["events"][0]["content"] if sections["events"] else ""
    if latest_event:
        summary_lines.append(f"Latest checkpoint event: {latest_event}")
    for label, title in (
        ("decisions", "Decisions"),
        ("next_steps", "Next steps"),
        ("facts", "Facts"),
        ("open_questions", "Open questions"),
    ):
        for item in sections.get(label, [])[:2]:
            summary_lines.append(f"{title}: {item['content']}")

    resume_commands = [
        f'aq-context-manage summary --task "{args.task}" --project {args.project} --topic {args.topic} --json',
        f'aq-memory search "{resume_query}" --project {args.project} --limit 5',
        f'aq-context-bootstrap --task "resume {args.task}" --scope context-offload --format json',
        'aq-context-card --card context-offload --level standard',
        f'aq-hints "resume {args.task}" --format=json --agent=codex',
    ]
    return {
        "task": args.task,
        "resume_query": resume_query,
        "project": args.project,
        "topic": args.topic,
        "context_assist_profiles": ["embedded-assist"],
        "matched_items": [_fact_preview(item) for item in matched_items[: args.limit]],
        "recent_checkpoint_items": [_fact_preview(item) for item in recent_items[: args.limit]],
        "summary_lines": summary_lines,
        "latest_event": latest_event,
        "decisions": sections["decisions"],
        "facts": sections["facts"],
        "next_steps": sections["next_steps"],
        "open_questions": sections["open_questions"],
        "resume_commands": resume_commands,
        "guidance": "Prefer this compact summary before replaying broader transcript history in a fresh session.",
    }


def cmd_checkpoint(args):
    """Persist a structured checkpoint to aq-memory and print fresh-session resume steps."""
    entries = _checkpoint_entries(args)
    if not entries:
        raise SystemExit("checkpoint requires at least one of --fact, --decision, --next-step, or --open-question")
    if not AQ_MEMORY_SCRIPT.exists():
        raise SystemExit(f"aq-memory not found at {AQ_MEMORY_SCRIPT}")

    created_by = args.created_by or os.getenv("AQ_ACTIVE_AGENT") or os.getenv("USER") or "unknown"
    shared_tags = [tag.strip() for tag in (args.tags or "").split(",") if tag.strip()]
    created_fact_ids: list[dict[str, str]] = []

    event_content = (
        f"Checkpoint saved for task '{args.task}'. Resume from harness memory instead of replaying full editor transcript."
    )
    event_command = [
        sys.executable,
        str(AQ_MEMORY_SCRIPT),
        "--storage",
        args.memory_storage,
        "--json",
        "add",
        event_content,
        "--project",
        args.project,
        "--topic",
        args.topic,
        "--type",
        "event",
        "--tags",
        ",".join(shared_tags + ["checkpoint", "resume", "task-state"]),
        "--source",
        "aq-context-manage",
        "--created-by",
        created_by,
    ]
    if args.agent_owner:
        event_command.extend(["--agent-owner", args.agent_owner])
    event_result = subprocess.run(event_command, capture_output=True, text=True, check=False)
    if event_result.returncode != 0:
        raise SystemExit((event_result.stderr or event_result.stdout or "aq-memory add failed").strip())
    try:
        event_payload = json.loads((event_result.stdout or "").strip())
    except json.JSONDecodeError as exc:
        raise SystemExit(f"unable to parse aq-memory event result: {exc}") from exc
    created_fact_ids.append({"category": "event", "fact_id": str(event_payload.get("fact_id", ""))})

    for content, fact_type, extra_tags in entries:
        command = [
            sys.executable,
            str(AQ_MEMORY_SCRIPT),
            "--storage",
            args.memory_storage,
            "--json",
            "add",
            content,
            "--project",
            args.project,
            "--topic",
            args.topic,
            "--type",
            fact_type,
            "--tags",
            ",".join(shared_tags + extra_tags + [args.topic]),
            "--source",
            "aq-context-manage",
            "--created-by",
            created_by,
        ]
        if args.agent_owner:
            command.extend(["--agent-owner", args.agent_owner])
        result = subprocess.run(command, capture_output=True, text=True, check=False)
        if result.returncode != 0:
            raise SystemExit((result.stderr or result.stdout or "aq-memory add failed").strip())
        try:
            payload = json.loads((result.stdout or "").strip())
        except json.JSONDecodeError as exc:
            raise SystemExit(f"unable to parse aq-memory result: {exc}") from exc
        created_fact_ids.append({"category": fact_type, "fact_id": str(payload.get("fact_id", ""))})

    resume_query = args.resume_query or args.task
    resume_commands = [
        f'aq-context-manage summary --task "{args.task}" --project {args.project} --topic {args.topic} --json',
        f'aq-memory search "{resume_query}" --project {args.project} --limit 5',
        f'aq-context-bootstrap --task "resume {args.task}" --scope context-offload --format json',
        'aq-context-card --card context-offload --level standard',
        f'aq-hints "resume {args.task}" --format=json --agent=codex',
    ]
    response = {
        "task": args.task,
        "project": args.project,
        "topic": args.topic,
        "created_by": created_by,
        "fact_count": len(created_fact_ids),
        "facts": created_fact_ids,
        "resume_commands": resume_commands,
        "guidance": "Start a fresh editor/agent session and recall this checkpoint from aq-memory before replaying transcript history.",
    }

    if args.json:
        print(json.dumps(response, indent=2))
        return

    print("Checkpoint stored")
    print("=" * 60)
    print(f"Task: {args.task}")
    print(f"Project/topic: {args.project}/{args.topic}")
    print(f"Stored facts: {len(created_fact_ids)}")
    print()
    print("Fresh-session resume:")
    for command in resume_commands:
        print(f"  {command}")
    print()
    print(response["guidance"])


def cmd_summary(args):
    """Build a compact prior-session summary from recent checkpoint facts."""
    payload = _build_summary_payload(args)
    if args.json:
        print(json.dumps(payload, indent=2))
        return

    print("Recent Session Summary")
    print("=" * 60)
    print(f"Task: {payload['task']}")
    print(f"Query: {payload['resume_query']}")
    print()
    if payload["summary_lines"]:
        for line in payload["summary_lines"]:
            print(f"- {line}")
    else:
        print("No matching checkpoint summary lines found.")
    print()
    print("Fresh-session resume:")
    for command in payload["resume_commands"]:
        print(f"  {command}")
    print()
    print(payload["guidance"])


def main():
    parser = argparse.ArgumentParser(
        description="Context Memory Management CLI",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  aq-context-manage stats                 # Show current statistics
  aq-context-manage check                 # Check if compaction needed
  aq-context-manage plan                  # Show compaction plan
  aq-context-manage update                # Update lifecycle states
  aq-context-manage compact               # Trigger compaction
  aq-context-manage checkpoint --task "resume slice" --decision "bounded retries to 2" --next-step "start fresh session"
  aq-context-manage summary --task "resume slice" --json
  aq-context-manage stats --json          # JSON output
        """
    )

    parser.add_argument(
        "command",
        choices=["stats", "check", "plan", "update", "compact", "checkpoint", "summary"],
        help="Command to execute"
    )

    parser.add_argument(
        "--json",
        action="store_true",
        help="Output in JSON format"
    )

    parser.add_argument(
        "--force",
        action="store_true",
        help="Force compaction even if not recommended"
    )

    parser.add_argument(
        "--db",
        type=Path,
        help="Path to context memory database (default: DATA_DIR/context_memory.db)"
    )
    parser.add_argument("--task", help="Checkpoint task summary.")
    parser.add_argument("--project", default="ai-stack", help="Memory project for checkpoint entries.")
    parser.add_argument("--topic", default="context-offload", help="Memory topic for checkpoint entries.")
    parser.add_argument("--fact", action="append", help="Durable fact to store. Repeatable.")
    parser.add_argument("--decision", action="append", help="Decision to store. Repeatable.")
    parser.add_argument("--next-step", dest="next_step", action="append", help="Next step to store. Repeatable.")
    parser.add_argument("--open-question", dest="open_question", action="append", help="Open question to store. Repeatable.")
    parser.add_argument("--resume-query", help="Override query string used in printed resume commands.")
    parser.add_argument("--limit", type=int, default=6, help="Maximum checkpoint facts to summarize.")
    parser.add_argument("--agent-owner", help="Optional memory owner for checkpoint entries.")
    parser.add_argument("--created-by", help="Creator identifier for checkpoint entries.")
    parser.add_argument("--tags", default="checkpoint,resume", help="Shared comma-separated tags for checkpoint entries.")
    parser.add_argument("--memory-storage", default=".aidb/temporal_facts.json", help="aq-memory storage path for checkpoint writes.")

    args = parser.parse_args()

    # Execute command
    if args.command == "checkpoint":
        if not args.task:
            parser.error("--task is required for checkpoint")
        cmd_checkpoint(args)
        return
    if args.command == "summary":
        if not args.task:
            parser.error("--task is required for summary")
        cmd_summary(args)
        return

    manager = ContextMemoryManager(db_path=args.db)
    if args.command == "stats":
        cmd_stats(manager, json_output=args.json)
    elif args.command == "check":
        cmd_check(manager, json_output=args.json)
    elif args.command == "plan":
        cmd_plan(manager, json_output=args.json)
    elif args.command == "update":
        cmd_update(manager, json_output=args.json)
    elif args.command == "compact":
        cmd_compact(manager, force=args.force)


if __name__ == "__main__":
    main()
