def build_grounded_prompt(
    intent: str,
    state: LoopState,
    hints: str,
    skills: str,
    research_context: str = "",
) -> str:
    """Build the structured prompt sent to aq-agent-loop --task."""

    iteration_header = (
        f"[LOOP CONTEXT â€” Iteration {state.iteration}/{state.max_iterations}]\n"
        f"Loop ID : {state.loop_id}\n"
        f"Phase   : EXECUTE\n"
        f"Intent  : {intent}\n"
    )

    # Previous iteration evidence (iteration â‰Ą 2)
    prior_evidence = ""
    if state.history:
        lines = ["", "PRIOR ITERATION EVIDENCE:"]
        for ev in state.history[-2:]:  # last 2 iterations max
            lines.append(
                f"  iter {ev.get('task_id','?')}: "
                f"success={ev.get('success')} "
                f"incomplete={ev.get('incomplete_result')} "
                f"tool_calls={ev.get('tool_calls',0)}\n"
                f"  result: {ev.get('result_preview','')[:200]}"
            )
            # Include review findings if any
            review = ev.get("review_findings")
            if review:
                lines.append(f"  REVIEW: {review[:300]}")
        prior_evidence = "\n".join(lines)

    hints_section = f"\nHINTS:\n{hints}" if hints else ""
    skills_section = f"\nSUGGESTED SKILLS: {skills}" if skills else ""
    research_section = f"\nMULTI-AGENT RESEARCH CONTEXT:\n{research_context}" if research_context else ""

    return "\n".join(filter(None, [
        iteration_header,
        hints_section,
        skills_section,
        research_section,
        prior_evidence,
        "",
        _WORKFLOW_CANON,
        "",
        "TASK:",
        intent,
    ]))


