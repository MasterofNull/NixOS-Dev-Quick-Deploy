def _now_iso() -> str:
    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")


def _loop_id() -> str:
    return f"loop-{int(time.time())}"


def _run_capture(cmd: list[str], timeout: int = 20) -> str:
    """Run a CLI tool and capture stdout; return '' on failure."""
    try:
        r = subprocess.run(
            cmd, capture_output=True, text=True,
            timeout=timeout, cwd=str(_REPO_ROOT),
        )
        return r.stdout.strip()
    except Exception:
        return ""


def get_hints(intent: str) -> str:
    """Fetch ranked hints for the intent from aq-hints."""
    out = _run_capture(
        [str(_SCRIPT_DIR / "aq-hints"), intent, "--max", "3", "--compact"],
        timeout=15,
    )
    if not out:
        out = _run_capture(
            [str(_SCRIPT_DIR / "aq-hints"), intent, "--max", "3"],
            timeout=15,
        )
    return out[:1000] if out else ""


def get_skills(intent: str) -> str:
    """Fetch skill suggestions for the intent from aq-skill-suggest."""
    out = _run_capture(
        [str(_SCRIPT_DIR / "aq-skill-suggest"), intent],
        timeout=15,
    )
    return out[:600] if out else ""


def _dispatch_local_probe(intent: str, loop_id: str) -> "str | None":
    """Fire a background research probe to delegate-to-local. Returns task ID or None."""
    probe = (
        f"RESEARCH PROBE for loop {loop_id}:\n"
        f"Research the following task and return a concise analysis (max 600 words):\n"
        f"  {intent}\n\n"
        f"Include: relevant existing code/config, known failure patterns, recommended approach. "
        f"Output ONLY the analysis â€” no tool calls, no file edits."
    )
    try:
        r = subprocess.run(
            [str(_SCRIPT_DIR / "delegate-to-local"), "--mode", "agent",
             "--role", "auto", "--prompt", probe,
             "--tool-manifest", "self-improvement"],
            capture_output=True, text=True, timeout=15, cwd=str(_REPO_ROOT),
            env={**os.environ, "DISPATCH_BAND": "background",
                 "DISPATCH_SOURCE": "aq-loop"},
        )
        # Last non-empty line of stdout is the task ID
        lines = [l for l in r.stdout.splitlines() if l.strip()]
        tid = lines[-1].strip() if lines else None
        if tid and tid.startswith("local-"):
            return tid
    except Exception:
        pass
    return None


def _dispatch_antigravity_probe(intent: str, loop_id: str) -> "str | None":
    """Fire a background architecture probe to delegate-to-antigravity. Returns task ID or None."""
    probe = (
        f"ARCHITECTURE PROBE for loop {loop_id}:\n"
        f"Provide architectural guidance and risk assessment for this task (max 500 words):\n"
        f"  {intent}\n\n"
        f"Include: design considerations, edge cases, NixOS-specific constraints, suggested approach. "
        f"Output ONLY the analysis â€” no file edits."
    )
    try:
        r = subprocess.run(
            [str(_SCRIPT_DIR / "delegate-to-antigravity"), "--mode", "architect",
             "--role", "architect", "--prompt", probe],
            capture_output=True, text=True, timeout=15, cwd=str(_REPO_ROOT),
        )
        lines = [l for l in r.stdout.splitlines() if l.strip()]
        # Last line should be the task ID (antigravity prints tid as last line)
        tid = lines[-1].strip() if lines else None
        if tid and (tid.startswith("antigravity-") or tid.startswith("gemini-")):
            return tid
    except Exception:
        pass
    return None


def _collect_probe_output(task_id: str, timeout_s: float) -> "str | None":
    """Poll .agents/delegation/outputs/<task_id>.log until non-empty or timeout."""
    log_path = _DELEGATION_OUTPUTS / f"{task_id}.log"
    deadline = time.monotonic() + timeout_s
    while time.monotonic() < deadline:
        if log_path.exists():
            try:
                content = log_path.read_text(errors="replace")
                # Wait for meaningful content (> 100 bytes) and no partial writes
                if len(content) > 100:
                    return content[:2000]
            except Exception:
                pass
        time.sleep(5)
    return None


def fanout_ground(
    intent: str, loop_id: str, fanout_timeout: int = 120,
) -> str:
    """Dispatch parallel research probes; return combined context string (best-effort)."""
    print(f"[aq-loop] GROUND: dispatching fan-out probes (timeout={fanout_timeout}s) ...")

    local_tid = _dispatch_local_probe(intent, loop_id)
    anti_tid = _dispatch_antigravity_probe(intent, loop_id)

    if local_tid:
        print(f"[aq-loop] GROUND: local research probe â†’ {local_tid}")
    if anti_tid:
        print(f"[aq-loop] GROUND: antigravity architecture probe â†’ {anti_tid}")

    if not local_tid and not anti_tid:
        print("[aq-loop] GROUND: no fan-out probes dispatched (delegation unavailable)")
        return ""

    # Allocate timeout: wait for both in parallel via sequential polling with deadline
    deadline = time.monotonic() + fanout_timeout
    local_result = anti_result = None
    while time.monotonic() < deadline and (
        (local_tid and local_result is None) or (anti_tid and anti_result is None)
    ):
        if local_tid and local_result is None:
            local_result = _collect_probe_output(local_tid, timeout_s=5)
        if anti_tid and anti_result is None:
            anti_result = _collect_probe_output(anti_tid, timeout_s=5)
        if not ((local_tid and local_result is None) or (anti_tid and anti_result is None)):
            break
        time.sleep(5)

    parts = []
    if local_result:
        parts.append(f"[LOCAL AGENT RESEARCH]\n{local_result.strip()[:1200]}")
    if anti_result:
        parts.append(f"[GEMINI ARCHITECTURE PROBE]\n{anti_result.strip()[:1200]}")

    if parts:
        received = len(parts)
        total = sum(1 for t in [local_tid, anti_tid] if t)
        print(f"[aq-loop] GROUND: fan-out collected {received}/{total} probe results")
        return "\n\n".join(parts)
    else:
        print(f"[aq-loop] GROUND: fan-out probes dispatched but no results within {fanout_timeout}s â€” proceeding")
        return ""


def fanout_verify(
    intent: str, result_summary: str, loop_id: str, iteration: int,
) -> "dict | None":
    """Dispatch completed result to antigravity reviewer. Returns verdict or None."""
    probe = (
        f"ACCEPTANCE REVIEW for loop {loop_id} iter {iteration}:\n"
        f"Task: {intent}\n\n"
        f"Completed output summary:\n{result_summary[:1500]}\n\n"
        f"Review this output for correctness, completeness, NixOS policy compliance, "
        f"and security. Output exactly one of:\n"
        f"  APPROVED: <one-line reason>\n"
        f"  CONCERNS: <specific issues to address>\n"
        f"  REJECTED: <specific failures>\n"
        f"Then a brief explanation (max 200 words)."
    )
    try:
        r = subprocess.run(
            [str(_SCRIPT_DIR / "delegate-to-antigravity"),
             "--mode", "reviewer", "--role", "reviewer",
             "--prompt", probe, "--wait"],
            capture_output=True, text=True, timeout=180, cwd=str(_REPO_ROOT),
        )
        output = r.stdout
        verdict = "unknown"
        for kw in ("APPROVED", "CONCERNS", "REJECTED"):
            if kw in output:
                verdict = kw
                break
        return {"verdict": verdict, "output": output[:1000]}
    except Exception as exc:
        print(f"[aq-loop] VERIFY: antigravity review skipped ({exc})")
        return None


def _is_issue_line(line: str) -> bool:
    """True if line is an actual [OPEN] issue entry (not a code string or comment)."""
    stripped = line.strip()
    # Must start with [OPEN] directly (real issue) or as first table cell (| [OPEN] ...)
    # Not embedded in quotes/code strings (those have leading spaces or content before [OPEN])
    return bool(stripped and (
        stripped.startswith("[OPEN]") or
        (stripped.startswith("|") and "| [OPEN]" in stripped and stripped.index("[OPEN]") < 6)
    ))


_SEVERITY_RANK = {"critical": 0, "high": 1, "medium": 2, "low": 3, "unknown": 4}


def _parse_open_issues() -> list[dict]:
    """Parse all [OPEN] issues from backlog, extracting severity from following lines."""
    if not _BACKLOG_PATH.exists():
        return []
    lines = _BACKLOG_PATH.read_text().splitlines()
    issues: list[dict] = []
    for i, line in enumerate(lines):
        if not _is_issue_line(line):
            continue
        text = line.strip().lstrip("|").strip()
        # Scan up to 6 following lines for Severity: field
        severity = "unknown"
        for j in range(i + 1, min(i + 7, len(lines))):
            lo = lines[j].lower()
            if "severity:" in lo:
                for level in ("critical", "high", "medium", "low"):
                    if level in lo:
                        severity = level
                        break
                break
            if _is_issue_line(lines[j]):
                break  # next issue started
        issues.append({"text": text, "lineno": i + 1, "severity": severity})
    return issues


def pop_from_backlog() -> tuple[str, str, int] | tuple[None, None, None]:
    """Return highest-priority [OPEN] issue (criticalâ†’highâ†’mediumâ†’lowâ†’unknown).

    Returns (clean_intent, raw_line_text, line_number) or (None, None, None).
    clean_intent has the [OPEN] prefix stripped (for readable task prompts).
    raw_line_text is the full original line (for claim/release replacement in backlog).
    """
    issues = _parse_open_issues()
    if not issues:
        return None, None, None
    best = min(issues, key=lambda x: _SEVERITY_RANK.get(x["severity"], 4))
    raw = best["text"]
    clean = raw
    for prefix in ("[OPEN]", "[IN-PROGRESS]", "[MONITOR]"):
        if clean.startswith(prefix):
            clean = clean[len(prefix):].strip()
            break
    return clean, raw, best["lineno"]


def list_open() -> None:
    """Print all [OPEN] issues sorted by severity."""
    issues = _parse_open_issues()
    if not issues:
        print("[aq-loop] No [OPEN] items in issues-backlog.md")
        return
    sorted_issues = sorted(issues, key=lambda x: _SEVERITY_RANK.get(x["severity"], 4))
    print(f"[aq-loop] {len(sorted_issues)} open issue(s) (priority order):\n")
    for item in sorted_issues:
        sev = item["severity"].upper()
        print(f"  [{sev:8s}] line {item['lineno']:4d}: {item['text'][:100]}")


