def write_escalation(state: LoopState) -> None:
    """Append escalation notice to issues-backlog.md."""
    ts = _now_iso()[:10]
    slug = state.intent[:60].replace(" ", "-").replace("/", "-").lower()
    notice = (
        f"\n[OPEN] aq-loop-escalation-{slug} â€” "
        f"Loop {state.loop_id} exhausted {state.max_iterations} iterations without COMPLETED signal. "
        f"Intent: {state.intent[:120]}. "
        f"Last status: {(state.history[-1] or {}).get('status','unknown') if state.history else 'no history'}. "
        f"Escalated at {ts}. Manual review required."
    )
    try:
        with open(_BACKLOG_PATH, "a") as f:
            f.write(notice + "\n")
        print(f"[aq-loop] Escalation written to issues-backlog.md")
    except Exception as e:
        print(f"[aq-loop] Could not write escalation: {e}", file=sys.stderr)


# â”€â”€ main loop â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

def run_loop(
    intent: str,
    max_iter: int = 3,
    dry_run: bool = False,
    timeout: int = 3600,
    tool_manifest: str = "full",
    backlog_line: str = "",
    task_type: str | None = None,
    fanout: bool = True,
    fanout_timeout: int = 120,
) -> int:
    """Run the outer orchestration loop. Returns 0 on success, 1 on escalation."""
    loop_id = _loop_id()

    state = LoopState(
        loop_id=loop_id,
        intent=intent,
        iteration=0,
        max_iterations=max_iter,
        phase="TRIAGE",
    )
    write_state(state)
    append_pulse(loop_id, 0, "TRIAGE", "started", intent[:80])
    update_resume(intent, "TRIAGE", "in-progress", loop_id)

    print(f"\n[aq-loop] {loop_id}")
    print(f"[aq-loop] Intent   : {intent[:100]}")
    print(f"[aq-loop] Max iter : {max_iter}")
    print(f"[aq-loop] Manifest : {tool_manifest}")
    # Show severity of backlog item for observability
    if backlog_line:
        issues = _parse_open_issues()
        sev = next((x["severity"] for x in issues
                    if x["text"][:60] in backlog_line), "unknown")
        print(f"[aq-loop] Severity : {sev}")
    print()

    # Claim backlog item so parallel agents skip it (skip on dry-run â€” no real work done)
    if backlog_line and not dry_run:
        _claim_backlog_item(backlog_line)

    # Ground once (hints/skills are stable across iterations)
    state.phase = "GROUND"
    write_state(state)
    hints = get_hints(intent)
    skills = get_skills(intent)
    if hints:
        print(f"[aq-loop] Hints loaded ({len(hints)} chars)")
    if skills:
        print(f"[aq-loop] Skills: {skills[:120]}")

    # Fan-out: dispatch parallel research + architecture probes (iteration 1 only)
    research_context = ""
    if fanout and not dry_run:
        research_context = fanout_ground(intent, loop_id, fanout_timeout=fanout_timeout)
    append_pulse(loop_id, 0, "GROUND", "grounded",
                 f"hints={bool(hints)} skills={bool(skills)} fanout_context={bool(research_context)}")

    for iteration in range(1, max_iter + 1):
        state.iteration = iteration
        state.phase = "EXECUTE"
        write_state(state)
        append_pulse(loop_id, iteration, "EXECUTE", f"starting iter {iteration}/{max_iter}")
        update_resume(intent, f"EXECUTE iter {iteration}", "in-progress", loop_id)

        grounded = build_grounded_prompt(intent, state, hints, skills, research_context)

        if dry_run:
            print(f"\n[aq-loop] DRY RUN â€” grounded prompt:\n{'='*60}")
            print(grounded)
            print('=' * 60)
            return 0

        print(f"\n[aq-loop] === Iteration {iteration}/{max_iter} ===")
        t0 = time.time()
        result = run_inner_loop(grounded, loop_id, iteration, timeout=timeout, tool_manifest=tool_manifest, task_type=task_type)
        elapsed = round(time.time() - t0, 1)

        evidence = extract_evidence(result)
        evidence["iteration"] = iteration
        state.history.append(evidence)

        state.phase = "VERIFY"
        write_state(state)

        completed = is_completed(result)
        status = "COMPLETED" if completed else "INCOMPLETE"
        print(f"[aq-loop] iter {iteration} â€” {status}  elapsed={elapsed}s  tools={evidence['tool_calls']}")

        if evidence.get("result_preview"):
            print(f"[aq-loop] result: {evidence['result_preview'][:200]}")

        append_pulse(loop_id, iteration, "VERIFY", status, f"elapsed={elapsed}s")

        if completed:
            # Fan-out VERIFY: dispatch completed result to antigravity reviewer
            review_verdict = None
            if fanout:
                result_summary = evidence.get("result_preview", intent[:300])
                review_verdict = fanout_verify(intent, result_summary, loop_id, iteration)
                if review_verdict:
                    verdict = review_verdict["verdict"]
                    print(f"[aq-loop] VERIFY review: {verdict}")
                    append_pulse(loop_id, iteration, "VERIFY-REVIEW", verdict,
                                 review_verdict["output"][:200])
                    if verdict == "REJECTED" and iteration < max_iter:
                        # Inject review findings for next iteration and continue
                        evidence["review_findings"] = review_verdict["output"][:500]
                        state.history[-1] = evidence
                        print(f"[aq-loop] Reviewer rejected â€” retrying with findings (iter {iteration+1})")
                        continue

            state.phase = "COMPLETE"
            write_state(state)
            append_pulse(loop_id, iteration, "COMPLETE", "loop finished")
            update_resume(intent, "COMPLETE", "completed", loop_id)
            archive_state(state)
            if backlog_line:
                _release_backlog_item(backlog_line, success=True)
            print(f"\n[aq-loop] Loop completed in {iteration} iteration(s).")
            return 0

        if iteration < max_iter:
            print(f"[aq-loop] Incomplete â€” will retry (iter {iteration+1}/{max_iter})")

    # Exhausted iterations
    state.phase = "ESCALATED"
    write_state(state)
    append_pulse(loop_id, max_iter, "ESCALATED", "max iterations reached")
    update_resume(intent, "ESCALATED", "escalated", loop_id)
    write_escalation(state)
    if backlog_line:
        _release_backlog_item(backlog_line, success=False)  # restore [OPEN]
    print(f"\n[aq-loop] Escalated after {max_iter} iterations. See issues-backlog.md.")
    return 1


