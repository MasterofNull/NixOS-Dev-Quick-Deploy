def _claim_backlog_item(line_text: str) -> None:
    """Mark a backlog issue [IN-PROGRESS] so other agents skip it."""
    if not _BACKLOG_PATH.exists():
        return
    content = _BACKLOG_PATH.read_text()
    slug = line_text.strip()[:80]
    updated = content.replace(slug, slug.replace("[OPEN]", "[IN-PROGRESS]", 1), 1)
    if updated != content:
        _BACKLOG_PATH.write_text(updated)


def _release_backlog_item(line_text: str, success: bool) -> None:
    """Release [IN-PROGRESS] â†’ [DONE] on success or [OPEN] on failure."""
    if not _BACKLOG_PATH.exists():
        return
    content = _BACKLOG_PATH.read_text()
    slug = line_text.strip()[:80]
    in_prog = slug.replace("[OPEN]", "[IN-PROGRESS]", 1)
    target = slug.replace("[OPEN]", "[DONE]", 1) if success else slug
    updated = content.replace(in_prog, target, 1)
    if updated != content:
        _BACKLOG_PATH.write_text(updated)


def run_inner_loop(
    grounded_prompt: str,
    loop_id: str,
    iteration: int,
    timeout: int = 3600,
    tool_manifest: str = "full",
    task_type: str | None = None,
) -> dict:
    """Invoke aq-agent-loop and return its JSON result summary."""
    out_fd, out_path = tempfile.mkstemp(
        prefix=f"aq-loop-{loop_id}-iter{iteration}-",
        suffix=".json",
    )
    os.close(out_fd)

    cmd = [
        str(_SCRIPT_DIR / "aq-agent-loop"),
        "--task", grounded_prompt,
        "--output", out_path,
        "--tool-manifest", tool_manifest,
    ]
    if task_type:
        cmd += ["--task-type", task_type]
    env = os.environ.copy()
    env["REPO_ROOT"] = str(_REPO_ROOT)

    print(f"[aq-loop] iter {iteration} â€” launching aq-agent-loop (manifest={tool_manifest} task_type={task_type or 'agent'}) ...")
    rc = subprocess.run(cmd, env=env, timeout=timeout)
    if rc.returncode not in (0, 1):
        return {"success": False, "error": f"aq-agent-loop exit {rc.returncode}", "tool_calls": []}

    try:
        with open(out_path) as f:
            result = json.load(f)
        return result
    except Exception as e:
        return {"success": False, "error": f"parse output: {e}", "tool_calls": []}
    finally:
        try:
            os.unlink(out_path)
        except Exception:
            pass


