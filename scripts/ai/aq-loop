def main() -> int:
    parser = argparse.ArgumentParser(
        description="Outer orchestration loop for autonomous local-agent task execution",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    src = parser.add_mutually_exclusive_group()
    src.add_argument("--intent", help="Explicit task description")
    src.add_argument("--from-backlog", action="store_true",
                     help="Pop first [OPEN] from issues-backlog.md")
    parser.add_argument("--max-iter", type=int, default=3,
                        help="Max iterations before escalation (default: 3)")
    parser.add_argument("--dry-run", action="store_true",
                        help="Print grounded prompt without executing")
    parser.add_argument("--check", action="store_true",
                        help="Print current LOOP_STATE.json and exit")
    parser.add_argument("--list-open", action="store_true",
                        help="List [OPEN] items from issues-backlog.md and exit")
    parser.add_argument("--timeout", type=int, default=3600,
                        help="Per-iteration timeout in seconds (default: 3600)")
    parser.add_argument("--tool-manifest", choices=["full", "self-improvement"], default=None,
                        help="Tool set passed to aq-agent-loop (auto: self-improvement for backlog, full for --intent)")
    parser.add_argument(
        "--task-type",
        default=None,
        choices=["structured", "lookup", "code", "reasoning", "agent", "research", "deep_reasoning"],
        help=(
            "LLM task profile passed to aq-agent-loop. Default: 'agent' (implementation tasks). "
            "Use 'deep_reasoning' for research/planning tasks to enable long-horizon read guard."
        ),
    )
    parser.add_argument("--no-fanout", action="store_true",
                        help="Disable multi-agent fan-out (skip parallel research/review probes)")
    parser.add_argument("--fanout-timeout", type=int, default=120,
                        help="Seconds to wait for fan-out probe results (default: 120)")

    args = parser.parse_args()

    if args.check:
        state = read_state()
        if state:
            print(json.dumps(state.to_dict(), indent=2))
        else:
            print("[aq-loop] No active loop state.")
        return 0

    if args.list_open:
        list_open()
        return 0

    backlog_line = ""
    if args.from_backlog:
        intent, raw_line, lineno = pop_from_backlog()
        if intent is None:
            print("[aq-loop] No [OPEN] items in issues-backlog.md")
            return 1
        backlog_line = raw_line  # raw text (with [OPEN]) used for claim/release in backlog
        print(f"[aq-loop] Popped from backlog (line {lineno}): {intent[:100]}")
        # Default to self-improvement manifest for backlog tasks unless overridden
        manifest = args.tool_manifest or "self-improvement"
    elif args.intent:
        intent = args.intent
        manifest = args.tool_manifest or "full"
    else:
        parser.print_help()
        return 1

    return run_loop(
        intent=intent,
        max_iter=args.max_iter,
        dry_run=args.dry_run,
        timeout=args.timeout,
        tool_manifest=manifest,
        backlog_line=backlog_line,
        task_type=args.task_type,
        fanout=not args.no_fanout,
        fanout_timeout=args.fanout_timeout,
    )


if __name__ == "__main__":
    sys.exit(main())
