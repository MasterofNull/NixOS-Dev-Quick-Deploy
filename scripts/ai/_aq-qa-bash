#!/usr/bin/env bash
# aq-qa — AI Stack QA phase runner (Phase 21.1)
#
# Runs discrete test checks for a given QA plan phase and outputs
# structured pass/fail results. Replaces 10-20 individual Bash tool
# calls per session with a single invocation.
#
# Usage:
#   aq-qa 0               Run Phase 0 (pre-flight smoke)
#   aq-qa 1               Run Phase 1 (infrastructure)
#   aq-qa phase0          Same as aq-qa 0
#   aq-qa all             Run all implemented phases
#   aq-qa 0 --json        Machine-readable JSON output
#   aq-qa 0 --sudo        Enable checks that require sudo (AppArmor)
#   aq-qa --layer 5       Run only Session/Persistence checks (Postgres, AIDB)
#   aq-qa --layer 4 --causality  Check L4 + all dependencies (L1-L3)
#
# Exit codes: 0 = all pass, 1 = one or more failed, 2 = usage error

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Phase 177: honor REPO_ROOT env var when set (coordinator calls Nix-store copy).
REPO_ROOT="${REPO_ROOT:-$(cd "${SCRIPT_DIR}/../.." && pwd)}"

# shellcheck source=../config/service-endpoints.sh
source "${REPO_ROOT}/config/service-endpoints.sh"

# ---------------------------------------------------------------------------
# Options
# ---------------------------------------------------------------------------
PHASE="${1:-help}"
JSON_OUTPUT=0
USE_SUDO=0
LAYER_FILTER=0
CAUSALITY_MODE=0

# Filter out phase arg if it's a number, otherwise default to all
if [[ "$PHASE" =~ ^[0-9]+$ || "$PHASE" == "all" ]]; then
    shift 2>/dev/null || true
else
    PHASE="all"
fi

args=("$@")
for ((i=0; i<${#args[@]}; i++)); do
  case "${args[i]}" in
    --json) JSON_OUTPUT=1 ;;
    --sudo) USE_SUDO=1 ;;
    --layer) LAYER_FILTER="${args[i+1]}"; (( i += 1 )) ;;
    --causality) CAUSALITY_MODE=1 ;;
    --help|-h) PHASE="help" ;;
  esac
done

PHASE="${PHASE#phase}"   # strip optional "phase" prefix
# Parsed for CLI compatibility; privileged checks are still explicit/bounded.
(( USE_SUDO == 0 || USE_SUDO == 1 ))

AQ_QA_FIXTURE_LLAMA_DIAG="${AQ_QA_FIXTURE_LLAMA_DIAG:-}"
AQ_QA_FIXTURE_APPARMOR_DIAG="${AQ_QA_FIXTURE_APPARMOR_DIAG:-}"

# ---------------------------------------------------------------------------
# Test result tracking
# ---------------------------------------------------------------------------
PASS=0
FAIL=0
SKIP=0
RESULTS=()  # "PASS|FAIL|SKIP id description"
START_TS=$(date +%s)
_QA_PROGRESS_HEARTBEAT_PID=""

_qa_progress_emit() {
  local state="$1" layer="${2:-}" id="${3:-}" desc="${4:-}" detail="${5:-}"
  local now elapsed
  now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  elapsed=$(( $(date +%s) - START_TS ))
  [[ -n "${AQ_QA_PROGRESS_JSON:-}" || -n "${AQ_QA_PROGRESS_JSONL:-}" ]] || return 0
  STATE="$state" LAYER="$layer" CHECK_ID="$id" DESC="$desc" DETAIL="$detail" NOW="$now" ELAPSED="$elapsed" \
  PASS_N="$PASS" FAIL_N="$FAIL" SKIP_N="$SKIP" PROGRESS_JSON="${AQ_QA_PROGRESS_JSON:-}" PROGRESS_JSONL="${AQ_QA_PROGRESS_JSONL:-}" \
  REPO_ROOT="${REPO_ROOT}" PHASE="${PHASE:-unknown}" \
    python3 - <<'PY' 2>/dev/null || true
import json, os, pathlib
import sys
payload = {
    "state": os.environ.get("STATE"),
    "layer": os.environ.get("LAYER") or None,
    "check_id": os.environ.get("CHECK_ID") or None,
    "description": os.environ.get("DESC") or None,
    "detail": os.environ.get("DETAIL") or None,
    "timestamp": os.environ.get("NOW"),
    "elapsed_s": int(os.environ.get("ELAPSED") or 0),
    "counts": {
        "pass": int(os.environ.get("PASS_N") or 0),
        "fail": int(os.environ.get("FAIL_N") or 0),
        "skip": int(os.environ.get("SKIP_N") or 0),
    },
}
if os.environ.get("PROGRESS_JSON"):
    path = pathlib.Path(os.environ["PROGRESS_JSON"])
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")
if os.environ.get("PROGRESS_JSONL"):
    path = pathlib.Path(os.environ["PROGRESS_JSONL"])
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a", encoding="utf-8") as fh:
        fh.write(json.dumps(payload, separators=(",", ":")) + "\n")
try:
    repo_root = pathlib.Path(os.environ["REPO_ROOT"])
    sys.path.insert(0, str(repo_root / "scripts" / "ai" / "lib"))
    import agent_run_events as events
    state = payload["state"]
    status = "succeeded" if state == "pass" else "failed" if state == "fail" else "running"
    events.emit_event(
        "validation",
        source="aq-qa",
        run_id=f"aq-qa-{os.environ.get('PHASE') or 'unknown'}",
        status=status,
        task_id=payload.get("check_id"),
        slice_id=payload.get("layer"),
        duration_ms=payload["elapsed_s"] * 1000,
        tool_name="aq-qa",
        payload=payload,
    )
except Exception:
    pass
PY
}

_qa_progress_start() {
  local layer="$1" id="$2" desc="$3"
  _qa_progress_emit "running" "$layer" "$id" "$desc"
  if [[ -n "${AQ_QA_PROGRESS_JSON:-}" || -n "${AQ_QA_PROGRESS_JSONL:-}" ]]; then
    (
      while true; do
        sleep "${AQ_QA_PROGRESS_HEARTBEAT_SECONDS:-10}"
        _qa_progress_emit "heartbeat" "$layer" "$id" "$desc"
      done
    ) &
    _QA_PROGRESS_HEARTBEAT_PID="$!"
  fi
}

_qa_progress_stop() {
  local state="$1" layer="$2" id="$3" desc="$4" detail="${5:-}"
  if [[ -n "${_QA_PROGRESS_HEARTBEAT_PID:-}" ]]; then
    kill "${_QA_PROGRESS_HEARTBEAT_PID}" 2>/dev/null || true
    wait "${_QA_PROGRESS_HEARTBEAT_PID}" 2>/dev/null || true
    _QA_PROGRESS_HEARTBEAT_PID=""
  fi
  _qa_progress_emit "$state" "$layer" "$id" "$desc" "$detail"
}

_pass() { local layer="$1" id="$2" desc="$3"; ((++PASS)); RESULTS+=("PASS|$layer|$id|$desc"); }
_fail() { local layer="$1" id="$2" desc="$3" reason="${4:-}"; ((++FAIL)); RESULTS+=("FAIL|$layer|$id|$desc${reason:+ ($reason)}"); }
_skip() { local layer="$1" id="$2" desc="$3" reason="${4:-}"; ((++SKIP)); RESULTS+=("SKIP|$layer|$id|$desc${reason:+ ($reason)}"); }

# OSI Layer Enforcement
_should_run() {
    local layer="$1"
    [[ "$LAYER_FILTER" -eq 0 ]] && return 0
    [[ "$LAYER_FILTER" -eq "$layer" ]] && return 0
    [[ "$CAUSALITY_MODE" -eq 1 && "$LAYER_FILTER" -gt "$layer" ]] && return 0
    return 1
}

# Run a command silently; pass/fail based on exit code.
_check() {
  local layer="$1" id="$2" desc="$3"; shift 3
  if ! _should_run "$layer"; then return 0; fi
  _qa_progress_start "$layer" "$id" "$desc"
  if "$@" >/dev/null 2>&1; then
    _pass "$layer" "$id" "$desc"
    _qa_progress_stop "pass" "$layer" "$id" "$desc"
  else
    _fail "$layer" "$id" "$desc"
    _qa_progress_stop "fail" "$layer" "$id" "$desc"
  fi
}

_check_timeout() {
  local layer="$1" id="$2" desc="$3" timeout_s="$4"; shift 4
  if ! _should_run "$layer"; then return 0; fi
  _qa_progress_start "$layer" "$id" "$desc"
  if timeout --foreground "$timeout_s" "$@" >/dev/null 2>&1; then
    _pass "$layer" "$id" "$desc"
    _qa_progress_stop "pass" "$layer" "$id" "$desc"
  else
    local rc=$?
    local reason="exit ${rc}"
    if [[ "$rc" -eq 124 ]]; then
      reason="timeout after ${timeout_s}s"
    fi
    _fail "$layer" "$id" "$desc" "$reason"
    _qa_progress_stop "fail" "$layer" "$id" "$desc" "$reason"
  fi
}

# Run a command and check output matches a pattern.
_check_output() {
  local layer="$1" id="$2" desc="$3" pattern="$4"; shift 4
  if ! _should_run "$layer"; then return 0; fi
  local out
  _qa_progress_start "$layer" "$id" "$desc"
  out=$("$@" 2>&1) || { _fail "$layer" "$id" "$desc" "command failed"; _qa_progress_stop "fail" "$layer" "$id" "$desc" "command failed"; return; }
  if printf '%s' "$out" | grep -qE "$pattern"; then
    _pass "$layer" "$id" "$desc"
    _qa_progress_stop "pass" "$layer" "$id" "$desc"
  else
    _fail "$layer" "$id" "$desc" "output: ${out:0:80}"
    _qa_progress_stop "fail" "$layer" "$id" "$desc" "output: ${out:0:80}"
  fi
}

_output_contains() {
  local pattern="$1"
  shift
  local out
  out=$("$@" 2>/dev/null || true)
  grep -qE "$pattern" <<<"$out"
}

_host_observer_url() {
  local path="${1:-/api/health/services/all}"
  local base="${AQ_HOST_OBSERVER_URL:-${DASHBOARD_API_URL:-http://127.0.0.1:8889}}"
  printf '%s/%s' "${base%/}" "${path#/}"
}

_host_observer_service_status() {
  local service_id="$1" payload
  local artifact="${AQ_HOST_OBSERVER_FILE:-/var/lib/ai-stack/hybrid/telemetry/latest-system-state.json}"
  if [[ -r "$artifact" ]]; then
    OBSERVER_FILE="$artifact" python3 - "$service_id" <<'PY' 2>/dev/null && return 0
import json
import os
import sys

service_id = sys.argv[1]
try:
    with open(os.environ["OBSERVER_FILE"], encoding="utf-8") as fh:
        doc = json.load(fh)
    services = doc.get("services", [])
    if isinstance(services, list):
        for service in services:
            if not isinstance(service, dict) or service.get("name") != service_id:
                continue
            status = service.get("status")
            print("healthy" if status == "active" else status or "unknown")
            raise SystemExit(0)
except Exception:
    pass
raise SystemExit(1)
PY
  fi

  payload="$(_http_get "$(_host_observer_url)" 5 2>/dev/null)" || return 1
  OBSERVER_PAYLOAD="$payload" python3 - "$service_id" <<'PY' 2>/dev/null
import json
import os
import sys

service_id = sys.argv[1]
try:
    doc = json.loads(os.environ.get("OBSERVER_PAYLOAD", ""))
    service = doc.get("services", {}).get(service_id, {})
    status = service.get("status")
    if status:
        print(status)
        raise SystemExit(0)
except Exception:
    pass
raise SystemExit(1)
PY
}

