# ---------------------------------------------------------------------------
# Output
# ---------------------------------------------------------------------------
_render_results() {
  local end_ts; end_ts=$(date +%s)
  local duration=$((end_ts - START_TS))

  if [[ "$JSON_OUTPUT" -eq 1 ]]; then
    python3 - "$PHASE" "$PASS" "$FAIL" "$SKIP" "$duration" "$LAYER_FILTER" "$CAUSALITY_MODE" "${RESULTS[@]}" <<'PYEOF'
import sys, json
phase, passed, failed, skipped, duration, layer_filter, causality_mode = sys.argv[1:8]
layer_filter, causality_mode = int(layer_filter), int(causality_mode)
items = []
layers = {}
for entry in sys.argv[8:]:
    status, layer, id_, desc = entry.split('|', 3)
    item = {"layer": int(layer), "id": id_, "status": status, "description": desc}
    items.append(item)
    layers.setdefault(int(layer), []).append(item)
# degraded_confidence: causality mode active and a dependency layer has failures
degraded_confidence = False
if causality_mode and layer_filter > 0:
    degraded_confidence = any(
        any(i["status"] == "FAIL" for i in layers[l])
        for l in layers if l < layer_filter
    )
print(json.dumps({
    "phase": phase, "passed": int(passed), "failed": int(failed),
    "skipped": int(skipped), "duration_s": int(duration),
    "degraded_confidence": degraded_confidence,
    "tests": items,
    "layers": {str(k): v for k, v in sorted(layers.items())}
}, indent=2))
PYEOF
    return
  fi

  local GREEN='\033[0;32m' RED='\033[0;31m' YELLOW='\033[1;33m' BLUE='\033[0;34m' NC='\033[0m'
  printf '\n%b━━━ aq-qa phase %s ━━━%b\n' "${BLUE}" "${PHASE}" "${NC}"
  local prev_layer=""
  for entry in "${RESULTS[@]}"; do
    IFS='|' read -r status layer id_ desc <<< "$entry"
    if [[ "$layer" != "$prev_layer" ]]; then
      printf '%b  [L%s]%b\n' "${BLUE}" "$layer" "${NC}"
      prev_layer="$layer"
    fi
    case "$status" in
      PASS) printf '  %b✓%b %-16s %s\n' "${GREEN}" "${NC}" "$id_" "$desc" ;;
      FAIL) printf '  %b✗%b %-16s %s\n' "${RED}" "${NC}" "$id_" "$desc" ;;
      SKIP) printf '  %b–%b %-16s %s\n' "${YELLOW}" "${NC}" "$id_" "$desc" ;;
    esac
  done
  if [[ "$CAUSALITY_MODE" -eq 1 && "$LAYER_FILTER" -gt 0 && "$FAIL" -gt 0 ]]; then
    printf '\n%b⚠ DEGRADED CONFIDENCE — lower-layer failures may invalidate L%s results%b\n' \
      "${YELLOW}" "${LAYER_FILTER}" "${NC}"
  fi
  printf '\n%b%d passed%b · %b%d failed%b · %d skipped · %ds\n\n' \
    "${GREEN}" "${PASS}" "${NC}" "${RED}" "${FAIL}" "${NC}" "${SKIP}" "${duration}"

  # Persist summary for aq-report regression_containment proxy (Phase 96.1).
  local _qa_json="${REPO_ROOT}/data/hybrid/telemetry/latest-qa-results.json"
  mkdir -p "$(dirname "${_qa_json}")" 2>/dev/null || true
  python3 - "$PHASE" "$PASS" "$FAIL" "$SKIP" "$duration" "${RESULTS[@]}" > "${_qa_json}" 2>/dev/null <<'PYEOF' || true
import sys, json
from datetime import datetime, timezone
phase, passed, failed, skipped, duration = sys.argv[1:6]
items = []
for entry in sys.argv[6:]:
    status, layer, id_, desc = entry.split('|', 3)
    items.append({"layer": int(layer), "id": id_, "status": status, "description": desc})
print(json.dumps({
    "phase": phase, "passed": int(passed), "failed": int(failed),
    "skipped": int(skipped), "duration_s": int(duration),
    "generated_at": datetime.now(tz=timezone.utc).isoformat(),
    "tests": items,
}, indent=2))
PYEOF
}

