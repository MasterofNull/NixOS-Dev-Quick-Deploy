_p57_check_pipeline_stages() {
  python3 -c "
import json, sys
d = json.load(open(sys.argv[1]))
stages = d.get('promotion_pipeline', {}).get('stages', [])
if len(stages) < 6:
    print(f'expected >=6 stages, got {len(stages)}', file=sys.stderr)
    sys.exit(1)
" "${_p57_matrix}"
}

