# Port binding check.
_port() {
  local layer="$1" id="$2" desc="$3" port="$4"
  local attempts="${AQ_QA_PORT_RETRY_ATTEMPTS:-4}"
  local delay="${AQ_QA_PORT_RETRY_DELAY_SECONDS:-1}"
  local port_name="${id#0.2.1:}"
  local i denied=0
  for ((i=1; i<=attempts; i++)); do
    local port_rc
    port_rc=0
    _tcp_port_open "$port" || port_rc=$?
    if [[ "$port_rc" -eq 0 ]]; then
      _pass "$layer" "$id" "$desc"
      return 0
    fi
    [[ "$port_rc" -eq 2 ]] && denied=1
    local ss_out
    ss_out="$(ss -tlnp 2>&1 || true)"
    if grep -qE ":${port} " <<<"$ss_out"; then
      _pass "$layer" "$id" "$desc"
      return 0
    fi
    if grep -qiE 'operation not permitted|cannot open netlink' <<<"$ss_out"; then
      denied=1
    fi
    (( i < attempts )) && sleep "${delay}"
  done
  if [[ "$denied" -eq 1 ]]; then
    local observer_service observer_status
    observer_service="$(_host_observer_service_for_port_name "$port_name" || true)"
    if [[ -n "$observer_service" ]]; then
      observer_status="$(_host_observer_service_status "$observer_service" || true)"
      if [[ "$observer_status" == "healthy" ]]; then
        _pass "$layer" "$id" "$desc via host observer"
        return 0
      fi
    fi
    _skip "$layer" "$id" "$desc" "host port probe denied in current sandbox"
    return 0
  fi
  _fail "$layer" "$id" "$desc" "port $port not bound"
}

# Feature-flagged port: validate the config<->runtime CONTRACT against the unit's declared intent
# instead of a naive bound check (which fails whenever the feature is legitimately off). Used for
# ports gated by a profile flag, e.g. open-webui gated by mySystem.aiStack.ui.enable.
#   enabled + bound     -> PASS (running as configured)
#   enabled + not bound -> FAIL (real regression — should be up, isn't)
#   disabled + not bound-> PASS (correctly off)
#   disabled + bound    -> FAIL (stale/unexpected process holding the port)
_feature_port_contract() {
  local layer="$1" id="$2" name="$3" port="$4" unit="$5"
  local enabled=0 bound=0 ufs ss_listeners
  ufs="$(systemctl is-enabled "$unit" 2>/dev/null || true)"
  case "$ufs" in enabled|enabled-runtime|static|indirect) enabled=1 ;; esac
  ss_listeners="$(ss -tlnH 2>/dev/null || true)"
  grep -qE "[:.]${port}[[:space:]]" <<<"${ss_listeners}" && bound=1
  if [[ $enabled -eq 1 && $bound -eq 1 ]]; then
    _pass "$layer" "$id" "port $port ($name) bound (unit enabled)"
  elif [[ $enabled -eq 1 && $bound -eq 0 ]]; then
    _fail "$layer" "$id" "port $port ($name) bound" "unit enabled but port $port not bound — service down"
  elif [[ $enabled -eq 0 && $bound -eq 0 ]]; then
    _pass "$layer" "$id" "$name disabled + port $port correctly not bound"
  else
    _fail "$layer" "$id" "$name off => port $port unbound" "unit disabled but port $port is bound — stale/unexpected process"
  fi
}

