_systemd_unit_state() {
  local unit="$1" out rc state
  out="$(systemctl is-active "$unit" 2>&1)" && { printf 'active'; return 0; }
  rc=$?
  if grep -qiE 'operation not permitted|failed to connect' <<<"$out"; then
    local short observer_status
    short="${unit%.service}"
    observer_status="$(_host_observer_service_status "$short" || true)"
    if [[ "$observer_status" == "healthy" ]]; then
      printf 'observer:healthy'
      return 0
    elif [[ -n "$observer_status" ]]; then
      printf 'observer:%s' "$observer_status"
      return 0
    fi
    state="$(systemctl show "$unit" --property=ActiveState --value 2>/dev/null || true)"
    if [[ "$state" == "active" ]]; then
      printf 'active'
    else
      printf 'denied'
    fi
    return 0
  fi
  printf 'inactive:%s' "${out:-rc=$rc}"
}

_tcp_port_open() {
  local port="$1"
  python3 - "$port" <<'PY' 2>/dev/null
import socket
import sys

port = int(sys.argv[1])
try:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
        sock.settimeout(0.5)
        raise SystemExit(0 if sock.connect_ex(("127.0.0.1", port)) == 0 else 1)
except PermissionError:
    raise SystemExit(2)
PY
}

_primary_user() {
