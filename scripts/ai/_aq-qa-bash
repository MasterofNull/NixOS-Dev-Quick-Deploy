_aq_report_snapshot() {
  if [[ -n "${AQ_QA_AQ_REPORT_JSON:-}" ]]; then
    printf '%s' "${AQ_QA_AQ_REPORT_JSON}"
    return 0
  fi

  local snapshot_path="${AQ_QA_AQ_REPORT_PATH:-/var/lib/ai-stack/hybrid/telemetry/latest-aq-report.json}"
  if [[ -s "$snapshot_path" ]] && python3 -m json.tool "$snapshot_path" >/dev/null 2>&1; then
    AQ_QA_AQ_REPORT_JSON="$(cat "$snapshot_path")"
    printf '%s' "${AQ_QA_AQ_REPORT_JSON}"
    return 0
  fi

  # aq-report can be CPU/model intensive and is often triggered indirectly by
  # editor/dashboard agents. Do not spawn it from aq-qa by default; callers that
  # need a fresh report must opt in explicitly.
  if [[ "${AQ_QA_ALLOW_INLINE_REPORT:-0}" == "1" ]]; then
    AQ_QA_AQ_REPORT_JSON="$(
      cd "${REPO_ROOT}" && AQ_PRIMARY_HOME="$(_primary_home)" python3 "${SCRIPT_DIR}/aq-report" --format json 2>/dev/null || true
    )"
    [[ -n "${AQ_QA_AQ_REPORT_JSON}" ]] || return 1
    printf '%s' "${AQ_QA_AQ_REPORT_JSON}"
    return 0
  fi

  return 1
}

