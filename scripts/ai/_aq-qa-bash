# HTTP health check: curl URL, expect JSON with status=ok.
_http_health() {
  local layer="$1" id="$2" desc="$3" url="$4"
  if ! _should_run "$layer"; then return 0; fi
  local body rc status
  _qa_progress_start "$layer" "$id" "$desc"
  set +e
  body="$(_http_get "$url" 5)"
  rc=$?
  set -e
  if [[ "$rc" -eq 77 ]]; then
    _skip "$layer" "$id" "$desc" "HTTP probe denied in current sandbox"
    _qa_progress_stop "skip" "$layer" "$id" "$desc" "HTTP probe denied in current sandbox"
    return
  fi
  status=$(printf '%s' "$body" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('status',''))" 2>/dev/null || true)
  if [[ "$status" == "ok" ]]; then
    _pass "$layer" "$id" "$desc"
    _qa_progress_stop "pass" "$layer" "$id" "$desc"
  else
    _fail "$layer" "$id" "$desc" "status='$status' url=$url"
    _qa_progress_stop "fail" "$layer" "$id" "$desc" "status='$status' url=$url"
  fi
}

_check_http_output() {
  local layer="$1" id="$2" desc="$3" pattern="$4" url="$5" timeout_s="${6:-5}"
  if ! _should_run "$layer"; then return 0; fi
  local out rc
  _qa_progress_start "$layer" "$id" "$desc"
  set +e
  out="$(_http_get "$url" "$timeout_s")"
  rc=$?
  set -e
  if [[ "$rc" -eq 77 ]]; then
    _skip "$layer" "$id" "$desc" "HTTP probe denied in current sandbox"
    _qa_progress_stop "skip" "$layer" "$id" "$desc" "HTTP probe denied in current sandbox"
    return
  elif [[ "$rc" -ne 0 ]]; then
    _fail "$layer" "$id" "$desc" "HTTP probe failed"
    _qa_progress_stop "fail" "$layer" "$id" "$desc" "HTTP probe failed"
    return
  fi
  if printf '%s' "$out" | grep -qE "$pattern"; then
    _pass "$layer" "$id" "$desc"
    _qa_progress_stop "pass" "$layer" "$id" "$desc"
  else
    _fail "$layer" "$id" "$desc" "output: ${out:0:80}"
    _qa_progress_stop "fail" "$layer" "$id" "$desc" "output: ${out:0:80}"
  fi
}

