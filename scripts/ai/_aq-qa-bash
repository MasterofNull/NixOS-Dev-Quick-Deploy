  local out rc py_err headers=()
  if [[ -n "$api_key" ]]; then
    headers+=(-H "X-API-Key: ${api_key}")
  fi
  out="$(curl -sS -o /dev/null -w '%{http_code}' --max-time "${timeout_s}" "${headers[@]}" "$url" 2>&1)"
  rc=$?
  if [[ "$rc" -eq 0 && "$out" =~ ^[0-9]{3}$ ]]; then
    printf '%s' "$out"
    return 0
  fi
  if grep -qiE 'Operation not permitted|PermissionError' <<<"$out"; then
    return 77
  fi
  py_err="$(mktemp)"
  if timeout --foreground "$((timeout_s + 1))" python3 - "$url" "$timeout_s" "$api_key" 2>"${py_err}" <<'PY'
