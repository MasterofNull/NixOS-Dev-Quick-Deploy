_http_get() {
  local url="$1" timeout_s="${2:-5}" api_key="${3:-}"
  local out py_err
  local headers=()
  if [[ -n "$api_key" ]]; then
    headers+=(-H "X-API-Key: ${api_key}")
  fi
  out="$(curl -sf --max-time "${timeout_s}" "${headers[@]}" "$url" 2>/dev/null)" && {
    printf '%s' "$out"
    return 0
  }
  py_err="$(mktemp)"
  if timeout --foreground "$((timeout_s + 1))" python3 - "$url" "$timeout_s" "$api_key" 2>"${py_err}" <<'PY'
import sys
from urllib.request import Request, urlopen

url, api_key = sys.argv[1], sys.argv[3]
timeout_s = float(sys.argv[2])
headers = {}
if api_key:
    headers["X-API-Key"] = api_key
request = Request(url, headers=headers, method="GET")
with urlopen(request, timeout=timeout_s) as response:
    sys.stdout.write(response.read().decode("utf-8", "replace"))
PY
  then
    rm -f "${py_err}"
    return 0
  fi
  if grep -qiE 'Operation not permitted|PermissionError' "${py_err}"; then
    rm -f "${py_err}"
    return 77
  fi
  rm -f "${py_err}"
  return 1
}

