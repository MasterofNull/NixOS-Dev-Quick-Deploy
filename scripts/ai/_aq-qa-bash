expected_chat_context = local_agent_profile.get("advertisedContextWindow") or default_profile.get("advertisedContextWindow")
expected_chat_context = int(expected_chat_context) if expected_chat_context is not None else None
bounded_chat_context = local_agent_profile.get("maxInputTokens")
bounded_chat_context = int(bounded_chat_context) if bounded_chat_context is not None else None
minimum_chat_context = bounded_chat_context or expected_chat_context or 4096
minimum_chat_context = max(4096, int(minimum_chat_context))
minimum_chat_max_tokens = 1024

expected_tab_context = continue_profile.get("advertisedContextWindow") or default_profile.get("advertisedContextWindow")
expected_tab_context = int(expected_tab_context) if expected_tab_context is not None else None
expected_tab_max_tokens = max(32, min(96, minimum_chat_max_tokens)) if minimum_chat_max_tokens is not None else None

models = data.get("models") or []
if not any(
    isinstance(model, dict)
    and model.get("apiBase") == "http://127.0.0.1:8085/v1"
    and ((model.get("requestOptions") or {}).get("headers") or {}).get("X-AI-Profile") == "local-agent"
    and int(model.get("contextLength") or 0) >= minimum_chat_context
    and int(model.get("maxTokens") or 0) >= minimum_chat_max_tokens
    for model in models
):
    raise SystemExit(1)

tab_model = data.get("tabAutocompleteModel") or {}
if tab_model.get("apiBase") != "http://127.0.0.1:8085/v1":
    raise SystemExit(1)
if ((tab_model.get("requestOptions") or {}).get("headers") or {}).get("X-AI-Profile") != "continue-local":
    raise SystemExit(1)
if expected_tab_context is not None and int(tab_model.get("contextLength") or 0) < expected_tab_context:
    raise SystemExit(1)
if (
    int(tab_model.get("maxTokens") or 0)
    != (expected_tab_max_tokens if expected_tab_max_tokens is not None else max(32, int(tab_model.get("maxTokens") or 0)))
):
    raise SystemExit(1)
# aq-hints context provider was removed in Continue v1.3.38+ (not a supported provider type);
# harness context is now delivered via the local-agent switchboard profile card instead.
PY
}

