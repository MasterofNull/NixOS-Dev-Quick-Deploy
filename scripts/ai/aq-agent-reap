#!/usr/bin/env python3
"""aq-agent-reap — kill orphaned/wedged aq-agent-loop processes holding the llama slot.

The self-watchdog inside aq-agent-loop stops NEW orphans from lingering (it self-exits
when reparented to init). This reaper cleans up any that predate the watchdog or slip
through, and is safe to run from cron / a systemd timer.

An aq-agent-loop process is reaped when:
  - it is ORPHANED — ppid == 1 (its dispatcher died), OR
  - its wall-clock exceeds --max-age (default 3600s) — runaway/wedged.

Kills the whole process group (dispatch spawns with start_new_session=True) so any
children go too. Dry-run by default is off; pass --dry-run to preview.

It also (opt-in) reconciles the delegation registry: a background dispatch whose process
dies — or an antigravity dispatch that never records a pid — leaves its registry row stuck
at status=running forever (the reaper historically only killed processes, never fixed the
registry). --reconcile-registry marks such rows (dead/absent pid, aged past --registry-age)
as status=orphaned so ops views show true live state.

Usage:
  aq-agent-reap [--max-age SECONDS] [--dry-run]           # process reaping (default)
  aq-agent-reap --reconcile-registry [--registry-age S]   # + registry reconciliation
  aq-agent-reap --registry-only --dry-run                 # preview registry pass only
"""
from __future__ import annotations

import argparse
import json
import os
import signal
import subprocess
import sys
import tempfile
from datetime import datetime, timezone
from pathlib import Path
from typing import List, Dict


AGENT_MATCH = "scripts/ai/aq-agent-loop"
REGISTRY = Path(__file__).resolve().parents[2] / ".agents" / "delegation" / "registry.jsonl"


def _parse_ts(s: str):
    try:
        return datetime.fromisoformat((s or "").strip().replace("Z", "+00:00")).timestamp()
    except Exception:
        return None


def _pid_alive(pid) -> bool:
    """True if pid names a live process. Absent/invalid pid -> False; foreign pid -> True."""
    if not pid:
        return False
    try:
        os.kill(int(pid), 0)
        return True
    except PermissionError:
        return True            # exists, owned by another uid — never orphan it
    except (ProcessLookupError, ValueError, TypeError, OSError):
        return False


def should_orphan_row(rec: Dict, now: float, age_s: int) -> tuple[bool, str]:
    """Pure decision: mark a registry row orphaned? Reconcile only rows that are
    status=running, whose pid is dead/absent, AND older than age_s (the age bound
    protects a just-dispatched task that hasn't recorded its pid yet)."""
    if rec.get("status") != "running":
        return False, ""
    if _pid_alive(rec.get("pid")):
        return False, ""       # live work — never touch
    ts = _parse_ts(rec.get("created", ""))
    if ts is None:
        return False, "no timestamp — skip"
    age = now - ts
    if age < age_s:
        return False, ""
    return True, f"pid={rec.get('pid')} dead, age {int(age)}s > {age_s}s"


def _dispatch_active() -> int:
    """Count live delegate/agent processes that may be APPENDING to the registry.
    The reconcile rewrites the whole file (read → replace); a concurrent append during
    that window would be lost, so a live write is refused while dispatch is active."""
    try:
        out = subprocess.run(["pgrep", "-af", r"delegate-to-|aq-agent-loop|aq-loop"],
                             capture_output=True, text=True, timeout=1.5).stdout
    except Exception:
        return 0
    self_pid = str(os.getpid())
    return sum(1 for ln in out.splitlines()
               if ln and ln.split(" ", 1)[0] != self_pid
               and "aq-agent-reap" not in ln and "pgrep" not in ln)


def reconcile_registry(path: Path, age_s: int, dry_run: bool, force: bool = False) -> int:
    """Rewrite status=running rows with dead pid + age>age_s to status=orphaned.
    Atomic (temp + os.replace); preserves row order and every other row verbatim.
    Refuses to WRITE while dispatch is active (would race concurrent appends) unless
    --force; still prints what it would do (safe preview)."""
    if not path.exists():
        print(f"[aq-agent-reap] no registry at {path}")
        return 0
    active = _dispatch_active()
    if active and not dry_run and not force:
        print(f"[aq-agent-reap] {active} active dispatch proc(s) — refusing live registry "
              "rewrite (would race concurrent appends). Showing preview; use --force to "
              "write anyway, or run when quiescent.")
        dry_run = True
    now = datetime.now(timezone.utc).timestamp()
    lines = path.read_text(encoding="utf-8").splitlines()
    out: List[str] = []
    changed = 0
    for line in lines:
        s = line.strip()
        if not s:
            continue
        try:
            rec = json.loads(s)
        except json.JSONDecodeError:
            out.append(line)               # preserve anything unparseable verbatim
            continue
        orphan, reason = should_orphan_row(rec, now, age_s)
        if orphan:
            action = "WOULD ORPHAN" if dry_run else "ORPHANING"
            print(f"[aq-agent-reap] {action} registry row {rec.get('agent','?')} "
                  f"{rec.get('id','')} — {reason}")
            if not dry_run:
                rec["status"] = "orphaned"
                rec["orphaned_at"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
                rec["orphaned_by"] = "aq-agent-reap"
            changed += 1
        out.append(json.dumps(rec))
    if changed and not dry_run:
        with tempfile.NamedTemporaryFile("w", encoding="utf-8", dir=str(path.parent),
                                         delete=False, suffix=".tmp") as fh:
            fh.write("\n".join(out) + "\n")
            tmp = fh.name
        os.replace(tmp, path)
    if changed == 0:
        print("[aq-agent-reap] registry clean — no stale running rows to reconcile")
    return changed


def should_reap(ppid: int, etimes: int, max_age: int) -> tuple[bool, str]:
    """Pure decision: reap an aq-agent-loop process? Returns (reap, reason)."""
    if ppid == 1:
        return True, "orphaned (ppid=1, dispatcher died)"
    if etimes > max_age:
        return True, f"runaway (age {etimes}s > max_age {max_age}s)"
    return False, ""


def progress_recent(cmd: str, grace: float = 300.0) -> bool:
    """True if the proc is still making progress (its AGENT_PROGRESS_FILE was written within
    `grace`). A working ORPHAN (ppid=1 but streaming) must NOT be reaped — only a wedged one.
    Progress file = the run's --output path + '.progress.json'."""
    import re
    import time as _t
    m = re.search(r"--output\s+(\S+)", cmd)
    if not m:
        return False
    prog = m.group(1) + ".progress.json"
    try:
        return (_t.time() - os.path.getmtime(prog)) < grace
    except OSError:
        return False


def _list_agent_procs() -> List[Dict]:
    """List running aq-agent-loop processes (pid, ppid, etimes, cmd)."""
    out = subprocess.run(
        ["ps", "-eo", "pid=,ppid=,etimes=,args="],
        capture_output=True, text=True,
    ).stdout
    procs: List[Dict] = []
    for line in out.splitlines():
        parts = line.split(None, 3)
        if len(parts) < 4:
            continue
        pid, ppid, etimes, cmd = parts
        if AGENT_MATCH not in cmd:
            continue
        # Exclude this reaper itself and any grep/ps wrapper.
        if "aq-agent-reap" in cmd:
            continue
        try:
            procs.append({"pid": int(pid), "ppid": int(ppid),
                          "etimes": int(etimes), "cmd": cmd})
        except ValueError:
            continue
    return procs


def _kill(pid: int) -> None:
    """Kill the process group if possible, else the process."""
    try:
        os.killpg(os.getpgid(pid), signal.SIGKILL)
    except Exception:
        try:
            os.kill(pid, signal.SIGKILL)
        except Exception:
            pass


def main() -> int:
    ap = argparse.ArgumentParser(description=__doc__)
    ap.add_argument("--max-age", type=int,
                    default=int(os.environ.get("AGENT_REAP_MAX_AGE", "3600")))
    ap.add_argument("--reconcile-registry", action="store_true",
                    help="also mark stale status=running rows (dead pid, aged) as orphaned")
    ap.add_argument("--registry-age", type=int,
                    default=int(os.environ.get("AQ_REAP_REGISTRY_AGE_S", "1800")),
                    help="min age (s) before a dead-pid running row is orphaned (default 1800)")
    ap.add_argument("--registry-only", action="store_true",
                    help="skip process reaping; run only the registry reconciliation pass")
    ap.add_argument("--force", action="store_true",
                    help="write the registry even while dispatch is active (races appends)")
    ap.add_argument("--dry-run", action="store_true")
    args = ap.parse_args()

    if args.reconcile_registry or args.registry_only:
        reconcile_registry(REGISTRY, args.registry_age, args.dry_run, force=args.force)
    if args.registry_only:
        return 0

    reaped = 0
    for p in _list_agent_procs():
        reap, reason = should_reap(p["ppid"], p["etimes"], args.max_age)
        if not reap:
            continue
        # A WORKING orphan (ppid=1 but still streaming its progress file) is a legit detached
        # run — never reap it. Only wedged orphans (no recent progress) or runaways get killed.
        if reason.startswith("orphaned") and progress_recent(p["cmd"]):
            continue
        action = "WOULD REAP" if args.dry_run else "REAPING"
        print(f"[aq-agent-reap] {action} pid={p['pid']} ppid={p['ppid']} "
              f"age={p['etimes']}s — {reason}")
        if not args.dry_run:
            _kill(p["pid"])
            reaped += 1

    if reaped == 0 and not args.dry_run:
        print("[aq-agent-reap] no orphaned/runaway aq-agent-loop processes")
    return 0


if __name__ == "__main__":
    sys.exit(main())
