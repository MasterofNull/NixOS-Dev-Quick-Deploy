#!/usr/bin/env python3
"""aq-agent-reap — kill orphaned/wedged aq-agent-loop processes holding the llama slot.

The self-watchdog inside aq-agent-loop stops NEW orphans from lingering (it self-exits
when reparented to init). This reaper cleans up any that predate the watchdog or slip
through, and is safe to run from cron / a systemd timer.

An aq-agent-loop process is reaped when:
  - it is ORPHANED — ppid == 1 (its dispatcher died), OR
  - its wall-clock exceeds --max-age (default 3600s) — runaway/wedged.

Kills the whole process group (dispatch spawns with start_new_session=True) so any
children go too. Dry-run by default is off; pass --dry-run to preview.

Usage:
  aq-agent-reap [--max-age SECONDS] [--dry-run]
"""
from __future__ import annotations

import argparse
import os
import signal
import subprocess
import sys
from typing import List, Dict


AGENT_MATCH = "scripts/ai/aq-agent-loop"


def should_reap(ppid: int, etimes: int, max_age: int) -> tuple[bool, str]:
    """Pure decision: reap an aq-agent-loop process? Returns (reap, reason)."""
    if ppid == 1:
        return True, "orphaned (ppid=1, dispatcher died)"
    if etimes > max_age:
        return True, f"runaway (age {etimes}s > max_age {max_age}s)"
    return False, ""


def _list_agent_procs() -> List[Dict]:
    """List running aq-agent-loop processes (pid, ppid, etimes, cmd)."""
    out = subprocess.run(
        ["ps", "-eo", "pid=,ppid=,etimes=,args="],
        capture_output=True, text=True,
    ).stdout
    procs: List[Dict] = []
    for line in out.splitlines():
        parts = line.split(None, 3)
        if len(parts) < 4:
            continue
        pid, ppid, etimes, cmd = parts
        if AGENT_MATCH not in cmd:
            continue
        # Exclude this reaper itself and any grep/ps wrapper.
        if "aq-agent-reap" in cmd:
            continue
        try:
            procs.append({"pid": int(pid), "ppid": int(ppid),
                          "etimes": int(etimes), "cmd": cmd})
        except ValueError:
            continue
    return procs


def _kill(pid: int) -> None:
    """Kill the process group if possible, else the process."""
    try:
        os.killpg(os.getpgid(pid), signal.SIGKILL)
    except Exception:
        try:
            os.kill(pid, signal.SIGKILL)
        except Exception:
            pass


def main() -> int:
    ap = argparse.ArgumentParser(description=__doc__)
    ap.add_argument("--max-age", type=int,
                    default=int(os.environ.get("AGENT_REAP_MAX_AGE", "3600")))
    ap.add_argument("--dry-run", action="store_true")
    args = ap.parse_args()

    reaped = 0
    for p in _list_agent_procs():
        reap, reason = should_reap(p["ppid"], p["etimes"], args.max_age)
        if not reap:
            continue
        action = "WOULD REAP" if args.dry_run else "REAPING"
        print(f"[aq-agent-reap] {action} pid={p['pid']} ppid={p['ppid']} "
              f"age={p['etimes']}s — {reason}")
        if not args.dry_run:
            _kill(p["pid"])
            reaped += 1

    if reaped == 0 and not args.dry_run:
        print("[aq-agent-reap] no orphaned/runaway aq-agent-loop processes")
    return 0


if __name__ == "__main__":
    sys.exit(main())
