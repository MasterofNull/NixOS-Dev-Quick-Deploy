_AIDB_KEY_FILE = os.environ.get("AIDB_API_KEY_FILE", "/run/secrets/aidb_api_key")
_AIDB_PROJECT = "wiki-sections"
# Dedicated Qdrant collection for targeted wiki retrieval. POST /documents always
# vectorizes into the shared 'knowledge' collection (server default), so a named
# 'wiki-sections' collection — declared in AIDB ALLOWED_COLLECTIONS and expected by
# collection-scoped queries — must be created + populated directly here (embed via
# AIDB /vector/embed, upsert to Qdrant). Mirrors the archive_collaboration workaround.
_QDRANT_URL = os.environ.get("QDRANT_URL", "http://127.0.0.1:6333").rstrip("/")
_WIKI_COLLECTION = "wiki-sections"
_EMBED_DIM = int(os.environ.get("AIDB_EMBEDDING_DIMENSION", "1024"))


