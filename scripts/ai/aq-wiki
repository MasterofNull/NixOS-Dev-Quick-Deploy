# ── helpers ──────────────────────────────────────────────────────────────────

def _load_graph():
    if not _GRAPH.exists():
        sys.exit(
            f"Knowledge graph not found: {_GRAPH}\n"
            "Run: scripts/ai/aq-understand-anything ensure\n"
            "Then: /understand  (in Claude Code)  or  aq-understand-anything validate-batches"
        )
    with open(_GRAPH, "rb") as f:
        return json.loads(f.read())


def _load_meta() -> dict:
    if _WIKI_META.exists():
        try:
            return json.loads(_WIKI_META.read_text())
        except Exception:
            pass
    return {}


def _save_meta(meta: dict):
    _WIKI_DIR.mkdir(parents=True, exist_ok=True)
    _WIKI_META.write_text(json.dumps(meta, indent=2))


def _git_changed_paths_since(since_ts: str) -> set:
    """Return set of file paths changed since ISO timestamp (git log)."""
    try:
        result = subprocess.run(
            ["git", "-C", str(_REPO), "log", "--name-only", "--pretty=format:",
             f"--since={since_ts}"],
            capture_output=True, text=True, timeout=15,
        )
        return {line.strip() for line in result.stdout.splitlines() if line.strip()}
    except Exception:
        return set()


def _nodes_for_subsystem(nodes: list, prefix: str) -> list:
    return [n for n in nodes if (n.get("filePath") or "").startswith(prefix)]


def _complexity_key(n: dict) -> int:
    return {"complex": 0, "medium": 1, "moderate": 1, "simple": 2}.get(
        n.get("complexity", "simple"), 3
    )


# ── rendering ─────────────────────────────────────────────────────────────────

def _render_section(name: str, info: dict, nodes: list, graph_meta: dict) -> str:
    now = datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")

    files = sorted([n for n in nodes if n.get("type") == "file"], key=_complexity_key)
    funcs = sorted(
        [n for n in nodes if n.get("type") in ("function", "function:")],
        key=_complexity_key,
    )
    classes = sorted([n for n in nodes if n.get("type") == "class"], key=_complexity_key)

    title = name.replace("-", " ").title()

    out = [
        "---",
        "doc_type: reference",
        f'title: "Wiki: {title}"',
        f"subsystem: {name}",
        f"generated: {now}",
        f"graph_generated: {graph_meta.get('generated', 'unknown')}",
        f"graph_nodes: {len(nodes)}",
        "---",
        "",
        f"# {title}",
        "",
        f"> {info['desc']}",
        "",
        "*Auto-generated from `knowledge-graph.json`. Do not edit manually.*  ",
        "*Refresh: `aq-wiki --update`  ·  Full regeneration: `aq-wiki --init --force`*",
        "",
    ]

    # Key files
    if files:
        out += [
            "## Key Files",
            "",
            "| File | Summary | Complexity |",
            "|------|---------|------------|",
        ]
        for f in files[:25]:
            fname = f.get("name") or Path(f.get("filePath", "?")).name
            summary = (f.get("summary") or "—").strip().replace("|", "\\|")[:90]
            cplx = f.get("complexity", "?")
            out.append(f"| `{fname}` | {summary} | {cplx} |")
        out.append("")

    # Public functions / entry points (complex ones first)
    if funcs:
        out += [
            "## Key Functions",
            "",
            "| Function | File | Summary |",
            "|----------|------|---------|",
        ]
        for fn in funcs[:20]:
            fname = fn.get("name", "?")
            ffile = Path(fn.get("filePath", "?")).name
            summary = (fn.get("summary") or "—").strip().replace("|", "\\|")[:90]
            out.append(f"| `{fname}` | `{ffile}` | {summary} |")
        out.append("")

    # Classes
    if classes:
        out += [
            "## Classes",
            "",
            "| Class | File | Summary |",
            "|-------|------|---------|",
        ]
        for cl in classes[:15]:
            cname = cl.get("name", "?")
            cfile = Path(cl.get("filePath", "?")).name
            summary = (cl.get("summary") or "—").strip().replace("|", "\\|")[:90]
            out.append(f"| `{cname}` | `{cfile}` | {summary} |")
        out.append("")

    # Related docs
    related = info.get("related_docs", [])
    if related:
        out += ["## Related Documentation", ""]
        for doc in related:
            out.append(f"- `{doc}`")
        out.append("")

    # Coverage
    out += [
        "## Coverage",
        "",
        f"- **Nodes**: {len(nodes)} total "
        f"({len(files)} files, {len(funcs)} functions, {len(classes)} classes)",
        f"- **Path prefix**: `{info['prefix']}/`",
        f"- **Graph**: `.understand-anything/knowledge-graph.json`"
        f"  (generated {graph_meta.get('generated', '?')})",
        "",
    ]

    return "\n".join(out)


def _write_index(wiki_meta: dict, graph_meta: dict):
    """Write wiki/README.md — the navigation entry point for agents."""
    now = datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")
    lines = [
        "# Codebase Wiki — Navigation Index",
        "",
        f"Auto-generated from `knowledge-graph.json` ({graph_meta.get('generated', now)}).  ",
        "**Do not edit manually.** Refresh: `aq-wiki --update`",
        "",
        "## Quick Reference",
        "",
        "```bash",
        "aq-wiki --section <name>    # print a section",
        "aq-wiki --status            # freshness check",
        "aq-wiki --update            # differential refresh after code changes",
        "aq-wiki --seed-aidb         # push to AIDB for semantic search",
        "```",
        "",
        "## Subsystem Sections",
        "",
        "| Section | Nodes | Description |",
        "|---------|-------|-------------|",
    ]
    for name, info in SUBSYSTEMS.items():
        rec = wiki_meta.get(name, {})
        nc = rec.get("node_count", "—")
        lines.append(f"| [`{name}`]({name}.md) | {nc} | {info['desc']} |")

    lines += [
        "",
        "## Agent Usage Pattern (OpenWiki-style)",
        "",
        "Agents load wiki sections **on demand by path** — not embedded in context:",
        "",
        "```bash",
        "# Before architecture work on the coordinator:",
        "cat .understand-anything/wiki/hybrid-coordinator.md",
        "",
        "# Before switchboard profile changes:",
        "aq-wiki --section switchboard",
        "",
        "# Before NixOS module work:",
        "aq-wiki --section nix-modules",
        "",
        "# Before delegation script changes:",
        "aq-wiki --section ai-scripts",
        "```",
        "",
        "## Progressive Disclosure Integration",
        "",
        "Wiki sections are wired into `config/progressive-disclosure-domains.json`.",
        "At `standard` and `full` disclosure levels, the relevant wiki section is",
        "automatically referenced in domain context. Agents can also query AIDB:",
        "",
        "```bash",
        "# Semantic search across wiki sections (after --seed-aidb):",
        "aq-hints 'how does switchboard route requests' --source wiki-sections",
        "```",
        "",
    ]

    (_WIKI_DIR / "README.md").write_text("\n".join(lines))


# ── commands ──────────────────────────────────────────────────────────────────

def cmd_init(force: bool = False):
    graph = _load_graph()
    nodes = graph.get("nodes", [])
    graph_meta = graph.get("metadata", {})

    _WIKI_DIR.mkdir(parents=True, exist_ok=True)
    wiki_meta = _load_meta()
    generated = []

    for name, info in SUBSYSTEMS.items():
        out_path = _WIKI_DIR / f"{name}.md"
        if out_path.exists() and not force:
            rec = wiki_meta.get(name, {})
            if rec.get("graph_generated") == graph_meta.get("generated"):
                print(f"  skip  {name:<25}  (up to date)")
                continue

        sub_nodes = _nodes_for_subsystem(nodes, info["prefix"])
        if not sub_nodes:
            print(f"  skip  {name:<25}  (0 nodes for prefix '{info['prefix']}')")
            continue

        content = _render_section(name, info, sub_nodes, graph_meta)
        out_path.write_text(content)
        wiki_meta[name] = {
            "graph_generated": graph_meta.get("generated", "?"),
            "node_count": len(sub_nodes),
            "generated": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
        }
        print(f"  wrote {name:<25}  ({len(sub_nodes):4d} nodes,  {len(content):6d} chars)")
        generated.append(name)

    _write_index(wiki_meta, graph_meta)
    _save_meta(wiki_meta)

    print(f"\n{len(generated)} sections → .understand-anything/wiki/")
    if generated:
        print("Next: aq-wiki --seed-aidb   (push to AIDB for semantic search)")


def cmd_update():
    graph = _load_graph()
    nodes = graph.get("nodes", [])
    graph_meta = graph.get("metadata", {})

    wiki_meta = _load_meta()
    if not wiki_meta:
        print("No previous wiki run — running full init.")
        cmd_init()
        return

    last_gen = min(
        (v["generated"] for v in wiki_meta.values() if v.get("generated")),
        default="",
    )
    if not last_gen:
        cmd_init()
        return

    changed = _git_changed_paths_since(last_gen)
    if not changed:
        print(f"No git changes since {last_gen}. Wiki is current.")
        return

    print(f"Git changes since {last_gen}: {len(changed)} paths")

    updated = []
    for name, info in SUBSYSTEMS.items():
        prefix = info["prefix"]
        if not any(p.startswith(prefix) for p in changed):
            # Also refresh if graph itself is newer than section
            rec = wiki_meta.get(name, {})
            if rec.get("graph_generated") == graph_meta.get("generated"):
                continue

        sub_nodes = _nodes_for_subsystem(nodes, prefix)
        if not sub_nodes:
            continue

        out_path = _WIKI_DIR / f"{name}.md"
        content = _render_section(name, info, sub_nodes, graph_meta)
        out_path.write_text(content)
        wiki_meta[name] = {
            "graph_generated": graph_meta.get("generated", "?"),
            "node_count": len(sub_nodes),
            "generated": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
        }
        print(f"  updated {name}")
        updated.append(name)

    if updated:
        _write_index(wiki_meta, graph_meta)
        _save_meta(wiki_meta)
        print(f"\nUpdated: {', '.join(updated)}")
    else:
        print("No sections needed update.")


def cmd_status():
    graph = _load_graph()
    graph_meta = graph.get("metadata", {})
    wiki_meta = _load_meta()

    print(f"Knowledge graph: {graph_meta.get('generated', 'unknown')}")
    print(f"  Nodes: {len(graph.get('nodes', []))}, Edges: {len(graph.get('edges', []))}")
    print(f"\nWiki (.understand-anything/wiki/):")
    print(f"  {'Section':<28} {'Nodes':>6}  {'Generated':<22}  Status")
    print("  " + "-" * 70)

    for name, info in SUBSYSTEMS.items():
        rec = wiki_meta.get(name, {})
        path = _WIKI_DIR / f"{name}.md"
        nc = str(rec.get("node_count", "—")) if rec else "—"
        gen = rec.get("generated", "—")[:19] if rec else "—"
        if not path.exists():
            status = "MISSING — run: aq-wiki --init"
        elif rec.get("graph_generated") != graph_meta.get("generated"):
            status = "STALE — run: aq-wiki --update"
        else:
            status = "OK"
        print(f"  {name:<28} {nc:>6}  {gen:<22}  {status}")

    readme = _WIKI_DIR / "README.md"
    print(f"\n  Index: {'present' if readme.exists() else 'MISSING'} ({readme})")
    print(f"\nRefresh: aq-wiki --update  (diff)  |  aq-wiki --init --force  (full)")


def cmd_list():
    if not _WIKI_DIR.exists():
        print("No wiki sections yet. Run: aq-wiki --init")
        return
    sections = sorted(p for p in _WIKI_DIR.glob("*.md") if p.stem != "README")
    if not sections:
        print("No wiki sections found. Run: aq-wiki --init")
        return
    print("Available wiki sections:")
    for path in sections:
        lc = len(path.read_text().splitlines())
        info = SUBSYSTEMS.get(path.stem, {})
        desc = info.get("desc", "")[:60]
        print(f"  {path.stem:<28}  ({lc:3d} lines)  {desc}")


def cmd_section(name: str):
    path = _WIKI_DIR / f"{name}.md"
    if not path.exists():
        candidates = [p for p in _WIKI_DIR.glob("*.md") if name.lower() in p.stem.lower()]
        if len(candidates) == 1:
            path = candidates[0]
        else:
            available = [p.stem for p in _WIKI_DIR.glob("*.md") if p.stem != "README"]
            sys.exit(
                f"Wiki section not found: {name}\n"
                f"Available: {', '.join(sorted(available))}\n"
                f"Hint: run 'aq-wiki --init' if wiki hasn't been generated yet."
            )
    sys.stdout.write(path.read_text())


def _embed_via_aidb(text: str, key: str) -> list:
    """Embed text through AIDB /vector/embed (1024-dim, same model as knowledge).

    Truncate to ~512 tokens (~1200 chars) — the embed server 500s on longer input.
    Matches the server's own _vectorize_doc_to_qdrant convention (server.py:3043).
    """
    payload = json.dumps({"texts": [text[:1200]]}).encode()
    req = urllib.request.Request(
        f"{_AIDB_URL}/vector/embed",
        data=payload,
        headers={"Content-Type": "application/json", "X-API-Key": key},
        method="POST",
    )
    with urllib.request.urlopen(req, timeout=30) as resp:
        data = json.loads(resp.read())
    embs = data.get("embeddings") or data.get("vectors") or []
    if not embs:
        raise ValueError("embed returned no vector")
    return embs[0]


def _ensure_wiki_collection() -> bool:
    """Create the wiki-sections Qdrant collection if absent (mirrors knowledge: 1024/Cosine)."""
    try:
        req = urllib.request.Request(f"{_QDRANT_URL}/collections/{_WIKI_COLLECTION}", method="GET")
        with urllib.request.urlopen(req, timeout=8) as resp:
            if resp.status == 200:
                return True
    except urllib.error.HTTPError as exc:
        if exc.code != 404:
            print(f"  WARN: collection probe HTTP {exc.code}")
    except Exception as exc:
        print(f"  WARN: Qdrant unreachable at {_QDRANT_URL}: {exc}")
        return False
    body = json.dumps({"vectors": {"size": _EMBED_DIM, "distance": "Cosine"}}).encode()
    req = urllib.request.Request(
        f"{_QDRANT_URL}/collections/{_WIKI_COLLECTION}",
        data=body, headers={"Content-Type": "application/json"}, method="PUT",
    )
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            ok = resp.status in (200, 201)
            print(f"  {'CREATED' if ok else 'WARN'} Qdrant collection '{_WIKI_COLLECTION}' [{resp.status}]")
            return ok
    except Exception as exc:
        print(f"  WARN: could not create collection '{_WIKI_COLLECTION}': {exc}")
        return False


def _upsert_wiki_point(name: str, content: str, rel_path: str, info: dict, key: str) -> bool:
    """Embed a section and upsert it as a point into the wiki-sections Qdrant collection."""
    import hashlib
    vector = _embed_via_aidb(f"wiki: {name}\n\n{content}", key)
    point_id = int(hashlib.md5(rel_path.encode()).hexdigest()[:8], 16)
    payload = {
        "project": _AIDB_PROJECT, "title": f"wiki: {name}", "subsystem": name,
        "relative_path": rel_path, "content": content[:4000],
        "description": info.get("desc", ""), "type": "wiki-section",
    }
    body = json.dumps({"points": [{"id": point_id, "vector": vector, "payload": payload}]}).encode()
    req = urllib.request.Request(
        f"{_QDRANT_URL}/collections/{_WIKI_COLLECTION}/points?wait=true",
        data=body, headers={"Content-Type": "application/json"}, method="PUT",
    )
    with urllib.request.urlopen(req, timeout=15) as resp:
        return resp.status < 300


def cmd_seed_aidb():
    if not _WIKI_DIR.exists():
        sys.exit("No wiki sections. Run: aq-wiki --init")

    key = _aidb_key()
    if not key:
        sys.exit(
            f"No AIDB API key found at {_AIDB_KEY_FILE} and AIDB_API_KEY env is unset.\n"
            "Ensure the AIDB secret is provisioned before seeding."
        )

    # Ensure the dedicated wiki-sections Qdrant collection exists for targeted retrieval.
    coll_ready = _ensure_wiki_collection()
    seeded = failed = coll_upserts = 0
    for path in sorted(_WIKI_DIR.glob("*.md")):
        if path.stem == "README":
            continue
        name = path.stem
        info = SUBSYSTEMS.get(name, {})
        rel_path = str(path.relative_to(_REPO))
        doc = {
            "content": path.read_text(),
            "project": _AIDB_PROJECT,
            "relative_path": rel_path,
            "title": f"wiki: {name}",
            "metadata": {
                "subsystem": name,
                "description": info.get("desc", ""),
                "type": "wiki-section",
                "prefix": info.get("prefix", ""),
            },
        }
        try:
            payload = json.dumps(doc).encode()
            req = urllib.request.Request(
                f"{_AIDB_URL}/documents",
                data=payload,
                headers={
                    "Content-Type": "application/json",
                    "X-API-Key": key,
                },
                method="POST",
            )
            with urllib.request.urlopen(req, timeout=15) as resp:
                ok = resp.status in (200, 201)
                print(f"  {'OK' if ok else 'WARN'} {name} [{resp.status}]")
                seeded += 1
        except urllib.error.HTTPError as exc:
            body = ""
            try:
                body = exc.read().decode(errors="replace")[:200]
            except Exception:
                pass
            print(f"  FAIL {name}: HTTP {exc.code} — {body}")
            failed += 1
        except Exception as exc:
            print(f"  FAIL {name}: {exc}")
            failed += 1

        # Also upsert into the dedicated wiki-sections Qdrant collection (targeted retrieval).
        if coll_ready:
            try:
                if _upsert_wiki_point(name, path.read_text(), rel_path, info, key):
                    coll_upserts += 1
            except Exception as exc:
                print(f"  WARN {name}: wiki-sections upsert failed: {exc}")

    print(f"\nSeeded {seeded} sections to AIDB (knowledge), {failed} failed.")
    print(f"Upserted {coll_upserts}/{seeded} into dedicated '{_WIKI_COLLECTION}' Qdrant collection.")
    if failed:
        print("HINT: Ensure AIDB is running at", _AIDB_URL)


# ── main ──────────────────────────────────────────────────────────────────────

def main():
    p = argparse.ArgumentParser(
        prog="aq-wiki",
        description=(
            "OpenWiki-pattern structured wiki from knowledge-graph.json.\n"
            "Generates .understand-anything/wiki/<subsystem>.md for agent reference."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  aq-wiki --init                    # first-time generation\n"
            "  aq-wiki --update                  # after code changes\n"
            "  aq-wiki --section hybrid-coordinator  # read a section\n"
            "  aq-wiki --status                  # freshness check\n"
            "  aq-wiki --seed-aidb               # push to AIDB\n"
        ),
    )
    g = p.add_mutually_exclusive_group()
    g.add_argument("--init", action="store_true",
                   help="Full wiki generation from knowledge graph")
    g.add_argument("--update", action="store_true",
                   help="Differential update (recent git changes only)")
    g.add_argument("--status", action="store_true",
                   help="Show wiki freshness and coverage")
    g.add_argument("--list", action="store_true",
                   help="List available wiki sections")
    g.add_argument("--section", metavar="NAME",
                   help="Print a specific wiki section to stdout")
    g.add_argument("--seed-aidb", action="store_true",
                   help="Seed wiki sections into AIDB wiki-sections collection")
    p.add_argument("--force", action="store_true",
                   help="Force regeneration (use with --init)")
    args = p.parse_args()

    if args.init:
        cmd_init(force=args.force)
    elif args.update:
        cmd_update()
    elif args.status:
        cmd_status()
    elif args.list:
        cmd_list()
    elif args.section:
        cmd_section(args.section)
    elif args.seed_aidb:
        cmd_seed_aidb()
    else:
        p.print_help()


if __name__ == "__main__":
    main()
