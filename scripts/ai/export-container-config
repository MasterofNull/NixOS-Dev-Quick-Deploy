distribution=$(. /etc/os-release;echo $ID$VERSION_ID)
curl -s -L https://nvidia.github.io/nvidia-docker/gpgkey | sudo apt-key add -
curl -s -L https://nvidia.github.io/nvidia-docker/$distribution/nvidia-docker.list | \
  sudo tee /etc/apt/sources.list.d/nvidia-docker.list
sudo apt-get update && sudo apt-get install -y nvidia-container-toolkit
sudo systemctl restart docker
```
EOF
            ;;
        vulkan)
            cat >> "$output" << 'EOF'
This configuration uses **Vulkan** for GPU acceleration.

### Requirements
- AMD or Intel GPU with Vulkan support
- Mesa Vulkan drivers installed
- /dev/dri device access

### Verification
```bash
# Check Vulkan support
vulkaninfo --summary
```
EOF
            ;;
        cpu)
            cat >> "$output" << 'EOF'
This configuration uses **CPU-only** inference.

No GPU drivers required. Performance will be limited compared to GPU acceleration.
Consider adding GPU support for better performance.
EOF
            ;;
    esac

    cat >> "$output" << 'EOF'

## Configuration

Edit `ai-stack.env` to customize:
- Model paths
- Port numbers
- Performance tuning
- GPU device selection

## Troubleshooting

### Check service status
```bash
docker-compose ps
docker-compose logs llama-server
```

### Verify GPU access
```bash
docker-compose exec llama-server nvidia-smi  # CUDA
docker-compose exec llama-server vulkaninfo   # Vulkan
```

## Generated From

This configuration was exported from NixOS-Dev-Quick-Deploy.
Source: https://github.com/your-repo/NixOS-Dev-Quick-Deploy
EOF

    log_success "Generated: $output"
}

# Main
main() {
    log_info "AI Stack Container Configuration Exporter"
    log_info "─────────────────────────────────────────"

    # Auto-detect GPU if needed
    if [[ "$GPU_VENDOR" == "auto" ]]; then
        GPU_VENDOR=$(detect_gpu_vendor)
        log_info "Detected GPU vendor: $GPU_VENDOR"
    fi

    # Resolve accelerator
    ACCELERATOR=$(resolve_accelerator "$GPU_VENDOR" "$ACCELERATOR")
    log_info "Using accelerator: $ACCELERATOR"

    # Create output directory
    mkdir -p "$OUTPUT_DIR"
    log_info "Output directory: $OUTPUT_DIR"

    # Generate files
    if [[ "$OUTPUT_FORMAT" == "env" || "$OUTPUT_FORMAT" == "both" ]]; then
        generate_env_file "$ACCELERATOR" "$GPU_VENDOR" "$OUTPUT_DIR/ai-stack.env"
    fi

    if [[ "$OUTPUT_FORMAT" == "compose" || "$OUTPUT_FORMAT" == "both" ]]; then
        generate_compose_file "$ACCELERATOR" "$GPU_VENDOR" "$OUTPUT_DIR/docker-compose.yml"
    fi

    generate_readme "$ACCELERATOR" "$GPU_VENDOR" "$OUTPUT_DIR/README.md"

    log_info "─────────────────────────────────────────"
    log_success "Container configuration exported to: $OUTPUT_DIR"
    log_info ""
    log_info "Next steps:"
    log_info "  1. Review and customize $OUTPUT_DIR/ai-stack.env"
    log_info "  2. Place model files in $MODELS_DIR"
    log_info "  3. cd $OUTPUT_DIR && docker-compose up -d"
}

main "$@"
