            "nix/modules/services/switchboard.nix",
        ],
        "acceptance": [
            "Execution loop surfaces aq-qa 0 --json before runtime-heavy work.",
            "Validation loop keeps tier0 gate and qa explicit before commit.",
        ],
    },
    {
        "id": "remote-task-schema",
        "goal": "Make remote delegation requests use a compact, explicit task contract.",
        "repo_paths": [
