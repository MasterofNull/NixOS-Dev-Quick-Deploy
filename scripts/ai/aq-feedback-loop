#!/usr/bin/env python3
"""
aq-feedback-loop - Turn agent feedback into a bounded harness execution loop.

This tool packages the existing harness primitives into one operator-facing loop:
PRD -> plan -> memory checkpoint -> execution -> validation -> commit.
"""

from __future__ import annotations

import argparse
import json
import subprocess
import textwrap
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parent.parent.parent
CONTEXT_BOOTSTRAP = REPO_ROOT / "scripts" / "ai" / "aq-context-bootstrap"
DEFAULT_PRD_PATH = "docs/development/LOCAL-AGENT-FEEDBACK-EXECUTION-LOOP-PRD-2026-05.md"
DEFAULT_PLAN_PATH = ".agents/plans/phase-29-feedback-driven-agent-loop.md"

WORKSTREAMS = [
    {
