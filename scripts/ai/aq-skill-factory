#!/usr/bin/env python3
# aq-skill-factory — Phase 89.5 PAEA Skill Factory
#
# Reads gap_patterns from training_ingest (delegation feedback analysis) and
# generates draft skill stubs in .agent/skills/auto-generated/ for human review.
#
# High-frequency gap patterns (>= MIN_COUNT occurrences) become skill candidates.
# Stubs are NOT active until manually reviewed and promoted to .agent/skills/<name>/.
#
# Usage:
#   aq-skill-factory                # generate stubs from last 168h
#   aq-skill-factory --dry-run      # show candidates without writing
#   aq-skill-factory --hours 72     # narrow window
#   aq-skill-factory --min-count 5  # raise frequency threshold
#   aq-skill-factory --list         # list existing auto-generated stubs

import argparse
import json
import re
import sys
import textwrap
from datetime import datetime, timezone
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[2]
AUTO_SKILLS_DIR = REPO_ROOT / ".agent" / "skills" / "auto-generated"
TRAINING_INGEST = REPO_ROOT / "ai-stack" / "local-agents" / "training_ingest.py"

DEFAULT_HOURS = 168
DEFAULT_MIN_COUNT = 3


def _slug(text: str) -> str:
    """Convert pattern text to a filesystem-safe slug."""
    slug = re.sub(r"[^a-z0-9]+", "-", text.lower().strip())
    slug = slug.strip("-")
    return slug[:60]


def _load_gap_patterns(hours: int) -> list:
    """Run training_ingest dry-run and return gap_patterns."""
    sys.path.insert(0, str(REPO_ROOT / "ai-stack" / "local-agents"))
    try:
        from training_ingest import TrainingIngestor  # type: ignore
    except ImportError as exc:
        print(f"ERROR: cannot import training_ingest: {exc}", file=sys.stderr)
        sys.exit(1)

    report = TrainingIngestor(dry_run=True).run(hours=hours)
    return report.get("gap_patterns", [])


def _generate_stub(gap: dict, slug: str) -> str:
    """Generate a SKILL.md stub from a gap_pattern entry."""
    pattern = gap.get("pattern", "")
    count = gap.get("count", 0)
    example = gap.get("example_task", "")
    failure_class = gap.get("failure_class", "unknown")
    ts = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

    return textwrap.dedent(f"""\
        ---
        # AUTO-GENERATED SKILL STUB — requires human review before promotion
        # Source: training_ingest gap_patterns analysis
        # Generated: {ts}
        # Pattern count: {count}
        # Failure class: {failure_class}
        # Status: DRAFT — do not use until reviewed and promoted
        ---

        # Skill: {slug}

        ## Origin
        Auto-generated from delegation feedback gap pattern (count={count}).
        Failure class: `{failure_class}`

        ## Problem Pattern
        {pattern}

        ## Example Task (where this gap was observed)
        ```
        {example}
        ```

        ## When to Use
        <!-- TODO: Fill in when this skill should be applied -->

        ## Guidance
        <!-- TODO: Fill in the actual skill guidance based on the pattern above -->

        ## References
        - Generated by `aq-skill-factory` from `training_ingest.py` gap analysis
        - Review and promote to `.agent/skills/{slug}/SKILL.md` when ready
        """)


def cmd_list() -> None:
    """List existing auto-generated skill stubs."""
    if not AUTO_SKILLS_DIR.exists():
        print("No auto-generated stubs yet.")
        return
    stubs = sorted(AUTO_SKILLS_DIR.glob("*/SKILL.md"))
    if not stubs:
        print("No auto-generated stubs yet.")
        return
    print(f"Auto-generated skill stubs ({len(stubs)}):")
    for stub in stubs:
        slug = stub.parent.name
        # Read first line with 'count'
        try:
            for line in stub.read_text().splitlines():
                if "Pattern count:" in line:
                    count = line.split(":", 1)[1].strip()
                    print(f"  {slug}  (count={count})")
                    break
            else:
                print(f"  {slug}")
        except OSError:
            print(f"  {slug}")


def cmd_generate(hours: int, min_count: int, dry_run: bool) -> None:
    """Generate skill stubs from gap_patterns."""
    print(f"Loading gap patterns (window={hours}h, min_count={min_count})...")
    gaps = _load_gap_patterns(hours)

    if not gaps:
        print("No gap patterns found in training data.")
        return

    candidates = [g for g in gaps if g.get("count", 0) >= min_count]
    print(f"Gap patterns total: {len(gaps)}, qualifying (>={min_count}): {len(candidates)}")

    if not candidates:
        print(f"No patterns meet min_count={min_count}. Highest count: {max(g.get('count',0) for g in gaps)}")
        return

    created = 0
    skipped = 0
    for gap in candidates:
        pattern = gap.get("pattern", "")
        if not pattern:
            continue
        slug = _slug(pattern)
        if not slug:
            continue

        stub_path = AUTO_SKILLS_DIR / slug / "SKILL.md"
        stub_content = _generate_stub(gap, slug)

        if dry_run:
            print(f"\n[DRY-RUN] Would create: .agent/skills/auto-generated/{slug}/SKILL.md")
            print(f"  pattern: {pattern[:80]}")
            print(f"  count: {gap.get('count')}, failure_class: {gap.get('failure_class')}")
            created += 1
            continue

        if stub_path.exists():
            print(f"  SKIP (exists): {slug}")
            skipped += 1
            continue

        stub_path.parent.mkdir(parents=True, exist_ok=True)
        stub_path.write_text(stub_content, encoding="utf-8")
        print(f"  CREATED: .agent/skills/auto-generated/{slug}/SKILL.md  (count={gap.get('count')})")
        created += 1

    if dry_run:
        print(f"\nDry-run complete: {created} candidate(s) would be generated.")
        print("Run without --dry-run to write stubs.")
    else:
        print(f"\nDone: {created} stub(s) created, {skipped} skipped (already exist).")
        if created > 0:
            print(f"Review stubs at: .agent/skills/auto-generated/")
            print("Promote to .agent/skills/<name>/SKILL.md after review.")


def main() -> None:
    parser = argparse.ArgumentParser(
        description="PAEA Skill Factory — generate skill stubs from gap patterns"
    )
    parser.add_argument("--hours", type=int, default=DEFAULT_HOURS,
                        help=f"Telemetry window in hours (default: {DEFAULT_HOURS})")
    parser.add_argument("--min-count", type=int, default=DEFAULT_MIN_COUNT,
                        help=f"Min pattern count to qualify (default: {DEFAULT_MIN_COUNT})")
    parser.add_argument("--dry-run", action="store_true",
                        help="Show candidates without writing files")
    parser.add_argument("--list", action="store_true",
                        help="List existing auto-generated stubs")
    args = parser.parse_args()

    if args.list:
        cmd_list()
    else:
        cmd_generate(args.hours, args.min_count, args.dry_run)


if __name__ == "__main__":
    main()
