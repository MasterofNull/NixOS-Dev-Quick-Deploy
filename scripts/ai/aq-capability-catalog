#!/usr/bin/env python3
"""Validate and render the system capability catalog."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parents[2]
CATALOG = ROOT / "config" / "system-capability-catalog.json"
REFERENCE = ROOT / "docs" / "operations" / "reference" / "SYSTEM-CAPABILITY-CATALOG.md"
INTAKE = ROOT / "config" / "agent-capability-intake-candidates.json"

REQUIRED_ENTRY_FIELDS = {
    "id",
    "name",
    "category",
    "kind",
    "state",
    "maturity",
    "owner",
    "summary",
    "agent_access",
    "primary_refs",
    "security",
    "validation",
    "parity_targets",
    "data_stores",
}

EXTERNAL_KINDS = {"external-mcp", "plugin-skill"}


def load_json(path: Path) -> dict[str, Any]:
    with path.open(encoding="utf-8") as handle:
        return json.load(handle)


def catalog() -> dict[str, Any]:
    return load_json(CATALOG)


def intake_ids() -> set[str]:
    payload = load_json(INTAKE)
    return {str(item.get("id", "")) for item in payload.get("candidates", [])}


def _repo_path_exists(ref: str) -> bool:
    if ref.startswith(("http://", "https://", "mcp://", "cli://")):
        return True
    return (ROOT / ref).exists()


def validate(payload: dict[str, Any]) -> list[str]:
    errors: list[str] = []
    ids: set[str] = set()
    known_intake_ids = intake_ids()

    if payload.get("policy", {}).get("source_of_truth") != "config/system-capability-catalog.json":
        errors.append("policy.source_of_truth must point at config/system-capability-catalog.json")

    entries = payload.get("entries")
    if not isinstance(entries, list) or not entries:
        return ["entries must be a non-empty list"]

    for index, entry in enumerate(entries):
        prefix = f"entries[{index}]"
        if not isinstance(entry, dict):
            errors.append(f"{prefix} must be an object")
            continue

        missing = sorted(REQUIRED_ENTRY_FIELDS - set(entry))
        if missing:
            errors.append(f"{prefix} missing fields: {', '.join(missing)}")
            continue

        entry_id = str(entry["id"])
        if entry_id in ids:
            errors.append(f"duplicate id: {entry_id}")
        ids.add(entry_id)

        for field in ("agent_access", "primary_refs", "validation", "parity_targets", "data_stores"):
            if not isinstance(entry.get(field), list):
                errors.append(f"{entry_id}.{field} must be a list")

        for ref in entry.get("primary_refs", []):
            if not _repo_path_exists(str(ref)):
                errors.append(f"{entry_id}.primary_refs missing: {ref}")

        security = entry.get("security", {})
        if not isinstance(security, dict):
            errors.append(f"{entry_id}.security must be an object")
            continue
        for field in ("admission", "risk", "required_gate"):
            if not security.get(field):
                errors.append(f"{entry_id}.security.{field} is required")

        if entry.get("kind") in EXTERNAL_KINDS or str(security.get("admission", "")).startswith("accepted"):
            candidate_id = security.get("intake_candidate_id")
            if not candidate_id:
                errors.append(f"{entry_id} external or accepted capability must declare intake_candidate_id")
            elif candidate_id not in known_intake_ids:
                errors.append(f"{entry_id}.security.intake_candidate_id not found in intake registry: {candidate_id}")

    return errors


def render_markdown(payload: dict[str, Any]) -> str:
    entries = sorted(payload["entries"], key=lambda item: (item["category"], item["id"]))
    lines = [
        "# System Capability Catalog",
        "",
        "<!-- generated by scripts/ai/aq-capability-catalog render-doc; edit config/system-capability-catalog.json instead -->",
        "",
        "Status: Active",
        f"Owner: {payload['owner']}",
        f"Last Updated: {payload['version']}",
        "",
        f"Version: `{payload['version']}`",
        f"Source of truth: `{payload['policy']['source_of_truth']}`",
        f"External ingestion gate: `{payload['policy']['external_ingestion_gate']}`",
        "",
        "## Use",
        "",
        "- Agents should search this catalog before adding tools, plugins, MCP servers, datasets, workflows, or feature surfaces.",
        "- External candidates remain deny-by-default until `capability-intake` records admission, mitigations, and validation.",
        "- Parity discovery should compare each entry's `parity_targets` against mature external repos, then open a bounded capability-intake slice for any proposed ingestion.",
        "",
        "## Reference",
        "",
        "| ID | Category | Kind | State | Security | Agents | Validation |",
        "|---|---|---|---|---|---|---|",
    ]
    for entry in entries:
        security = entry["security"]
        agents = ", ".join(entry["agent_access"])
        validation = "<br>".join(f"`{item}`" for item in entry["validation"])
        lines.append(
            "| {id} | {category} | {kind} | {state} | {admission} / {risk} | {agents} | {validation} |".format(
                id=entry["id"],
                category=entry["category"],
                kind=entry["kind"],
                state=entry["state"],
                admission=security["admission"],
                risk=security["risk"],
                agents=agents,
                validation=validation,
            )
        )

    lines.extend(["", "## Entries", ""])
    for entry in entries:
        lines.extend(
            [
                f"### {entry['id']}",
                "",
                entry["summary"],
                "",
                f"- Name: {entry['name']}",
                f"- Owner: {entry['owner']}",
                f"- Maturity: {entry['maturity']}",
                f"- State: {entry['state']}",
                f"- Primary refs: {', '.join(f'`{ref}`' for ref in entry['primary_refs'])}",
                f"- Data stores: {', '.join(f'`{store}`' for store in entry['data_stores']) or 'none'}",
                f"- Parity targets: {', '.join(entry['parity_targets'])}",
                f"- Security gate: `{entry['security']['required_gate']}`",
                "",
            ]
        )
    return "\n".join(lines).rstrip() + "\n"


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("command", choices=["validate", "render-doc", "check-doc"])
    args = parser.parse_args()

    payload = catalog()
    errors = validate(payload)
    if errors:
        for error in errors:
            print(f"ERROR: {error}", file=sys.stderr)
        return 1

    rendered = render_markdown(payload)
    if args.command == "validate":
        print(f"PASS: {len(payload['entries'])} catalog entries valid")
        return 0
    if args.command == "render-doc":
        print(rendered, end="")
        return 0

    current = REFERENCE.read_text(encoding="utf-8") if REFERENCE.exists() else ""
    if current != rendered:
        print(
            "ERROR: docs/operations/reference/SYSTEM-CAPABILITY-CATALOG.md is stale; run render-doc and update it",
            file=sys.stderr,
        )
        return 1
    print("PASS: capability catalog reference is up to date")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
