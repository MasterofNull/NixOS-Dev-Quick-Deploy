#!/usr/bin/env bash
# delegate-to-local — Delegate a task to the local Qwen model
#
# Phase 74F — thin bash shim; all dispatch logic lives in lib/dispatch.py.
#
# Modes:
#   agent     — full coding agent loop (aq-agent-loop): read/write files, git, validate
#   hybrid    — query through hybrid-coordinator (:8003) — research/analysis
#   direct    — POST directly to llama.cpp /v1/chat/completions — drafts/summaries
#   ralph     — route through ralph-wiggum tool-calling agent (:8004)
#
# Usage:
#   delegate-to-local --mode agent --prompt "implement X in file Y" [--wait]
#   delegate-to-local --prompt "analyze X and output findings"  # background by default
#   delegate-to-local --prompt "..." --wait                     # block until done
#   delegate-to-local --check <task-id>                         # read completed output
#   delegate-to-local --list                                     # list all tasks
#   delegate-to-local --status <task-id>                        # task status
#
# Options:
#   --prompt TEXT      Task prompt
#   --prompt-file FILE Read prompt from file
#   --mode MODE        Routing: agent|hybrid|direct|ralph  [default: hybrid]
#   --timeout SECS     Request timeout in seconds  [default: 300]
#   --role ROLE        Role: orchestrator|architect|implementer|reviewer  [default: implement]
#   --wait             Block until task completes (default: background)
#   --check ID         Print output of a completed task
#   --status ID        Show task status
#   --monitor          Show compact read-only JSON monitor for active/recent tasks
#   --repair-status ID Reconcile inferred terminal status into the registry
#   --repair-stale     Dry-run stale running-task repair unless --apply is provided
#   --dry-run          Preview repair-stale candidates without mutating registry
#   --apply            Apply repair-stale registry reconciliation
#   --list             List all registered tasks
#   --cancel ID        Cancel a running task
#   --kill-all         Kill all running tasks
#   --no-consult       Skip the router/claim consult gate before real dispatch
#                       (also: AQ_NO_CONSULT=1). Read-only subcommands above
#                       never consult regardless of this flag.
#   --help             Show this help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
DELEGATION_DIR="$REPO_ROOT/.agents/delegation"
LIB_DIR="$SCRIPT_DIR/lib"
DISPATCH="$LIB_DIR/dispatch.py"

# RSI-Readiness R5.1: seed a trace id for direct delegations (preserved if
# already set by a parent entrypoint, so the whole chain shares one trace).
source "$LIB_DIR/trace-seed.sh" 2>/dev/null || true

# Phase 56.1/56.7 — delegation audit bridge
# shellcheck disable=SC1091
source "${LIB_DIR}/audit-write.sh" 2>/dev/null || true

# Ports — read from env, fall back to harness defaults (source of truth: options.nix)
LLAMA_PORT="${LLAMA_PORT:-8080}"
HYBRID_PORT="${HYBRID_PORT:-8003}"
RALPH_PORT="${RALPH_PORT:-8004}"
# DIRECT_MAX_TOKENS is read by task_config._resolve_tokens() from the environment;
# export here so nohup subprocesses inherit it.
export DIRECT_MAX_TOKENS="${DIRECT_MAX_TOKENS:-4096}"
# P2.3 TURNED ON: GBNF repair-retry for the dispatched aq-agent-loop lane (the coordinator lane is
# turned on via its systemd Environment). 'repair' only constrains a malformed tool-call retry —
# bench-validated non-harmful. Override with AQ_LOCAL_GBNF= to disable, or =1/on to always-constrain.
export AQ_LOCAL_GBNF="${AQ_LOCAL_GBNF:-repair}"

die()  { echo "ERROR: $*" >&2; exit 1; }
info() { echo "[delegate-to-local] $*"; }

task_id() {
    # Subshell with pipefail disabled — tr exits SIGPIPE when head closes the pipe.
    local rand; rand="$(set +o pipefail; tr -dc 'a-z0-9' </dev/urandom 2>/dev/null | head -c6)" || rand="xxxxxx"
    echo "local-$(date +%Y%m%d-%H%M%S)-${rand}"
}

ensure_dirs() { mkdir -p "$DELEGATION_DIR/outputs"; }

# ── guard: only run CLI parsing when executed directly, not when sourced ─────
[[ "${BASH_SOURCE[0]}" != "${0}" ]] && return 0

# ── argument parsing ──────────────────────────────────────────────────────────
PROMPT=""
PROMPT_FILE=""
MODE="auto"   # Phase 74E: auto runs classify_mode() heuristic in dispatch.py
TIMEOUT=300
# "auto": dispatch.py auto_assign infers the role from the task itself
# (the old "implement" default was not a canonical role name and silently
# skipped role injection entirely).
ROLE="auto"
WAIT=false
TOOL_MANIFEST="full"
TASK_TYPE=""  # Phase 173: "research"|"analysis"|"prd" raises stagnation read limits to 15/25
SUBCMD=""
SUBCMD_ARG=""
REPAIR_STALE_APPLY=false
# Resolution B (DISPATCH-INTEGRATION-DESIGN.md amendment): dispatch.py stays
# frozen (L2B golden-manifest pin) — the router/claim consult seam lives here
# in the shim instead. Escape hatch for callers that must bypass it (e.g. the
# consult tooling's own self-tests, or a known-solo run).
NO_CONSULT=false
if [[ "${AQ_NO_CONSULT:-0}" == "1" || "${AQ_NO_CONSULT:-}" == "true" ]]; then
    NO_CONSULT=true
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        --prompt)         PROMPT="$2";         shift 2 ;;
        --prompt-file)    PROMPT_FILE="$2";    shift 2 ;;
        --mode)           MODE="$2";           shift 2 ;;
        --timeout)        TIMEOUT="$2";        shift 2 ;;
        --role)           ROLE="$2";           shift 2 ;;
        --wait)           WAIT=true;           shift   ;;
        --tool-manifest)  TOOL_MANIFEST="$2";  shift 2 ;;
        --task-type)      TASK_TYPE="$2";      shift 2 ;;
        --check)         SUBCMD="check";         SUBCMD_ARG="${2:-}"; shift; [[ $# -gt 0 ]] && shift ;;
        --status)        SUBCMD="status";        SUBCMD_ARG="${2:-}"; shift; [[ $# -gt 0 ]] && shift ;;
        --repair-status) SUBCMD="repair-status"; SUBCMD_ARG="${2:-}"; shift; [[ $# -gt 0 ]] && shift ;;
        --repair-stale)  SUBCMD="repair-stale";  shift   ;;
        --dry-run)       REPAIR_STALE_APPLY=false; shift ;;
        --apply)         REPAIR_STALE_APPLY=true;  shift ;;
        --list)          SUBCMD="list";          shift   ;;
        --monitor)       SUBCMD="monitor";       shift   ;;
        --cancel)        SUBCMD="cancel";        SUBCMD_ARG="${2:-}"; shift; [[ $# -gt 0 ]] && shift ;;
        --kill-all)      SUBCMD="kill-all";      shift   ;;
        --no-consult)    NO_CONSULT=true;        shift   ;;
        --help|-h)     grep "^#" "$0" | sed 's/^# \?//'; exit 0 ;;
        *) die "Unknown option: $1 (run with --help for usage)" ;;
    esac
done

case "$MODE" in
    auto|agent|hybrid|direct|ralph) ;;
    *) die "Invalid --mode '$MODE'. Valid: auto | agent | hybrid | direct | ralph" ;;
esac

case "$ROLE" in
    # auto: dispatch.py auto_assign infers the canonical role from the task
    auto) ;;
    # Canonical role-matrix values
    orchestrator|architect|implementer|reviewer) ;;
    # Legacy aliases (mapped to canonical in task_config.py)
    plan|implement|review|research) ;;
    *) die "Invalid --role '$ROLE'. Valid: auto | orchestrator | architect | implementer | reviewer" ;;
esac

# ── subcommands ───────────────────────────────────────────────────────────────
case "${SUBCMD:-}" in
    list)
        python3 "$DISPATCH" list --delegation-dir "$DELEGATION_DIR"
        ;;
    monitor)
        python3 "$DISPATCH" monitor --delegation-dir "$DELEGATION_DIR"
        ;;
    status)
        [[ -n "$SUBCMD_ARG" ]] || die "--status requires a task ID  (e.g. --status local-20260701-...)"
        python3 "$DISPATCH" status "$SUBCMD_ARG" --delegation-dir "$DELEGATION_DIR"
        ;;
    check)
        [[ -n "$SUBCMD_ARG" ]] || die "--check requires a task ID"
        python3 "$DISPATCH" check "$SUBCMD_ARG" --delegation-dir "$DELEGATION_DIR"
        ;;
    repair-status)
        [[ -n "$SUBCMD_ARG" ]] || die "--repair-status requires a task ID"
        python3 "$DISPATCH" repair-status "$SUBCMD_ARG" --delegation-dir "$DELEGATION_DIR"
        ;;
    repair-stale)
        _REPAIR_ARGS=(python3 "$DISPATCH" repair-stale --delegation-dir "$DELEGATION_DIR")
        [[ "$REPAIR_STALE_APPLY" == "true" ]] && _REPAIR_ARGS+=(--apply)
        "${_REPAIR_ARGS[@]}"
        ;;
    cancel)
        [[ -n "$SUBCMD_ARG" ]] || die "--cancel requires a task ID"
        python3 "$DISPATCH" cancel "$SUBCMD_ARG" --delegation-dir "$DELEGATION_DIR"
        ;;
    kill-all)
        python3 "$DISPATCH" kill-all --delegation-dir "$DELEGATION_DIR"
        ;;
    "")
        # Resolve prompt from file if needed
        if [[ -n "$PROMPT_FILE" ]]; then
            [[ -f "$PROMPT_FILE" ]] || die "Prompt file not found: $PROMPT_FILE"
            PROMPT="$(cat "$PROMPT_FILE")"
        fi
        [[ -n "$PROMPT" ]] || die "Provide --prompt TEXT or --prompt-file FILE (or --help)"

        ensure_dirs
        ID="$(task_id)"
        OUTPUT_FILE="$DELEGATION_DIR/outputs/${ID}.log"

        info "Delegating task: $ID"
        info "Routing mode:    $MODE"
        info "Role:            $ROLE"
        info "Output file:     $OUTPUT_FILE"

        # ── router/claim consult gate (advisory, fail-open) ─────────────────
        # Only the real-dispatch branch consults — --check/--status/--list/
        # --monitor/--cancel/--kill-all/--repair* never reach here. A missing/
        # erroring/timing-out consult CLI must never block a dispatch, so any
        # failure to get a parseable JSON reply is treated as proceed.
        CONSULT_SUBJECT="$ID"
        CONSULT_ROLE="$ROLE"
        [[ "$CONSULT_ROLE" == "auto" ]] && CONSULT_ROLE="implementer"
        consult_blocked=false
        consult_owner="unknown"
        if [[ "$NO_CONSULT" != "true" ]]; then
            GIT_HEAD="$(git -C "$REPO_ROOT" rev-parse HEAD 2>/dev/null || true)"
            CONSULT_ARGS=(timeout 15 python3 "$LIB_DIR/dispatch_consult.py" consult
                --subject "$CONSULT_SUBJECT" --role "$CONSULT_ROLE" --lane local)
            [[ -n "$GIT_HEAD" ]] && CONSULT_ARGS+=(--head "$GIT_HEAD")
            CONSULT_JSON="$("${CONSULT_ARGS[@]}" 2>/dev/null)" || CONSULT_JSON=""
            if [[ -n "$CONSULT_JSON" ]]; then
                if consult_owner="$(python3 -c '
import json, sys
try:
    d = json.loads(sys.argv[1])
except Exception:
    sys.exit(1)
if d.get("blocked"):
    print(d.get("current_owner") or "unknown")
    sys.exit(0)
sys.exit(1)
' "$CONSULT_JSON" 2>/dev/null)"; then
                    consult_blocked=true
                fi
            fi
        fi

        if [[ "$consult_blocked" == "true" ]]; then
            echo "REFUSED: subject '$CONSULT_SUBJECT' is already claimed by owner '$consult_owner' — not dispatching (see aq-slice-claim). Retry later, or pass --no-consult / AQ_NO_CONSULT=1 to override." >&2
            exit 2
        fi

        audit_event_start "local" "$ID" "${PROMPT:0:200}"

        # Build dispatch.py argument list (bash array preserves quoting for prompts
        # containing spaces/special chars — never interpolate via printf '%q').
        _DISPATCH_ARGS=(
            python3 "$DISPATCH" delegate
            --task-id        "$ID"
            --output         "$OUTPUT_FILE"
            --mode           "$MODE"
            --role           "$ROLE"
            --prompt         "$PROMPT"
            --timeout        "$TIMEOUT"
            --tool-manifest  "$TOOL_MANIFEST"
            --delegation-dir "$DELEGATION_DIR"
            --llama-url      "http://127.0.0.1:${LLAMA_PORT}"
            --hybrid-url     "http://127.0.0.1:${HYBRID_PORT}"
            --ralph-url      "http://127.0.0.1:${RALPH_PORT}"
            --script-dir     "$SCRIPT_DIR"
        )
        [[ -n "$TASK_TYPE" ]] && _DISPATCH_ARGS+=(--task-type "$TASK_TYPE")

        if [[ "$WAIT" == "true" ]]; then
            info "Running in blocking mode (timeout: ${TIMEOUT}s)..."
            if "${_DISPATCH_ARGS[@]}"; then
                audit_event_end "local" "$ID" "success" "0" \
                    "completed mode=${MODE}: ${PROMPT:0:100}" "$MODE"
                audit_save_session "local-${MODE}" "$ID" "$PROMPT" "$OUTPUT_FILE"
                [[ "$NO_CONSULT" != "true" ]] && { timeout 10 python3 "$LIB_DIR/dispatch_consult.py" release --subject "$CONSULT_SUBJECT" --owner local >/dev/null 2>&1 || true; }
                info "Task $ID completed."
                cat "$OUTPUT_FILE"
            else
                audit_event_end "local" "$ID" "error" "0" \
                    "failed mode=${MODE}: ${PROMPT:0:100}" "$MODE"
                audit_save_session "local-${MODE}" "$ID" "$PROMPT" "$OUTPUT_FILE"
                [[ "$NO_CONSULT" != "true" ]] && { timeout 10 python3 "$LIB_DIR/dispatch_consult.py" release --subject "$CONSULT_SUBJECT" --owner local >/dev/null 2>&1 || true; }
                info "Task $ID failed. Output:"
                cat "$OUTPUT_FILE"
                exit 1
            fi
        else
            # Background mode: this shim's own lifetime ends right after launch
            # while the real task keeps running detached (setsid) — there is no
            # "dispatch completed" event for the shim to observe here, so the
            # claim is deliberately NOT released in this branch. It stays held
            # under the requested lane until aq-slice-claim's own TTL/owner
            # path clears it; releasing now would let a second concurrent
            # dispatch race the still-running background task.
            # setsid dispatch.py into its OWN session so it survives the caller's
            # process-group being reaped (e.g. a round-driver/Bash call returning). Without
            # setsid, dispatch.py stayed in the caller's pgroup, was SIGKILLed when that group
            # died, and its aq-agent-loop child then orphaned (ppid=1) → the self-watchdog
            # killed a task that had barely started. setsid detaches it (own session leader,
            # no controlling terminal) — the ROOT fix for the orphaned/self-terminated dispatches.
            setsid "${_DISPATCH_ARGS[@]}" > /dev/null 2>&1 &
            BG_PID=$!
            disown "$BG_PID"
            info "Task $ID started in background (pid $BG_PID)"
            info "Check output:  delegate-to-local --check $ID"
            info "Check status:  delegate-to-local --status $ID"
            info "NOTE: Local model tasks take 90-300s. Check back in a few minutes."
            echo "$ID"
        fi
        ;;
esac
