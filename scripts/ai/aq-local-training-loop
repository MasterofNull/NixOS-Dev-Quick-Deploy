def _persist_result(result: Dict[str, Any]) -> None:
    """Append one loop result to RESULTS_LOG (for dashboard/health-spider pickup). TELEMETRY_DIR may be
    owned by ai-hybrid (mode 750); fall back to a user-writable path so the loop never crashes on write."""
    TELEMETRY_DIR.mkdir(parents=True, exist_ok=True)
    try:
        with open(RESULTS_LOG, "a", encoding="utf-8") as fh:
            fh.write(json.dumps(result) + "\n")
    except (PermissionError, OSError):
        fallback = DELEGATION_DIR / "training-loop-results.jsonl"
        fallback.parent.mkdir(parents=True, exist_ok=True)
        with open(fallback, "a", encoding="utf-8") as fh:
            fh.write(json.dumps(result) + "\n")


# Slot-contention preflight (WS8/prompt 5). Evals share the single APU llama.cpp
# slot with the F2.5 banded queue; running them behind other work makes every
# direct dispatch queue and time out, scoring a false 0/N that alarmed as a model
# regression (the real 2026-07-09 0/12 incident). Defer instead. 0 disables.
SLOT_CONTENTION_QUEUE_MAX = int(os.getenv("AQ_LOOP_SLOT_QUEUE_MAX", "0"))  # >this queued = contended
_SCHEDULER_STATE = _REPO_ROOT / ".agents" / "delegation" / "scheduler-state.json"


def _slot_contended() -> "tuple[bool, str]":
    """True if the local slot is busy or the banded queue is backed up.

    Consults the F2.5 slot_queue observability surface (scheduler-state.json)
    and llama.cpp /slots. Fail-open (not contended) on any read error so a
    missing surface never blocks eval — model-readiness still guards cold starts.
    """
    import urllib.request

    # 1. Banded queue depth from the slot_queue state file.
    try:
        st = json.loads(_SCHEDULER_STATE.read_text())
        running = st.get("running")
        depth = len(st.get("queue") or [])
        if running is not None:
            who = (running.get("id", "?") if isinstance(running, dict) else "?")
            return True, f"local slot held by queued job {who} (queue depth {depth})"
        if depth > SLOT_CONTENTION_QUEUE_MAX:
            return True, f"banded queue depth {depth} > {SLOT_CONTENTION_QUEUE_MAX}"
    except (OSError, ValueError, json.JSONDecodeError):
        pass  # no state file yet — fall through to the live slot probe

    # 2. Live llama.cpp slot state.
    try:
        with urllib.request.urlopen(f"{LLAMA_BASE_URL.rstrip('/')}/slots", timeout=5) as r:
            slots = json.loads(r.read())
            if slots and slots[0].get("is_processing", False):
                return True, "llama.cpp slot is_processing (busy with non-eval work)"
    except Exception:  # noqa: BLE001 — fail-open
        pass
    return False, "slot free"


def _wait_for_model_ready(timeout_s: int = MODEL_READY_TIMEOUT_S) -> bool:
    """True once llama.cpp is serving (not mid-reload). Probes /health then confirms it can generate
    with a 1-token completion — a healthy /health can still precede a model that isn't loaded. Bounded
    wait with backoff; returns False if still cold at the deadline so the caller can DEFER (not score
    a false 0/N). Uses urllib (stdlib) so it never depends on httpx being present after a rebuild."""
    import urllib.request

    if timeout_s <= 0:
        return True
    deadline = time.time() + timeout_s
    health_url = f"{LLAMA_BASE_URL.rstrip('/')}/health"
    gen_url = f"{LLAMA_BASE_URL.rstrip('/')}/v1/chat/completions"
    body = json.dumps({
        "messages": [{"role": "user", "content": "ready?"}],
        "max_tokens": 1, "chat_template_kwargs": {"enable_thinking": False},
    }).encode()
    attempt = 0
    while time.time() < deadline:
        attempt += 1
        try:
            with urllib.request.urlopen(health_url, timeout=5) as r:
                healthy = r.status == 200
        except Exception:  # noqa: BLE001
            healthy = False
        if healthy:
            try:
                req = urllib.request.Request(gen_url, data=body,
                                             headers={"Content-Type": "application/json"}, method="POST")
                with urllib.request.urlopen(req, timeout=30) as r:
                    if r.status == 200:
                        print(f"[training-loop]   model ready (health+generate OK, attempt {attempt})")
                        return True
            except Exception:  # noqa: BLE001
                pass
        remaining = int(deadline - time.time())
        if remaining <= 0:
            break
        print(f"[training-loop]   model not ready yet (attempt {attempt}); {remaining}s budget left",
              file=sys.stderr)
        time.sleep(min(15, max(1, remaining)))
    return False


def _submit_task(query: str, mode: str = "hybrid", http_timeout_secs: int = 0) -> Optional[str]:
    """
    Submit a task to delegate-to-local in background mode.
    Returns the task ID or None on error.

    http_timeout_secs: passed to delegate-to-local --timeout (0 = use default 300).
    For direct mode, callers should pass a higher value (e.g. 600) to tolerate
    one extra queued request in the llama.cpp HTTP queue without timing out.
    """
    # delegate-to-local accepts: agent|hybrid|direct|ralph
    # eval packs may specify "auto" (coordinator decides) — map to hybrid
    if mode not in ("agent", "hybrid", "direct", "ralph"):
        mode = "hybrid"
    delegate_bin = _SCRIPT_DIR / "delegate-to-local"
    if not delegate_bin.exists():
        print(f"[eval] ERROR: delegate-to-local not found at {delegate_bin}", file=sys.stderr)
        return None
    cmd = [str(delegate_bin), "--mode", mode, "--prompt", query]
    if http_timeout_secs > 0:
        cmd += ["--timeout", str(http_timeout_secs)]
    # For eval loop tasks, cap max_tokens to EVAL_MAX_TOKENS so bounded test cases
    # complete quickly.  Production / improvement tasks use DIRECT_MAX_TOKENS default.
    env = {**os.environ, "PYTHONUNBUFFERED": "1"}
    if mode == "direct":
        env.setdefault("DIRECT_MAX_TOKENS", str(EVAL_MAX_TOKENS))
    try:
        result = subprocess.run(
            cmd,
            capture_output=True, text=True, timeout=SUBMIT_TIMEOUT_S,
            env=env,
        )
        # Parse task ID from output lines like "[delegate-to-local] task_id=local-20260527-..."
        for line in result.stdout.splitlines():
            if "task_id=" in line:
                return line.split("task_id=", 1)[1].strip()
            if line.strip().startswith("local-"):
                return line.strip()
        # Fallback: last line of stderr might have it
        for line in result.stderr.splitlines():
            if "task_id=" in line:
                return line.split("task_id=", 1)[1].strip()
        return None
    except subprocess.TimeoutExpired:
        print(
            f"[eval] ERROR: delegate-to-local submission timed out after {SUBMIT_TIMEOUT_S}s",
            file=sys.stderr,
        )
        return None


def _cancel_task(task_id: str) -> None:
    """Cancel a delegated background task by calling delegate-to-local --cancel."""
    delegate_bin = _SCRIPT_DIR / "delegate-to-local"
    if not delegate_bin.exists():
        # Fallback: kill via registry PID directly
        for entry in _read_registry():
            if entry.get("id") == task_id and entry.get("status") == "running":
                pid = entry.get("pid")
                if pid:
                    try:
                        os.kill(int(pid), signal.SIGTERM)
                    except (ProcessLookupError, PermissionError):
                        pass
                _mark_registry_status(task_id, "cancelled")
        return
    try:
        subprocess.run(
            [str(delegate_bin), "--cancel", task_id],
            capture_output=True, timeout=10,
        )
        print(f"[eval] cancelled task {task_id}", file=sys.stderr)
    except Exception as exc:
        print(f"[eval] WARN: cancel failed for {task_id}: {exc}", file=sys.stderr)


async def _wait_for_task(task_id: str, timeout_s: int = DEFAULT_TASK_TIMEOUT_S) -> Optional[str]:
    """
    Wait for a delegated task to finish.

    Hook-style: watches the output file for existence/non-zero size (written by
    delegate-to-local when the background process completes) before touching the
    registry.  This reacts within POLL_INTERVAL_S of completion rather than on a
    fixed registry-parse cadence, and avoids hammering the registry JSONL.

    Falls back to a registry-only check if the output_file path is unavailable.
    """
    start = time.monotonic()
    last_log = start
    last_activity = start
    last_seen_mtime = 0.0
    output_file: Optional[Path] = None

    while True:
        now = time.monotonic()
        # Resolve output file path from registry (once)
        if output_file is None:
            for entry in _read_registry():
                if entry.get("id") == task_id:
                    of = entry.get("output_file", "")
                    if of:
                        output_file = (
                            Path(of) if os.path.isabs(of) else _REPO_ROOT / of
                        )
                    break

        newest_mtime = _artifact_newest_mtime(output_file)
        if newest_mtime > last_seen_mtime:
            last_seen_mtime = newest_mtime
            last_activity = now

        # Fast path: output file appeared — check registry for terminal status
        if output_file and output_file.exists() and output_file.stat().st_size > 0:
            for entry in _read_registry():
                if entry.get("id") == task_id:
                    status = entry.get("status", "running")
                    # delegate-to-local writes "done"; accept both for compat
                    if status in ("completed", "done"):
                        return _read_output(str(output_file))
                    if status == "failed":
                        return None
                    # File written but registry not yet updated — one more cycle
                    break

        # Layer 1: PID liveness — if the background process is dead but registry
        # still shows "running", mark it "stale" and bail immediately rather than
        # burning the full timeout_s waiting for a task that will never complete.
        entry_seen = False
        pid_seen = False
        for entry in _read_registry():
            if entry.get("id") != task_id:
                continue
            entry_seen = True
            status = entry.get("status", "running")
            # Accept stale/orphaned as terminal (set by reconciler or prior reap)
            if status in ("stale", "orphaned", "cancelled"):
                print(f"[eval] task {task_id} already {status}, skipping wait", file=sys.stderr)
                return None
            if status == "running":
                pid = entry.get("pid")
                if pid:
                    pid_seen = True
                    try:
                        os.kill(int(pid), 0)  # 0 = liveness probe, no signal sent
                    except ProcessLookupError:
                        print(f"[eval] orphan: {task_id} pid={pid} dead → stale",
                              file=sys.stderr)
                        _mark_registry_status(task_id, "stale")
                        return None
                    except PermissionError:
                        pass  # process exists but belongs to another user; keep waiting
            break

        elapsed = now - start
        idle_s = now - last_activity
        if idle_s >= timeout_s and (not entry_seen or not pid_seen):
            reason = "missing registry entry" if not entry_seen else "missing pid"
            print(f"[eval] STALE: task {task_id} {reason} after idle={idle_s:.0f}s", file=sys.stderr)
            if entry_seen:
                _mark_registry_status(task_id, "stale")
            return None
        if RUNAWAY_HARD_CAP_S > 0 and elapsed >= RUNAWAY_HARD_CAP_S:
            print(
                f"[eval] HARD_CAP: task {task_id} exceeded {RUNAWAY_HARD_CAP_S}s, cancelling",
                file=sys.stderr,
            )
            _cancel_task(task_id)
            return None
        if idle_s >= timeout_s and now - last_log >= WAIT_LOG_INTERVAL_S:
            last_log = now
            print(
                f"[eval] WAIT: task {task_id} alive; idle={idle_s:.0f}s "
                f"elapsed={elapsed:.0f}s timeout_window={timeout_s}s",
                file=sys.stderr,
            )

        await asyncio.sleep(POLL_INTERVAL_S)


# ── improvement proposal ───────────────────────────────────────────────────────

def _build_improvement_context(ingest_report: Dict) -> str:
    """
    Build a plain-text context block that summarises telemetry signals.
    This is prepended to improvement prompts sent to the local model.
    """
    lines = ["=== TELEMETRY CONTEXT ==="]
    if ingest_report.get("failure_summary"):
        lines.append("Delegation failure classes (last 24h):")
        for cls, cnt in ingest_report["failure_summary"].items():
            lines.append(f"  {cls}: {cnt}x")
    if ingest_report.get("gap_patterns"):
        lines.append("Top gap patterns (improvement actions from failed tasks):")
        for g in ingest_report["gap_patterns"][:5]:
            lines.append(f"  [{g['count']}x] {g['pattern']}")
    if ingest_report.get("proposals_auto_approved"):
        lines.append(f"Auto-approved proposals: {len(ingest_report['proposals_auto_approved'])}")
    if ingest_report.get("proposals_needing_review"):
        lines.append(f"Proposals needing review: {len(ingest_report['proposals_needing_review'])}")
    lines.append("=========================")
    return "\n".join(lines)


def _generate_improvement_prompt(
    failing_cases: List[Dict],
    ingest_report: Dict,
) -> str:
    """
    Build a prompt for the local model to propose concrete improvements.
    """
    ctx = _build_improvement_context(ingest_report)
    cases_text = "\n".join(
        f"  - case={r['case_id']} score={r['score']} missing={r['missing_keywords']}"
        for r in failing_cases[:8]
    )
    return (
        f"{ctx}\n\n"
        "You are reviewing eval results for the local Qwen3-35B AI harness.\n\n"
        "FAILING EVAL CASES:\n"
        f"{cases_text}\n\n"
        "Propose 3 concrete, targeted improvements to fix these failures. Each improvement must:\n"
        "1. Identify the root cause (missing knowledge, wrong profile, prompt framing issue)\n"
        "2. Specify the exact change (system prompt addition, profile tweak, switchboard config)\n"
        "3. Predict which missing keywords would be covered after the change\n"
        "4. Be safe to apply without human review (no secrets, no port changes, no model swap)\n\n"
        "Output as JSON array with keys: root_cause, change_type, change_description, "
        "expected_keyword_gains, confidence (0-1)."
    )


# ── loop ───────────────────────────────────────────────────────────────────────

class TrainingLoop:
    def __init__(
        self,
        eval_pack: Path = DEFAULT_EVAL_PACK,
        task_timeout: int = DEFAULT_TASK_TIMEOUT_S,
        dry_run: bool = False,
        verbose: bool = False,
    ):
        self.eval_pack = eval_pack
        self.task_timeout = task_timeout
        self.dry_run = dry_run
        self.verbose = verbose

    async def run_once(self, resume: bool = False) -> Dict[str, Any]:
        """Execute one full test/eval/improve cycle.

        resume=True: load checkpoint and skip cases already completed in this run_id.
        Enables safe restart after nixos-rebuild, hibernation, or SIGTERM.
        """
        global ACTIVE_RUN_ID
        run_id = f"loop-{datetime.now(timezone.utc).strftime('%Y%m%d-%H%M%S')}"
        if resume:
            # On resume, reuse the most recent incomplete run_id from checkpoint
            try:
                if CHECKPOINT_FILE.exists():
                    ckpt_data = json.loads(CHECKPOINT_FILE.read_text())
                    if ckpt_data:
                        run_id = sorted(ckpt_data.keys())[-1]
                        print(f"[training-loop] Resuming run {run_id}")
            except (json.JSONDecodeError, OSError):
                pass
        ACTIVE_RUN_ID = run_id
        print(f"[training-loop] Starting run {run_id}")
        _write_progress(run_id, "starting", dry_run=self.dry_run, eval_pack=str(self.eval_pack))

        # Layer 2: reap dead background processes before submitting new tasks
        reaped = _reap_orphans()
        if reaped:
            print(f"[training-loop] Reaped {reaped} orphaned task(s) from prior runs")
        _write_progress(run_id, "ingest", reaped_orphans=reaped)

        # ── 0. CORRECT ─────────────────────────────────────────────────────────
        # Close the loop's LEARNING step: turn PENDING local failures into repair pairs via the codex
        # teacher (own login, no API key) BEFORE ingest, so this run's ingest folds them into the
        # dataset. Skipped in dry-run and if AQ_LOOP_CORRECT=0. Best-effort — a teacher/quota hiccup
        # must never abort a training run (ingest still processes any already-corrected samples).
        corrected_count = 0
        if not self.dry_run and os.getenv("AQ_LOOP_CORRECT", "1") != "0":
            print("[training-loop] Phase 0: correcting pending failures (codex teacher)")
            correct_bin = _SCRIPT_DIR / "aq-correct-failures"
            try:
                cproc = subprocess.run(
                    [sys.executable, str(correct_bin), "--max",
                     os.getenv("AQ_LOOP_CORRECT_MAX", "10")],
                    capture_output=True, text=True,
                    timeout=int(os.getenv("AQ_LOOP_CORRECT_TIMEOUT", "600")),
                )
                for ln in (cproc.stdout or "").splitlines():
                    if "corrected -> repair pair" in ln:
                        corrected_count += 1
                print(f"[training-loop]   corrected {corrected_count} pending failure(s)")
            except subprocess.TimeoutExpired:
                print("[training-loop] WARNING: correction phase timed out — continuing to ingest",
                      file=sys.stderr)
            except Exception as exc:  # noqa: BLE001
                print(f"[training-loop] WARNING: correction phase failed: {exc} — continuing",
                      file=sys.stderr)
        _write_progress(run_id, "ingest", reaped_orphans=reaped, corrected=corrected_count)

        # ── 1. INGEST ──────────────────────────────────────────────────────────
        print("[training-loop] Phase 1: telemetry ingest")
        try:
            from training_ingest import TrainingIngestor
            ingestor = TrainingIngestor(dry_run=self.dry_run)
            ingest_report = ingestor.run(hours=24)
            print(
                f"[training-loop]   +{ingest_report['positive_samples_added']} training samples "
                f"(dataset total: {ingest_report['dataset_total']})"
            )
        except Exception as exc:
            print(f"[training-loop] WARNING: ingest failed: {exc}", file=sys.stderr)
            ingest_report = {}
        _write_progress(
            run_id,
            "eval",
            samples_added=ingest_report.get("positive_samples_added", 0),
            dataset_total=ingest_report.get("dataset_total", 0),
        )

        # ── 1b. MODEL READINESS PREFLIGHT ───────────────────────────────────────
        # Do not eval a cold model: after a rebuild/restart llama.cpp reloads ~22.5GB and every direct
        # dispatch times out, producing a false 0/N eval_failed (exactly what wasted the first real run).
        # Wait for it to actually serve; if still cold, DEFER — record an honest "deferred" run, not a
        # bogus regression the health-spider would alert on.
        # ── 1a. SLOT-CONTENTION PREFLIGHT ───────────────────────────────────────
        # Do not eval while the single APU slot is busy with other work: every
        # direct dispatch would queue and time out, scoring a false 0/N that
        # alarms as a model regression (the real 0/12 incident). Defer honestly.
        if not self.dry_run:
            contended, why = _slot_contended()
            if contended:
                print(f"[training-loop] slot contended ({why}) — DEFERRING eval this run",
                      file=sys.stderr)
                _write_progress(run_id, "deferred", reason="slot_contended")
                report = {
                    "run_id": run_id, "timestamp": datetime.now(timezone.utc).isoformat(),
                    "status": "deferred", "reason": "slot_contended", "detail": why,
                    "cases_total": 0, "pass_count": 0, "fail_count": 0, "pass_rate": None,
                    "corrected": corrected_count,
                }
                _persist_result(report)
                return report

        if not self.dry_run and not _wait_for_model_ready():
            print("[training-loop] model not ready after preflight budget — DEFERRING eval this run",
                  file=sys.stderr)
            _write_progress(run_id, "deferred", reason="model_not_ready")
            report = {
                "run_id": run_id, "timestamp": datetime.now(timezone.utc).isoformat(),
                "status": "deferred", "reason": "model_not_ready",
                "cases_total": 0, "pass_count": 0, "fail_count": 0, "pass_rate": None,
                "corrected": corrected_count,
            }
            _persist_result(report)
            return report

        # ── 1c. SCORER CERTIFICATION (R1.2) ─────────────────────────────────────
        # Certify the loop's scorer against the golden set BEFORE trusting any
        # score. An uncertified scorer (can't discriminate / grades noise) must
        # not gate ingest/train — the reward signal would be corrupt. Recorded on
        # the run so downstream automation and the dashboard see the trust state.
        self._scorer_certified, self._scorer_cert_reason = _certify_scorer()
        _write_progress(run_id, "scorer_certification",
                        certified=self._scorer_certified, reason=self._scorer_cert_reason)
        print(f"[training-loop] scorer certification: "
              f"{'CERTIFIED' if self._scorer_certified else 'NOT CERTIFIED — scores untrusted'} "
              f"({self._scorer_cert_reason})")

        # ── 2. EVAL ────────────────────────────────────────────────────────────
        print("[training-loop] Phase 2: delegating eval tasks")
        cases = _load_eval_pack(self.eval_pack)
        if not cases:
            print("[training-loop] ERROR: no eval cases found", file=sys.stderr)
            _write_progress(run_id, "error", error="no eval cases")
            return {"run_id": run_id, "error": "no eval cases"}

        # ── 3. EVAL + WAIT + SCORE ─────────────────────────────────────────────
        # direct mode tasks go to llama.cpp which is serial: serialize them with
        # a Semaphore(1) so each task gets its full timeout window.  hybrid/agent
        # mode tasks go to the coordinator queue which handles concurrency itself.
        # Load checkpoint: cases already scored in this run_id (from a prior interrupted run)
        completed_cases: Dict[str, Any] = _checkpoint_load(run_id) if resume else {}
        if completed_cases:
            print(f"[training-loop]   resuming: {len(completed_cases)} cases already done")

        print(f"[training-loop] Phase 2+3: submitting and scoring {len(cases)} cases…")
        direct_sem = asyncio.Semaphore(1)

        async def _eval_one(case: Dict) -> Dict:
            # Skip cases already completed in a prior interrupted run
            if case["id"] in completed_cases:
                prior = completed_cases[case["id"]]
                if self.verbose:
                    status = "PASS" if prior.get("pass") else "FAIL"
                    print(f"[training-loop]   {status} {case['id']} score={prior.get('score')} (resumed)")
                return prior

            mode = case.get("mode", "hybrid")

            tid: Optional[str] = None
            response: Optional[str] = None

            async def _submit_wait_track() -> Optional[str]:
                nonlocal tid
                # Direct eval uses llama.cpp on a serial local backend. 512-token
                # bounded cases can still need a long prefill/generation window on
                # this hardware, especially behind one queued request.
                _write_progress(run_id, "eval_submit", case_id=case.get("id"), mode=mode)
                http_to = EVAL_DIRECT_TIMEOUT_S if mode == "direct" else 0
                tid = _submit_task(case["query"], mode=mode, http_timeout_secs=http_to)
                if not tid:
                    return None
                if self.verbose:
                    print(f"[training-loop]   submitted {case['id']} → {tid}")
                _write_progress(run_id, "eval_wait", case_id=case.get("id"), mode=mode, task_id=tid)
                return await _wait_for_task(tid, timeout_s=self.task_timeout)

            if mode == "direct":
                # Serialized: only one direct request in-flight at a time
                async with direct_sem:
                    response = await _submit_wait_track()
            else:
                response = await _submit_wait_track()

            if response is None:
                error = "timeout_or_failed" if tid else "submit_failed"
                result = {**_score_response("", case), "task_id": tid, "error": error}
            else:
                result = _score_response(response, case)

            # Close the loop on FAILURES: a real model response that scored sub-threshold is an ideal
            # correction target (we know the expected keywords). Capture it so aq-correct-failures →
            # HITL → dataset can learn from it — the loop previously learned only from wins. Skip infra
            # submit-failures (response is None): those are not model knowledge misses. Best-effort.
            if response is not None and not result.get("pass"):
                try:
                    from training_capture import capture_failure
                    capture_failure(
                        prompt=case["query"],
                        bad_output=response or "",
                        failure_class="eval_low_score",
                        source="training-loop-eval",
                        tools_available=None,
                    )
                except Exception as exc:  # noqa: BLE001
                    print(f"[training-loop] WARNING: failure capture failed: {exc}",
                          file=sys.stderr)

            if self.verbose:
                status = "PASS" if result.get("pass") else "FAIL"
                print(f"[training-loop]   {status} {case['id']} score={result.get('score')}")
            _write_progress(
                run_id,
                "eval_case_done",
                case_id=case.get("id"),
                mode=mode,
                passed=bool(result.get("pass")),
                score=result.get("score"),
            )

            # Checkpoint after each task so partial progress survives interruption
            _checkpoint_save(run_id, {case["id"]: result})
            return result

        scores: List[Dict] = []
        scores = await asyncio.gather(*[_eval_one(c) for c in cases])

        # R1.2: abstentions (infra-noise, from the certified scorer) are NOT
        # capability results — exclude them from the pass/fail denominator so
        # contention/timeouts can't fake a regression (complements the prompt-5
        # degraded_infra path).
        abstained = [s for s in scores if s.get("abstain")]
        scored   = [s for s in scores if not s.get("abstain")]
        passing  = [s for s in scored if s.get("pass")]
        failing  = [s for s in scored if not s.get("pass")]
        # Infra failures (dispatch timeout / submit failure) are NOT model misses.
        infra_fail = [s for s in scores if s.get("error") in ("timeout_or_failed", "submit_failed")] + abstained
        pass_rate = len(passing) / max(len(scored), 1)
        print(f"[training-loop]   pass {len(passing)}/{len(scored)} ({pass_rate:.0%})"
              + (f" [{len(abstained)} abstained/infra]" if abstained else "")
              + (f" [scorer {'CERTIFIED' if getattr(self, '_scorer_certified', None) else 'UNCERTIFIED'}]"))
        _write_progress(run_id, "improve", pass_count=len(passing), fail_count=len(failing), cases_total=len(scores))

        # If infra failures dominate (contention/timeouts mid-run), this run is
        # DEGRADED INFRA, not a model regression: record pass_rate=None so the
        # health-spider / dashboard alarm does not fire a false collapse, and
        # skip the improve/capture phases (nothing real to learn from noise).
        _infra_degraded = (
            not self.dry_run
            and scores
            and len(infra_fail) >= max(1, len(scores) // 2)
            and len(passing) == 0
        )
        if _infra_degraded:
            print(f"[training-loop] {len(infra_fail)}/{len(scores)} infra-failures with 0 passes — "
                  f"recording DEGRADED_INFRA, not a regression", file=sys.stderr)
            _write_progress(run_id, "degraded_infra", infra_failures=len(infra_fail), cases_total=len(scores))
            report = {
                "run_id": run_id, "timestamp": _now(), "eval_pack": str(self.eval_pack.name),
                "status": "degraded_infra", "reason": "slot_contention_mid_run",
                "cases_total": len(scores), "pass_count": 0,
                "fail_count": 0, "infra_failures": len(infra_fail), "pass_rate": None,
                "ingest": {"samples_added": ingest_report.get("positive_samples_added", 0),
                           "dataset_total": ingest_report.get("dataset_total", 0)},
                "improvements_proposed": 0, "dry_run": self.dry_run,
            }
            _persist_result(report)
            return report

        # ── 4. IMPROVE ─────────────────────────────────────────────────────────
        improvements: List[Dict] = []
        if failing:
            print(f"[training-loop] Phase 4: generating improvements for {len(failing)} failures")
            improve_prompt = _generate_improvement_prompt(failing, ingest_report)
            improve_tid = _submit_task(improve_prompt, mode="hybrid")
            if improve_tid:
                improve_response = await _wait_for_task(improve_tid, timeout_s=self.task_timeout)
                if improve_response:
                    # Parse JSON array from response (may be wrapped in markdown).
                    try:
                        start = improve_response.find("[")
                        end   = improve_response.rfind("]") + 1
                        if start >= 0 and end > start:
                            improvements = json.loads(improve_response[start:end])
                    except (json.JSONDecodeError, ValueError):
                        improvements = [{"raw": improve_response[:500]}]
                    if self.verbose:
                        print(f"[training-loop]   {len(improvements)} improvement proposals")

        # ── 5. VALIDATE ────────────────────────────────────────────────────────
        # (Placeholder for a future re-run-with-improvements cycle.
        # Full implementation deferred — needs switchboard profile hot-reload.)
        validated_improvements: List[Dict] = []
        if improvements and not self.dry_run:
            # For now, log improvements as pending proposals for human review.
            proposals_path = TELEMETRY_DIR / "optimization_proposals.jsonl"
            for imp in improvements:
                proposal = {
                    "proposal_id": f"loop-{run_id}-{len(validated_improvements)}",
                    "proposal_type": "training_loop_finding",
                    "title": imp.get("root_cause", str(imp)[:60]),
                    "rationale": imp.get("change_description", ""),
                    "evidence": {
                        "failing_cases": [s["case_id"] for s in failing],
                        "expected_keyword_gains": imp.get("expected_keyword_gains", []),
                    },
                    "status": "pending",
                    "approval_required": True,
                    "confidence": imp.get("confidence", 0.5),
                    "created_at": _now(),
                    "source": "aq-local-training-loop",
                }
                validated_improvements.append(proposal)
                with open(proposals_path, "a", encoding="utf-8") as fh:
                    fh.write(json.dumps(proposal) + "\n")

        # ── 6. WRITE RESULTS ───────────────────────────────────────────────────
        result = {
            "run_id": run_id,
            "timestamp": _now(),
            "eval_pack": str(self.eval_pack.name),
            "cases_total": len(cases),
            "pass_count": len(passing),
            "fail_count": len(failing),
            "abstained": len(abstained),
            "pass_rate": round(pass_rate, 3),
            # R1.2: whether the scorer is trustworthy this run. When False, these
            # scores must NOT be trusted to gate ingest/train (reward signal is
            # not certified). Surfaced to the dashboard + downstream automation.
            "scorer_certified": getattr(self, "_scorer_certified", None),
            "scorer_cert_reason": getattr(self, "_scorer_cert_reason", None),
            "ingest": {
                "samples_added": ingest_report.get("positive_samples_added", 0),
                "dataset_total": ingest_report.get("dataset_total", 0),
                "top_failures": list(ingest_report.get("failure_summary", {}).items())[:5],
            },
            "scores": scores,
            "improvements_proposed": len(validated_improvements),
            "dry_run": self.dry_run,
        }

        if not self.dry_run:
            _persist_result(result)

        # PULSE log entry.
        _pulse(f"aq-local-training-loop run {run_id}: "
               f"pass={len(passing)}/{len(cases)}, "
               f"+{ingest_report.get('positive_samples_added', 0)} training samples, "
               f"{len(validated_improvements)} improvement proposals written")

        # Clear checkpoint — run completed successfully, no resume needed
        _checkpoint_clear(run_id)
        _write_progress(
            run_id,
            "complete",
            pass_count=len(passing),
            fail_count=len(failing),
            cases_total=len(cases),
            samples_added=ingest_report.get("positive_samples_added", 0),
            proposals=len(validated_improvements),
        )
        ACTIVE_RUN_ID = None

        return result

    async def run_daemon(self, interval_minutes: int = 60) -> None:
        """Run continuously, once per interval_minutes."""
        print(f"[training-loop] Daemon mode — interval {interval_minutes}m")
        while True:
            try:
                result = await self.run_once()
                print(f"[training-loop] Cycle complete: pass_rate={result.get('pass_rate', '?')}")
            except Exception as exc:
                print(f"[training-loop] ERROR in cycle: {exc}", file=sys.stderr)
            print(f"[training-loop] Sleeping {interval_minutes}m…")
            await asyncio.sleep(interval_minutes * 60)


def _pulse(msg: str) -> None:
    ts = _now()
    entry = f"[{ts}] [aq-local-training-loop] [run]: {msg}\n"
    try:
        with open(PULSE_LOG, "a", encoding="utf-8") as fh:
            fh.write(entry)
    except OSError:
        pass


def _status(n: int = 10) -> None:
    # Check both primary (telemetry) and fallback (delegation) results paths.
    # TELEMETRY_DIR is mode 750 (ai-hybrid:ai-stack) — hyperd can't write there,
    # so run_once() falls back to DELEGATION_DIR/training-loop-results.jsonl.
    _fallback = DELEGATION_DIR / "training-loop-results.jsonl"
    runs: dict = {}
    for path in [RESULTS_LOG, _fallback]:
        if not path.exists():
            continue
        for raw in open(path, encoding="utf-8", errors="replace"):
            try:
                run = json.loads(raw)
                runs[run["run_id"]] = run  # deduplicates by run_id
            except (json.JSONDecodeError, KeyError):
                pass
    if not runs:
        print("No results yet.")
    else:
        for run in sorted(runs.values(), key=lambda r: r.get("timestamp", ""))[-n:]:
            dr = " [dry]" if run.get("dry_run") else ""
            print(
                f"{run['timestamp'][:19]}  {run['run_id']}"
                f"  pass={run['pass_count']}/{run['cases_total']}"
                f"  +{run['ingest']['samples_added']} samples"
                f"  {run['improvements_proposed']} proposals{dr}"
            )

    if not PROGRESS_FILE.exists():
        return
    try:
        progress = json.loads(PROGRESS_FILE.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return
    print(
        "progress "
        f"{progress.get('updated_at', '?')[:19]} "
        f"{progress.get('run_id', '?')} "
        f"phase={progress.get('phase', '?')}"
    )
    for key in ("case_id", "mode", "task_id", "pass_count", "fail_count", "cases_total", "samples_added", "dataset_total"):
        if key in progress:
            print(f"  {key}: {progress[key]}")


# ── CLI ────────────────────────────────────────────────────────────────────────

def _cli() -> None:
    parser = argparse.ArgumentParser(
        description="Local model test/eval/improve loop",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--eval-pack", type=Path, default=DEFAULT_EVAL_PACK,
                        help="Eval pack JSON (default: data/harness-gap-eval-pack.json)")
    parser.add_argument("--mode", choices=["once", "daemon"], default="once",
                        help="Run once or loop as daemon (default: once)")
    parser.add_argument("--interval", type=int, default=60,
                        help="Daemon interval in minutes (default: 60)")
    parser.add_argument("--task-timeout", type=int, default=DEFAULT_TASK_TIMEOUT_S,
                        help=f"Max seconds per local task (default: {DEFAULT_TASK_TIMEOUT_S})")
    parser.add_argument("--dry-run", action="store_true",
                        help="Score and propose but do not write improvements")
    parser.add_argument("--status", action="store_true",
                        help="Print recent run summaries and exit")
    parser.add_argument("--resume", action="store_true",
                        help="Resume the most recent interrupted run from checkpoint")
    parser.add_argument("--verbose", "-v", action="store_true",
                        help="Verbose per-case output")
    args = parser.parse_args()

    if args.status:
        _status()
        return

    # SIGTERM handler: rebuild/shutdown must not hang systemd for a long eval
    # wait. Per-case checkpoints are already written after each completed case;
    # incomplete delegated tasks are reconciled on the next run.
    _shutdown = {"requested": False}

    def _on_sigterm(signum: int, frame: object) -> None:
        print("[training-loop] signal received — writing progress and exiting",
              file=sys.stderr)
        _write_progress(ACTIVE_RUN_ID or "unknown", "stopping", signal=signum)
        _shutdown["requested"] = True
        raise SystemExit(0)

    signal.signal(signal.SIGTERM, _on_sigterm)
    signal.signal(signal.SIGHUP, _on_sigterm)

    loop_runner = TrainingLoop(
        eval_pack=args.eval_pack,
        task_timeout=args.task_timeout,
        dry_run=args.dry_run,
        verbose=args.verbose,
    )

    if args.mode == "daemon":
        asyncio.run(loop_runner.run_daemon(interval_minutes=args.interval))
    else:
        result = asyncio.run(loop_runner.run_once(resume=args.resume))
        print(json.dumps({
            "pass_rate": result.get("pass_rate"),
            "pass": result.get("pass_count"),
            "total": result.get("cases_total"),
            "samples_added": result.get("ingest", {}).get("samples_added"),
            "proposals": result.get("improvements_proposed"),
        }, indent=2))


if __name__ == "__main__":
    _cli()
