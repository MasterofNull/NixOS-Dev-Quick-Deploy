ACTIVE_RUN_ID: Optional[str] = None

# ── helpers ────────────────────────────────────────────────────────────────────

def _now() -> str:
    return datetime.now(timezone.utc).isoformat()


def _load_eval_pack(path: Path) -> List[Dict]:
    with open(path, encoding="utf-8") as fh:
        data = json.load(fh)
    cases = data.get("cases", data) if isinstance(data, dict) else data
    return cases if isinstance(cases, list) else []


def _score_response(response: str, case: Dict) -> Dict[str, Any]:
    """Grade a response using the R1-CERTIFIED exec scorer.

    RSI-Readiness R1.2: delegates to eval_integrity.exec_scorer — exec-based
    where the case declares scoring (json_parse/py_compile), keyword coverage
    otherwise — and ABSTAINS on infra-noise (empty/timeout) instead of scoring a
    false 0. This is the scorer that PASSES the trustworthiness gate; the old
    keyword+length heuristic did not (couldn't discriminate, graded noise). An
    abstained case is excluded from pass/fail so contention can't fake a regression.
    """
    keywords = case.get("expected_keywords", [])
    words = len(response.split())
    try:
        from eval_integrity import exec_scorer  # certified scorer (R1.3)
        r = exec_scorer(response, case)
    except Exception:
        # Fail-safe: if the certified scorer is unavailable, fall back to a
        # conservative keyword+abstain so a bad import never crashes the loop.
        low = response.strip().lower()
        if not low or any(m in low for m in ("queued behind busy", "error: model", "[error:")):
            r = {"score": 0.0, "abstain": True}
        else:
            hit = sum(1 for k in keywords if k.lower() in low)
            r = {"score": round(hit / max(len(keywords), 1), 3), "abstain": False}

    if r.get("abstain"):
        return {"case_id": case.get("id"), "score": None, "abstain": True,
                "word_count": words, "pass": False, "infra_noise": True}
    score = r.get("score", 0.0)
    matched = [k for k in keywords if k.lower() in response.lower()]
    return {
        "case_id": case.get("id"),
        "score": round(score, 3),
        "abstain": False,
        "coverage": round(score, 3),
        "matched_keywords": matched,
        "missing_keywords": [k for k in keywords if k.lower() not in response.lower()],
        "word_count": words,
        "pass": score >= 0.6,
    }


def _certify_scorer() -> "tuple[bool, str]":
    """Run the R1.3 trustworthiness gate on the loop's scorer against the golden
    set. Returns (certified, reason). Fail-safe: any error -> uncertified (never
    silently 'trust'). Missing golden set -> uncertified with guidance."""
    try:
        import eval_integrity as EI
        tasks_p = GOLDEN_DIR / "tasks.json"
        if not tasks_p.exists():
            return False, f"golden set missing at {tasks_p}"
        golden = json.loads(tasks_p.read_text())

        def _adapter(resp: str, task: Dict) -> Dict[str, Any]:
            r = _score_response(resp, task)
            return {"score": r.get("score") or 0.0, "abstain": bool(r.get("abstain"))}

        res = EI.trustworthiness_gate(_adapter, golden, str(GOLDEN_DIR))
        return res.trustworthy, res.reason
    except Exception as exc:  # noqa: BLE001 — uncertified on any failure
        return False, f"certification error: {type(exc).__name__}: {exc}"


def _read_registry() -> List[Dict]:
    if not REGISTRY.exists():
        return []
    entries = []
    for raw in open(REGISTRY, encoding="utf-8", errors="replace"):
        raw = raw.strip()
        if not raw:
            continue
        try:
            entries.append(json.loads(raw))
        except json.JSONDecodeError:
            pass
    return entries


def _mark_registry_status(task_id: str, new_status: str) -> None:
    """Rewrite registry in-place to set task_id's status to new_status."""
    if not REGISTRY.exists():
        return
    lines = []
    for raw in REGISTRY.read_text(encoding="utf-8", errors="replace").splitlines():
        raw = raw.strip()
        if not raw:
            continue
        try:
            entry = json.loads(raw)
            if entry.get("id") == task_id:
                entry["status"] = new_status
            lines.append(json.dumps(entry))
        except json.JSONDecodeError:
            lines.append(raw)
    REGISTRY.write_text("\n".join(lines) + "\n", encoding="utf-8")


def _checkpoint_save(run_id: str, completed: Dict[str, Any]) -> None:
    """Write per-task results to checkpoint so --resume can skip done tasks."""
    try:
        existing: Dict = {}
        if CHECKPOINT_FILE.exists():
            try:
                existing = json.loads(CHECKPOINT_FILE.read_text())
            except (json.JSONDecodeError, OSError):
                pass
        existing.setdefault(run_id, {}).update(completed)
        CHECKPOINT_FILE.write_text(json.dumps(existing, indent=2))
    except OSError:
        pass  # non-fatal — checkpoint is a best-effort optimisation


def _checkpoint_load(run_id: str) -> Dict[str, Any]:
    """Return {case_id: score_dict} for cases already completed in run_id."""
    try:
        if CHECKPOINT_FILE.exists():
            data = json.loads(CHECKPOINT_FILE.read_text())
            return data.get(run_id, {})
    except (json.JSONDecodeError, OSError):
        pass
    return {}


def _checkpoint_clear(run_id: str) -> None:
    """Remove checkpoint entry once a run completes successfully."""
    try:
        if not CHECKPOINT_FILE.exists():
            return
        data = json.loads(CHECKPOINT_FILE.read_text())
        data.pop(run_id, None)
        CHECKPOINT_FILE.write_text(json.dumps(data, indent=2))
    except (json.JSONDecodeError, OSError):
        pass


def _write_progress(run_id: str, phase: str, **fields: Any) -> None:
    """Best-effort progress sidecar for long systemd/timer runs."""
    payload = {
        "run_id": run_id,
        "phase": phase,
        "updated_at": _now(),
        **fields,
    }
    try:
        PROGRESS_FILE.parent.mkdir(parents=True, exist_ok=True)
        tmp = PROGRESS_FILE.with_suffix(PROGRESS_FILE.suffix + ".tmp")
        tmp.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
        tmp.replace(PROGRESS_FILE)
    except OSError:
        pass


def _task_age_seconds(task_id: str) -> Optional[float]:
    """
    Parse submission time from task ID (format: local-YYYYMMDD-HHMMSS-xxx).
    Returns age in seconds, or None if ID format doesn't match.
    """
    from datetime import datetime as _dt
    parts = task_id.split("-")
    # expect: ['local', 'YYYYMMDD', 'HHMMSS', 'xxx']
    if len(parts) < 4:
        return None
    try:
        ts = _dt.strptime(f"{parts[1]}-{parts[2]}", "%Y%m%d-%H%M%S")
        age = (_dt.now() - ts).total_seconds()
        return age
    except (ValueError, IndexError):
        return None


def _reap_orphans() -> int:
    """
    Layer 2: invoke the canonical registry reconciler to mark dead-PID 'running'
    entries as 'stale'.  Falls back to an inline sweep if the tool is unavailable.

    Also cancels live-PID tasks whose age exceeds DEFAULT_TASK_TIMEOUT_S — these
    are ghost processes from previously killed training runs that still hold the
    llama.cpp slot.

    Returns count of entries reaped.
    """
    reaped = 0

    # Phase A: reconcile dead PIDs via canonical tool
    registry_tool = _SCRIPT_DIR / "aq-delegation-registry"
    if registry_tool.exists():
        try:
            result = subprocess.run(
                [str(registry_tool), "reconcile"],
                capture_output=True, text=True, timeout=10,
            )
            out = result.stdout.strip()
            if out:
                data = json.loads(out)
                reaped += int(data.get("stale_marked", 0))
        except Exception as exc:
            print(f"[reap] registry tool failed, falling back inline: {exc}", file=sys.stderr)
            # Inline fallback: scan + mark dead PIDs as 'stale'
            for entry in _read_registry():
                if entry.get("status") != "running":
                    continue
                pid = entry.get("pid")
                if not pid:
                    continue
                try:
                    os.kill(int(pid), 0)
                except ProcessLookupError:
                    _mark_registry_status(entry["id"], "stale")
                    print(f"[reap] stale: {entry['id']} pid={pid} dead", file=sys.stderr)
                    reaped += 1
                except (PermissionError, ValueError):
                    pass

    # Phase B: report old live tasks without cancelling them. Local inference is
    # slow and serial on this hardware; age alone is not a failure signal. The
    # wait loop cancels only when liveness/progress says a task is stale, or when
    # AQ_LOOP_RUNAWAY_HARD_CAP is explicitly set.
    now_entries = _read_registry()
    for entry in now_entries:
        if entry.get("status") != "running":
            continue
        age = _task_age_seconds(entry["id"])
        if age is None or age <= DEFAULT_TASK_TIMEOUT_S:
            continue
        print(
            f"[reap] live-aged: {entry['id']} age={age:.0f}s > {DEFAULT_TASK_TIMEOUT_S}s, keeping live",
            file=sys.stderr,
        )

    return reaped


def _read_output(output_file: str) -> str:
    path = Path(output_file)
    if not path.exists():
        return ""
    return path.read_text(encoding="utf-8", errors="replace")


def _artifact_newest_mtime(output_file: Optional[Path]) -> float:
    """Newest mtime for output/progress/heartbeat/steps artifacts."""
    if output_file is None:
        return 0.0
    paths = [
        output_file,
        Path(str(output_file) + ".progress.json"),
        Path(str(output_file) + ".heartbeat.json"),
        Path(str(output_file) + ".steps.jsonl"),
    ]
    newest = 0.0
    for path in paths:
        try:
            newest = max(newest, path.stat().st_mtime)
        except OSError:
            continue
    return newest


