#!/usr/bin/env python3
"""aq-slice-claim — atomic single-owner slice claim.

Fixes the structural gap that let two orchestration loops (Fable + Codex)
independently claim and build the same slice (L2B-B, tier0-isolation),
producing duplicate/tangled work. DESIGN SSOT:
`.agents/plans/agent-agnostic-factory/DESIGN.md` §3 item 1.

CAS primitive: reuses the exact atomic-rename pattern from
`scripts/ai/aq-antigravity-inbox::cmd_claim` — same-filesystem
`Path.rename()` can only succeed once, so two racing claimants cannot both
win. Here the rename target is the claim file itself: a claim is created
with `os.open(..., O_CREAT | O_EXCL)` (the create-side CAS — there is no
pre-existing "pending" file to rename the way the inbox lane has one) and
released/reclaimed by removing that file. Fail-closed throughout: any
unexpected OSError during the CAS refuses the operation rather than
silently allowing a double-claim.

Stale-claim reclaim additionally serializes against every other mutation
of the same slice's claim file via a per-slice advisory `flock` (see
`_locked_claim`): both `_write_claim_exclusive` (fresh O_CREAT|O_EXCL
create) and `_reclaim_stale` (expired-claim rename) take this lock before
touching a given claim path, so a reclaimer's "is this still expired?"
check and the rename that acts on it happen as one atomic step relative to
every other claimant — no other thread can install or evict a claim at
that path in between. This closes a narrow TOCTOU where an unlocked
read-then-unlink-by-path (or an unlocked read-then-rename) could let a
"straggler" reclaimer — one holding a now-outdated read of an
already-expired claim — clobber a claim a different actor legitimately
installed in the meantime. See
`.agents/plans/agent-agnostic-factory/ROUTER-CORE-ACCEPTANCE.md` Item 1.

No network, no credentials.
"""

from __future__ import annotations

import argparse
import contextlib
import fcntl
import json
import os
import sys
import time
import uuid
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

REPO = Path(__file__).resolve().parents[2]
CLAIMS_DIR = REPO / ".agent" / "collaboration" / "slice-claims"

DEFAULT_TTL_SECONDS = 4 * 60 * 60  # 4h — long enough for a bounded implementer slice


def _now() -> float:
    return time.time()


def _now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def _rel(path: Path) -> str:
    try:
        return str(path.relative_to(REPO))
    except ValueError:
        return str(path)


def _claim_path(slice_id: str) -> Path:
    # slice_id is used as a bare filename component only — no path separators
    # allowed, so a crafted slice-id cannot traverse outside CLAIMS_DIR.
    if "/" in slice_id or "\\" in slice_id or slice_id in (".", ".."):
        raise ValueError(f"invalid slice-id: {slice_id!r}")
    return CLAIMS_DIR / f"{slice_id}.claim"


def _load_claim(path: Path) -> dict[str, Any] | None:
    try:
        raw = path.read_text(encoding="utf-8")
    except FileNotFoundError:
        return None
    try:
        data = json.loads(raw)
    except json.JSONDecodeError:
        return {"_corrupt": True}
    return data if isinstance(data, dict) else {"_corrupt": True}


def _is_expired(claim: dict[str, Any]) -> bool:
    expires = claim.get("expires")
    if not isinstance(expires, (int, float)):
        return False
    return _now() >= expires


def _emit(payload: dict[str, Any], as_json: bool) -> int:
    if as_json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        for key, value in payload.items():
            if isinstance(value, (dict, list)):
                value = json.dumps(value, sort_keys=True)
            print(f"{key}: {value}")
    return 0 if payload.get("ok", True) else 1


def _slice_lock_path(path: Path) -> Path:
    return path.with_name(f".{path.name}.lock")


@contextlib.contextmanager
def _locked_claim(path: Path):
    """Serialize every mutation of ONE slice's claim file against every
    other mutation of that same claim file, via a per-slice advisory
    `flock`. Both `_write_claim_exclusive` (fresh O_CREAT|O_EXCL create)
    and `_reclaim_stale` (expired-claim rename) take this lock before
    touching `path`.

    This is what makes `_reclaim_stale`'s "is this claim still expired?"
    check race-safe against the rename that immediately follows it: while
    the lock is held, no other thread can be inside its own locked section
    for the same path, so nothing else can install a fresh claim (a
    concurrent create) or evict/replace the current one (a concurrent
    reclaim) between the check and the rename. What the check observes is
    still true one Python statement later — there is no read-then-act gap
    left to race, unlike a plain read that isn't lock-protected.

    Advisory `flock` is sufficient here (not `fcntl.lockf`/POSIX record
    locks) because every mutator in this file — the only writers of claim
    paths — goes through this same helper; nothing outside this process
    family touches `.agent/collaboration/slice-claims/`. `cmd_release`'s
    unlink is intentionally NOT lock-gated: it races safely against a
    concurrent reclaim's rename because unlink() and rename() are each
    individually atomic on the same directory entry — whichever runs first
    wins cleanly and the other gets FileNotFoundError, with no torn state
    possible either way.
    """
    lock_path = _slice_lock_path(path)
    lock_path.parent.mkdir(parents=True, exist_ok=True)
    fd = os.open(str(lock_path), os.O_CREAT | os.O_RDWR, 0o644)
    try:
        fcntl.flock(fd, fcntl.LOCK_EX)
        yield
    finally:
        try:
            fcntl.flock(fd, fcntl.LOCK_UN)
        except OSError:
            pass
        os.close(fd)


def _write_claim_exclusive(path: Path, record: dict[str, Any]) -> bool:
    """Create `path` iff it does not already exist. O_CREAT|O_EXCL open is
    the atomic create-side CAS primitive (POSIX guarantees the open()
    syscall itself is the exclusivity check — no separate exists()-then-
    create() race window). Mirrors the rename-based CAS in
    aq-antigravity-inbox but for a from-scratch claim file rather than an
    already-existing pending drop. Fail-closed: any OSError other than
    "already exists" propagates so the caller refuses to proceed.

    Runs inside `_locked_claim` alongside `_reclaim_stale` — see that
    function's docstring for why a fresh create needs to serialize against
    a concurrent stale-reclaim on the same path.
    """
    path.parent.mkdir(parents=True, exist_ok=True)
    with _locked_claim(path):
        fd = None
        try:
            fd = os.open(str(path), os.O_CREAT | os.O_EXCL | os.O_WRONLY, 0o644)
        except FileExistsError:
            return False
        try:
            with os.fdopen(fd, "w", encoding="utf-8") as fh:
                fh.write(json.dumps(record, indent=2, sort_keys=True) + "\n")
        except OSError:
            # Fail-closed: writing the payload failed after create — remove
            # the partial claim rather than leave a corrupt lock nobody can
            # trust.
            try:
                path.unlink()
            except OSError:
                pass
            raise
        return True


def _reclaim_stale(path: Path, slice_id: str) -> dict[str, Any] | None:
    """Atomically remove an expired claim so a fresh acquire can proceed.

    RACE-SAFETY (lock-protected re-verify-then-rename, not a bare
    read-then-unlink/rename-by-path):

    An earlier version of this function read the claim, confirmed it was
    expired, then unlinked (and later, a still-unsafe revision, renamed) it
    BY PATH with no synchronization against other mutators. That action was
    not protected from a concurrent actor installing a FRESH claim at the
    same path between the confirming read and the unlink/rename — the
    unlink/rename would then destroy that fresh claim instead, silently
    clobbering a legitimate holder (the exact double-claim this tool exists
    to prevent). Worse, a purely content-bound "rename blind, then detect a
    mismatch and try to restore" design still has a residual gap: the
    restore itself can lose to a THIRD concurrent actor grabbing the
    momentarily-freed path, permanently orphaning whichever claim got
    caught in the shuffle — confirmed empirically under real multi-thread
    contention (a raw stress harness with 6 racing threads against one
    already-expired claim reproduced two believed-holders in ~5% of runs
    before this fix). See
    `.agents/plans/agent-agnostic-factory/ROUTER-CORE-ACCEPTANCE.md` Item 1.

    Fix: hold `_locked_claim(path)` across BOTH the expiry re-check and the
    rename that acts on it. Because every mutator of this path (this
    function and `_write_claim_exclusive`) takes the same per-slice lock,
    nothing else can be mid-mutation of `path` while we hold it — so the
    fact we just observed ("this claim is expired") is still true at the
    very next statement, and the rename can never grab anything other than
    exactly the expired claim we just confirmed. No post-hoc content
    comparison or restore-on-mismatch is needed, because there is nothing
    left to mismatch: by construction, whatever is at `path` when the
    rename executes IS what `_load_claim` just read, one statement earlier,
    under the same lock.

    If a straggler reaches this function after the world has already moved
    on (someone else reclaimed it, or a fresh claim was installed on a now-
    free path), its lock-protected re-read sees that directly — either
    `path` is gone (`_load_claim` returns `None`) or it holds a non-expired
    claim — and it no-ops without ever attempting a rename. Nothing is ever
    evicted "speculatively."

    Any OSError other than the expected FileNotFoundError propagates
    (fail-closed) rather than being silently swallowed, matching the
    contract `_write_claim_exclusive` uses elsewhere in this file.
    """
    with _locked_claim(path):
        claim = _load_claim(path)
        if claim is None or not _is_expired(claim):
            return None  # already gone, or already replaced by a fresh claim

        tmp_path = path.with_name(f".{path.name}.reclaim.{os.getpid()}.{uuid.uuid4().hex}")
        try:
            os.rename(path, tmp_path)
        except FileNotFoundError:
            # Should not happen under the lock (nothing else can be
            # concurrently mutating `path`), but fail closed rather than
            # assume success if it somehow does.
            return None
        try:
            tmp_path.unlink()
        except OSError:
            pass  # non-fatal cleanup — path is free either way
        return claim


def cmd_acquire(args: argparse.Namespace) -> int:
    slice_id = args.slice_id
    owner = args.owner
    ttl = args.ttl if args.ttl and args.ttl > 0 else DEFAULT_TTL_SECONDS
    try:
        path = _claim_path(slice_id)
    except ValueError as exc:
        return _emit({"ok": False, "reason": "invalid-slice-id", "error": str(exc)}, args.json)

    record = {
        "slice_id": slice_id,
        "owner": owner,
        "head": args.head,
        "ts": _now_iso(),
        "acquired_at": _now(),
        "expires": _now() + ttl,
        "ttl_seconds": ttl,
    }

    try:
        created = _write_claim_exclusive(path, record)
    except OSError as exc:
        # Fail-closed: CAS mechanism itself broke (disk/dir issue) — refuse
        # rather than assume we're safe to proceed unclaimed.
        return _emit(
            {"ok": False, "reason": "cas-error", "error": str(exc), "slice_id": slice_id}, args.json
        )

    if created:
        return _emit(
            {
                "ok": True,
                "slice_id": slice_id,
                "owner": owner,
                "claim": _rel(path),
                "expires": record["expires"],
                "reason": "acquired",
            },
            args.json,
        )

    # Claim file already exists — inspect it. It may be held (fail with the
    # current owner's identity) or stale/expired (reclaim once, then retry
    # the exclusive create exactly once more).
    existing = _load_claim(path)
    if existing is not None and not existing.get("_corrupt") and _is_expired(existing):
        try:
            reclaimed = _reclaim_stale(path, slice_id)
        except OSError as exc:
            # Fail-closed: the reclaim's CAS machinery itself broke — refuse
            # rather than assume it's safe to proceed as if unclaimed.
            return _emit(
                {"ok": False, "reason": "cas-error", "error": str(exc), "slice_id": slice_id},
                args.json,
            )
        if reclaimed is not None:
            try:
                created = _write_claim_exclusive(path, record)
            except OSError as exc:
                return _emit(
                    {"ok": False, "reason": "cas-error", "error": str(exc), "slice_id": slice_id},
                    args.json,
                )
            if created:
                return _emit(
                    {
                        "ok": True,
                        "slice_id": slice_id,
                        "owner": owner,
                        "claim": _rel(path),
                        "expires": record["expires"],
                        "reason": "acquired-after-stale-reclaim",
                        "previous_owner": reclaimed.get("owner"),
                    },
                    args.json,
                )
        # Lost the reclaim race — fall through to reporting current holder below.
        existing = _load_claim(path)

    if existing is None:
        # Vanished between exclusive-create failure and read (released by
        # holder concurrently) — fail closed rather than assume it's free;
        # caller should retry.
        return _emit(
            {"ok": False, "reason": "transient-race-retry", "slice_id": slice_id}, args.json
        )

    if existing.get("_corrupt"):
        # Fail-closed: cannot verify current holder identity from a corrupt
        # claim file — refuse rather than silently overwrite.
        return _emit(
            {"ok": False, "reason": "corrupt-claim-refuse", "slice_id": slice_id, "claim": _rel(path)},
            args.json,
        )

    return _emit(
        {
            "ok": False,
            "reason": "already-held",
            "slice_id": slice_id,
            "current_owner": existing.get("owner"),
            "current_head": existing.get("head"),
            "held_since": existing.get("ts"),
            "expires": existing.get("expires"),
        },
        args.json,
    )


def cmd_release(args: argparse.Namespace) -> int:
    slice_id = args.slice_id
    owner = args.owner
    try:
        path = _claim_path(slice_id)
    except ValueError as exc:
        return _emit({"ok": False, "reason": "invalid-slice-id", "error": str(exc)}, args.json)

    existing = _load_claim(path)
    if existing is None:
        return _emit({"ok": False, "reason": "no-such-claim", "slice_id": slice_id}, args.json)
    if existing.get("_corrupt"):
        return _emit(
            {"ok": False, "reason": "corrupt-claim-refuse", "slice_id": slice_id}, args.json
        )
    if existing.get("owner") != owner:
        # Only the holder releases — fail-closed against a non-holder
        # clearing someone else's active claim.
        return _emit(
            {
                "ok": False,
                "reason": "not-holder",
                "slice_id": slice_id,
                "current_owner": existing.get("owner"),
                "requested_by": owner,
            },
            args.json,
        )

    try:
        path.unlink()
    except FileNotFoundError:
        return _emit({"ok": False, "reason": "no-such-claim", "slice_id": slice_id}, args.json)

    return _emit({"ok": True, "slice_id": slice_id, "owner": owner, "reason": "released"}, args.json)


def cmd_status(args: argparse.Namespace) -> int:
    slice_id = args.slice_id
    try:
        path = _claim_path(slice_id)
    except ValueError as exc:
        return _emit({"ok": False, "reason": "invalid-slice-id", "error": str(exc)}, args.json)

    existing = _load_claim(path)
    if existing is None:
        return _emit({"ok": True, "slice_id": slice_id, "held": False}, args.json)
    if existing.get("_corrupt"):
        return _emit(
            {"ok": True, "slice_id": slice_id, "held": True, "corrupt": True}, args.json
        )
    return _emit(
        {
            "ok": True,
            "slice_id": slice_id,
            "held": not _is_expired(existing),
            "expired": _is_expired(existing),
            "owner": existing.get("owner"),
            "head": existing.get("head"),
            "ts": existing.get("ts"),
            "expires": existing.get("expires"),
        },
        args.json,
    )


def cmd_list(args: argparse.Namespace) -> int:
    if not CLAIMS_DIR.exists():
        return _emit({"ok": True, "claims": []}, args.json)
    claims = []
    for path in sorted(CLAIMS_DIR.glob("*.claim")):
        data = _load_claim(path)
        if data is None:
            continue
        if data.get("_corrupt"):
            claims.append({"slice_id": path.stem, "corrupt": True})
            continue
        claims.append(
            {
                "slice_id": data.get("slice_id", path.stem),
                "owner": data.get("owner"),
                "head": data.get("head"),
                "ts": data.get("ts"),
                "expires": data.get("expires"),
                "expired": _is_expired(data),
            }
        )
    return _emit({"ok": True, "claims": claims}, args.json)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    sub = parser.add_subparsers(dest="cmd", required=True)

    acquire = sub.add_parser("acquire", help="Atomically claim a slice (CAS, fail-closed)")
    acquire.add_argument("slice_id")
    acquire.add_argument("--owner", required=True)
    acquire.add_argument("--head", default=None, help="Commit/hash the claim is scoped to")
    acquire.add_argument("--ttl", type=int, default=DEFAULT_TTL_SECONDS, help="Claim TTL in seconds")
    acquire.add_argument("--json", action="store_true")
    acquire.set_defaults(func=cmd_acquire)

    release = sub.add_parser("release", help="Release a held slice (holder only)")
    release.add_argument("slice_id")
    release.add_argument("--owner", required=True)
    release.add_argument("--json", action="store_true")
    release.set_defaults(func=cmd_release)

    status = sub.add_parser("status", help="Show a single slice's claim state")
    status.add_argument("slice_id")
    status.add_argument("--json", action="store_true")
    status.set_defaults(func=cmd_status)

    listp = sub.add_parser("list", help="List all known claims")
    listp.add_argument("--json", action="store_true")
    listp.set_defaults(func=cmd_list)

    return parser


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    return int(args.func(args))


if __name__ == "__main__":
    raise SystemExit(main())
