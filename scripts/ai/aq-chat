    def _build_fast_path_payload(self, messages: List[Dict[str, str]]) -> Dict[str, Any]:
        """Build switchboard payload for conversational fast-path turns.

        All 4 required fields must be set explicitly:
          - stream: True  (switchboard forces SSE for local targets; be explicit — Phase 109.1)
          - max_tokens: 1024  (continue-local has no ceiling; caller controls)
          - chat_template_kwargs: {"enable_thinking": False}  (Qwen3 CRITICAL — not top-level)
          - frequency_penalty: 0.0  (prevents token blackout on dense output — MEMORY.md pattern)
        """
        local_model_id = os.getenv("AI_LOCAL_MODEL_ID", "local")
        return {
            "model": local_model_id,
            "messages": messages,
            "stream": True,                                      # CRITICAL — Phase 109.1
            "stream_options": {"include_usage": True},           # Phase 173: token counts in final SSE chunk
            "max_tokens": 1024,                                  # CRITICAL — no ceiling otherwise
            "temperature": self.temperature,
            "frequency_penalty": 0.0,                            # CRITICAL — prevent token blackout
            "chat_template_kwargs": {"enable_thinking": False},  # CRITICAL — Qwen3 thinking tokens
        }

    async def _write_routing_event(self, event: Dict[str, Any]) -> None:
        """Fire-and-forget routing event write to agent-run-events.jsonl."""
        try:
            # Import harness_paths SSOT; fall back to env var or absolute production path.
            try:
                _local_agents = REPO_ROOT / "ai-stack" / "local-agents"
                if str(_local_agents) not in sys.path:
                    sys.path.insert(0, str(_local_agents))
                from harness_paths import AGENT_RUN_EVENTS as _events_path
                path = Path(str(_events_path))
            except ImportError:
                path = Path(os.environ.get(
                    "AQ_AGENT_RUN_EVENTS_PATH",
                    "/var/lib/ai-stack/hybrid/telemetry/agent-run-events.jsonl",
                ))
            path.parent.mkdir(parents=True, exist_ok=True)
            with open(path, "a", encoding="utf-8") as fh:
                fh.write(json.dumps(event) + "\n")
        except Exception:
            pass  # fire-and-forget: never raise

    async def _stream_fast_path(
        self, prompt: str, messages: List[Dict[str, str]]
    ) -> None:
        """Conversational fast-path: POST directly to switchboard continue-local profile.

        Bypasses the coordinator delegate (~50s overhead) for turns classified as
        conversational (no tool calls needed). Uses SSE parsing — never response.json().

        Emits a routing_decision event before the HTTP request (Phase D.4).
        """
        classification = classify_chat_intent(prompt)
        wire_profile = "continue-local"
        self._wire_profile = wire_profile

        # D.4 — routing event BEFORE HTTP request (fire-and-forget)
        asyncio.create_task(self._write_routing_event({
            "event_type": "routing_decision",
            "task_id": self._session_id,
            "path": "fast_path",
            "profile": wire_profile,
            "classification": classification.mode,
            "matched_phrase": classification.matched_phrase,
            "seq": self._next_routing_seq(),
            "ts": time.time(),
        }))

        # Phase 174: inject harness hints into fast-path turns.
        # Fast-path bypasses coordinator semantic tooling entirely. This lightweight
        # /hints call (2s timeout, returns empty on failure) enriches the system
        # prompt with AIDB-derived patterns before the model sees the turn.
        hints = await self._fetch_fast_path_hints(prompt)
        if hints:
            fp_messages = list(messages)
            if fp_messages and fp_messages[0].get("role") == "system":
                fp_messages[0] = {
                    "role": "system",
                    "content": fp_messages[0]["content"] + f"\n\n[HARNESS HINTS]\n{hints}",
                }
            else:
                fp_messages.insert(0, {"role": "system", "content": f"[HARNESS HINTS]\n{hints}"})
        else:
            fp_messages = messages

        target_url = f"{self.switchboard_url}/v1/chat/completions"
        headers = {
            "X-Agent-Source": "aq-chat",
            "X-Agent-Role": "orchestrator",
            "X-Agent-Boundary": "human_gate",
            "X-AI-Profile": wire_profile,
        }
        payload = self._build_fast_path_payload(fp_messages)

        try:
            full_response = ""
            _fp_tok_in: int = 0
            _fp_tok_out: int = 0
            _fp_t0 = time.perf_counter()
            self.is_thinking = False
            print()
            async with self.client.stream("POST", target_url, json=payload, headers=headers) as response:
                if response.status_code != 200:
                    detail = self._response_error_detail(response)
                    suffix = f" {detail}" if detail else ""
                    console.print(
                        f"[bold red]Fast-path error: {response.status_code} from switchboard.[/]{suffix}"
                    )
                    # Fall through gracefully — caller can retry via coordinator
                    return

                async for line in response.aiter_lines():
                    if self.interrupt_event.is_set():
                        console.print("\n[bold yellow]Interrupted![/]")
                        break
                    if not line.startswith("data: "):
                        continue
                    content = line[6:]
                    if content.strip() == "[DONE]":
                        break
                    try:
                        chunk = json.loads(content)
                    except json.JSONDecodeError:
                        continue
                    # Capture token usage from final SSE usage chunk (Phase 173)
                    _usage = chunk.get("usage") or {}
                    if _usage:
                        _fp_tok_in = int(_usage.get("prompt_tokens") or 0)
                        _fp_tok_out = int(_usage.get("completion_tokens") or 0)
                    token = (
                        (chunk.get("choices") or [{}])[0]
                        .get("delta", {})
                        .get("content", "") or ""
                    )
                    if "<think>" in token or "<thought>" in token:
                        self.is_thinking = True
                        continue
                    elif "</think>" in token or "</thought>" in token:
                        self.is_thinking = False
                        continue
                    full_response += token
                    if not self.is_thinking:
                        print(token, end="", flush=True)

            _fp_latency_ms = round((time.perf_counter() - _fp_t0) * 1000, 1)
            print()
            self._last_turn_had_tool_calls = False
            self._record_response(prompt, full_response)
            # Phase 173: emit local_inference training event for fast-path turns.
            # Fast-path bypasses coordinator delegate (ai_coordinator_handlers.py Phase 110.1),
            # so this is the only site that can emit for continue-local turns.
            if full_response.strip():
                asyncio.create_task(self._emit_local_inference_event(
                    query=prompt,
                    response=full_response,
                    profile=wire_profile,
                    latency_ms=_fp_latency_ms,
                    tok_in=_fp_tok_in or None,
                    tok_out=_fp_tok_out or None,
                ))
            self._write_feedback_turn(fast_path=True)
        except asyncio.CancelledError:
            console.print("\n[dim]Interrupted.[/]")
            raise
        except Exception as e:
            console.print(f"[bold red]Fast-path error: {e}[/]")

    def _write_feedback_turn(self, fast_path: bool = False) -> None:
        """Internal: record per-turn metadata to feedback log (no rating — use /rate for that)."""
        # This is NOT the same as _write_feedback() which records explicit /rate commands.
        # It records routing decisions so training_ingest can correlate profile → quality.
        # Intentionally lightweight — no I/O on every turn, only when explicitly rating.
        pass  # placeholder: called from _stream_fast_path for future telemetry hooks

    async def _fetch_fast_path_hints(self, query: str) -> str:
        """Fetch top-2 harness hints for fast-path turns via coordinator /hints endpoint.

        Phase 174: Fast-path bypasses coordinator semantic tooling entirely, so the
        model never receives AIDB-derived hints. This adds a lightweight /hints call
        (~100-200ms) to enrich the system prompt before forwarding to switchboard.
        Returns empty string on any failure — never blocks the turn.
        """
        try:
            import urllib.parse
            q = urllib.parse.quote(query[:200])
            async with httpx.AsyncClient(timeout=2.0) as c:
                api_key_path = "/run/secrets/hybrid_coordinator_api_key"
                api_key = ""
                try:
                    api_key = Path(api_key_path).read_text().strip()
                except Exception:
                    pass
                hdrs = {"X-API-Key": api_key} if api_key else {}
                r = await c.get(f"{self.hybrid_url}/hints?q={q}&limit=2", headers=hdrs)
                if r.status_code != 200:
                    return ""
                data = r.json()
                hints = data.get("hints", []) if isinstance(data, dict) else []
                snippets = [
                    str(h.get("snippet") or h.get("text") or "").strip()
                    for h in hints
                    if isinstance(h, dict)
                ]
                return "\n".join(s for s in snippets if s)
        except Exception:
            return ""

    async def _emit_local_inference_event(
        self,
        query: str,
        response: str,
        profile: str,
        latency_ms: float = 0.0,
        tok_in: Optional[int] = None,
        tok_out: Optional[int] = None,
    ) -> None:
        """Write a local_inference event to hybrid-events.jsonl for training ingest.

        Phase 173: Fills the fast-path training dark path. The coordinator delegate path
        emits these events via ai_coordinator_handlers.py Phase 110.1, but the fast-path
        (continue-local → switchboard direct) bypasses the coordinator entirely.
        """
        import datetime as _dt
        tel_path = Path(os.getenv("TELEMETRY_DIR", "/var/lib/ai-stack/hybrid/telemetry")) / "hybrid-events.jsonl"
        evt = json.dumps({
            "event_type": "local_inference",
            "timestamp": _dt.datetime.now(_dt.timezone.utc).isoformat().replace("+00:00", "Z"),
            "query": query[:4000],
            "response": response[:4000],
            "model": os.getenv("AI_LOCAL_MODEL_ID", "local"),
            "latency_ms": latency_ms,
            "tokens_in": tok_in,
            "tokens_out": tok_out,
            "profile": profile,
            "source": "aq-chat-fast-path",
        })
        try:
            await asyncio.to_thread(lambda: open(tel_path, "a", encoding="utf-8").write(evt + "\n"))
        except Exception:
            pass  # telemetry is best-effort; never block the chat turn

    async def _stream_chat(self, prompt: str):
        self.context_history.append({"role": "user", "content": prompt})
        self.interrupt_event.clear()
        self.steering_prompt = None

        # -----------------------------------------------------------------------
        # Phase D.2 — conversational fast-path guard
        # Bypass coordinator (~50s overhead) for turns that need no tool calls.
        # Guard conditions:
        #   1. tool_mode is ENABLED (not disabled at session or turn level)
        #   2. turn is classified conversational by chat_intent
        #   3. --no-fastpath flag not set (debug escape hatch)
        #   4. last turn didn't use tools (preserves tool-call context continuity)
        #   5. local profile (fast-path only makes sense for local targets)
        #   6. no snapshot required (snapshot turns always need coordinator context)
        # -----------------------------------------------------------------------
        is_local_profile = self.active_profile in {"local", "local-tool-calling"}
        if (
            is_local_profile
            and self.tool_mode == ToolMode.ENABLED
            and not self._no_fastpath
            and not self._last_turn_had_tool_calls
            and is_conversational(prompt)
            and not self._should_use_local_snapshot(prompt)
        ):
            await self._stream_fast_path(prompt, list(self.context_history))
            return

        thinking_msg = f"Synthesizing via [bold]{self.active_profile}[/]..."
        with console.status(f"[bold #00d9ff]{thinking_msg}", spinner="dots"):
            local_model_id = os.getenv("AI_LOCAL_MODEL_ID", "local")
            local_snapshot = await self._build_local_snapshot(prompt)
            tool_free_turn = self._should_bypass_tools_for_turn(prompt)
            request_messages = list(self.context_history)
            if local_snapshot:
                request_messages = (
                    self.context_history[:-1]
                    + [{
                        "role": "system",
                        "content": (
                            "TRUSTED LOCAL PREFLIGHT SNAPSHOT FOR THIS TURN:\n"
                            f"{local_snapshot}\n\n"
                            "Answer contract: be concise and human-readable. Start with current status, "
                            "then give the top 3 evidence-backed next improvements. Use only snapshot "
                            "evidence for current-state claims. Do not mention unavailable tool calls."
                        ),
                    }]
                    + self.context_history[-1:]
                )
            elif tool_free_turn:
                request_messages = (
                    self.context_history[:-1]
                    + [{
                        "role": "system",
                        "content": (
                            "TOOL-FREE TURN: answer from the prompt and conversation context only. "
                            "Do not emit tool calls, do not claim live command results, and keep the "
                            "answer code-ready and concrete."
                        ),
                    }]
                    + self.context_history[-1:]
                )
            payload = {
                "model": local_model_id if self.active_profile in {"local", "local-tool-calling"} else self.active_profile,
                "messages": request_messages,
                "stream": True,
                "temperature": self.temperature,
                "agent_type": "human",
                "frequency_penalty": 0.0,
            }

            headers = {
                "X-Agent-Source": "aq-chat",
                "X-Agent-Role": "orchestrator",
                "X-Agent-Boundary": "human_gate",
            }
            if self.active_profile == "local":
                headers["X-AI-Lane"] = "high-priority"

            if self.active_profile in {"local", "local-tool-calling"} or local_snapshot or tool_free_turn:
                # Human local turns use the same coordinator delegation path as autonomous local agents.
                target_url = f"{self.hybrid_url}/control/ai-coordinator/delegate"
                headers["X-AI-Profile"] = "local-tool-calling"
                wire_profile = "local-tool-calling" if self.local_tools_enabled and not tool_free_turn else "default"
                self._wire_profile = wire_profile
                payload = self._build_coordinator_delegate_payload(
                    prompt,
                    request_messages,
                    tool_free_turn=tool_free_turn,
                )
            else:
                target_url = f"{self.hybrid_url}/v1/orchestrate"
                self._wire_profile = self.active_profile

            try:
                if self.active_profile in {"local", "local-tool-calling"} or local_snapshot or tool_free_turn:
                    # D.4 — routing event before HTTP request (fire-and-forget)
                    asyncio.create_task(self._write_routing_event({
                        "event_type": "routing_decision",
                        "task_id": self._session_id,
                        "path": "coordinator",
                        "profile": self._wire_profile,
                        "classification": "agentic",
                        "tool_free_turn": tool_free_turn,
                        "snapshot_turn": bool(local_snapshot),
                        "seq": self._next_routing_seq(),
                        "ts": time.time(),
                    }))
                    response = await self.client.post(target_url, json=payload, headers=headers)
                    if response.status_code != 200:
                        detail = self._response_error_detail(response)
                        suffix = f" {detail}" if detail else ""
                        console.print(f"[bold red]Error: Received {response.status_code} from local backend.[/]{suffix}")
                        return
                    try:
                        body = response.json()
                    except json.JSONDecodeError:
                        console.print("[bold red]Error: local backend returned non-JSON response.[/]")
                        return
                    # D.2: track whether coordinator used tools (for next-turn fast-path gate)
                    self._last_turn_had_tool_calls = bool(
                        body.get("tool_calls_made", 0)
                    )
                    full_response = self._assistant_content_from_body(body)
                    self._record_and_render_assistant_response(prompt, full_response)
                    return

                async with self.client.stream("POST", target_url, json=payload, headers=headers) as response:
                    if response.status_code != 200:
                        console.print(f"[bold red]Error: Received {response.status_code} from {self.active_profile} backend.[/]")
                        return

                    full_response = ""
                    self.is_thinking = False
                    print()

                    async for line in response.aiter_lines():
                        if self.interrupt_event.is_set():
                            console.print("\n[bold yellow]Interrupted! Steering with new prompt...[/]")
                            break

                        if line.startswith("data: "):
                            try:
                                content = line[6:]
                                if content.strip() == "[DONE]":
                                    break
                                chunk = json.loads(content)
                                token = chunk.get("choices", [{}])[0].get("delta", {}).get("content", "") or ""

                                if "<think>" in token or "<thought>" in token:
                                    self.is_thinking = True
                                    print("\n[dim]Thoughts: ", end="", flush=True)
                                    continue
                                elif "</think>" in token or "</thought>" in token:
                                    self.is_thinking = False
                                    print("[/dim]\n", end="", flush=True)
                                    continue

                                full_response += token
                                if self.is_thinking:
                                    print(f"\033[2m{token}\033[0m", end="", flush=True)
                                else:
                                    print(token, end="", flush=True)
                            except json.JSONDecodeError:
                                continue

                    print()
                    if not self.interrupt_event.is_set():
                        self._last_turn_had_tool_calls = False
                        self._record_and_render_assistant_response(prompt, full_response)
                    else:
                        # Handle steering
                        steer_msg = f"INTERRUPT: {self.steering_prompt}"
                        self.context_history.append({"role": "assistant", "content": full_response + " [INTERRUPTED]"})
                        # Re-trigger with steering
                        await self._stream_chat(steer_msg)
            except asyncio.CancelledError:
                console.print("\n[dim]Interrupted.[/]")
                raise
            except Exception as e:
                err_msg = str(e)
                if not err_msg:
                    err_msg = repr(e)
                console.print(f"[bold red]Inference Loop Interrupted: {err_msg}[/]")

    async def handle_slash_command(self, cmd: str):
        parts = cmd.split()
        base = parts[0].lower()

        if base == "/clear":
            # Preserve system prompt if present
            sys_msg = [m for m in self.context_history if m.get("role") == "system"]
            self.context_history = sys_msg
            console.clear()
            console.print("[dim italic]Neural buffer cleared.[/]")
        elif base == "/reset":
            # Preserve system prompt if present
            sys_msg = [m for m in self.context_history if m.get("role") == "system"]
            self.context_history = sys_msg
            console.print("[bold yellow]Conversation reset.[/]")
        elif base == "/status":
            await self.show_status()
        elif base == "/brief":
            self._show_brief()
        elif base == "/route":
            if len(parts) > 1:
                target = parts[1]
                if target in self.available_agents:
                    self.active_profile = target
                    self.model_name = await self._get_active_model()
                    console.print(f"[bold green]Routed to {target}[/]")
                else:
                    console.print(f"[red]Unknown route: {target}. Available: {list(self.available_agents.keys())}[/]")
            else:
                console.print(f"[yellow]Current route: {self.active_profile}[/]")
        elif base == "/save":
            filename = parts[1] if len(parts) > 1 else f"chat_{int(time.time())}.md"
            self._save_chat(filename)
        elif base == "/load":
            if len(parts) > 1:
                self._load_chat(parts[1])
            else:
                console.print("[red]Usage: /load <filename>[/]")
        elif base == "/prime":
            console.print("[bold cyan]Pruning context via aq-prime...[/]")
            os.system("aq-prime")
        elif base == "/search":
            query = " ".join(parts[1:])
            if query: await self._rag_search(query)
            else: console.print("[red]Usage: /search <query>[/]")
        elif base == "/tools":
            show_all = len(parts) > 1 and parts[1].lower() == "all"
            await self._show_tools(show_all=show_all)
        elif base == "/rate":
            # /rate good|bad [optional comment]
            if len(parts) < 2 or parts[1].lower() not in ("good", "bad"):
                console.print("[yellow]Usage: /rate good|bad [optional comment][/]")
            else:
                rating = parts[1].lower()
                comment = " ".join(parts[2:]) if len(parts) > 2 else ""
                self._write_feedback(rating, comment)
        elif base == "/exit":
            sys.exit(0)
        else:
            console.print(f"[red]Unknown command: {base}[/]")

    def _save_chat(self, filename: str):
        path = REPO_ROOT / "data" / "chats" / filename
        path.parent.mkdir(parents=True, exist_ok=True)
        with open(path, "w") as f:
            for msg in self.context_history:
                f.write(f"## {msg['role'].upper()}\n\n{msg['content']}\n\n")
        console.print(f"[bold green]Chat saved to {path}[/]")

    def _load_chat(self, filename: str):
        path = REPO_ROOT / "data" / "chats" / filename
        if not path.exists():
            console.print(f"[red]File not found: {path}[/]")
            return

        try:
            self.context_history = []
            with open(path, "r") as f:
                content = f.read()
                blocks = content.split("## ")
                for b in blocks:
                    if not b.strip(): continue
                    lines = b.split("\n")
                    role = lines[0].strip().lower()
                    text = "\n".join(lines[1:]).strip()
                    if role in ["user", "assistant", "system"]:
                        self.context_history.append({"role": role, "content": text})
            console.print(f"[bold green]Loaded {len(self.context_history)} turns from {path}[/]")
        except Exception as e:
            console.print(f"[bold red]Load failed: {e}[/]")

    def _write_feedback(
        self,
        rating: str,
        comment: str,
        *,
        fast_path: bool = False,
    ) -> None:
        """
        Write a user feedback entry to delegation-feedback.jsonl.
        Activates the feedback stream for the training pipeline.

        Phase C.3: records self._wire_profile (actual wire profile, e.g. "local-tool-calling")
        NOT self.active_profile (always "local") — fixes training data poisoning.
        Also records tool_mode and fast_path for downstream analysis.
        """
        import datetime as _dt
        feedback_path = Path(os.getenv(
            "TELEMETRY_DIR", "/var/lib/ai-stack/hybrid/telemetry"
        )) / "delegation-feedback.jsonl"
        entry = {
            "event_type": "user_feedback",
            "rating": rating,
            "comment": comment,
            "query": self._last_user_msg[:500] if self._last_user_msg else "",
            "response_preview": self._last_assistant_msg[:300] if self._last_assistant_msg else "",
            # Phase C.3: actual wire profile (not self.active_profile which is always "local")
            "profile": self._wire_profile,
            "active_profile": self.active_profile,
            "tool_mode": self.tool_mode.value,
            "fast_path": fast_path,
            "timestamp": _dt.datetime.now(_dt.timezone.utc).isoformat(),
            # Map bad ratings to improvement_actions so training_ingest can pick them up
            "improvement_actions": [comment] if rating == "bad" and comment else (
                ["response quality too low — review profile routing"] if rating == "bad" else []
            ),
            "failure_class": "user_rated_bad" if rating == "bad" else "none",
        }
        try:
            with open(feedback_path, "a", encoding="utf-8") as fh:
                fh.write(json.dumps(entry) + "\n")
            icon = "[bold green]✓[/]" if rating == "good" else "[bold red]✗[/]"
            console.print(f"{icon} Feedback recorded ({rating}). Use `aq-local-training-loop` to process.")
        except OSError as exc:
            console.print(f"[red]Could not write feedback: {exc}[/]")

