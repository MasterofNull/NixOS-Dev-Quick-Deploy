            )
        except Exception as e:
            console.print(f"[red]Could not load TOOL_CATALOG: {e}[/]")
            # Fallback: show legacy tool_registry view
            try:
                registry_path = REPO_ROOT / "ai-stack" / "local-agents"
                if str(registry_path) not in sys.path:
                    sys.path.insert(0, str(registry_path))
                from tool_registry import get_registry
                from builtin_tools.ai_coordination import register_ai_coordination_tools
                from builtin_tools.computer_use import register_computer_use_tools
                from builtin_tools.file_operations import register_file_tools
                from builtin_tools.git_tools import register_git_tools
                from builtin_tools.shell_tools import register_shell_tools
                registry = get_registry()
                if not registry.tools:
                    register_file_tools(registry)
                    register_shell_tools(registry)
                    register_git_tools(registry)
                    register_ai_coordination_tools(registry)
                    register_computer_use_tools(registry)
                table = Table(title="Local Agent Tool Registry (fallback)", border_style="#ff00ff")
                table.add_column("Tool Name", style="bold cyan")
                table.add_column("Safety", style="magenta")
                table.add_column("Description")
                for name, tool in registry.get_all_tools().items():
                    table.add_row(name, str(tool.safety_policy.value), tool.description)
                console.print(table)
            except Exception as e2:
                console.print(f"[red]Fallback registry also failed: {e2}[/]")

    async def show_status(self):
        grid = Table.grid(expand=True)
        grid.add_column(style="cyan")
        grid.add_column(style="magenta", justify="right")

        active_model = await self._get_active_model()
        grid.add_row("Active Model", active_model)
        grid.add_row("Current Profile", self.active_profile)
        grid.add_row("History Depth", f"{len(self.context_history)} messages")
        grid.add_row("Temperature", str(self.temperature))

        console.print(Panel(grid, title="[bold #00d9ff]System Context[/]", border_style="#00d9ff"))

        try:
            load = os.getloadavg()
            res_table = Table(title="Host Resources", box=None)
            res_table.add_column("Load (1/5/15m)", style="dim")
            res_table.add_row(f"{load[0]:.2f} / {load[1]:.2f} / {load[2]:.2f}")
            console.print(res_table)
        except: pass

        if self.available_agents:
            pool_table = Table(title="Available Agent Pool", box=None, header_style="bold blue")
            pool_table.add_column("ID")
            pool_table.add_column("Description")
            for aid, desc in self.available_agents.items():
                style = "bold green" if aid == self.active_profile else "dim"
                pool_table.add_row(aid, desc, style=style)
            console.print(pool_table)

    async def run(self):
        await self._discover_pool()
        self.model_name = await self._get_active_model()


        # Inject harness-aware system prompt for all local delegation profiles.
        # local-tool-calling routes to coordinator /delegate (same as agentic delegation);
        # injecting context here puts the system message in context_history → request_messages →
        # coordinator extracts it and passes it to the local agent as system_prompt, giving
        # aq-chat interactive turns the same harness grounding as autonomous agent dispatches.
        if self.inject_context and self.active_profile in {"local", "local-tool-calling"}:
            with console.status("[dim]Grounding model in harness context...[/]", spinner="dots"):
                sys_prompt = await self._build_harness_system_prompt()
            self.context_history = [{"role": "system", "content": sys_prompt}]
            console.print("[dim italic]Harness context injected.[/]")

        # Phase C.4 — session-start banner (one-time, suppressible with --quiet)
        if not self._quiet:
            wire = self._wire_profile
            tool_count = self._runtime_tool_count()
            fast_path_status = "enabled" if not self._no_fastpath else "disabled (--no-fastpath)"
            console.print(
                f"[dim][aq-chat] Profile: {wire} | "
                f"Fast-path: {fast_path_status} | "
                f"Tools: {tool_count} available[/dim]"
            )

        console.print(Panel.fit(
            f"[bold #00d9ff]Command Center HUD v2.3[/]\n"
            f"[dim]Unified routing: coordinator + fast-path.[/]\n"
            f"Active: [bold #ff00ff]{self.active_profile}[/] ({self.model_name})",
            border_style="#00d9ff"
        ))

        while True:
            try:
                # Phase C.2 — D3 HUD format: [local | ltc | tools:15] ❯
                tool_count = self._runtime_tool_count()
                p_text_str = self._build_prompt_text(
                    self.active_profile,
                    self._wire_profile,
                    self.tool_mode,
                    tool_count,
                    verbose=self._verbose_hud,
                )
                # prompt_toolkit HTML: escape the prompt text for safe embedding
                p_text = f'<prompt>{p_text_str}</prompt>'
                user_input = await self.session.prompt_async(HTML(p_text), style=STYLE)
                user_input = user_input.strip()

                if not user_input: continue

                if user_input.startswith("/"):
                    await self.handle_slash_command(user_input)
                else:
                    await self._stream_chat(user_input)

            except EOFError: break
            except KeyboardInterrupt: continue

def parse_args():
    parser = argparse.ArgumentParser(description="aq-chat: Professional AI Terminal")
    parser.add_argument("--profile", default="local", help="Initial agent profile/lane")
    parser.add_argument("--llama-url", help="Override llama.cpp URL")
    parser.add_argument("--hybrid-url", help="Override hybrid-coordinator URL")
    parser.add_argument("--switchboard-url", help="Override switchboard URL")
    parser.add_argument("--temperature", type=float, default=0.2, help="Model sampling temperature")
    parser.add_argument("--max-tools", type=int, default=0,
                        help="Deprecated compatibility flag; local tool loops are progress-guarded")
    parser.add_argument("--no-inject", action="store_true",
                        help="Skip harness context injection (raw session, no system prompt)")
    parser.add_argument("--no-tools", action="store_true",
                        help="Disable tool calls for the session (ToolMode.DISABLED_SESSION)")
    # Phase D: fast-path control
    parser.add_argument("--no-fastpath", action="store_true",
                        help="Disable conversational fast-path (debug escape hatch; all turns go via coordinator)")
    # Phase C: HUD verbosity
    parser.add_argument("--verbose-hud", action="store_true",
                        help="Expand HUD abbreviations to full profile names (e.g. ltc → local-tool-calling)")
    parser.add_argument("--quiet", action="store_true",
                        help="Suppress session-start banner and informational messages")
    return parser.parse_args()

if __name__ == "__main__":
    args = parse_args()
    chat = AQChat(args)
    try:
        asyncio.run(chat.run())
    except KeyboardInterrupt:
        console.print("\n[dim]Interrupted.[/]")
