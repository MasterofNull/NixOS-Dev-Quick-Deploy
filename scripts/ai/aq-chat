        if tool_mode == ToolMode.DISABLED_TURN:
            return f"[{active_profile} | off | turn] ❯ "
        if tool_mode == ToolMode.DISABLED_SESSION:
            return f"[{active_profile} | {wire_display} | tools:off] ❯ "
        # ENABLED
        return f"[{active_profile} | {wire_display} | tools:{tool_count}] ❯ "

    def _runtime_tool_count(self) -> int:
        """Return cached tool count from parity contract (read once at session start)."""
        if self._tool_count_cache is not None:
            return self._tool_count_cache
        contract = self._load_parity_contract()
        required = contract.get("required_tools", [])
        # Fallback: if contract not available, use a sensible default
        count = len(required) if required else 3
        self._tool_count_cache = count
        return count

    def _next_routing_seq(self) -> int:
        self._routing_seq += 1
        return self._routing_seq

