    def _run_snapshot_command(self, label: str, command: List[str], timeout: int = 8) -> Dict[str, Any]:
        """Run a read-only local snapshot command for grounding chat answers."""
        try:
            proc = subprocess.run(
                command,
                cwd=REPO_ROOT,
                text=True,
                capture_output=True,
                timeout=timeout,
                check=False,
            )
            stdout = (proc.stdout or "").strip()
            stderr = (proc.stderr or "").strip()
            return {
                "label": label,
                "command": " ".join(command),
                "returncode": proc.returncode,
                "stdout": stdout[:2000],
                "stderr": stderr[:1000],
            }
        except subprocess.TimeoutExpired:
            return {
                "label": label,
                "command": " ".join(command),
                "returncode": 124,
                "stdout": "",
                "stderr": f"timed out after {timeout}s",
            }
        except OSError as exc:
            return {
                "label": label,
                "command": " ".join(command),
                "returncode": 127,
                "stdout": "",
                "stderr": str(exc),
            }

    def _should_use_local_snapshot(self, prompt: str) -> bool:
        compact = " ".join(prompt.lower().split())
        return any(keyword in compact for keyword in SNAPSHOT_KEYWORDS)

    async def _build_local_snapshot(self, prompt: str) -> Optional[str]:
        """Build a compact trusted snapshot for operational recommendation prompts."""
        if not self._should_use_local_snapshot(prompt):
            return None

        commands = [
            ("git_status", ["git", "status", "--short"], 6),
            ("alerts_count", ["scripts/ai/aq-alerts", "--count"], 6),
            ("failed_units", ["systemctl", "--failed", "--no-pager"], 8),
            ("open_issues", ["rg", "-n", "^\\[OPEN\\]", ".agent/memory/issues-backlog.md"], 6),
            ("health_spider_once", ["scripts/ai/aq-health-spider", "--once"], 20),
        ]
        results = [
            self._run_snapshot_command(label, command, timeout)
            for label, command, timeout in commands
        ]
        return json.dumps(
            {
                "source": "aq-chat trusted local preflight",
                "repo_root": str(REPO_ROOT),
                "checks": results,
                "limits": [
                    "Full aq-qa was not run inside this chat turn unless shown above.",
                    "Use only these command outputs for current-state claims.",
                    "Do not recommend a rebuild unless a check reports pending activation or failed units.",
                    "If a command failed, report it as a snapshot command failure, not as confirmed system degradation.",
                ],
            },
            indent=2,
        )

    async def _build_harness_system_prompt(self) -> str:
        """Fetch live coordinator state and build a harness-aware system prompt.

        This grounds the local model in the actual running system so it can give
        specific, actionable answers rather than generic advice.
        """
        hw: Dict[str, Any] = {}
        model_id = self.model_name

        # Fetch live hardware state (fast path — 200ms timeout)
        try:
            async with httpx.AsyncClient(timeout=2.0) as c:
                r = await c.get(f"{self.hybrid_url}/api/hardware/state")
                if r.status_code == 200:
                    hw = r.json()
        except Exception:
            pass

        ram_free  = hw.get("ram_free_gb",  "?")
        ram_total = hw.get("ram_total_gb", "?")
        thermal   = hw.get("thermal_tier", "unknown")
        cpu_t     = hw.get("temp_cpu_c")
        gpu_t     = hw.get("temp_gpu_c")
        mtp       = hw.get("mtp_acceptance_rate")
        ngl       = hw.get("n_gpu_layers_current")

        temps = ""
        if cpu_t is not None: temps += f" CPU={cpu_t:.1f}°C"
        if gpu_t is not None: temps += f" GPU={gpu_t:.1f}°C"
        mtp_str = f"{mtp * 100:.0f}%" if mtp is not None else "N/A"
        ram_str = (
            f"{ram_free:.1f} GB free / {ram_total:.1f} GB total"
            if isinstance(ram_free, float) else "unknown"
        )

        return f"""You are AQ, the expert coding and systems developer for NixOS-Dev-Quick-Deploy (ThinkPad P14s AMD, Cezanne APU, 27 GB RAM, NixOS flake).

STACK: llama.cpp :8080 ({model_id}, n_gpu_layers={ngl or 12}/12) | embed :8081 | coordinator :8003 | switchboard :8085 | AIDB :8002 | dashboard :8889
HARDWARE: thermal={thermal}{temps} | RAM={ram_str} | MTP={mtp_str}
CONSTRAINTS: gpu_layers≤12 | ports from nix/modules/core/options.nix only | dashboard/backend hot-reloads; coordinator/switchboard/llama need nixos-rebuild

=== OPERATIONAL RULES ===
1. CHECK-IN FIRST: Before making system changes, show your research and proposed plan with proof (file reads, command outputs).
2. EVIDENCE-BASED: Ground every answer in the actual system state using tools.
3. NIXOS MASTERY: Apply best practices for NixOS and declarative configuration.
4. TOOLS: run_command, read_file, search_files, git_status, query_context, get_hint, harness_health, get_prsi_pending, prsi_orchestrate, query_aidb, get_working_memory, recommend_agent_for_task — invoke directly.

BEHAVIORAL RULES: casual chat → plain text no tools | search before answering (harness-first) | max 2 retries → stop | commits: type(scope): desc + Co-Authored-By"""

    async def _discover_pool(self):
        """Discover available agents from the system pool."""
        local_model_id = os.getenv("AI_LOCAL_MODEL_ID", "local-model")
        try:
            offloading_path = REPO_ROOT / "ai-stack" / "offloading"
            if str(offloading_path) not in sys.path:
                sys.path.insert(0, str(offloading_path))

            from agent_pool_manager import AgentPoolManager
            self.pool_manager = AgentPoolManager()
            self.available_agents = {
                "local": f"Local Inference ({local_model_id})",
                **{a.agent_id: f"{a.name} ({a.model_id})" for a in self.pool_manager.agents.values()}
            }
        except Exception as e:
            console.print(f"[dim]Note: Agent pool discovery restricted ({e})[/]")
            self.available_agents = {"local": f"Local Inference ({local_model_id})"}

    async def _get_active_model(self) -> str:
        if self.active_profile == "local":
            return os.getenv("AI_LOCAL_MODEL_ID", "local-model")
        return self.available_agents.get(self.active_profile, self.active_profile)

    def _uses_switchboard_local_tools(self) -> bool:
        return self.local_tools_enabled and self.active_profile in {"local", "local-tool-calling"}

    @staticmethod
    def _assistant_content_from_body(body: Dict[str, Any]) -> str:
        """Extract assistant text from an OpenAI-compatible response body."""
        choices = body.get("choices") if isinstance(body, dict) else None
        if not isinstance(choices, list) or not choices:
            return ""
        first = choices[0] if isinstance(choices[0], dict) else {}
        message = first.get("message") if isinstance(first.get("message"), dict) else {}
        if isinstance(message.get("content"), str):
            return message["content"]
        delta = first.get("delta") if isinstance(first.get("delta"), dict) else {}
        if isinstance(delta.get("content"), str):
            return delta["content"]
        return ""

    def _record_and_render_assistant_response(self, prompt: str, full_response: str) -> None:
        """Render the completed response once and update conversation/feedback state."""
        full_response = full_response.strip()
        if not full_response:
            console.print("[yellow]No assistant content returned.[/]")
            return
        console.print()
        console.print(Markdown(full_response))
        self.context_history.append({"role": "assistant", "content": full_response})
        self._last_user_msg = prompt
        self._last_assistant_msg = full_response

    async def _stream_chat(self, prompt: str):
        self.context_history.append({"role": "user", "content": prompt})
        self.interrupt_event.clear()
        self.steering_prompt = None

        thinking_msg = f"Synthesizing via [bold]{self.active_profile}[/]..."
        with console.status(f"[bold #00d9ff]{thinking_msg}", spinner="dots"):
            local_model_id = os.getenv("AI_LOCAL_MODEL_ID", "local")
            switchboard_local_tools = self._uses_switchboard_local_tools()
            local_snapshot = await self._build_local_snapshot(prompt)
            request_messages = list(self.context_history)
            if local_snapshot:
                request_messages = (
                    self.context_history[:-1]
                    + [{
                        "role": "system",
                        "content": (
                            "TRUSTED LOCAL PREFLIGHT SNAPSHOT FOR THIS TURN:\n"
                            f"{local_snapshot}\n\n"
                            "Answer contract: be concise and human-readable. Start with current status, "
                            "then give the top 3 evidence-backed next improvements. Use only snapshot "
                            "evidence for current-state claims. Do not mention unavailable tool calls."
                        ),
                    }]
                    + self.context_history[-1:]
                )
            payload = {
                "model": local_model_id if self.active_profile in {"local", "local-tool-calling"} else self.active_profile,
                "messages": request_messages,
                "stream": True,
                "temperature": self.temperature,
                "agent_type": "human"
            }

            headers = {
                "X-Agent-Source": "aq-chat",
                "X-Agent-Role": "orchestrator",
                "X-Agent-Boundary": "human_gate",
            }
            if self.active_profile == "local":
                headers["X-AI-Lane"] = "high-priority"

            if switchboard_local_tools and not local_snapshot:
                target_url = f"{self.switchboard_url}/v1/chat/completions"
                headers["X-AI-Profile"] = "local-tool-calling"
                payload["stream"] = False
                payload["max_tool_calls"] = self.max_tool_calls
                payload["chat_template_kwargs"] = {"enable_thinking": False}
            elif self.active_profile == "local" or local_snapshot:
                target_url = f"{self.llama_url}/v1/chat/completions"
                payload["chat_template_kwargs"] = {"enable_thinking": False}
                if local_snapshot:
                    payload["stream"] = False
                    payload["max_tokens"] = 512
            else:
                target_url = f"{self.hybrid_url}/v1/orchestrate"

            try:
                if switchboard_local_tools:
                    response = await self.client.post(target_url, json=payload, headers=headers)
                    if response.status_code != 200:
                        console.print(f"[bold red]Error: Received {response.status_code} from {self.active_profile} backend.[/]")
                        return
                    try:
                        body = response.json()
                    except json.JSONDecodeError:
                        console.print("[bold red]Error: local-tool-calling backend returned non-JSON response.[/]")
                        return
                    if body.get("local_tool_budget_exhausted"):
                        console.print("[yellow]local tool budget exhausted; answer finalized from completed tool outputs[/]")
                    full_response = self._assistant_content_from_body(body)
                    self._record_and_render_assistant_response(prompt, full_response)
                    return

                if local_snapshot:
                    response = await self.client.post(target_url, json=payload, headers=headers)
                    if response.status_code != 200:
                        console.print(f"[bold red]Error: Received {response.status_code} from local backend.[/]")
                        return
                    try:
                        body = response.json()
                    except json.JSONDecodeError:
                        console.print("[bold red]Error: local backend returned non-JSON response.[/]")
                        return
                    full_response = self._assistant_content_from_body(body)
                    self._record_and_render_assistant_response(prompt, full_response)
                    return

                async with self.client.stream("POST", target_url, json=payload, headers=headers) as response:
                    if response.status_code != 200:
                        console.print(f"[bold red]Error: Received {response.status_code} from {self.active_profile} backend.[/]")
                        return

                    full_response = ""
                    self.is_thinking = False
                    print()

                    async for line in response.aiter_lines():
                        if self.interrupt_event.is_set():
                            console.print("\n[bold yellow]Interrupted! Steering with new prompt...[/]")
                            break

                        if line.startswith("data: "):
                            try:
                                content = line[6:]
                                if content.strip() == "[DONE]":
                                    break
                                chunk = json.loads(content)
                                token = chunk.get("choices", [{}])[0].get("delta", {}).get("content", "") or ""

                                if "<think>" in token or "<thought>" in token:
                                    self.is_thinking = True
                                    print("\n[dim]Thoughts: ", end="", flush=True)
                                    continue
                                elif "</think>" in token or "</thought>" in token:
                                    self.is_thinking = False
                                    print("[/dim]\n", end="", flush=True)
                                    continue

                                full_response += token
                                if self.is_thinking:
                                    print(f"\033[2m{token}\033[0m", end="", flush=True)
                                else:
                                    print(token, end="", flush=True)
                            except json.JSONDecodeError:
                                continue

                    print()
                    if not self.interrupt_event.is_set():
                        self._record_and_render_assistant_response(prompt, full_response)
                    else:
                        # Handle steering
                        steer_msg = f"INTERRUPT: {self.steering_prompt}"
                        self.context_history.append({"role": "assistant", "content": full_response + " [INTERRUPTED]"})
                        # Re-trigger with steering
                        await self._stream_chat(steer_msg)
            except Exception as e:
                err_msg = str(e)
                if not err_msg:
                    err_msg = repr(e)
                console.print(f"[bold red]Inference Loop Interrupted: {err_msg}[/]")

    async def handle_slash_command(self, cmd: str):
        parts = cmd.split()
        base = parts[0].lower()

        if base == "/clear":
            # Preserve system prompt if present
            sys_msg = [m for m in self.context_history if m.get("role") == "system"]
            self.context_history = sys_msg
            console.clear()
            console.print("[dim italic]Neural buffer cleared.[/]")
        elif base == "/reset":
            # Preserve system prompt if present
            sys_msg = [m for m in self.context_history if m.get("role") == "system"]
            self.context_history = sys_msg
            console.print("[bold yellow]Conversation reset.[/]")
        elif base == "/status":
            await self.show_status()
        elif base == "/route":
            if len(parts) > 1:
                target = parts[1]
                if target in self.available_agents:
                    self.active_profile = target
                    self.model_name = await self._get_active_model()
                    console.print(f"[bold green]Routed to {target}[/]")
                else:
                    console.print(f"[red]Unknown route: {target}. Available: {list(self.available_agents.keys())}[/]")
            else:
                console.print(f"[yellow]Current route: {self.active_profile}[/]")
        elif base == "/save":
            filename = parts[1] if len(parts) > 1 else f"chat_{int(time.time())}.md"
            self._save_chat(filename)
        elif base == "/load":
            if len(parts) > 1:
                self._load_chat(parts[1])
            else:
                console.print("[red]Usage: /load <filename>[/]")
        elif base == "/prime":
            console.print("[bold cyan]Pruning context via aq-prime...[/]")
            os.system("aq-prime")
        elif base == "/search":
            query = " ".join(parts[1:])
            if query: await self._rag_search(query)
            else: console.print("[red]Usage: /search <query>[/]")
        elif base == "/tools":
            await self._show_tools()
        elif base == "/rate":
            # /rate good|bad [optional comment]
            if len(parts) < 2 or parts[1].lower() not in ("good", "bad"):
                console.print("[yellow]Usage: /rate good|bad [optional comment][/]")
            else:
                rating = parts[1].lower()
                comment = " ".join(parts[2:]) if len(parts) > 2 else ""
                self._write_feedback(rating, comment)
        elif base == "/exit":
            sys.exit(0)
        else:
            console.print(f"[red]Unknown command: {base}[/]")

    def _save_chat(self, filename: str):
        path = REPO_ROOT / "data" / "chats" / filename
        path.parent.mkdir(parents=True, exist_ok=True)
        with open(path, "w") as f:
            for msg in self.context_history:
                f.write(f"## {msg['role'].upper()}\n\n{msg['content']}\n\n")
        console.print(f"[bold green]Chat saved to {path}[/]")

    def _load_chat(self, filename: str):
        path = REPO_ROOT / "data" / "chats" / filename
        if not path.exists():
            console.print(f"[red]File not found: {path}[/]")
            return

        try:
            self.context_history = []
            with open(path, "r") as f:
                content = f.read()
                blocks = content.split("## ")
                for b in blocks:
                    if not b.strip(): continue
                    lines = b.split("\n")
                    role = lines[0].strip().lower()
                    text = "\n".join(lines[1:]).strip()
                    if role in ["user", "assistant", "system"]:
                        self.context_history.append({"role": role, "content": text})
            console.print(f"[bold green]Loaded {len(self.context_history)} turns from {path}[/]")
        except Exception as e:
            console.print(f"[bold red]Load failed: {e}[/]")

    def _write_feedback(self, rating: str, comment: str) -> None:
        """
        Write a user feedback entry to delegation-feedback.jsonl.
        Activates the feedback stream (currently 0MB) for the training pipeline.
        """
        import datetime as _dt
        feedback_path = Path(os.getenv(
            "TELEMETRY_DIR", "/var/lib/ai-stack/hybrid/telemetry"
        )) / "delegation-feedback.jsonl"
        entry = {
            "event_type": "user_feedback",
            "rating": rating,
            "comment": comment,
            "query": self._last_user_msg[:500] if self._last_user_msg else "",
            "response_preview": self._last_assistant_msg[:300] if self._last_assistant_msg else "",
            "profile": self.active_profile,
            "timestamp": _dt.datetime.now(_dt.timezone.utc).isoformat(),
            # Map bad ratings to improvement_actions so training_ingest can pick them up
            "improvement_actions": [comment] if rating == "bad" and comment else (
                ["response quality too low — review profile routing"] if rating == "bad" else []
            ),
            "failure_class": "user_rated_bad" if rating == "bad" else "none",
        }
        try:
            with open(feedback_path, "a", encoding="utf-8") as fh:
                fh.write(json.dumps(entry) + "\n")
            icon = "[bold green]✓[/]" if rating == "good" else "[bold red]✗[/]"
            console.print(f"{icon} Feedback recorded ({rating}). Use `aq-local-training-loop` to process.")
        except OSError as exc:
            console.print(f"[red]Could not write feedback: {exc}[/]")

    async def _rag_search(self, query: str):
        with console.status("[bold cyan]Searching knowledge base...", spinner="bouncingBar"):
            try:
                async with httpx.AsyncClient(timeout=10.0) as client:
                    resp = await client.get(f"{self.hybrid_url}/api/documents?search={query}&limit=5")
                    if resp.status_code == 200:
                        results = resp.json().get("results", [])
                        if not results:
                            console.print("[yellow]No relevant documents found.[/]")
                            return

                        table = Table(title=f"RAG Results: {query}", border_style="cyan")
                        table.add_column("Score", style="dim", justify="right")
                        table.add_column("Source", style="green")
                        table.add_column("Snippet", style="white")
                        for r in results:
                            table.add_row(f"{r['score']:.2f}", r['source'], r['content'][:120].replace("\n", " ") + "...")
                        console.print(table)
                    else:
                        console.print(f"[red]Search API error: {resp.status_code}[/]")
            except Exception as e:
                console.print(f"[red]Search connection failed: {e}[/]")

    async def _show_tools(self):
        try:
            registry_path = REPO_ROOT / "ai-stack" / "local-agents"
            if str(registry_path) not in sys.path:
                sys.path.insert(0, str(registry_path))
            from tool_registry import get_registry
            from builtin_tools.ai_coordination import register_ai_coordination_tools
            from builtin_tools.computer_use import register_computer_use_tools
            from builtin_tools.file_operations import register_file_tools
            from builtin_tools.git_tools import register_git_tools
            from builtin_tools.shell_tools import register_shell_tools
            registry = get_registry()
            if not registry.tools:
                register_file_tools(registry)
                register_shell_tools(registry)
                register_git_tools(registry)
                register_ai_coordination_tools(registry)
                register_computer_use_tools(registry)

            table = Table(title="Local Agent Tool Registry", border_style="#ff00ff")
            table.add_column("Tool Name", style="bold cyan")
            table.add_column("Safety", style="magenta")
            table.add_column("Description")

            for name, tool in registry.get_all_tools().items():
                table.add_row(name, str(tool.safety_policy.value), tool.description)
            console.print(table)
        except Exception as e:
            console.print(f"[red]Could not load tool registry: {e}[/]")

    async def show_status(self):
        grid = Table.grid(expand=True)
        grid.add_column(style="cyan")
        grid.add_column(style="magenta", justify="right")

        active_model = await self._get_active_model()
        grid.add_row("Active Model", active_model)
        grid.add_row("Current Profile", self.active_profile)
        grid.add_row("History Depth", f"{len(self.context_history)} messages")
        grid.add_row("Temperature", str(self.temperature))

        console.print(Panel(grid, title="[bold #00d9ff]System Context[/]", border_style="#00d9ff"))

        try:
            load = os.getloadavg()
            res_table = Table(title="Host Resources", box=None)
            res_table.add_column("Load (1/5/15m)", style="dim")
            res_table.add_row(f"{load[0]:.2f} / {load[1]:.2f} / {load[2]:.2f}")
            console.print(res_table)
        except: pass

        if self.available_agents:
            pool_table = Table(title="Available Agent Pool", box=None, header_style="bold blue")
            pool_table.add_column("ID")
            pool_table.add_column("Description")
            for aid, desc in self.available_agents.items():
                style = "bold green" if aid == self.active_profile else "dim"
                pool_table.add_row(aid, desc, style=style)
            console.print(pool_table)

    async def run(self):
        await self._discover_pool()
        self.model_name = await self._get_active_model()

        # Inject harness-aware system prompt
        if self.inject_context and self.active_profile == "local":
            with console.status("[dim]Grounding model in harness context...[/]", spinner="dots"):
                sys_prompt = await self._build_harness_system_prompt()
            self.context_history = [{"role": "system", "content": sys_prompt}]
            console.print("[dim italic]Harness context injected.[/]")

        console.print(Panel.fit(
            f"[bold #00d9ff]Command Center HUD v2.2-STELLAR[/]\n"
            f"[dim]Professional-grade edge orchestration interface.[/]\n"
            f"Active: [bold #ff00ff]{self.active_profile}[/] ({self.model_name})",
            border_style="#00d9ff"
        ))

        while True:
            try:
                p_text = f'<prompt>[{self.active_profile}]</prompt> <model>❯</model> '
                user_input = await self.session.prompt_async(HTML(p_text), style=STYLE)
                user_input = user_input.strip()

                if not user_input: continue

                if user_input.startswith("/"):
                    await self.handle_slash_command(user_input)
                else:
                    await self._stream_chat(user_input)

            except EOFError: break
            except KeyboardInterrupt: continue

def parse_args():
    parser = argparse.ArgumentParser(description="aq-chat: Professional AI Terminal")
    parser.add_argument("--profile", default="local", help="Initial agent profile/lane")
    parser.add_argument("--llama-url", help="Override llama.cpp URL")
    parser.add_argument("--hybrid-url", help="Override hybrid-coordinator URL")
    parser.add_argument("--switchboard-url", help="Override switchboard URL")
    parser.add_argument("--temperature", type=float, default=0.2, help="Model sampling temperature")
    parser.add_argument("--max-tools", type=int, default=16,
                        help="Max tool calls allowed per local turn (default: 16)")
    parser.add_argument("--no-inject", action="store_true",
                        help="Skip harness context injection (raw session, no system prompt)")
    parser.add_argument("--no-tools", action="store_true",
                        help="Use raw llama.cpp local chat without Switchboard local-tool-calling")
    return parser.parse_args()

if __name__ == "__main__":
    args = parse_args()
    chat = AQChat(args)
    asyncio.run(chat.run())
