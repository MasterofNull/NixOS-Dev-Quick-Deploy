    def _run_snapshot_command(self, label: str, command: List[str], timeout: int = 8) -> Dict[str, Any]:
        """Run a read-only local snapshot command for grounding chat answers."""
        try:
            proc = subprocess.run(
                command,
                cwd=REPO_ROOT,
                text=True,
                capture_output=True,
                timeout=timeout,
                check=False,
            )
            stdout = (proc.stdout or "").strip()
            stderr = (proc.stderr or "").strip()
            return {
                "label": label,
                "command": " ".join(command),
                "returncode": proc.returncode,
                "stdout": stdout[:2000],
                "stderr": stderr[:1000],
            }
        except subprocess.TimeoutExpired:
            return {
                "label": label,
                "command": " ".join(command),
                "returncode": 124,
                "stdout": "",
                "stderr": f"timed out after {timeout}s",
            }
        except OSError as exc:
            return {
                "label": label,
                "command": " ".join(command),
                "returncode": 127,
                "stdout": "",
                "stderr": str(exc),
            }

    def _should_use_local_snapshot(self, prompt: str) -> bool:
        compact = " ".join(prompt.lower().split())
        return any(keyword in compact for keyword in SNAPSHOT_KEYWORDS)

    @property
    def local_tools_enabled(self) -> bool:
        """Compatibility property: True when tool_mode is ENABLED."""
        return self.tool_mode == ToolMode.ENABLED

    def _should_bypass_tools_for_turn(self, prompt: str) -> bool:
        """Return True if this turn should skip tool calls.

        Delegates to is_conversational() from chat_intent.py (Phase B).
        Also respects session-level DISABLED_SESSION mode.
        """
        if self.tool_mode == ToolMode.DISABLED_SESSION:
            return True
        return is_conversational(prompt)

    def _collect_local_snapshot(self) -> Dict[str, Any]:
        """Collect the trusted read-only local checks used for operational grounding."""
        results = [
            self._run_snapshot_command(label, command, timeout)
            for label, command, timeout in SNAPSHOT_CHECKS
        ]
        return {
            "source": "aq-chat trusted local preflight",
            "repo_root": str(REPO_ROOT),
            "checks": results,
            "limits": [
                "Full aq-qa was not run inside this chat turn unless shown above.",
                "Use only these command outputs for current-state claims.",
                "The issue backlog is historical; only [OPEN] entries are current issues.",
                "Do not recommend a rebuild unless a check reports pending activation or failed units.",
                "If a command failed, report it as a snapshot command failure, not as confirmed system degradation.",
            ],
        }

    async def _build_local_snapshot(self, prompt: str) -> Optional[str]:
        """Build a compact trusted snapshot for operational recommendation prompts."""
        if not self._should_use_local_snapshot(prompt):
            return None

        return json.dumps(self._collect_local_snapshot(), indent=2)

    @staticmethod
    def _compact_text(value: str, limit: int = 120) -> str:
        return " ".join(value.split())[:limit]

    def _brief_row(self, result: Dict[str, Any]) -> tuple[str, str, str]:
        label = result.get("label", "unknown")
        returncode = result.get("returncode")
        stdout = str(result.get("stdout") or "").strip()
        stderr = str(result.get("stderr") or "").strip()

        if returncode == 124:
            return label, "timeout", stderr or "command timed out"
        if returncode == 127:
            return label, "unavailable", stderr or "command unavailable"

        if label == "git_status":
            if returncode == 0 and not stdout:
                return label, "clean", "working tree has no reported changes"
            changed = len(stdout.splitlines()) if stdout else 0
            return label, "changes", f"{changed} changed path(s)"

        if label == "alerts_count":
            detail = stdout or stderr or "no output"
            status = "pending" if returncode not in (0, None) else "clear"
            return label, status, detail

        if label == "failed_units":
            if returncode == 0 and ("0 loaded units listed" in stdout or not stdout):
                return label, "clear", "no failed systemd units reported"
            lines = [line for line in stdout.splitlines() if line.strip()]
            return label, "attention", lines[0][:120] if lines else (stderr or "check returned output")

        if label == "open_issues":
            if returncode == 1 and not stdout:
                return label, "clear", "no open issue backlog entries found"
            if returncode == 0:
                return label, "open", f"{len(stdout.splitlines())} open issue backlog entries"
            return label, "error", stderr or f"exit {returncode}"

        if label == "dashboard_osi":
            if returncode == 0:
                status = "ok" if "failed=0" in stdout else "attention"
                return label, status, stdout or "dashboard OSI endpoint returned no summary"
            return label, "error", stderr or f"exit {returncode}"

        if label == "health_spider_once":
            lines = [line for line in stdout.splitlines() if line.strip()]
            status = "ok" if returncode == 0 else "error"
            if lines:
                detail = self._compact_text(lines[-1], 80)
                return label, status, f"{len(lines)} output lines; {detail}"
            err_lines = [line for line in stderr.splitlines() if line.strip()]
            if returncode == 0:
                return label, status, f"completed; {len(err_lines)} progress line(s)"
            return label, status, self._compact_text(stderr or f"exit {returncode}")

        status = "ok" if returncode == 0 else "error"
        detail = stdout.splitlines()[0][:120] if stdout else (stderr or f"exit {returncode}")
        return label, status, detail

