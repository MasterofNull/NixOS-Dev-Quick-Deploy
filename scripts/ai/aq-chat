    @staticmethod
    def _assistant_content_from_body(body: Dict[str, Any]) -> str:
        """Extract assistant text from an OpenAI-compatible response body."""
        choices = body.get("choices") if isinstance(body, dict) else None
        if not isinstance(choices, list) or not choices:
            return ""
        first = choices[0] if isinstance(choices[0], dict) else {}
        message = first.get("message") if isinstance(first.get("message"), dict) else {}
        if isinstance(message.get("content"), str):
            return message["content"]
        delta = first.get("delta") if isinstance(first.get("delta"), dict) else {}
        if isinstance(delta.get("content"), str):
            return delta["content"]
        for key in ("content", "response", "result", "output"):
            value = body.get(key)
            if isinstance(value, str):
                return value
            if isinstance(value, dict):
                nested = value.get("content") or value.get("output") or value.get("response")
                if isinstance(nested, str):
                    return nested
        return ""

    def _build_coordinator_delegate_payload(
        self,
        prompt: str,
        request_messages: List[Dict[str, str]],
        *,
        tool_free_turn: bool,
    ) -> Dict[str, Any]:
        """Build the canonical coordinator delegate payload for local aq-chat turns."""
        payload: Dict[str, Any] = {
            "task": prompt,
            "messages": request_messages,
            "profile": "local-tool-calling" if self.local_tools_enabled and not tool_free_turn else "default",
            "role": "orchestrator" if self.local_tools_enabled and not tool_free_turn else "reviewer",
            "agent_type": "human",
            "temperature": self.temperature,
            "max_tokens": 1024,
            "stream": False,
            "frequency_penalty": 0.0,
        }
        payload["chat_template_kwargs"] = {"enable_thinking": False}
        if tool_free_turn:
            payload["tools"] = []
            payload["tool_choice"] = "none"
        return payload

    @staticmethod
    def _response_error_detail(response: httpx.Response) -> str:
        text = response.text.strip()
        if not text:
            return ""
        try:
            body = response.json()
        except json.JSONDecodeError:
            return text[:500]
        for key in ("error", "detail", "message"):
            value = body.get(key) if isinstance(body, dict) else None
            if isinstance(value, str) and value.strip():
                return value.strip()[:500]
        return text[:500]

    def _record_response(self, prompt: str, full_response: str) -> None:
        """Update conversation/feedback state only — no rendering.

        Used by _stream_fast_path where content is already streamed token-by-token.
        Calling _record_and_render_assistant_response there would double-print.
        """
        full_response = full_response.strip()
        if not full_response:
            return
        self.context_history.append({"role": "assistant", "content": full_response})
        self._last_user_msg = prompt
        self._last_assistant_msg = full_response

    def _record_and_render_assistant_response(self, prompt: str, full_response: str) -> None:
        """Render the completed response once and update conversation/feedback state."""
        full_response = full_response.strip()
        if not full_response:
            console.print("[yellow]No assistant content returned.[/]")
            return
        console.print()
        console.print(Markdown(full_response))
        self.context_history.append({"role": "assistant", "content": full_response})
        self._last_user_msg = prompt
        self._last_assistant_msg = full_response

