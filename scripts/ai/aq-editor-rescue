#!/usr/bin/env python3
"""
aq-editor-rescue — bounded rescue workflow for swollen Continue/VSCodium sessions.

Usage:
  aq-editor-rescue --task "Continue editor is freezing" --format json
  aq-editor-rescue --task "Continue editor is freezing" --execute
"""

from __future__ import annotations

import argparse
import json
import os
import shlex
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, List, Optional


REPO_ROOT = Path(__file__).resolve().parents[2]
CONTEXT_MANAGE = Path(os.getenv("AQ_EDITOR_RESCUE_CONTEXT_MANAGE", str(REPO_ROOT / "scripts" / "ai" / "aq-context-manage")))
AQ_REPORT = Path(os.getenv("AQ_EDITOR_RESCUE_AQ_REPORT", str(REPO_ROOT / "scripts" / "ai" / "aq-report")))
AQ_QA = os.getenv("AQ_EDITOR_RESCUE_AQ_QA", "aq-qa")
REPAIR_CMD = os.getenv("AQ_EDITOR_RESCUE_REPAIR_CMD", "vscodium-repair")
REGENERATE_CONTINUE_CONFIG_CMD = os.getenv(
    "AQ_EDITOR_RESCUE_REGENERATE_CONTINUE_CONFIG_CMD",
    "home-manager switch --flake .",
)
EDITOR_RESCUE_HISTORY_PATH = Path(
    os.getenv("AQ_EDITOR_RESCUE_HISTORY_PATH", "/var/lib/ai-stack/hybrid/telemetry/editor-rescue-history.jsonl")
)
CHECKPOINT_TIMEOUT_SECONDS = int(os.getenv("AQ_EDITOR_RESCUE_CHECKPOINT_TIMEOUT_SECONDS", "20"))
REPORT_TIMEOUT_SECONDS = int(os.getenv("AQ_EDITOR_RESCUE_REPORT_TIMEOUT_SECONDS", "180"))
QA_TIMEOUT_SECONDS = int(os.getenv("AQ_EDITOR_RESCUE_QA_TIMEOUT_SECONDS", "150"))
REPAIR_TIMEOUT_SECONDS = int(os.getenv("AQ_EDITOR_RESCUE_REPAIR_TIMEOUT_SECONDS", "120"))
REGENERATE_TIMEOUT_SECONDS = int(os.getenv("AQ_EDITOR_RESCUE_REGENERATE_TIMEOUT_SECONDS", "900"))


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Checkpoint, diagnose, repair, and resume editor-facing AI surfaces.")
    parser.add_argument("--task", required=True, help="Editor failure or recovery summary.")
    parser.add_argument("--format", dest="fmt", default="text", choices=["text", "json"], help="Output format.")
    parser.add_argument("--execute", action="store_true", help="Run the repair step in addition to checkpointing and diagnostics.")
    parser.add_argument("--skip-checkpoint", action="store_true", help="Skip the aq-context-manage checkpoint step.")
    parser.add_argument("--skip-qa", action="store_true", help="Skip aq-qa phase 0 collection.")
    parser.add_argument("--decision", action="append", help="Checkpoint decision. Repeatable.")
    parser.add_argument("--next-step", dest="next_step", action="append", help="Checkpoint next step. Repeatable.")
    parser.add_argument("--open-question", dest="open_question", action="append", help="Checkpoint open question. Repeatable.")
    parser.add_argument("--fact", action="append", help="Checkpoint durable fact. Repeatable.")
    parser.add_argument("--project", default="ai-stack", help="Checkpoint project.")
    parser.add_argument("--topic", default="editor-rescue", help="Checkpoint topic.")
    parser.add_argument("--repair-command", default=REPAIR_CMD, help="Repair command to run in execute mode.")
    parser.add_argument(
        "--regenerate-continue-config",
        action="store_true",
        help="Run home-manager to regenerate ~/.continue/config.json after repair when needed.",
    )
    parser.add_argument(
        "--regenerate-command",
        default=REGENERATE_CONTINUE_CONFIG_CMD,
        help="Command to regenerate the Continue config after repair.",
    )
    return parser.parse_args()


def _run(command: List[str], *, parse_json: bool = False, timeout: Optional[int] = None) -> Dict[str, Any]:
    try:
        result = subprocess.run(command, capture_output=True, text=True, check=False, timeout=timeout)
    except subprocess.TimeoutExpired as exc:
        stdout = (exc.stdout or "").strip() if isinstance(exc.stdout, str) else ""
        stderr = (exc.stderr or "").strip() if isinstance(exc.stderr, str) else ""
        return {
            "command": command,
            "returncode": None,
            "stdout": stdout,
            "stderr": stderr,
            "ok": False,
            "timed_out": True,
            "timeout_seconds": timeout,
            "error": f"timed out after {timeout}s",
        }
    except OSError as exc:
        return {
            "command": command,
            "returncode": None,
            "stdout": "",
            "stderr": "",
            "ok": False,
            "os_error": str(exc),
            "errno": getattr(exc, "errno", None),
        }
    payload: Dict[str, Any] = {
        "command": command,
        "returncode": result.returncode,
        "stdout": (result.stdout or "").strip(),
        "stderr": (result.stderr or "").strip(),
        "ok": result.returncode == 0,
    }
    if parse_json and payload["stdout"]:
        try:
            payload["json"] = json.loads(payload["stdout"])
        except json.JSONDecodeError as exc:
            payload["ok"] = False
            payload["parse_error"] = str(exc)
    return payload


def _default_decisions(args: argparse.Namespace) -> List[str]:
    if args.decision:
        return list(args.decision)
    return [
        "Checkpoint editor rescue state into aq-memory before replaying or clearing swollen transcripts.",
        "Prefer fresh-session resume from harness memory after repeated editor failures instead of reopening the same transcript.",
    ]


def _default_next_steps(args: argparse.Namespace) -> List[str]:
    if args.next_step:
        return list(args.next_step)
    return [
        "Inspect aq-report continue_editor.state_budget and aq-qa 0.5.7 before relaunching VSCodium.",
        "Start a fresh editor/agent session and resume from aq-memory recall after repair.",
    ]


def _default_open_questions(args: argparse.Namespace) -> List[str]:
    if args.open_question:
        return list(args.open_question)
    return ["Which editor surface is still replaying raw transcripts or repeated bootstrap text?"]


def _default_facts(args: argparse.Namespace) -> List[str]:
    if args.fact:
        return list(args.fact)
    return ["Editor rescue run initiated because local AI surfaces are hanging or freezing."]


def checkpoint_state(args: argparse.Namespace) -> Dict[str, Any]:
    if args.skip_checkpoint:
        return {"skipped": True, "reason": "skip_checkpoint"}
    command = [
        sys.executable,
        str(CONTEXT_MANAGE),
        "--json",
        "checkpoint",
        "--task",
        args.task,
        "--project",
        args.project,
        "--topic",
        args.topic,
    ]
    for item in _default_decisions(args):
        command.extend(["--decision", item])
    for item in _default_next_steps(args):
        command.extend(["--next-step", item])
    for item in _default_open_questions(args):
        command.extend(["--open-question", item])
    for item in _default_facts(args):
        command.extend(["--fact", item])
    return _run(command, parse_json=True, timeout=CHECKPOINT_TIMEOUT_SECONDS)


def report_snapshot() -> Dict[str, Any]:
    return _run([sys.executable, str(AQ_REPORT), "--format", "json"], parse_json=True, timeout=REPORT_TIMEOUT_SECONDS)


def qa_snapshot(args: argparse.Namespace) -> Dict[str, Any]:
    if args.skip_qa:
        return {"skipped": True, "reason": "skip_qa"}
    return _run([AQ_QA, "0", "--json"], parse_json=True, timeout=QA_TIMEOUT_SECONDS)


def maybe_repair(args: argparse.Namespace) -> Dict[str, Any]:
    if not args.execute:
        return {"skipped": True, "reason": "plan_mode"}
    command = shlex.split(args.repair_command)
    result = _run(command, timeout=REPAIR_TIMEOUT_SECONDS)
    if result.get("errno") == 8 and len(command) == 1:
        return _run(["bash", "-lc", command[0]], timeout=REPAIR_TIMEOUT_SECONDS)
    return result


def maybe_regenerate_continue_config(args: argparse.Namespace, repair: Dict[str, Any], qa: Dict[str, Any]) -> Dict[str, Any]:
    if not args.regenerate_continue_config:
        return {"skipped": True, "reason": "not_requested"}
    if not args.execute:
        return {"skipped": True, "reason": "plan_mode"}
    if not repair.get("ok"):
        return {"skipped": True, "reason": "repair_failed"}
    command = shlex.split(args.regenerate_command)
    result = _run(command, timeout=REGENERATE_TIMEOUT_SECONDS)
    if result.get("errno") == 8 and len(command) == 1:
        return _run(["bash", "-lc", command[0]], timeout=REGENERATE_TIMEOUT_SECONDS)
    return result


def resume_commands(task: str, project: str) -> List[str]:
    return [
        f'aq-memory search "{task}" --project {project} --limit 5',
        f'aq-context-bootstrap --task "resume {task}" --scope context-offload --format json',
        'aq-context-card --card context-offload --level standard',
        "aq-qa 0 --json",
        "codium",
    ]


def summarize(
    report: Dict[str, Any],
    qa: Dict[str, Any],
    repair: Dict[str, Any],
    regenerate_continue_config: Dict[str, Any],
    regenerate_command: str,
) -> Dict[str, Any]:
    summary: Dict[str, Any] = {
        "state_budget": None,
        "qa_phase_0": None,
        "qa_failures": [],
        "next_actions": [],
        "repair": {
            "ran": bool(repair and not repair.get("skipped")),
            "ok": bool(repair.get("ok", False)) if repair else False,
        },
        "regenerate_continue_config": {
            "ran": bool(regenerate_continue_config and not regenerate_continue_config.get("skipped")),
            "ok": bool(regenerate_continue_config.get("ok", False)) if regenerate_continue_config else False,
            "command": regenerate_command,
        },
    }
    report_json = report.get("json") if isinstance(report, dict) else None
    if isinstance(report_json, dict):
        summary["state_budget"] = (((report_json.get("continue_editor") or {}).get("state_budget")) or None)
    qa_json = qa.get("json") if isinstance(qa, dict) else None
    if isinstance(qa_json, dict):
        qa_failures = [
            {
                "id": item.get("id"),
                "description": item.get("description"),
            }
            for item in (qa_json.get("tests") or [])
            if str(item.get("status", "")).upper() == "FAIL"
        ]
        summary["qa_phase_0"] = {
            "passed": qa_json.get("passed"),
            "failed": qa_json.get("failed"),
            "skipped": qa_json.get("skipped"),
        }
        summary["qa_failures"] = qa_failures
        failure_ids = {str(item.get("id", "")) for item in qa_failures}
        if "0.5.2" in failure_ids:
            if regenerate_continue_config.get("ok"):
                summary["next_actions"].append("Continue config regeneration ran; rerun aq-qa 0 if 0.5.2 still appears stale before relaunching codium.")
            else:
                summary["next_actions"].append(
                    f"Run `{regenerate_command}` to regenerate ~/.continue/config.json after vscodium-repair reset the config version."
                )
        if any(failure_id.startswith("0.5.") for failure_id in failure_ids):
            summary["next_actions"].append("Relaunch codium only after the Continue config and editor-runtime checks pass again in aq-qa 0.")
    if repair and repair.get("ok"):
        summary["next_actions"].append("Use aq-memory recall and start a fresh editor session instead of reopening the previous swollen transcript.")
    return summary


def render_text(payload: Dict[str, Any]) -> str:
    lines = ["Editor Rescue", "=" * 60]
    checkpoint = payload.get("checkpoint") or {}
    report = payload.get("report") or {}
    qa = payload.get("qa") or {}
    repair = payload.get("repair") or {}
    regenerate_continue_config = payload.get("regenerate_continue_config") or {}
    summary = payload.get("summary") or {}
    if checkpoint.get("skipped"):
        lines.append("Checkpoint: skipped")
    else:
        lines.append(f"Checkpoint: {'ok' if checkpoint.get('ok') else 'failed'}")
    state_budget = summary.get("state_budget") or {}
    if state_budget:
        lines.append(
            f"Editor budget: {'healthy' if state_budget.get('healthy') else 'degraded'} "
            f"({state_budget.get('passed_n', 0)}/{state_budget.get('total_checks', 0)} checks passed)"
        )
    else:
        report_status = "timed out" if report.get("timed_out") else ("ok" if report.get("ok") else "failed")
        lines.append(f"aq-report: {report_status}")
    qa_phase_0 = summary.get("qa_phase_0") or {}
    if qa_phase_0:
        lines.append(
            f"aq-qa phase 0: {qa_phase_0.get('passed', 0)} passed, "
            f"{qa_phase_0.get('failed', 0)} failed, {qa_phase_0.get('skipped', 0)} skipped"
        )
    else:
        qa_status = "skipped" if qa.get("skipped") else ("timed out" if qa.get("timed_out") else ("ok" if qa.get("ok") else "failed"))
        lines.append(f"aq-qa phase 0: {qa_status}")
    if repair.get("skipped"):
        lines.append("Repair: plan mode only (not executed)")
    else:
        repair_status = "timed out" if repair.get("timed_out") else ("ok" if repair.get("ok") else "failed")
        lines.append(f"Repair: {repair_status}")
    if regenerate_continue_config.get("skipped"):
        if regenerate_continue_config.get("reason") == "not_requested":
            lines.append("Continue config regeneration: skipped")
    else:
        regenerate_status = (
            "timed out"
            if regenerate_continue_config.get("timed_out")
            else ("ok" if regenerate_continue_config.get("ok") else "failed")
        )
        lines.append(f"Continue config regeneration: {regenerate_status}")
    qa_failures = summary.get("qa_failures") or []
    if qa_failures:
        lines.append("QA failures:")
        for item in qa_failures[:5]:
            lines.append(f"  {item.get('id')}: {item.get('description')}")
    next_actions = summary.get("next_actions") or []
    if next_actions:
        lines.append("")
        lines.append("Next actions:")
        for action in next_actions:
            lines.append(f"  {action}")
    lines.append("")
    lines.append("Fresh-session resume:")
    for command in payload.get("resume_commands") or []:
        lines.append(f"  {command}")
    return "\n".join(lines)


def _append_history_record(args: argparse.Namespace, payload: Dict[str, Any]) -> None:
    summary = payload.get("summary") or {}
    state_budget = summary.get("state_budget") or {}
    qa_phase_0 = summary.get("qa_phase_0") or {}
    qa_failures = summary.get("qa_failures") or []
    repair = payload.get("repair") or {}
    regenerate = payload.get("regenerate_continue_config") or {}
    record = {
        "timestamp": datetime.now(tz=timezone.utc).isoformat().replace("+00:00", "Z"),
        "task": args.task,
        "project": args.project,
        "topic": args.topic,
        "execute": bool(args.execute),
        "skip_checkpoint": bool(args.skip_checkpoint),
        "skip_qa": bool(args.skip_qa),
        "checkpoint_ok": bool((payload.get("checkpoint") or {}).get("ok", False)),
        "report_ok": bool((payload.get("report") or {}).get("ok", False)),
        "state_budget_healthy": bool(state_budget.get("healthy", False)) if state_budget else None,
        "state_budget_failed_ids": [
            str(item.get("id", ""))
            for item in (state_budget.get("checks") or [])
            if str(item.get("status", "")).upper() == "FAIL"
        ],
        "qa_available": bool(qa_phase_0),
        "qa_passed": qa_phase_0.get("passed"),
        "qa_failed": qa_phase_0.get("failed"),
        "qa_skipped": qa_phase_0.get("skipped"),
        "qa_failure_ids": [str(item.get("id", "")) for item in qa_failures],
        "repair_attempted": bool(args.execute),
        "repair_ok": bool(repair.get("ok", False)) if not repair.get("skipped") else None,
        "repair_timed_out": bool(repair.get("timed_out", False)),
        "regenerate_requested": bool(args.regenerate_continue_config),
        "regenerate_ok": bool(regenerate.get("ok", False)) if not regenerate.get("skipped") else None,
        "regenerate_timed_out": bool(regenerate.get("timed_out", False)),
        "next_actions": summary.get("next_actions") or [],
        "final_ok": (
            bool((payload.get("checkpoint") or {}).get("ok", True))
            and bool((payload.get("report") or {}).get("ok", True))
            and bool((payload.get("qa") or {}).get("ok", True))
            and bool(repair.get("ok", True))
            and bool(regenerate.get("ok", True))
        ),
    }
    try:
        EDITOR_RESCUE_HISTORY_PATH.parent.mkdir(parents=True, exist_ok=True)
        with EDITOR_RESCUE_HISTORY_PATH.open("a", encoding="utf-8") as handle:
            handle.write(json.dumps(record) + "\n")
    except OSError:
        return


def main() -> int:
    args = parse_args()
    checkpoint = checkpoint_state(args)
    report = report_snapshot()
    qa = qa_snapshot(args)
    repair = maybe_repair(args)
    regenerate_continue_config = maybe_regenerate_continue_config(args, repair, qa)
    if regenerate_continue_config.get("ok") and not args.skip_qa:
        qa = qa_snapshot(args)
    payload = {
        "task": args.task,
        "checkpoint": checkpoint,
        "report": report,
        "qa": qa,
        "repair": repair,
        "regenerate_continue_config": regenerate_continue_config,
        "resume_commands": resume_commands(args.task, args.project),
    }
    payload["summary"] = summarize(report, qa, repair, regenerate_continue_config, args.regenerate_command)
    _append_history_record(args, payload)

    if args.fmt == "json":
        print(json.dumps(payload, indent=2))
    else:
        print(render_text(payload))

    if (
        checkpoint.get("ok", True)
        and report.get("ok", True)
        and qa.get("ok", True)
        and repair.get("ok", True)
        and regenerate_continue_config.get("ok", True)
    ) or (repair.get("skipped") and regenerate_continue_config.get("skipped")):
        return 0
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
