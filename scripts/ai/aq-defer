#!/usr/bin/env python3
"""
aq-defer <id> --hours N — Phase 86 alert deferral CLI.

Extends an alert's TTL by N hours without rejecting it.

Usage:
  aq-defer attn-a3f8c2b1 --hours 4
"""
from __future__ import annotations

import argparse
import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
sys.path.insert(0, str(_HERE / "lib"))

from attention_queue import get_by_id, extend_ttl  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(description="Defer a pending alert by extending its TTL")
    parser.add_argument("id", help="Alert ID (e.g. attn-a3f8c2b1)")
    parser.add_argument("--hours", type=int, required=True, help="Hours to extend TTL by")
    args = parser.parse_args()

    if args.hours < 1 or args.hours > 168:
        print("--hours must be 1–168 (max 1 week)", file=sys.stderr)
        return 1

    alert = get_by_id(args.id)
    if not alert:
        print(f"Alert {args.id!r} not found.", file=sys.stderr)
        return 1

    if alert.get("status") != "pending":
        print(f"Alert {args.id} is already {alert.get('status')!r} — cannot defer.")
        return 1

    ok = extend_ttl(args.id, args.hours)
    if ok:
        print(f"  Deferred: {alert.get('title', args.id)}")
        print(f"  Extended TTL by {args.hours}h.")
        return 0
    print("  extend_ttl() failed.", file=sys.stderr)
    return 1


if __name__ == "__main__":
    sys.exit(main())
