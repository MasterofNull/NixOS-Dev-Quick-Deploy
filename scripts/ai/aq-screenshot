#!/usr/bin/env bash
# aq-screenshot — Capture dashboard/webapp screenshots using system chromium.
# Uses Playwright Python with the nix-installed chromium; never downloads browsers.
#
# Usage:
#   aq-screenshot <url> <output.png> [--tab <tab-id>] [--wait <ms>] [--full-page]
#   aq-screenshot --all-tabs http://localhost:8889 /tmp/dash   # saves dash-{tab}.png
#
# Env:
#   CHROMIUM_PATH   Override chromium binary (default: auto-detected from nix profile)
#
# shellcheck shell=bash
set -euo pipefail

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<'EOF'
aq-screenshot — Capture dashboard/webapp screenshots using system Chromium.

Usage:
  aq-screenshot <url> <output.png> [--tab <tab-id>] [--wait <ms>] [--full-page]
  aq-screenshot --all-tabs <url> <output-prefix> [--wait <ms>]

Examples:
  aq-screenshot http://localhost:8889 /tmp/dashboard.png
  aq-screenshot http://localhost:8889 /tmp/security.png --tab tab-security
  aq-screenshot --all-tabs http://localhost:8889 /tmp/dashboard

Environment:
  CHROMIUM_PATH   Override Chromium binary path.

Requires the Python Playwright package. Home Manager provides it through
nix/home/base.nix; this command never downloads browser binaries at runtime.
EOF
  exit 0
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

# Resolve system chromium — nix profile first, then PATH
CHROMIUM_PATH="${CHROMIUM_PATH:-}"
if [[ -z "$CHROMIUM_PATH" ]]; then
  for candidate in \
    "$HOME/.nix-profile/bin/chromium" \
    "/run/current-system/sw/bin/chromium" \
    "$(command -v chromium 2>/dev/null || true)" \
    "$(command -v chromium-browser 2>/dev/null || true)"; do
    if [[ -x "$candidate" ]]; then
      CHROMIUM_PATH="$candidate"
      break
    fi
  done
fi

if [[ -z "$CHROMIUM_PATH" ]]; then
  echo "ERROR: chromium not found. Install via: nix-env -iA nixpkgs.chromium" >&2
  exit 1
fi

export CHROMIUM_PATH
export PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# Generate inline Python screenshot script
"${PYTHON_BIN:-python3}" - "$@" <<PYEOF
import sys
import os
import time
import argparse

try:
    from playwright.sync_api import sync_playwright
except ImportError:
    print("ERROR: playwright Python module not installed.", file=sys.stderr)
    print("After nixos-rebuild, run: home-manager switch", file=sys.stderr)
    sys.exit(1)

CHROMIUM = os.environ["CHROMIUM_PATH"]

parser = argparse.ArgumentParser(description="Capture screenshots with system chromium")
parser.add_argument("url",         nargs="?", help="URL to capture")
parser.add_argument("output",      nargs="?", help="Output .png path")
parser.add_argument("--tab",       help="CSS id of tab element to click before capture")
parser.add_argument("--wait",      type=int, default=2000, help="Wait ms after load (default 2000)")
parser.add_argument("--full-page", action="store_true", default=True)
parser.add_argument("--width",     type=int, default=1600)
parser.add_argument("--height",    type=int, default=900)
parser.add_argument("--all-tabs",  action="store_true", help="Capture all standard dashboard tabs")
parser.add_argument("--prefix",    help="File prefix for --all-tabs mode")
args = parser.parse_args()

tabs_spec = [
    ("overview",     None,                "tab-overview"),
    ("intelligence", None,                "tab-intelligence"),
    ("operations",   None,                "tab-operations"),
    ("security",     None,                "tab-security"),
]

errors = []

def capture(page, url, output, tab_id=None, wait_ms=2000, full_page=True):
    page.goto(url)
    page.wait_for_load_state("networkidle")
    if tab_id:
        try:
            page.click(f"#{tab_id}")
            page.wait_for_load_state("networkidle")
        except Exception:
            pass
    time.sleep(wait_ms / 1000)
    page.screenshot(path=output, full_page=full_page)
    print(f"SAVED {output}")

with sync_playwright() as p:
    browser = p.chromium.launch(
        executable_path=CHROMIUM,
        headless=True,
        args=["--no-sandbox", "--disable-dev-shm-usage"],
    )
    page = browser.new_page(viewport={"width": args.width, "height": args.height})
    page.on("console", lambda m: errors.append(m.text) if m.type == "error" else None)

    if args.all_tabs:
        base_url = args.url or "http://localhost:8889"
        prefix   = args.prefix or args.output or "/tmp/dash"
        for name, url_override, tid in tabs_spec:
            out = f"{prefix}-{name}.png"
            capture(page, url_override or base_url, out, tab_id=tid if name != "overview" else None,
                    wait_ms=args.wait)
    else:
        if not args.url or not args.output:
            parser.print_help()
            sys.exit(1)
        capture(page, args.url, args.output, tab_id=args.tab, wait_ms=args.wait,
                full_page=args.full_page)

    browser.close()

if errors:
    print("\nJS Console Errors:")
    for e in errors[:10]:
        print(f"  {e}")
PYEOF
