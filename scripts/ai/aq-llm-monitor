#!/usr/bin/env bash
set -euo pipefail

# Local LLM Monitor CLI
# Tracks local LLM operations, value contributions, and autonomous actions

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
MONITOR_SCRIPT="$REPO_ROOT/ai-stack/monitoring/local_llm_monitor.py"

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

usage() {
    cat <<EOF
Local LLM Monitor - Track local model operations and value contributions

Usage:
    aq-llm-monitor <command> [options]

Commands:
    metrics                  Show current metrics (default: 24h)
    value-report             Show value contribution report
    health                   Check local LLM health status
    contributions            List recent contributions
    autonomous               Show autonomous operation stats
    integration-test         Test integration with AI stack
    cleanup <days>           Clean up old records

Options:
    --hours <N>             Time window in hours (default: 24)
    --json                  Output as JSON
    --watch                 Continuously update (5s intervals)

Examples:
    # Quick health check
    aq-llm-monitor health

    # Last hour metrics
    aq-llm-monitor metrics --hours 1

    # Value report
    aq-llm-monitor value-report

    # Monitor continuously
    aq-llm-monitor metrics --watch

    # Clean up old data
    aq-llm-monitor cleanup 30

EOF
    exit 1
}

check_python() {
    if ! command -v python3 &>/dev/null; then
        echo -e "${RED}Error: python3 not found${NC}" >&2
        exit 1
    fi
}

check_postgres() {
    POSTGRES_PASSWORD="${POSTGRES_PASSWORD:-}"
    if [[ -z "$POSTGRES_PASSWORD" ]] && [[ -f /run/secrets/postgres_password ]]; then
        POSTGRES_PASSWORD="$(cat /run/secrets/postgres_password)"
        export POSTGRES_PASSWORD
    fi
}

health() {
    echo -e "${YELLOW}Checking Local LLM Health...${NC}"
    echo ""

    # Chat model
    echo "Chat Model (port 8080):"
    if curl -s --max-time 5 http://localhost:8080/health | jq -r '.status // "unhealthy"' 2>/dev/null; then
        echo -e "${GREEN}âś“ Healthy${NC}"
    else
        echo -e "${RED}âś— Unhealthy or unreachable${NC}"
    fi
    echo ""

    # Embedding model
    echo "Embedding Model (port 8081):"
    if curl -s --max-time 5 http://localhost:8081/health | jq -r '.status // "unhealthy"' 2>/dev/null; then
        echo -e "${GREEN}âś“ Healthy${NC}"
    else
        echo -e "${RED}âś— Unhealthy or unreachable${NC}"
    fi
    echo ""

    # Process check
    echo "Processes:"
    if pgrep -a llama-server | grep -q "8080"; then
        echo -e "${GREEN}âś“ Chat model running${NC}"
    else
        echo -e "${RED}âś— Chat model not found${NC}"
    fi

    if pgrep -a llama-server | grep -q "8081"; then
        echo -e "${GREEN}âś“ Embedding model running${NC}"
    else
        echo -e "${RED}âś— Embedding model not found${NC}"
    fi
    echo ""

    # Check monitoring database
    echo "Monitoring Database:"
    if check_postgres && python3 "$MONITOR_SCRIPT" --metrics --hours 1 &>/dev/null; then
        echo -e "${GREEN}âś“ Connected${NC}"
    else
        echo -e "${YELLOW}âš  Database connection issue${NC}"
    fi
}

metrics() {
    local hours="${1:-24}"
    local format="${2:-human}"

    check_python
    check_postgres

    if [[ "$format" == "json" ]]; then
        python3 "$MONITOR_SCRIPT" --metrics --hours "$hours"
    else
        echo -e "${YELLOW}Local LLM Metrics (last ${hours}h)${NC}"
        echo ""
        python3 "$MONITOR_SCRIPT" --metrics --hours "$hours" | jq -r '
            "Operations:",
            "  Total: \(.operations | map(.count) | add // 0)",
            "  By Type:",
            (.operations[] | "    \(.operation_type): \(.count) ops, avg \(.avg_tokens | round) tokens, \(.avg_latency_ms | round)ms, quality: \(.avg_quality | . * 100 | round)%"),
            "",
            "Purposes:",
            (.purposes[] | "  \(.purpose): \(.count) ops, value: \(.avg_value | . * 100 | round)%"),
            "",
            "Contributions:",
            (.contributions[] | "  \(.contribution_type): \(.count) total, \(.applied_count) applied, impact: \(.avg_impact | . * 100 | round)%"),
            "",
            "Health:",
            "  Chat Model: \(.health.chat_model.status) (\(.health.chat_model.latency_ms)ms)",
            "  Embedding Model: \(.health.embedding_model.status) (\(.health.embedding_model.latency_ms)ms)"
        '
    fi
}

value_report() {
    local hours="${1:-24}"
    local format="${2:-human}"

    check_python
    check_postgres

    if [[ "$format" == "json" ]]; then
        python3 "$MONITOR_SCRIPT" --value-report --hours "$hours"
    else
        echo -e "${YELLOW}Local LLM Value Contribution Report (last ${hours}h)${NC}"
        echo ""
        python3 "$MONITOR_SCRIPT" --value-report --hours "$hours" | jq -r '
            "Summary:",
            "  Total Operations: \(.summary.total_operations)",
            "  Autonomous Operations: \(.summary.autonomous_operations) (\(.summary.autonomy_ratio * 100 | round)%)",
            "  Average Value Score: \(.summary.average_value_score)",
            "  High-Value Operations: \(.summary.high_value_operations)",
            "  Applied Contributions: \(.summary.applied_contributions)",
            "",
            "Top High-Value Operations:",
            (.high_value_operations[:5][] | "  [\(.value_score | . * 100 | round)%] \(.operation_type) - \(.purpose) (\(.tokens) tokens)"),
            "",
            "Recent Applied Contributions:",
            (.applied_contributions[:5][] | "  [\(.impact_score | . * 100 | round)%] \(.contribution_type): \(.description[:60])..."),
            "",
            "Autonomous Improvement Integration:",
            "  Improvement Cycles: \(.autonomous_improvement_integration.improvement_cycles // 0)",
            "  Trigger Events: \(.autonomous_improvement_integration.trigger_events // 0)",
            "  Hypotheses Generated: \(.autonomous_improvement_integration.hypotheses_generated // 0)"
        '
    fi
}

contributions() {
    check_python
    check_postgres

    echo -e "${YELLOW}Recent Local LLM Contributions${NC}"
    echo ""

    PGPASSWORD="$POSTGRES_PASSWORD" psql -h 127.0.0.1 -U postgres -d ai_context -c "
        SELECT
            contribution_type,
            LEFT(description, 60) as description,
            ROUND(impact_score::numeric, 2) as impact,
            status,
            created_at
        FROM local_llm_contributions
        ORDER BY created_at DESC
        LIMIT 20;
    " 2>/dev/null || echo -e "${RED}Database query failed${NC}"
}

autonomous_stats() {
    check_postgres

    echo -e "${YELLOW}Autonomous Operation Statistics${NC}"
    echo ""

    PGPASSWORD="$POSTGRES_PASSWORD" psql -h 127.0.0.1 -U postgres -d ai_context -c "
        SELECT
            session_type,
            operation_type,
            COUNT(*) as operations,
            ROUND(AVG(value_score)::numeric, 3) as avg_value,
            ROUND(AVG(input_tokens + output_tokens)::numeric, 0) as avg_tokens
        FROM local_llm_operations
        WHERE created_at >= NOW() - INTERVAL '24 hours'
        GROUP BY session_type, operation_type
        ORDER BY session_type, operations DESC;
    " 2>/dev/null || echo -e "${RED}Database query failed${NC}"
}

integration_test() {
    echo -e "${YELLOW}Testing Local LLM Integration...${NC}"
    echo ""

    # Test 1: Chat endpoint
    echo "1. Testing chat endpoint..."
    response=$(curl -s --max-time 10 -X POST http://localhost:8080/chat/completions \
        -H "Content-Type: application/json" \
        -d '{"messages":[{"role":"user","content":"Say test"}],"max_tokens":10}')

    if echo "$response" | jq -e '.choices[0].message.content' &>/dev/null; then
        echo -e "${GREEN}âś“ Chat endpoint working${NC}"
    else
        echo -e "${RED}âś— Chat endpoint failed${NC}"
        echo "$response" | jq '.'
    fi
    echo ""

    # Test 2: Embedding endpoint
    echo "2. Testing embedding endpoint..."
    embed_response=$(curl -s --max-time 10 -X POST http://localhost:8081/embeddings \
        -H "Content-Type: application/json" \
        -d '{"input":"test"}')

    if echo "$embed_response" | jq -e '.data[0].embedding' &>/dev/null; then
        echo -e "${GREEN}âś“ Embedding endpoint working${NC}"
    else
        echo -e "${RED}âś— Embedding endpoint failed${NC}"
        echo "$embed_response" | jq '.'
    fi
    echo ""

    # Test 3: Monitoring database
    echo "3. Testing monitoring database..."
    if check_postgres && python3 "$MONITOR_SCRIPT" --metrics --hours 1 &>/dev/null; then
        echo -e "${GREEN}âś“ Monitoring database accessible${NC}"
    else
        echo -e "${RED}âś— Monitoring database failed${NC}"
    fi
    echo ""

    # Test 4: Integration with autonomous improvement
    echo "4. Checking autonomous improvement integration..."
    if systemctl is-active --quiet ai-autonomous-improvement.service 2>/dev/null; then
        echo -e "${GREEN}âś“ Autonomous improvement service active${NC}"
    else
        echo -e "${YELLOW}âš  Autonomous improvement service not active${NC}"
    fi

    if systemctl is-active --quiet ai-autonomous-improvement.timer 2>/dev/null; then
        next_run=$(systemctl status ai-autonomous-improvement.timer 2>/dev/null | grep "Trigger:" | awk '{print $2, $3, $4}')
        echo -e "${GREEN}âś“ Timer active, next run: $next_run${NC}"
    else
        echo -e "${YELLOW}âš  Timer not active${NC}"
    fi
}

cleanup() {
    local days="${1:-30}"

    check_python
    check_postgres

    echo -e "${YELLOW}Cleaning up records older than ${days} days...${NC}"
    python3 "$MONITOR_SCRIPT" --cleanup "$days"
    echo -e "${GREEN}âś“ Cleanup complete${NC}"
}

watch_metrics() {
    local hours="${1:-24}"

    while true; do
        clear
        metrics "$hours" "human"
        echo ""
        echo -e "${YELLOW}Refreshing every 5 seconds... (Ctrl+C to stop)${NC}"
        sleep 5
    done
}

# Main command routing
COMMAND="${1:-}"
shift || true

case "$COMMAND" in
    metrics)
        HOURS=24
        FORMAT="human"
        WATCH=false

        while [[ $# -gt 0 ]]; do
            case "$1" in
                --hours)
                    HOURS="$2"
                    shift 2
                    ;;
                --json)
                    FORMAT="json"
                    shift
                    ;;
                --watch)
                    WATCH=true
                    shift
                    ;;
                *)
                    echo "Unknown option: $1" >&2
                    usage
                    ;;
            esac
        done

        if [[ "$WATCH" == "true" ]]; then
            watch_metrics "$HOURS"
        else
            metrics "$HOURS" "$FORMAT"
        fi
        ;;

    value-report)
        HOURS=24
        FORMAT="human"

        while [[ $# -gt 0 ]]; do
            case "$1" in
                --hours)
                    HOURS="$2"
                    shift 2
                    ;;
                --json)
                    FORMAT="json"
                    shift
                    ;;
                *)
                    echo "Unknown option: $1" >&2
                    usage
                    ;;
            esac
        done

        value_report "$HOURS" "$FORMAT"
        ;;

    health)
        health
        ;;

    contributions)
        contributions
        ;;

    autonomous)
        autonomous_stats
        ;;

    integration-test)
        integration_test
        ;;

    cleanup)
        DAYS="${1:-30}"
        cleanup "$DAYS"
        ;;

    ""|--help|-h|help)
        usage
        ;;

    *)
        echo -e "${RED}Unknown command: $COMMAND${NC}" >&2
        echo ""
        usage
        ;;
esac
