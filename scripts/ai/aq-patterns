#!/usr/bin/env bash
# aq-patterns — Extract and analyze recurring patterns from AI stack telemetry
# Identifies high-frequency patterns for integration into hints/RAG
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

# Default paths
HINT_AUDIT_PATH="${HINT_AUDIT_LOG_PATH:-/var/log/nixos-ai-stack/hint-audit.jsonl}"
TOOL_AUDIT_PATH="${TOOL_AUDIT_LOG_PATH:-/var/log/nixos-ai-stack/tool-audit.jsonl}"
GAPS_PATH="${GAPS_JSONL:-/var/lib/ai-stack/query_gaps.jsonl}"
OUTPUT_FORMAT="text"
MIN_OCCURRENCES=3
MIN_QUALITY_SCORE=0.7

usage() {
    cat <<EOF
Usage: aq-patterns [command] [options]

Commands:
    extract         Extract patterns from telemetry (default)
    list            List known patterns
    stats           Show pattern statistics
    quality         Score and filter patterns

Options:
    --min-occurrences N    Minimum occurrences to qualify (default: 3)
    --min-quality N        Minimum quality score 0.0-1.0 (default: 0.7)
    --format json|text     Output format (default: text)
    --since DURATION       Time window (e.g., 7d, 24h)
    --help                 Show this help

Examples:
    aq-patterns extract --min-occurrences 5
    aq-patterns stats --format json
    aq-patterns quality --min-quality 0.8
EOF
}

extract_hint_patterns() {
    if [[ ! -f "$HINT_AUDIT_PATH" ]]; then
        echo "No hint audit data found at $HINT_AUDIT_PATH" >&2
        return 0
    fi

    python3 - "$HINT_AUDIT_PATH" "$MIN_OCCURRENCES" "$OUTPUT_FORMAT" <<'PYTHON'
import json
import sys
from collections import Counter
from pathlib import Path

audit_path = Path(sys.argv[1])
min_occurrences = int(sys.argv[2])
output_format = sys.argv[3]

patterns = Counter()
hint_types = Counter()
successful_hints = Counter()

for line in audit_path.read_text().splitlines()[-1000:]:
    try:
        entry = json.loads(line)
        hint_id = entry.get("hint_id", "")
        hint_type = entry.get("hint_type", "unknown")
        accepted = entry.get("accepted", False)

        if hint_id:
            patterns[hint_id] += 1
            hint_types[hint_type] += 1
            if accepted:
                successful_hints[hint_id] += 1
    except:
        continue

# Filter by minimum occurrences
qualifying = {k: v for k, v in patterns.items() if v >= min_occurrences}

if output_format == "json":
    result = {
        "patterns": [
            {
                "id": k,
                "occurrences": v,
                "success_count": successful_hints.get(k, 0),
                "success_rate": successful_hints.get(k, 0) / v if v > 0 else 0,
                "quality_score": min(1.0, (successful_hints.get(k, 0) / v) * 1.2) if v > 0 else 0
            }
            for k, v in sorted(qualifying.items(), key=lambda x: -x[1])
        ],
        "type_distribution": dict(hint_types.most_common(10)),
        "total_patterns": len(qualifying),
        "min_occurrences_threshold": min_occurrences
    }
    print(json.dumps(result, indent=2))
else:
    print(f"Hint Patterns (≥{min_occurrences} occurrences):")
    print("-" * 60)
    for hint_id, count in sorted(qualifying.items(), key=lambda x: -x[1])[:20]:
        success = successful_hints.get(hint_id, 0)
        rate = success / count if count > 0 else 0
        print(f"  {hint_id}: {count}x (success: {rate:.0%})")
    print(f"\nTotal qualifying patterns: {len(qualifying)}")
PYTHON
}

extract_gap_patterns() {
    if [[ ! -f "$GAPS_PATH" ]]; then
        echo "No gaps data found at $GAPS_PATH" >&2
        return 0
    fi

    python3 - "$GAPS_PATH" "$MIN_OCCURRENCES" "$OUTPUT_FORMAT" <<'PYTHON'
import json
import sys
from collections import Counter
from pathlib import Path

gaps_path = Path(sys.argv[1])
min_occurrences = int(sys.argv[2])
output_format = sys.argv[3]

topic_patterns = Counter()
query_patterns = Counter()

for line in gaps_path.read_text().splitlines()[-500:]:
    try:
        entry = json.loads(line)
        topic = entry.get("topic", "")
        query = entry.get("query", "")[:50]  # Truncate for grouping

        if topic:
            topic_patterns[topic] += 1
        if query:
            # Normalize query for pattern detection
            normalized = " ".join(query.lower().split()[:5])
            query_patterns[normalized] += 1
    except:
        continue

qualifying_topics = {k: v for k, v in topic_patterns.items() if v >= min_occurrences}
qualifying_queries = {k: v for k, v in query_patterns.items() if v >= min_occurrences}

if output_format == "json":
    result = {
        "topic_patterns": [
            {"topic": k, "occurrences": v, "priority": min(1.0, v / 10)}
            for k, v in sorted(qualifying_topics.items(), key=lambda x: -x[1])
        ],
        "query_patterns": [
            {"query_prefix": k, "occurrences": v}
            for k, v in sorted(qualifying_queries.items(), key=lambda x: -x[1])[:15]
        ],
        "total_topic_patterns": len(qualifying_topics),
        "total_query_patterns": len(qualifying_queries)
    }
    print(json.dumps(result, indent=2))
else:
    print(f"\nGap Topic Patterns (≥{min_occurrences} occurrences):")
    print("-" * 60)
    for topic, count in sorted(qualifying_topics.items(), key=lambda x: -x[1])[:15]:
        print(f"  {topic}: {count}x")
    print(f"\nTotal topic patterns: {len(qualifying_topics)}")
PYTHON
}

show_stats() {
    python3 - "$HINT_AUDIT_PATH" "$GAPS_PATH" "$OUTPUT_FORMAT" <<'PYTHON'
import json
import sys
from pathlib import Path
from collections import Counter
from datetime import datetime

hint_path = Path(sys.argv[1])
gaps_path = Path(sys.argv[2])
output_format = sys.argv[3]

stats = {
    "hint_audit": {"exists": hint_path.exists(), "lines": 0, "unique_hints": 0},
    "gaps": {"exists": gaps_path.exists(), "lines": 0, "unique_topics": 0},
    "pattern_library_estimate": 0
}

if hint_path.exists():
    lines = hint_path.read_text().splitlines()
    stats["hint_audit"]["lines"] = len(lines)
    hints = set()
    for line in lines[-500:]:
        try:
            hints.add(json.loads(line).get("hint_id", ""))
        except:
            pass
    stats["hint_audit"]["unique_hints"] = len(hints)

if gaps_path.exists():
    lines = gaps_path.read_text().splitlines()
    stats["gaps"]["lines"] = len(lines)
    topics = set()
    for line in lines[-500:]:
        try:
            topics.add(json.loads(line).get("topic", ""))
        except:
            pass
    stats["gaps"]["unique_topics"] = len(topics)

stats["pattern_library_estimate"] = stats["hint_audit"]["unique_hints"] + stats["gaps"]["unique_topics"]
stats["generated_at"] = datetime.utcnow().isoformat() + "Z"

if output_format == "json":
    print(json.dumps(stats, indent=2))
else:
    print("Pattern Extraction Statistics")
    print("=" * 40)
    print(f"Hint Audit: {stats['hint_audit']['lines']} entries, {stats['hint_audit']['unique_hints']} unique hints")
    print(f"Query Gaps: {stats['gaps']['lines']} entries, {stats['gaps']['unique_topics']} unique topics")
    print(f"Estimated Pattern Library Size: {stats['pattern_library_estimate']}")
PYTHON
}

# Parse arguments
COMMAND="${1:-extract}"
shift || true

while [[ $# -gt 0 ]]; do
    case "$1" in
        --min-occurrences)
            MIN_OCCURRENCES="$2"
            shift 2
            ;;
        --min-quality)
            MIN_QUALITY_SCORE="$2"
            shift 2
            ;;
        --format)
            OUTPUT_FORMAT="$2"
            shift 2
            ;;
        --since)
            # TODO: Implement time filtering
            shift 2
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            usage
            exit 1
            ;;
    esac
done

case "$COMMAND" in
    extract)
        extract_hint_patterns
        extract_gap_patterns
        ;;
    list)
        extract_hint_patterns
        ;;
    stats)
        show_stats
        ;;
    quality)
        # Filter by quality score
        MIN_OCCURRENCES=1
        extract_hint_patterns | python3 -c "
import sys, json
data = json.load(sys.stdin) if '--format json' in ' '.join(sys.argv) else None
if data:
    data['patterns'] = [p for p in data['patterns'] if p.get('quality_score', 0) >= $MIN_QUALITY_SCORE]
    print(json.dumps(data, indent=2))
" 2>/dev/null || extract_hint_patterns
        ;;
    *)
        echo "Unknown command: $COMMAND" >&2
        usage
        exit 1
        ;;
esac
