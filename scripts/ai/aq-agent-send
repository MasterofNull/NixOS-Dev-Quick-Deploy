#!/usr/bin/env python3
"""aq-agent-send — send an operator message to a RUNNING agent (intervention channel).

A running aq-agent-loop polls its control queue between turns and injects your message
into its conversation (as [OPERATOR INTERVENTION]) or stops on --cancel. Pair with
`aq-tui-dashboard --matrix` to watch the effect.

  aq-agent-send <task_id> "focus on the switchboard path, not the coordinator"
  aq-agent-send <task_id> "wrong direction — stop and re-plan" --cancel
"""
import sys
from importlib.machinery import SourceFileLoader
from pathlib import Path

_REPO = Path(__file__).resolve().parents[2]
_cc = SourceFileLoader(
    "control_channel", str(_REPO / "ai-stack" / "local-agents" / "control_channel.py")
).load_module()


def main() -> int:
    args = sys.argv[1:]
    cancel = "--cancel" in args
    args = [a for a in args if a != "--cancel"]
    if len(args) < 2:
        print('usage: aq-agent-send <task_id> "<message>" [--cancel]', file=sys.stderr)
        return 2
    task_id, text = args[0], " ".join(args[1:])
    try:
        rec = _cc.send(task_id, text, kind="cancel" if cancel else "inject")
    except ValueError as e:
        print(f"error: {e}", file=sys.stderr)
        return 1
    print(f"[aq-agent-send] queued {rec['kind']} -> {task_id}: {text[:60]}")
    print(f"  the agent injects it at its next turn. watch: aq-tui-dashboard --focus {task_id}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
