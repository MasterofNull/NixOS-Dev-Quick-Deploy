#!/usr/bin/env python3
"""
aq-drop-daemon — Phase 85 PAEA Drop Zone Daemon.

Watches .agents/drops/*.drop.yaml for task files, validates them via
DropSpec, dispatches via dispatch_task(), then archives processed files.

Designed to run as a long-lived systemd service (ai-drop-daemon.service).

Security: DropSpec rejects injection patterns before any dispatch.
          All dispatch is via Python import — no shell-out.
          fcntl.LOCK_NB prevents double-dispatch if two instances run.
"""
from __future__ import annotations

import fcntl
import logging
import os
import signal
import sys
import time
from datetime import datetime, timezone
from pathlib import Path

# ── path resolution ───────────────────────────────────────────────────────────
_HERE = Path(__file__).resolve().parent        # scripts/ai/
_LIB = _HERE / "lib"
# Use REPO_ROOT env var when set (systemd unit, Nix store script) — __file__ resolves
# to the read-only Nix store copy which causes EROFS on any write attempt.
import os as _os
_REPO_ROOT = Path(_os.environ["REPO_ROOT"]) if "REPO_ROOT" in _os.environ else _HERE.parent.parent
for _p in [str(_LIB), str(_REPO_ROOT)]:
    if _p not in sys.path:
        sys.path.insert(0, _p)

from drop_spec import DropSpec, DropSpecError              # noqa: E402
from task_config import TaskConfig                         # noqa: E402
from task_registry import TaskRegistry                     # noqa: E402
from dispatch import classify_mode, dispatch_task          # noqa: E402

try:
    from attention_queue import push
except ImportError:
    # Fallback for environments where attention_queue is not yet available
    def push(*args, **kwargs): return None

# ── config ────────────────────────────────────────────────────────────────────
_DROPS_DIR      = _REPO_ROOT / ".agents" / "drops"
_ARCHIVE_DIR    = _DROPS_DIR / "archive"
_FAILED_DIR     = _DROPS_DIR / "failed"
_LOCK_FILE      = _DROPS_DIR / ".lock"
_DELEGATION_DIR = _REPO_ROOT / ".agents" / "delegation"
_OUTPUTS_DIR    = _DELEGATION_DIR / "outputs"

_POLL_INTERVAL_S   = 2
_GC_EVERY_N_CYCLES = 60   # run expired-lock GC every ~120s

_LLAMA_URL  = os.environ.get("LLAMA_URL",  "http://127.0.0.1:8080")
_HYBRID_URL = os.environ.get("HYBRID_URL", "http://127.0.0.1:8003")
_RALPH_URL  = os.environ.get("RALPH_URL",  "http://127.0.0.1:8004")
_TIMEOUT_S  = int(os.environ.get("DROP_DAEMON_TIMEOUT", "300"))

# Rate limit: max dispatches per cycle window (prevents flooding)
_MAX_DISPATCHES_PER_CYCLE = int(os.environ.get("DROP_MAX_PER_CYCLE", "3"))
# Hard cap on total queued files at any time
_MAX_QUEUED = int(os.environ.get("DROP_MAX_QUEUED", "20"))

# ── logging ───────────────────────────────────────────────────────────────────
logging.basicConfig(
    level=logging.INFO,
    format='{"ts":"%(asctime)s","level":"%(levelname)s","msg":"%(message)s"}',
    datefmt="%Y-%m-%dT%H:%M:%SZ",
    stream=sys.stdout,
)
log = logging.getLogger("aq-drop-daemon")

# ── graceful shutdown ─────────────────────────────────────────────────────────
_running = True

def _handle_signal(signum, frame):  # noqa: ARG001
    global _running
    log.info("signal %d received — shutting down cleanly", signum)
    _running = False

signal.signal(signal.SIGTERM, _handle_signal)
signal.signal(signal.SIGINT, _handle_signal)


# ── helpers ───────────────────────────────────────────────────────────────────

def _ensure_dirs() -> None:
    for d in (_DROPS_DIR, _ARCHIVE_DIR, _FAILED_DIR, _OUTPUTS_DIR):
        d.mkdir(parents=True, exist_ok=True)


def _scan_drops() -> list[Path]:
    """Return *.drop.yaml files in .agents/drops/, sorted oldest-first."""
    return sorted(_DROPS_DIR.glob("*.drop.yaml"), key=lambda p: p.stat().st_mtime)


def _archive(path: Path) -> None:
    os.rename(path, _ARCHIVE_DIR / path.name)
    log.info("archived drop=%s", path.name)


def _fail(path: Path, reason: str) -> None:
    os.rename(path, _FAILED_DIR / path.name)
    log.error("failed drop=%s reason=%s", path.name, reason)


def _process_drop(drop_path: Path, registry: TaskRegistry) -> None:
    """Validate → dispatch → archive/fail a single drop file."""
    try:
        spec = DropSpec.from_file(drop_path)
    except DropSpecError as exc:
        _fail(drop_path, str(exc))
        return

    # Resolve "auto" mode via heuristic classifier
    resolved_mode = classify_mode(spec.prompt) if spec.mode == "auto" else spec.mode

    # Slice 3: Attention Queue Integration
    # mode=agent → human_gate (has shell execution capability)
    # mode=direct|hybrid → auto_ok for inference-only drops
    if resolved_mode == "agent":
        boundary = "human_gate"
    else:
        boundary = "auto_ok"

    push(
        source="drop_dispatch",
        severity="medium",
        autonomy_boundary=boundary,
        title=f"Drop Dispatch: {spec.role} ({resolved_mode})",
        detail=f"Objective: {spec.prompt[:100]}...\nFile: {drop_path.name}",
        proposed_action=f"Approve dispatch of drop {drop_path.name}",
        payload={
            "drop_path": str(drop_path),
            "mode": resolved_mode,
            "role": spec.role,
            "prompt": spec.prompt
        },
        executor="drop_dispatch"
    )

    if boundary == "human_gate":
        log.info("drop=%s gated for human approval (mode=agent)", drop_path.name)
        return

    try:
        config = TaskConfig.from_args(
            mode=resolved_mode,
            role=spec.role,
            timeout_secs=_TIMEOUT_S,
            max_tokens=None,
            llama_url=_LLAMA_URL,
            hybrid_url=_HYBRID_URL,
            ralph_url=_RALPH_URL,
        )
    except ValueError as exc:
        _fail(drop_path, f"TaskConfig error: {exc}")
        return

    task_id = f"drop-{spec.drop_id[:8]}"
    output_file = _OUTPUTS_DIR / f"{task_id}.log"

    log.info(
        "dispatching drop=%s task=%s mode=%s role=%s priority=%d",
        drop_path.name, task_id, resolved_mode, spec.role, spec.priority,
    )

    try:
        success = dispatch_task(
            config=config,
            prompt=spec.prompt,
            task_id=task_id,
            output_file=output_file,
            registry=registry,
            script_dir=_HERE,
        )
    except Exception as exc:
        log.exception("dispatch_task raised for drop=%s: %s", drop_path.name, exc)
        _fail(drop_path, f"dispatch exception: {exc}")
        return

    if success:
        _archive(drop_path)
    else:
        _fail(drop_path, "dispatch_task returned False")


def _gc_expired_locks(registry: TaskRegistry) -> None:
    """Release PENDING.json entries whose heartbeat has expired (Intent Lock v2)."""
    try:
        released = registry.release_expired_locks()
        if released:
            log.info("GC released expired locks: %s", released)
    except Exception as exc:
        log.warning("GC pass failed: %s", exc)


# ── main loop ─────────────────────────────────────────────────────────────────

def main() -> None:
    _ensure_dirs()
    registry = TaskRegistry(_DELEGATION_DIR, _REPO_ROOT)
    log.info("aq-drop-daemon started watching %s", _DROPS_DIR)

    cycle = 0
    while _running:
        try:
            with open(_LOCK_FILE, "w") as lock_fh:
                try:
                    fcntl.flock(lock_fh, fcntl.LOCK_EX | fcntl.LOCK_NB)
                except BlockingIOError:
                    # Another instance holds the scan lock — skip this cycle
                    log.debug("scan lock held by another instance, skipping cycle")
                    time.sleep(_POLL_INTERVAL_S)
                    continue
                try:
                    drops = _scan_drops()
                    # Hard cap: refuse to queue more than _MAX_QUEUED files at once
                    if len(drops) > _MAX_QUEUED:
                        log.warning(
                            "drop queue depth %d exceeds limit %d — oldest %d will be processed, rest left for next cycle",
                            len(drops), _MAX_QUEUED, _MAX_DISPATCHES_PER_CYCLE,
                        )
                        drops = drops[:_MAX_DISPATCHES_PER_CYCLE]
                    else:
                        drops = drops[:_MAX_DISPATCHES_PER_CYCLE]
                    for drop_path in drops:
                        if not _running:
                            break
                        _process_drop(drop_path, registry)
                    cycle += 1
                    if cycle % _GC_EVERY_N_CYCLES == 0:
                        _gc_expired_locks(registry)
                finally:
                    fcntl.flock(lock_fh, fcntl.LOCK_UN)
        except Exception as exc:
            log.exception("unexpected error in main loop: %s", exc)

        time.sleep(_POLL_INTERVAL_S)

    log.info("aq-drop-daemon stopped")


if __name__ == "__main__":
    main()
