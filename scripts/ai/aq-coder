#!/usr/bin/env bash
# aq-coder — switch to fast local coding model (qwen3-4b, ~2.5 GB, 30 GPU layers)
# Optimised for quick iteration: short edits, inline help, smoke tests.
# Switch back with: aq-architect
#
# Usage:
#   aq-coder              Switch to qwen3-4b
#   aq-coder --dry-run    Preview without changes
#   aq-coder --list       Show available models + current active
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ "${1-}" == "--list" ]]; then
    exec sudo "$SCRIPT_DIR/aq-model-switch" --list
fi

echo "Switching to fast coding model (qwen3-4b)..."
exec sudo "$SCRIPT_DIR/aq-model-switch" qwen3-4b "$@"
