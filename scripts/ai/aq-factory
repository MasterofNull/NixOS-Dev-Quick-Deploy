#!/usr/bin/env python3
"""
aq-factory — Toolbox Factory for dynamic tool scaffolding.
"""
import os
import sys
from pathlib import Path

def create_tool(tool_name: str, purpose: str):
    base_dir = Path("ai-stack/agents/skills") / tool_name
    base_dir.mkdir(parents=True, exist_ok=True)
    
    # Generate SKILL.md
    skill_content = f"# Skill: {tool_name}\n\n- **Purpose**: {purpose}\n- **Workflow**: ...\n"
    (base_dir / "SKILL.md").write_text(skill_content)
    
    # Generate __init__.py
    (base_dir / "__init__.py").write_text("def run(args):\n    return 'Not implemented'\n")
    
    # Generate Test
    test_content = "import unittest\nfrom . import run\nclass TestTool(unittest.TestCase):\n    def test_run(self): pass\n"
    (base_dir / "test.py").write_text(test_content)
    
    print(f"Tool '{tool_name}' scaffolded at {base_dir}")

if __name__ == "__main__":
    if len(sys.argv) < 3:
        print("Usage: aq-factory <name> <purpose>")
    else:
        create_tool(sys.argv[1], sys.argv[2])
