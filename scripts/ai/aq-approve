#!/usr/bin/env python3
"""
aq-approve <id> — Phase 86 alert approval CLI.

Marks a human_gate alert as approved and runs its executor if present.
Executor dispatch uses a hardcoded safe handler table — no raw eval().

Usage:
  aq-approve attn-a3f8c2b1
"""
from __future__ import annotations

import subprocess
import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
_REPO_ROOT = _HERE.parent.parent
sys.path.insert(0, str(_HERE))
sys.path.insert(0, str(_HERE / "lib"))

from attention_queue import get_by_id, resolve  # noqa: E402
from task_config import TaskConfig               # noqa: E402
from task_registry import TaskRegistry           # noqa: E402
from dispatch import dispatch_task                # noqa: E402

# ── Safe executor dispatch table ─────────────────────────────────────────────
# executor field in the alert must match a KEY here. Free-form shell strings
# are NOT executed. This prevents arbitrary code execution via alert injection.

def _handle_apparmor_fix(alert: dict) -> bool:
    """Apply staged AppArmor rules and commit via apparmor-fix-agent."""
    payload = alert.get("payload", {})
    profile = payload.get("profile", "")
    rules = payload.get("rules_proposed", [])
    if not rules:
        print("  No rules in payload — nothing to apply.", file=sys.stderr)
        return False
    print(f"  Applying {len(rules)} AppArmor rule(s) to profile {profile!r}...")
    # Delegate the actual commit back to apparmor-fix-agent in commit-only mode
    repo_root = _HERE.parent.parent
    fix_agent = repo_root / "scripts" / "automation" / "apparmor-fix-agent.py"
    if fix_agent.exists():
        result = subprocess.run(
            [sys.executable, str(fix_agent), "--commit-staged", "--alert-id", alert["id"]],
            cwd=str(repo_root), capture_output=True, text=True, timeout=60,
        )
        if result.returncode == 0:
            print("  AppArmor fix applied and committed.")
            return True
        print(f"  apparmor-fix-agent --commit-staged failed:\n{result.stderr}", file=sys.stderr)
        return False
    print("  apparmor-fix-agent not found — apply rules manually.", file=sys.stderr)
    return False


def _handle_nixos_rebuild_hint(alert: dict) -> bool:
    """Print the exact nixos-rebuild command — does NOT run it (rebuild requires sudo)."""
    print()
    print("  This action requires a NixOS rebuild. Run the following command:")
    print()
    print("    sudo nixos-rebuild switch --flake .#hyperd-ai-dev")
    print()
    print("  Then verify with: aq-qa 0")
    return True


def _handle_drop_dispatch(alert: dict) -> bool:
    """Dispatch a gated agent drop."""
    payload = alert.get("payload", {})
    drop_path_str = payload.get("drop_path")
    if not drop_path_str:
        print("  No drop_path in payload.", file=sys.stderr)
        return False
    
    drop_path = Path(drop_path_str)
    if not drop_path.exists():
        print(f"  Drop file not found: {drop_path}", file=sys.stderr)
        return False

    print(f"  Dispatching approved drop: {drop_path.name}...")
    
    # Setup TaskConfig (mimic aq-drop-daemon defaults)
    import os
    config = TaskConfig.from_args(
        mode=payload.get("mode", "agent"),
        role=payload.get("role", "generalist"),
        timeout_secs=int(os.environ.get("DROP_DAEMON_TIMEOUT", "300")),
        llama_url=os.environ.get("LLAMA_URL",  "http://127.0.0.1:8080"),
        hybrid_url=os.environ.get("HYBRID_URL", "http://127.0.0.1:8003"),
        ralph_url=os.environ.get("RALPH_URL",  "http://127.0.0.1:8004"),
    )
    
    registry = TaskRegistry(_REPO_ROOT / ".agents" / "delegation", _REPO_ROOT)
    task_id = f"drop-{alert['id'][5:]}" # use alert id suffix
    output_file = _REPO_ROOT / ".agents" / "delegation" / "outputs" / f"{task_id}.log"
    output_file.parent.mkdir(parents=True, exist_ok=True)

    success = dispatch_task(
        config=config,
        prompt=payload.get("prompt", ""),
        task_id=task_id,
        output_file=output_file,
        registry=registry,
        script_dir=_HERE,
    )

    if success:
        # Archive the drop file
        archive_dir = drop_path.parent / "archive"
        archive_dir.mkdir(parents=True, exist_ok=True)
        os.rename(drop_path, archive_dir / drop_path.name)
        print(f"  Dispatch successful. Task logged to {output_file.name}")
        return True
    
    print("  Dispatch failed.", file=sys.stderr)
    return False


_EXECUTOR_TABLE = {
    "apparmor_fix":      _handle_apparmor_fix,
    "nixos_rebuild_hint": _handle_nixos_rebuild_hint,
    "drop_dispatch":     _handle_drop_dispatch,
}


def _apparmor_rules_already_present(profile: str, rules: list) -> bool:
    """Return True when all proposed AppArmor rules already exist in mcp-servers.nix."""
    if not profile or not rules:
        return False
    nix_file = _REPO_ROOT / "nix" / "modules" / "services" / "mcp-servers.nix"
    try:
        text = nix_file.read_text(encoding="utf-8")
    except OSError:
        return False
    if profile not in text:
        return False
    return all(str(rule).strip() in text for rule in rules)


def main() -> int:
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print("Usage: aq-approve <alert-id>")
        return 1

    alert_id = sys.argv[1]
    alert = get_by_id(alert_id)

    if not alert:
        print(f"Alert {alert_id!r} not found.", file=sys.stderr)
        return 1

    if alert.get("status") != "pending":
        print(f"Alert {alert_id} is already {alert.get('status')!r} — nothing to approve.")
        return 0

    boundary = alert.get("autonomy_boundary", "")
    print(f"\n  Approving: {alert.get('title', alert_id)}")
    print(f"  Boundary:  {boundary}")

    # Run executor if present
    executor_key = alert.get("executor")
    if executor_key:
        if (
            executor_key == "apparmor_fix"
            and _apparmor_rules_already_present(
                alert.get("payload", {}).get("profile", ""),
                alert.get("payload", {}).get("rules_proposed", []),
            )
        ):
            print("  Proposed AppArmor rule(s) already present in mcp-servers.nix.")
            executor_key = None
        handler = _EXECUTOR_TABLE.get(executor_key)
        if executor_key is None:
            pass
        elif not handler:
            print(f"  Unknown executor key {executor_key!r} — approval recorded but no action taken.", file=sys.stderr)
        else:
            ok = handler(alert)
            if not ok:
                print(f"  Executor failed. Alert NOT resolved — retry after fixing the issue.")
                return 1

    # Mark resolved
    ok = resolve(alert_id, "approved", resolved_by="human")
    if ok:
        print(f"  Approved. Alert archived.")
        return 0
    else:
        print(f"  resolve() failed — alert may have been resolved by another process.", file=sys.stderr)
        return 1


if __name__ == "__main__":
    sys.exit(main())
