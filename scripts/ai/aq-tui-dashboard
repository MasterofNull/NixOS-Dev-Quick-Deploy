class SourceReadError(ValueError):
    """Bounded source-reader failure projected as typed blocked evidence."""


def _bounded_regular_bytes(path: Path, max_bytes: int = MAX_SOURCE_BYTES) -> bytes:
    try:
        info = path.lstat()
    except FileNotFoundError:
        return b""
    except OSError as exc:
        raise SourceReadError("source_unavailable") from exc
    if stat.S_ISLNK(info.st_mode) or not stat.S_ISREG(info.st_mode):
        raise SourceReadError("source_not_regular")
    if info.st_size > max_bytes:
        raise SourceReadError("source_too_large")
    try:
        with path.open("rb") as handle:
            data = handle.read(max_bytes + 1)
    except OSError as exc:
        raise SourceReadError("source_unavailable") from exc
    if len(data) > max_bytes:
        raise SourceReadError("source_too_large")
    return data


def _bounded_json(path: Path, max_bytes: int = 65536) -> dict:
    raw = _bounded_regular_bytes(path, max_bytes)
    if not raw:
        return {}
    try:
        value = json.loads(raw.decode("utf-8"))
    except (UnicodeDecodeError, json.JSONDecodeError) as exc:
        raise SourceReadError("source_malformed") from exc
    if not isinstance(value, dict):
        raise SourceReadError("source_malformed")
    return value


def _regular_file_present(path: Path) -> bool:
    try:
        info = path.lstat()
    except FileNotFoundError:
        return False
    except OSError as exc:
        raise SourceReadError("source_unavailable") from exc
    if stat.S_ISLNK(info.st_mode) or not stat.S_ISREG(info.st_mode):
        raise SourceReadError("source_not_regular")
    return info.st_size > 0


def _mtime_or_zero(path: Path) -> float:
    try:
        return path.lstat().st_mtime
    except OSError:
        return 0.0


def _read_proc_file(path: Path, max_bytes: int) -> bytes:
    try:
        with path.open("rb") as handle:
            data = handle.read(max_bytes + 1)
    except (FileNotFoundError, ProcessLookupError):
        raise
    except (PermissionError, OSError) as exc:
        raise SourceReadError("proc_permission_denied") from exc
    if len(data) > max_bytes:
        raise SourceReadError("proc_record_too_large")
    return data


def _parse_proc_stat(raw: str) -> tuple[int, int, int, int, int]:
    close = raw.rfind(")")
    if close < 2:
        raise SourceReadError("proc_stat_malformed")
    try:
        pid = int(raw[: raw.find(" ")])
        fields = raw[close + 2 :].split()
        return pid, int(fields[1]), int(fields[2]), int(fields[3]), int(fields[19])
    except (ValueError, IndexError) as exc:
        raise SourceReadError("proc_stat_malformed") from exc


def read_proc_facts(proc_root: Path = PROC_ROOT) -> tuple[list[dict], list[str]]:
    facts: list[dict] = []
    errors: list[str] = []
    unreadable_recorded = False
    try:
        pids = sorted((p for p in proc_root.iterdir() if p.name.isdigit()),
                      key=lambda p: int(p.name))
    except OSError:
        return [], ["proc_root_unavailable"]
    if len(pids) > MAX_PROCESSES:
        return [], ["process_snapshot_too_large"]
    for entry in pids:
        pid = int(entry.name)
        try:
            parsed_pid, ppid, pgid, session, start_time = _parse_proc_stat(
                _read_proc_file(entry / "stat", MAX_PROC_STAT_BYTES).decode("utf-8", "replace")
            )
            executable = os.readlink(entry / "exe")
            if Path(executable).name.lower() not in AGENT_EXECUTABLES:
                continue
            cmdline_raw = _read_proc_file(entry / "cmdline", MAX_PROC_CMDLINE_BYTES)
            argv = [part.decode("utf-8", "replace") for part in cmdline_raw.split(b"\0") if part]
            if len(argv) > MAX_ARGV or any(len(arg) > MAX_TEXT for arg in argv):
                raise SourceReadError("process_argv_invalid")
            if len(executable) > 4096:
                raise SourceReadError("proc_record_too_large")
            cgroup_raw = _read_proc_file(entry / "cgroup", MAX_PROC_CGROUP_BYTES)
            cgroup = None
            for line in cgroup_raw.decode("utf-8", "replace").splitlines():
                parts = line.split(":", 2)
                if len(parts) == 3 and parts[2]:
                    cgroup = parts[2]
                    if parts[0] == "0":
                        break
            facts.append({
                "pid": parsed_pid, "start_time": start_time, "ppid": ppid,
                "pgid": pgid, "session": session, "cgroup": cgroup,
                "executable": executable, "argv": argv,
            })
        except (FileNotFoundError, ProcessLookupError):
            continue
        except PermissionError:
            if not unreadable_recorded:
                facts.append({"pid": pid, "error": "permission_denied"})
                unreadable_recorded = True
            errors.append("proc_permission_denied")
        except SourceReadError as exc:
            if not unreadable_recorded:
                facts.append({"pid": pid, "error": "permission_denied"})
                unreadable_recorded = True
            errors.append(str(exc) or "proc_unavailable")
        except OSError:
            if not unreadable_recorded:
                facts.append({"pid": pid, "error": "permission_denied"})
                unreadable_recorded = True
            errors.append("proc_unavailable")
    return facts, sorted(set(errors))


def read_registry_facts(registry_path: Path = REGISTRY,
                        outputs_dir: Path = OUTPUTS) -> tuple[list[dict], list[str]]:
    errors: list[str] = []
    try:
        raw = _bounded_regular_bytes(registry_path)
    except SourceReadError as exc:
        return [], [f"registry_{exc}"]
    sources: list[dict] = []
    for line in raw.splitlines():
        if not line.strip():
            continue
        if len(sources) >= MAX_REGISTRY:
            return [], ["registry_snapshot_too_large"]
        try:
            source = json.loads(line)
        except json.JSONDecodeError:
            errors.append("registry_record_malformed")
            continue
        if not isinstance(source, dict):
            errors.append("registry_record_malformed")
            continue
        sources.append(source)

    active = [source for source in sources
              if str(source.get("status", "")).lower() in ACTIVE_REGISTRY_STATES]
    terminal = [source for source in sources
                if str(source.get("status", "")).lower() not in ACTIVE_REGISTRY_STATES]
    selected = active + terminal[-TERMINAL_HISTORY_LIMIT:]
    rows: list[dict] = []
    for source in selected:
        task_id = str(source.get("id", ""))
        lane = str(source.get("agent", "unknown"))
        if lane.startswith("local-"):
            lane = "local"
        elif lane in {"gemini", "local-antigravity"}:
            lane = "antigravity"
        status = str(source.get("status", "unknown")).lower()
        status = {
            "stale": "orphaned", "partial-success": "completed",
            "failed_orphaned_no_output": "failed",
        }.get(status, status)
        rec = {key: source.get(key) for key in (
            "id", "agent", "role", "profile", "status", "pid", "pid_start_time",
            "artifact_present",
        )}
        rec["agent"] = lane
        rec["status"] = status
        task_id_valid = bool(SAFE_TASK_ID.fullmatch(task_id))
        if task_id_valid:
            output_path = outputs_dir / f"{task_id}.log"
            try:
                rec["artifact_present"] = _regular_file_present(output_path)
            except SourceReadError as exc:
                errors.append(f"output_{exc}")
        if task_id_valid and status in ACTIVE_REGISTRY_STATES:
            try:
                progress = _bounded_json(outputs_dir / f"{task_id}.log.progress.json")
                if progress:
                    producer = progress.get("producer")
                    rec["progress"] = {
                        "trusted": progress.get("trusted") is True
                        and producer in TRUSTED_PROGRESS_PRODUCERS,
                        "producer": producer if producer in TRUSTED_PROGRESS_PRODUCERS else "untrusted",
                        "phase": progress.get("phase") if isinstance(progress.get("phase"), str) else None,
                        "observed_at": progress.get("observed_at")
                        if isinstance(progress.get("observed_at"), int) else int(_now()),
                    }
            except SourceReadError as exc:
                errors.append(f"progress_{exc}")
        elif not task_id_valid:
            errors.append("registry_task_id_invalid")
        rows.append(rec)
    return rows, sorted(set(errors))


def _declared_output_present(task_path: Path, raw: bytes) -> bool:
    match = OUTPUT_PATH.search(raw.decode("utf-8", "replace"))
    if not match:
        return False
    plans_root = (REPO_ROOT / ".agents" / "plans").resolve()
    candidate = (REPO_ROOT / match.group("path")).resolve()
    try:
        candidate.relative_to(plans_root)
    except ValueError:
        return False
    try:
        return _regular_file_present(candidate)
    except SourceReadError:
        return False


def read_inbox_facts(inbox_dir: Path = ANTIGRAVITY_INBOX,
                     archive_root: Path = ANTIGRAVITY_ARCHIVE) -> tuple[list[dict], list[str]]:
    facts: list[dict] = []
    errors: list[str] = []
    pending_candidates: list[tuple[Path, bool, int | None]] = []
    archived_candidates: list[tuple[Path, bool, int | None]] = []
    try:
        if inbox_dir.exists():
            pending_candidates.extend((p, True, None) for p in sorted(inbox_dir.iterdir())
                                      if p.name != ".lane-state.json")
        if archive_root.exists():
            for directory in sorted(archive_root.glob("antigravity-inbox-*")):
                if directory.is_dir() and not directory.is_symlink():
                    archived_at = int(directory.stat().st_mtime)
                    archived_candidates.extend((p, False, archived_at)
                                               for p in sorted(directory.iterdir()))
    except OSError:
        return [], ["inbox_root_unavailable"]
    if len(pending_candidates) + len(archived_candidates) > MAX_INBOX:
        return [], ["inbox_snapshot_too_large"]
    archived_candidates.sort(key=lambda item: _mtime_or_zero(item[0]), reverse=True)
    candidates = pending_candidates + archived_candidates[:INBOX_HISTORY_LIMIT]
    for path, pending, archived_at in candidates:
        try:
            raw = _bounded_regular_bytes(path)
            info = path.stat()
            item = {
                "name": path.name, "pending": pending, "dropped_at": int(info.st_mtime),
                "output_present": _declared_output_present(path, raw),
            }
            if not pending:
                item["archived_at"] = archived_at if archived_at is not None else int(info.st_mtime)
            facts.append(item)
        except SourceReadError as exc:
            errors.append(f"inbox_{exc}")
    return facts, sorted(set(errors))


def _source_error_work(reason: str) -> dict:
    safe = re.sub(r"[^a-z0-9_]+", "_", reason.lower()).strip("_") or "source_unavailable"
    return {
        "work_id": f"source:{safe}"[:128], "lane": "system", "role": "observer",
        "model_profile": None, "authority": "collaboration_event", "state": "conflict",
        "phase": None, "progress_age_s": None, "pid_identity": None, "dedup_group": None,
        "access": "read_only", "terminal_reason": None, "artifact": "not_applicable",
        "visibility": "blocked", "reason_code": safe, "freshness": "unavailable",
    }


def read_agent_ops_projection(*, proc_root: Path = PROC_ROOT, registry_path: Path = REGISTRY,
                              outputs_dir: Path = OUTPUTS, inbox_dir: Path = ANTIGRAVITY_INBOX,
                              archive_root: Path = ANTIGRAVITY_ARCHIVE, use_cache: bool = True) -> dict:
    cached_at, cached = _cache["projection"]
    if use_cache and cached and _now() - cached_at < 2:
        return cached
    processes, proc_errors = read_proc_facts(proc_root)
    registry, registry_errors = read_registry_facts(registry_path, outputs_dir)
    inbox, inbox_errors = read_inbox_facts(inbox_dir, archive_root)
    try:
        projection = project_agent_ops(now=int(_now()), registry=registry,
                                       processes=processes, inbox=inbox)
    except ProjectionError as exc:
        projection = project_agent_ops(now=int(_now()), registry=[], processes=[], inbox=[])
        proc_errors.append(str(exc))
    source_errors = sorted(set(proc_errors + registry_errors + inbox_errors))
    if source_errors:
        projection["work"].extend(_source_error_work(reason) for reason in source_errors)
        projection["work"].sort(key=lambda item: (item["visibility"] != "blocked", item["work_id"]))
        projection["health"] = {
            "verdict": "blocked",
            "reason_codes": sorted(set(projection["health"]["reason_codes"] + source_errors)),
            "source_freshness": "unavailable",
        }
    contract_health(projection)
    _cache["projection"] = (_now(), projection)
    return projection


def _now() -> float:
    return time.time()


def _parse_ts(s: str):
    try:
        return datetime.fromisoformat((s or "").strip().replace("Z", "+00:00")).timestamp()
    except Exception:
        return None


def _age(ts) -> str:
    if ts is None:
        return "—"
    d = max(0, int(_now() - ts))
    if d < 60:
        return f"{d}s"
    if d < 3600:
        return f"{d // 60}m"
    return f"{d // 3600}h"


def _tail_json(path: Path, n: int) -> list:
    out = []
    try:
        for line in _bounded_regular_bytes(path).decode("utf-8", "replace").splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                out.append(json.loads(line))
            except json.JSONDecodeError:
                continue
    except (OSError, SourceReadError):
        return []
    return out[-n:]


def tail_output(task_id: str, n: int = 40, max_bytes: int = 8192) -> list:
    """Last n lines of a delegation's output log (bounded read for speed)."""
    if not task_id or not SAFE_TASK_ID.fullmatch(task_id):
        return []
    p = OUTPUTS / f"{task_id}.log"
    if not p.exists():
        return []
    try:
        size = p.stat().st_size
        with open(p, "rb") as fh:
            if size > max_bytes:
                fh.seek(size - max_bytes)
            data = fh.read().decode("utf-8", "replace")
    except OSError:
        return []
    return data.splitlines()[-n:]


def _read_progress(task_id: str) -> dict:
    """Read the agent progress sidecar. dispatch writes it at '<output>.progress.json' where
    <output> is '<id>.log' — i.e. '<id>.log.progress.json'. Returns {} if absent/unparseable.
    Carries the agent_executor's INTERNAL task_id (used to key the live stream file) plus
    status/tool_call_count/llm_stream_chars."""
    if not task_id or not SAFE_TASK_ID.fullmatch(task_id):
        return {}
    p = OUTPUTS / f"{task_id}.log.progress.json"
    try:
        return _bounded_json(p)
    except SourceReadError:
        return {}
    return {}


def read_live_stream(task_id: str, n: int = 40) -> tuple:
    """Near-real-time agent output/reasoning. The local agent_executor writes a live stream file
    (tokens/tool-calls as they arrive) keyed by its INTERNAL task id, NOT the dispatch id the
    operator/matrix knows. Resolve the internal id via the progress sidecar so the two correlate.
    codex/others stream into their output log (which grows live). Returns (lines, src)."""
    prog = _read_progress(task_id)
    candidates = []
    if task_id and SAFE_TASK_ID.fullmatch(task_id):
        candidates.append(task_id)               # lanes that key the stream by dispatch id
    inner = prog.get("task_id")
    if isinstance(inner, str) and inner != task_id and SAFE_TASK_ID.fullmatch(inner):
        candidates.append(inner)                 # local: internal aq-<ts> id from the sidecar
    for sid in candidates:
        sf = STREAMS / f"{sid}.txt"
        if sf.exists():
            try:
                txt = sf.read_text(encoding="utf-8", errors="replace")
                if txt.strip():
                    return txt.splitlines()[-n:], "live-stream"
            except OSError:
                pass
    # No streamed tokens yet (e.g. a long cold prefill). Surface the progress STATE so the pane
    # shows what the agent is doing (prefilling, N tool calls) instead of a blank/"waiting" line.
    status = prog.get("status")
    if status:
        tc = prog.get("tool_call_count", 0)
        chars = prog.get("llm_stream_chars", 0)
        note = f"[{status}]  tool_calls={tc}  streamed_chars={chars}"
        if status == "llm_waiting" and not chars:
            note += "  — model prefilling/generating (no tokens emitted yet this turn)"
        return [note], "progress-state"
    return tail_output(task_id, n=n), "output-log"


def assess_attention(rec: dict) -> tuple:
    """Return (level, reason). level in ok|failed|stalled|loop — worst-first for triage."""
    status = rec.get("status", "?")
    ts = _parse_ts(rec.get("created", ""))
    if status in ("failed", "error"):
        return ("failed", f"exited {status}")
    # error-loop: same non-empty line repeated LOOP_REPEAT+ times in the output tail
    tail = tail_output(rec.get("id", ""), n=30)
    if tail:
        counts: dict = {}
        for ln in tail:
            s = ln.strip()
            if len(s) > 8:
                counts[s] = counts.get(s, 0) + 1
        worst = max(counts.items(), key=lambda x: x[1], default=("", 0))
        if worst[1] >= LOOP_REPEAT:
            return ("loop", f"x{worst[1]} repeat: {worst[0][:32]}")
    if status == "running" and ts is not None and (_now() - ts) > STALL_S:
        return ("stalled", f"running >{STALL_S // 60}m, no completion")
    return ("ok", "")


def read_active_delegations(window_s: int = 900, limit: int = 10) -> list:
    """Sanitized registry-authority cards from the closed Agent Ops projection."""
    rows = []
    _ = window_s
    for item in read_agent_ops_projection()["work"]:
        if item["authority"] != "delegation_registry":
            continue
        status = item["state"]
        if status == "terminal":
            continue
        level = "ok" if item["visibility"] == "tracked" else (
            "stalled" if status == "stale" else "failed"
        )
        rows.append({
            "agent": item["lane"], "role": item.get("role") or "",
            "fid": item["work_id"], "id": item["work_id"][-16:], "status": status,
            "age": _age(_now() - item["progress_age_s"]) if item["progress_age_s"] is not None else "—",
            "ts": 0, "attn": level,
            "attn_reason": "" if level == "ok" else item["reason_code"],
        })
    _rank = {"failed": 0, "loop": 1, "stalled": 2, "ok": 3}
    rows.sort(key=lambda r: (_rank.get(r["attn"], 3), r["status"] != "running", -r["ts"]))
    return rows[:limit]


def read_running_procs() -> list:
    procs = []
    seen: set[str] = set()
    for item in read_agent_ops_projection()["work"]:
        identity = item.get("pid_identity")
        group = item.get("dedup_group")
        if not identity or item["state"] == "terminal" or (group and group in seen):
            continue
        if group:
            seen.add(group)
        procs.append({
            "pid": str(identity["pid"]), "label": item["lane"],
            "cmd": item["reason_code"], "daemon": item["reason_code"] == "idle_daemon",
            "visibility": item["visibility"], "dedup_group": item["dedup_group"],
        })
    return procs


def probe_services() -> list:
    ts, val = _cache["health"]
    if _now() - ts < 5:
        return val
    out = []
    for name, port, path in SERVICES:
        state = "unreachable"
        try:
            with urllib.request.urlopen(f"http://127.0.0.1:{port}{path}", timeout=0.4) as r:
                state = "ok" if r.status == 200 else f"http {r.status}"
        except Exception:
            state = "unreachable"
        out.append({"name": name, "port": port, "state": state})
    _cache["health"] = (_now(), out)
    return out


def read_a2a(n: int = 8) -> list:
    rows = []
    for rec in _tail_json(A2A_AUDIT, n):
        direction = rec.get("direction", "")
        summ = rec.get("summary", "")
        if direction == "outbound":
            dec = "FLAGGED" if rec.get("secret_findings") else "CLEAN"
        else:
            dec = next((d for d in ("BLOCK", "WARN", "ALLOW") if d in summ), "·")
        rows.append({"ts": (rec.get("ts", "") or "")[11:19], "dir": direction,
                     "to": rec.get("to", ""), "dec": dec, "summary": summ[:44]})
    return rows


def read_pulse(n: int = 5) -> list:
    if not PULSE.exists():
        return []
    try:
        return [l for l in PULSE.read_text(encoding="utf-8").splitlines() if l.strip()][-n:]
    except OSError:
        return []


# ── rendering ────────────────────────────────────────────────────────────────
_DEC_STYLE = {"BLOCK": "bold red", "WARN": "yellow", "FLAGGED": "bold magenta",
              "ALLOW": "green", "CLEAN": "dim", "·": "dim"}
_STATUS_STYLE = {"running": "bold green", "completed": "cyan", "error": "bold red",
                 "failed": "bold red", "partial": "yellow"}


def make_layout() -> Layout:
    layout = Layout()
    layout.split_column(Layout(name="header", size=3), Layout(name="main"),
                        Layout(name="footer", size=7))
    layout["main"].split_row(Layout(name="left"), Layout(name="right"))
    layout["left"].split_column(Layout(name="delegations"), Layout(name="procs"))
    layout["right"].split_column(Layout(name="health"), Layout(name="a2a"))
    return layout


def panel_header() -> Panel:
    grid = Table.grid(expand=True)
    grid.add_column(justify="left", ratio=1)
    grid.add_column(justify="right")
    procs = read_running_procs()
    n_active = sum(1 for p in procs if not p.get("daemon"))
    n_daemon = sum(1 for p in procs if p.get("daemon"))
    n_deleg = sum(1 for r in read_active_delegations() if r["status"] == "running")
    n_attn = sum(1 for r in read_active_delegations() if r["attn"] != "ok")
    attn_txt = (Text(f"  ⚠ {n_attn} need attention", style="bold red")
                if n_attn else Text("  ✓ all nominal", style="green"))
    right = Text(f"{n_deleg} delegation(s) · {n_active} active proc · {n_daemon} daemon  "
                 f"{datetime.now().strftime('%H:%M:%S')}", style="white")
    right.append_text(attn_txt)
    grid.add_row(Text("AGENTIC OPS — delegations & current operations", style="bold cyan"), right)
    return Panel(grid, style="blue")


_ATTN_MARK = {"failed": ("✗", "bold red"), "loop": ("↻", "bold red"),
              "stalled": ("◷", "yellow"), "ok": (" ", "dim")}


def panel_delegations() -> Panel:
    t = Table(expand=True, pad_edge=False)
    t.add_column("!", width=1); t.add_column("agent", style="bold"); t.add_column("task")
    t.add_column("status"); t.add_column("age", justify="right")
    rows = read_active_delegations()
    if not rows:
        t.add_row("", "—", "no active/recent delegations", "", "")
    for r in rows:
        mark, mstyle = _ATTN_MARK.get(r["attn"], (" ", "dim"))
        sstyle = mstyle if r["attn"] != "ok" else _STATUS_STYLE.get(r["status"], "white")
        label = r["attn_reason"] or r["id"] if r["attn"] != "ok" else r["id"]
        t.add_row(Text(mark, style=mstyle), r["agent"], label,
                  Text(r["status"], style=sstyle), r["age"])
    return Panel(t, title="Active Delegations (running + <15m; ✗/↻/◷ = attention)",
                 border_style="magenta")


def panel_procs() -> Panel:
    t = Table(expand=True, pad_edge=False)
    t.add_column("pid", justify="right"); t.add_column("lane", style="bold"); t.add_column("cmd")
    procs = read_running_procs()
    if not procs:
        t.add_row("—", "idle", "no agent processes running")
    for p in procs[:8]:
        style = "bold red" if p.get("visibility") == "blocked" else "white"
        t.add_row(p["pid"], p["label"], Text(p["cmd"], style=style))
    return Panel(t, title="Projected Processes (sanitized)", border_style="green")


def panel_health() -> Panel:
    t = Table(expand=True, pad_edge=False)
    t.add_column("service"); t.add_column("state"); t.add_column("port", justify="right")
    for s in probe_services():
        style = "bold green" if s["state"] == "ok" else "bold red"
        t.add_row(s["name"], Text(s["state"], style=style), str(s["port"]))
    return Panel(t, title="Service Health (live probe)", border_style="cyan")


def panel_a2a() -> Panel:
    t = Table(expand=True, pad_edge=False)
    t.add_column("time"); t.add_column("→"); t.add_column("dec"); t.add_column("summary")
    rows = read_a2a()
    if not rows:
        t.add_row("—", "", "", "no A2A safeguard events")
    for r in rows:
        t.add_row(r["ts"], r["to"], Text(r["dec"], style=_DEC_STYLE.get(r["dec"], "white")), r["summary"])
    return Panel(t, title="A2A Safeguards (audit tail)", border_style="yellow")


def panel_footer() -> Panel:
    lines = read_pulse(5)
    body = Text("\n".join(lines) if lines else "no recent PULSE activity", style="dim")
    return Panel(body, title="Ops Activity — PULSE.log", style="blue")


def render(layout: Layout) -> None:
    layout["header"].update(panel_header())
    layout["delegations"].update(panel_delegations())
    layout["procs"].update(panel_procs())
    layout["health"].update(panel_health())
    layout["a2a"].update(panel_a2a())
    layout["footer"].update(panel_footer())


def _resolve_task(token: str) -> dict:
    """Match a delegation by full id or a trailing-substring (last-16 shown in the table)."""
    for rec in reversed(_tail_json(REGISTRY, 800)):
        rid = rec.get("id", "") or ""
        if rid == token or rid.endswith(token):
            return rec
    return {}


def panel_focus(task_id: str) -> Panel:
    """cmux-style single-agent pane: one delegation's metadata + live output tail."""
    rec = _resolve_task(task_id)
    if not rec:
        return Panel(Text(f"no delegation matching '{task_id}'", style="red"),
                     title="Focus", border_style="red")
    level, reason = assess_attention(rec)
    head = Table.grid(expand=True)
    head.add_column(); head.add_column(justify="right")
    mark, mstyle = _ATTN_MARK.get(level, (" ", "dim"))
    head.add_row(Text(f"{rec.get('agent','?')}  {rec.get('id','')}", style="bold cyan"),
                 Text(f"{mark} {level} {reason}".strip(), style=mstyle))
    lines, src = read_live_stream(rec.get("id", ""), n=40)
    out = "\n".join(lines) if lines else "(no output yet — awaiting first token)"
    inner = Table.grid(expand=True)
    inner.add_row(head)
    inner.add_row(Text("status: " + rec.get("status", "?") + "   created: " + rec.get("created", "?"),
                       style="dim"))
    inner.add_row(_selections_line(rec))
    inner.add_row(Text("─" * 60, style="dim"))
    inner.add_row(Text(out, style="white"))
    return Panel(inner, title=f"Focus — {rec.get('id','')}",
                 border_style="red" if level != "ok" else "cyan")


def _registry_input(fid: str) -> str:
    """The prompt/task a delegation received (registry `description`) — the agent's INPUT."""
    for rec in reversed(_tail_json(REGISTRY, 800)):
        if (rec.get("id", "") or "") == fid:
            return (rec.get("description", "") or "").strip()
    return ""


# lane → (model shown, switchboard/CLI profile). Derived from the known lane config; the
# per-REQUEST switchboard selections (leased bundle, injectHints, zero_trust) are correlated
# to a task only once F3 emits OTel spans — shown as "…" until then, not fabricated.
_LANE_SELECT = {
    "local-agent":  ("Qwen3-35B (active.gguf)", "local-agent"),
    "local-direct": ("Qwen3-35B (active.gguf)", "local-direct"),
    "local":        ("Qwen3-35B (active.gguf)", "local-agent"),
    "codex":        ("gpt-5.5", "codex-cli"),
    "antigravity":  ("gemini-3.x (IDE OAuth)", "IDE-inbox"),
    "gemini":       ("gemini-3.x", "IDE-inbox"),
}


def _selections_line(rec: dict) -> Text:
    """Compact capability-selection readout per agent (role · model · profile · tools)."""
    agent = rec.get("agent", "")
    model, profile = _LANE_SELECT.get(agent, ("?", "?"))
    role = rec.get("role") or "—"
    # tool-call count from the agent progress sidecar if present (local lane). The sidecar lives at
    # '<id>.log.progress.json' (the --output path + '.progress.json'), not '<id>.progress.json'.
    tools = "…"
    prog = _read_progress(rec.get("fid") or rec.get("id", ""))
    if prog.get("tool_call_count") is not None:
        tools = str(prog.get("tool_call_count"))
    # Attention badge — reuse the row's computed attention, or derive it for a raw registry rec
    # (focus pane). Surfaces error-loop (↻) / stalled (◷) / failed (✗) right on the selections line.
    level = rec.get("attn")
    reason = rec.get("attn_reason", "")
    if level is None:
        level, reason = assess_attention(rec)
    t = Text()
    t.append("⚙ ", style="dim")
    t.append(f"role={role}", style="cyan")
    t.append(f"  model={model}", style="magenta")
    t.append(f"  profile={profile}", style="green")
    t.append(f"  tools={tools}", style="yellow")
    t.append("  bundle/zt=(F3)", style="dim")
    mark, mstyle = _ATTN_MARK.get(level, (" ", "dim"))
    if level and level != "ok":
        badge = {"loop": "ERROR-LOOP", "stalled": "STALLED", "failed": "FAILED"}.get(level, level.upper())
        t.append(f"  [{mark} {badge}", style="bold " + mstyle.replace("bold ", ""))
        if reason:
            t.append(f": {reason[:36]}", style=mstyle)
        t.append("]", style="bold " + mstyle.replace("bold ", ""))
    else:
        t.append("  [✓]", style="green")
    return t


def panel_agent_cell(rec: dict, out_lines: int = 16) -> Panel:
    """One agent pane: INPUT header (prompt) + live OUTPUT tail — the cmux per-agent view."""
    fid = rec["fid"]
    level = rec["attn"]
    mark, mstyle = _ATTN_MARK.get(level, (" ", "dim"))
    title = f"{mark} {rec['agent']}  {fid[-20:]}  [{rec['status']} {rec['age']}]"
    inp = _registry_input(fid) or "(no recorded input)"
    out, src = read_live_stream(fid, n=out_lines)
    body = Text()
    body.append("IN  ", style="bold cyan")
    body.append(inp[:180] + ("…" if len(inp) > 180 else "") + "\n", style="cyan")
    body.append_text(_selections_line(rec)); body.append("\n")
    body.append(f"── OUT ({src}, near-real-time) " + "─" * 20 + "\n", style="dim")
    if out:
        body.append("\n".join(out[-out_lines:]), style="white")
    else:
        body.append("(no output yet — streaming or awaiting first token)", style="dim yellow")
    return Panel(body, title=title, border_style="red" if level != "ok" else "green",
                 padding=(0, 1))


def render_matrix() -> Columns:
    """Grid of live per-agent panes: running delegations + active (non-daemon) agent
    processes. Idle daemons (codex/gemini app-servers) are summarized, not shown as work."""
    running = [r for r in read_active_delegations(limit=8) if r["status"] == "running"]
    cells = [panel_agent_cell(r) for r in running[:8]]

    # Active agent processes with no registry row (e.g. a concurrent codex/gemini working
    # outside our delegate-to-* path) — surface them so live work is never hidden.
    procs = read_running_procs()
    active = [p for p in procs if not p.get("daemon")]
    daemons = [p for p in procs if p.get("daemon")]
    for p in active[:4]:
        cells.append(Panel(Text(f"pid {p['pid']}\n{p['cmd']}", style="white"),
                           title=f"⚙ {p['label']} (process, no task log)", border_style="green"))

    if not cells:
        msg = Text("no active delegations", style="dim")
        if daemons:
            msg.append(f"\n{len(daemons)} agent daemon(s) present but idle: ", style="dim")
            msg.append(", ".join(sorted({p["label"] for p in daemons})), style="dim cyan")
            msg.append("\n(daemons are persistent IDE/MCP backends — not active work)", style="dim")
        else:
            msg.append(" — dispatch work to populate the matrix", style="dim")
        return Columns([Panel(msg, title="Agent Matrix")])
    return Columns(cells, equal=True, expand=True, column_first=True)


def matrix_footer() -> Panel:
    """Intervention controls — how to act on what the matrix shows."""
    t = Text()
    t.append("Respond to a live agent: ", style="bold")
    t.append('aq-agent-send <id> "message"', style="bold yellow")
    t.append("  |  stop: ", style="dim")
    t.append('aq-agent-send <id> "..." --cancel', style="yellow")
    t.append("  |  reap: ", style="dim")
    t.append("aq-agent-reap --reconcile-registry", style="yellow")
    t.append("  |  drill: ", style="dim")
    t.append("--focus <id>", style="yellow")
    return Panel(t, style="blue")


def snapshot() -> dict:
    """Machine-readable state for programmable drill-in (cmux 'read screen' analog)."""
    projection = read_agent_ops_projection()
    dele = read_active_delegations(limit=25)
    return {
        "ts": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "agent_ops": projection,
        "agent_ops_contract": contract_health(projection),
        "delegations": dele,
        "attention": [
            {"agent": d["agent"], "id": d["fid"], "level": d["attn"], "reason": d["attn_reason"]}
            for d in dele if d["attn"] != "ok"
        ],
        "processes": read_running_procs(),
        "health": probe_services(),
        "a2a_recent": read_a2a(10),
    }


def main() -> int:
    ap = argparse.ArgumentParser(prog="aq-tui-dashboard", description="Live delegations + operations TUI")
    ap.add_argument("--once", action="store_true", help="render one snapshot and exit")
    ap.add_argument("--interval", type=float, default=2.0, help="refresh seconds (default 2)")
    ap.add_argument("--focus", metavar="TASK_ID", help="drill into one delegation's live output")
    ap.add_argument("--matrix", action="store_true",
                    help="grid of ALL running agents — each pane shows its live input + output")
    ap.add_argument("--json", action="store_true", help="print machine-readable state and exit")
    args = ap.parse_args()

    if args.json:
        print(json.dumps(snapshot(), indent=2))
        return 0

    # Matrix mode: every running agent as its own live input+output pane (cmux "no hidden agents").
    if args.matrix:
        def _matrix_group():
            g = Layout()
            g.split_column(Layout(panel_header(), size=3), Layout(name="grid"),
                           Layout(matrix_footer(), size=3))
            g["grid"].update(render_matrix())
            return g
        if args.once or not console.is_terminal:
            console.print(_matrix_group()); return 0
        with Live(_matrix_group(), refresh_per_second=1, screen=True) as live:
            try:
                while True:
                    live.update(_matrix_group()); time.sleep(args.interval)
            except KeyboardInterrupt:
                pass
        return 0

    # Focus mode: a single-delegation live pane (cmux per-agent view).
    if args.focus:
        if args.once or not console.is_terminal:
            console.print(panel_focus(args.focus)); return 0
        with Live(panel_focus(args.focus), refresh_per_second=1, screen=True) as live:
            try:
                while True:
                    live.update(panel_focus(args.focus)); time.sleep(args.interval)
            except KeyboardInterrupt:
                pass
        return 0

    layout = make_layout()
    if args.once or not console.is_terminal:
        render(layout)
        console.print(layout)
        return 0
    with Live(layout, refresh_per_second=1, screen=True):
        try:
            while True:
                render(layout)
                time.sleep(args.interval)
        except KeyboardInterrupt:
            pass
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
