#!/usr/bin/env python3
"""aq-quickstart — generate a per-hardware quickstart + verify first-delegation readiness.

god-tier prompt 10 (WS-EDGE/WS10): the productization exit test is a clean
machine going from `nix run` to a first successful local delegation in under an
hour, documented ONLY by the quickstart the installer generates for its own
hardware class. This composes the whole god-tier sequence:
  hw_probe (E1) -> model_budget (P6) -> a tailored quickstart + readiness gates.

Modes:
  aq-quickstart            # print the quickstart tailored to THIS machine
  aq-quickstart --write    # save it to docs/QUICKSTART.generated.md
  aq-quickstart --doctor   # verify readiness gates for a first local delegation
  aq-quickstart --json     # machine-readable (hardware + budget + gate results)
"""

from __future__ import annotations

import argparse
import json
import os
import sys
import urllib.request
from pathlib import Path

_HERE = Path(__file__).resolve().parent
_REPO = _HERE.parent.parent
sys.path.insert(0, str(_HERE / "lib"))


def _probe() -> dict:
    import importlib.util
    spec = importlib.util.spec_from_file_location("_hw", str(_HERE / "lib" / "hw_probe.py"))
    m = importlib.util.module_from_spec(spec)
    sys.modules[spec.name] = m
    spec.loader.exec_module(m)
    return m.probe() if hasattr(m, "probe") else json.loads(
        __import__("subprocess").run([sys.executable, str(_HERE / "lib" / "hw_probe.py")],
                                     capture_output=True, text=True).stdout)


def _budget(probe: dict) -> dict:
    import model_budget  # type: ignore
    return model_budget.derive_budget(probe)


def _llama_url() -> str:
    port = os.environ.get("LLAMA_PORT", "8080")
    return f"http://127.0.0.1:{port}"


# ── readiness gates for a FIRST successful local delegation ───────────────────

def _gate_repo() -> tuple[bool, str]:
    ok = (_REPO / "flake.nix").exists() and (_HERE / "delegate-to-local").exists()
    return ok, "repo + delegate-to-local present" if ok else "run from inside the repo checkout"


def _gate_nix() -> tuple[bool, str]:
    from shutil import which
    ok = which("nix") is not None
    return ok, "nix available" if ok else "install Nix (flakes) — see quickstart"


def _gate_llama_health() -> tuple[bool, str]:
    try:
        with urllib.request.urlopen(f"{_llama_url()}/health", timeout=5) as r:
            return r.status == 200, "llama.cpp serving on :8080" if r.status == 200 else f"llama /health {r.status}"
    except Exception as e:  # noqa: BLE001
        return False, f"llama.cpp not reachable ({type(e).__name__}) — `sudo systemctl start llama-cpp`"


def _gate_model_generate() -> tuple[bool, str]:
    """The definitive gate: can the model produce a token? (first delegation works)."""
    body = json.dumps({"messages": [{"role": "user", "content": "ok"}],
                       "max_tokens": 1, "chat_template_kwargs": {"enable_thinking": False}}).encode()
    try:
        req = urllib.request.Request(f"{_llama_url()}/v1/chat/completions", data=body,
                                     headers={"Content-Type": "application/json"}, method="POST")
        with urllib.request.urlopen(req, timeout=45) as r:
            return r.status == 200, "model generates (first delegation READY)" if r.status == 200 else f"generate {r.status}"
    except Exception as e:  # noqa: BLE001
        return False, f"model not generating ({type(e).__name__}) — model may be loading (~22GB, wait)"


def doctor() -> dict:
    gates = [
        ("repo", _gate_repo()), ("nix", _gate_nix()),
        ("llama_health", _gate_llama_health()), ("model_generate", _gate_model_generate()),
    ]
    results = [{"gate": g, "ok": ok, "detail": d} for g, (ok, d) in gates]
    ready = all(r["ok"] for r in results)
    return {"ready_for_first_delegation": ready, "gates": results}


# ── quickstart generation (hardware-tailored) ─────────────────────────────────

def render_quickstart(probe: dict, budget: dict) -> str:
    hw = budget.get("hardware_class", "unknown")
    ram = budget.get("ram_total_gb")
    main = budget.get("main_model", {})
    sr = budget.get("small_resident", {})
    tps = (probe.get("derived") or {}).get("tok_per_sec_estimate")
    small = sr.get("candidate_now") or sr.get("candidate_after_quant_down") or {}
    # Rough first-delegation time budget by class (model load + one bounded gen).
    load_min = {"embedded": 5, "laptop": 8, "desktop": 12, "server": 6}.get(hw, 15)

    return f"""# Quickstart (generated for this machine — {hw}, {ram} GB)

*Generated by `aq-quickstart` from hw_probe + model_budget. Do not hand-edit —
regenerate on a new machine. Target: `nix run` → first local delegation < 1 hour.*

## Your hardware
- Class: **{hw}** · RAM: **{ram} GB** · CPU: {(probe.get('cpu') or {}).get('model', '?')}
- GPU: {(probe.get('gpu') or {}).get('primary', {}).get('memory_type', 'none')} · GPU layers: {(probe.get('derived') or {}).get('suggested_n_gpu_layers')}
- Recommended main model: **{main.get('b_params')}B @ {main.get('quant')}** (~{main.get('size_gb')} GB)
- Small resident model: {"**"+small.get('example','—')+"** fits" if small else "not on this hardware"} ({budget.get('recommendation')})

## 1. Bring up the stack
```bash
nix run .#hyperd-ai-dev        # or your host attr; builds + starts the AI stack
```
The model GGUF (~{main.get('size_gb')} GB) downloads on a timer, not at boot. On {hw}-class
hardware expect **~{load_min} min** for the model to finish loading the first time.

## 2. Wait for readiness (the gate)
```bash
aq quickstart --doctor        # green when the model can generate
```
Re-run until `ready_for_first_delegation: true`. This checks: repo present, nix
available, llama.cpp serving, and — the real test — the model produces a token.

## 3. First local delegation
```bash
aq event tail -n 1 2>/dev/null; \\
delegate-to-local --mode direct --role auto --wait \\
  --prompt "In one sentence, what does this AI harness do?"
```
That is your first successful local delegation. At this hardware's throughput
({tps or 'measure with `bench-local-agent`'} tok/s) a one-sentence answer returns in seconds once the
model is warm.

## 4. Orient
```bash
aq --list        # all commands   ·   aq usage   # what's used
aq qa 0          # health check    ·   aq prime   # onboarding
```

## Everything is one entrypoint
`aq <command>` routes to any harness tool (auto-discovered). Behavior across every
model mirrors Claude Fable 5 (see .agent/FABLE-PARITY-CONTRACT.md).
"""


def main() -> int:
    ap = argparse.ArgumentParser(prog="aq-quickstart")
    ap.add_argument("--write", action="store_true", help="save to docs/QUICKSTART.generated.md")
    ap.add_argument("--doctor", action="store_true", help="verify first-delegation readiness")
    ap.add_argument("--json", action="store_true", help="machine-readable output")
    args = ap.parse_args()

    if args.doctor:
        d = doctor()
        if args.json:
            print(json.dumps(d, indent=2))
        else:
            for g in d["gates"]:
                print(f"  [{'PASS' if g['ok'] else 'FAIL'}] {g['gate']:16s} {g['detail']}")
            print(f"\n  first delegation {'READY' if d['ready_for_first_delegation'] else 'NOT READY'}")
        return 0 if d["ready_for_first_delegation"] else 1

    probe = _probe()
    budget = _budget(probe)
    if args.json:
        print(json.dumps({"hardware": probe.get("derived"), "budget": budget}, indent=2))
        return 0
    doc = render_quickstart(probe, budget)
    if args.write:
        out = _REPO / "docs" / "QUICKSTART.generated.md"
        out.parent.mkdir(parents=True, exist_ok=True)
        out.write_text(doc)
        print(f"wrote {out.relative_to(_REPO)}")
    else:
        print(doc)
    return 0


if __name__ == "__main__":
    sys.exit(main())
