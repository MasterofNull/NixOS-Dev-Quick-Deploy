#!/usr/bin/env bash
# aq-qa — AI Stack QA phase runner (Phase 21.1)
#
# Runs discrete test checks for a given QA plan phase and outputs
# structured pass/fail results. Replaces 10-20 individual Bash tool
# calls per session with a single invocation.
#
# Usage:
#   aq-qa 0               Run Phase 0 (pre-flight smoke)
#   aq-qa 1               Run Phase 1 (infrastructure)
#   aq-qa phase0          Same as aq-qa 0
#   aq-qa all             Run all implemented phases
#   aq-qa 0 --json        Machine-readable JSON output
#   aq-qa 0 --sudo        Enable checks that require sudo (AppArmor)
#
# Exit codes: 0 = all pass, 1 = one or more failed, 2 = usage error

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

# shellcheck source=../config/service-endpoints.sh
source "${REPO_ROOT}/config/service-endpoints.sh"

# ---------------------------------------------------------------------------
# Options
# ---------------------------------------------------------------------------
PHASE="${1:-help}"
JSON_OUTPUT=0
USE_SUDO=0
shift 2>/dev/null || true
for arg in "$@"; do
  case "$arg" in
    --json)  JSON_OUTPUT=1 ;;
    --sudo)  USE_SUDO=1 ;;
    --help|-h) PHASE=help ;;
  esac
done

PHASE="${PHASE#phase}"   # strip optional "phase" prefix

AQ_QA_FIXTURE_LLAMA_DIAG="${AQ_QA_FIXTURE_LLAMA_DIAG:-}"
AQ_QA_FIXTURE_APPARMOR_DIAG="${AQ_QA_FIXTURE_APPARMOR_DIAG:-}"

# ---------------------------------------------------------------------------
# Test result tracking
# ---------------------------------------------------------------------------
PASS=0
FAIL=0
SKIP=0
RESULTS=()  # "PASS|FAIL|SKIP id description"
START_TS=$(date +%s)

_pass() { local id="$1" desc="$2"; PASS=$((PASS+1)); RESULTS+=("PASS|$id|$desc"); }
_fail() { local id="$1" desc="$2" reason="${3:-}"; FAIL=$((FAIL+1)); RESULTS+=("FAIL|$id|$desc${reason:+ ($reason)}"); }
_skip() { local id="$1" desc="$2" reason="${3:-}"; SKIP=$((SKIP+1)); RESULTS+=("SKIP|$id|$desc${reason:+ ($reason)}"); }

# Run a command silently; pass/fail based on exit code.
_check() {
  local id="$1" desc="$2"; shift 2
  if "$@" >/dev/null 2>&1; then
    _pass "$id" "$desc"
  else
    _fail "$id" "$desc"
  fi
}

# Run a command and check output matches a pattern.
_check_output() {
  local id="$1" desc="$2" pattern="$3"; shift 3
  local out
  out=$("$@" 2>&1) || { _fail "$id" "$desc" "command failed"; return; }
  if printf '%s' "$out" | grep -qE "$pattern"; then
    _pass "$id" "$desc"
  else
    _fail "$id" "$desc" "output: ${out:0:80}"
  fi
}

_output_contains() {
  local pattern="$1"
  shift
  local out
  out=$("$@" 2>/dev/null || true)
  grep -qE "$pattern" <<<"$out"
}

_primary_user() {
  if [[ -n "${AQ_QA_PRIMARY_USER:-}" ]]; then
    printf '%s' "${AQ_QA_PRIMARY_USER}"
    return 0
  fi
  if [[ -n "${SUDO_USER:-}" ]]; then
    printf '%s' "${SUDO_USER}"
    return 0
  fi
  local repo_owner
  repo_owner="$(stat -c '%U' "${REPO_ROOT}" 2>/dev/null || true)"
  if [[ -n "${repo_owner}" && "${repo_owner}" != "UNKNOWN" ]]; then
    printf '%s' "${repo_owner}"
    return 0
  fi
  printf '%s' "${USER:-}"
}

_primary_home() {
  if [[ -n "${AQ_QA_PRIMARY_HOME:-}" ]]; then
    printf '%s' "${AQ_QA_PRIMARY_HOME}"
    return 0
  fi
  local user home_dir
  user="$(_primary_user)"
  home_dir="$(getent passwd "${user}" 2>/dev/null | cut -d: -f6)"
  if [[ -n "${home_dir}" ]]; then
    printf '%s' "${home_dir}"
    return 0
  fi
  printf '%s' "${HOME:-}"
}

_primary_user_path() {
  local home_dir
  home_dir="$(_primary_home)"
  printf '%s' "${home_dir}/.npm-global/bin:${home_dir}/.local/bin:${home_dir}/.nix-profile/bin:${PATH}"
}

_continue_cli_path() {
  local user home_dir
  if command -v cn >/dev/null 2>&1; then
    command -v cn
    return 0
  fi
  user="$(_primary_user)"
  home_dir="$(getent passwd "${user}" 2>/dev/null | cut -d: -f6)"
  for candidate in \
    "${HOME:-}/.nix-profile/bin/cn" \
    "${home_dir}/.nix-profile/bin/cn" \
    "/etc/profiles/per-user/${user}/bin/cn"
  do
    [[ -x "${candidate}" ]] || continue
    printf '%s' "${candidate}"
    return 0
  done
  return 1
}

_run_clean_primary_shell() {
  local primary_home primary_user
  primary_home="$(_primary_home)"
  primary_user="$(_primary_user)"
  env \
    HOME="${primary_home}" \
    USER="${primary_user}" \
    LOGNAME="${primary_user}" \
    PATH="$(_primary_user_path)" \
    bash --noprofile --norc -c "$1"
}

_continue_cli_help() {
  local cli
  cli="$(_continue_cli_path)" || return 1
  env \
    HOME="$(_primary_home)" \
    USER="$(_primary_user)" \
    LOGNAME="$(_primary_user)" \
    PATH="$(_primary_user_path)" \
    "${cli}" --help
}

# HTTP health check: curl URL, expect JSON with status=ok.
_http_health() {
  local id="$1" desc="$2" url="$3"
  local status
  status=$(curl -sf --max-time 5 "$url" 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('status',''))" 2>/dev/null || true)
  if [[ "$status" == "ok" ]]; then
    _pass "$id" "$desc"
  else
    _fail "$id" "$desc" "status='$status' url=$url"
  fi
}

_continue_config_ok() {
  local cfg="$(_primary_home)/.continue/config.json"
  [[ -f "$cfg" ]] || return 1
  python3 - "$cfg" "${SWITCHBOARD_URL}" <<'PY'
import json, sys
from urllib.request import urlopen

cfg_path = sys.argv[1]
switchboard_url = sys.argv[2].rstrip("/")
with open(cfg_path, "r", encoding="utf-8") as fh:
    data = json.load(fh)

if str(data.get("__configVersion") or "") not in {"23.0", "24.0", "25.0"}:
    raise SystemExit(1)

with urlopen(f"{switchboard_url}/health", timeout=5) as response:
    health = json.load(response)

profiles = health.get("profiles") or {}
continue_profile = profiles.get("continue-local") or {}
default_profile = profiles.get("default") or {}

expected_context = continue_profile.get("advertisedContextWindow") or default_profile.get("advertisedContextWindow")
expected_chat_max_tokens = continue_profile.get("maxOutputTokens") or default_profile.get("maxOutputTokens")
expected_context = int(expected_context) if expected_context is not None else None
expected_chat_max_tokens = int(expected_chat_max_tokens) if expected_chat_max_tokens is not None else None
expected_tab_max_tokens = max(32, min(96, expected_chat_max_tokens)) if expected_chat_max_tokens is not None else None

models = data.get("models") or []
if not any(
    isinstance(model, dict)
    and model.get("apiBase") == "http://127.0.0.1:8085/v1"
    and (
        int(model.get("contextLength") or 0) == expected_context
        if expected_context is not None
        else int(model.get("contextLength") or 0) >= 12000
    )
    and (
        int(model.get("maxTokens") or 0) == expected_chat_max_tokens
        if expected_chat_max_tokens is not None
        else int(model.get("maxTokens") or 0) >= 512
    )
    for model in models
):
    raise SystemExit(1)

if not any(
    isinstance(model, dict)
    and model.get("apiBase") == "http://127.0.0.1:8085/v1"
    and ((model.get("requestOptions") or {}).get("headers") or {}).get("X-AI-Profile") == "continue-local"
    and (
        int(model.get("contextLength") or 0) == expected_context
        if expected_context is not None
        else int(model.get("contextLength") or 0) >= 12000
    )
    and (
        int(model.get("maxTokens") or 0) == expected_chat_max_tokens
        if expected_chat_max_tokens is not None
        else int(model.get("maxTokens") or 0) >= 512
    )
    for model in models
):
    raise SystemExit(1)

tab_model = data.get("tabAutocompleteModel") or {}
if tab_model.get("apiBase") != "http://127.0.0.1:8085/v1":
    raise SystemExit(1)
if ((tab_model.get("requestOptions") or {}).get("headers") or {}).get("X-AI-Profile") != "continue-local":
    raise SystemExit(1)
if expected_context is not None and int(tab_model.get("contextLength") or 0) != expected_context:
    raise SystemExit(1)
if (
    int(tab_model.get("maxTokens") or 0)
    != (expected_tab_max_tokens if expected_tab_max_tokens is not None else max(32, int(tab_model.get("maxTokens") or 0)))
):
    raise SystemExit(1)
providers = data.get("contextProviders") or []
if not any(
    isinstance(provider, dict)
    and provider.get("name") == "aq-hints"
        and ((provider.get("params") or {}).get("endpoint") == "http://127.0.0.1:8003/hints")
    for provider in providers
):
    raise SystemExit(1)
PY
}

_continue_local_smoke() {
  # Qwen3.6-35B with partial GPU offload (12/41 layers) takes ~30-35s for a short
  # completion through the switchboard (profile-card injection adds ~125 prompt tokens).
  # Use 90s to give the model enough headroom on this hardware.
  curl -sf --max-time 90 \
    -H 'Content-Type: application/json' \
    -H 'X-AI-Profile: continue-local' \
    -d '{"model":"aq-continue-smoke","messages":[{"role":"user","content":"Reply with only CONTINUE_OK"}],"max_tokens":8,"n_predict":8,"temperature":0}' \
    "${SWITCHBOARD_URL}/v1/chat/completions" | \
    python3 -c 'import json,sys; data=json.load(sys.stdin); choice=(data.get("choices") or [{}])[0]; msg=choice.get("message") or {}; content=(msg.get("content") or "").strip(); reasoning=(msg.get("reasoning_content") or "").strip(); usage=data.get("usage") or {}; completion_tokens=int(usage.get("completion_tokens") or 0); observed=content or reasoning; print(observed or completion_tokens); raise SystemExit(0 if observed or completion_tokens > 0 else 1)'
}

_continue_local_large_context_smoke() {
  bash "${REPO_ROOT}/scripts/testing/test-switchboard-continue-context-window.sh"
}

_continue_editor_flow_smoke() {
