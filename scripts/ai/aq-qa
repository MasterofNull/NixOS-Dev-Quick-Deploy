}
_p57_check_gate_present() {
  [[ -x "${_p57_gate}" ]]
}
_p57_check_bench_present() {
  [[ -x "${_p57_bench}" ]]
}
_p57_check_host_class_recognized() {
  # Verify the capability matrix contains a hardware_classes entry for the class
  # reported by facts.nix (or derived from the running system's GPU vendor).
  local host_class=""
  # Try facts.nix first
  if [[ -f "${REPO_ROOT}/nix/hosts/${HOSTNAME:-$(hostname -s)}/facts.nix" ]]; then
    host_class="$(grep -Eo 'accelerationClass = "[^"]*"' \
      "${REPO_ROOT}/nix/hosts/${HOSTNAME:-$(hostname -s)}/facts.nix" 2>/dev/null \
      | awk -F'"' '{print $2}' | head -1 || true)"
  fi
  # Fall back: derive from running GPU vendor
  if [[ -z "${host_class}" ]]; then
    local gpu_vendor="none"
    if command -v lspci >/dev/null 2>&1; then
      local gpu_info
      gpu_info="$(lspci 2>/dev/null | grep -iE 'vga|3d|display' || true)"
      [[ "${gpu_info}" =~ AMD|ATI|Radeon ]] && gpu_vendor="amd"
      [[ "${gpu_info}" =~ NVIDIA ]] && gpu_vendor="nvidia"
    fi
    case "${gpu_vendor}" in
      amd)    host_class="amd-apu-renoir" ;;
      nvidia) host_class="nvidia-turing-plus" ;;
      *)      host_class="generic-cpu" ;;
    esac
  fi
  [[ -n "${host_class}" ]] && \
    python3 -c "
import json, sys
d = json.load(open(sys.argv[1]))
cls = sys.argv[2]
if cls not in d.get('hardware_classes', {}):
    print('class not found:', cls, file=sys.stderr)
    sys.exit(1)
" "${_p57_matrix}" "${host_class}"
}
_p57_check_host_promotion_status_set() {
  local host_class=""
  if [[ -f "${REPO_ROOT}/nix/hosts/${HOSTNAME:-$(hostname -s)}/facts.nix" ]]; then
    host_class="$(grep -Eo 'accelerationClass = "[^"]*"' \
      "${REPO_ROOT}/nix/hosts/${HOSTNAME:-$(hostname -s)}/facts.nix" 2>/dev/null \
      | awk -F'"' '{print $2}' | head -1 || true)"
  fi
  [[ -z "${host_class}" ]] && host_class="amd-apu-renoir"
  local status
  status="$(python3 -c "
import json, sys
d = json.load(open(sys.argv[1]))
cls = sys.argv[2]
print(d.get('hardware_classes', {}).get(cls, {}).get('promotion_status', ''))
" "${_p57_matrix}" "${host_class}" 2>/dev/null || true)"
  [[ -n "${status}" && "${status}" != "unknown" ]]
}
