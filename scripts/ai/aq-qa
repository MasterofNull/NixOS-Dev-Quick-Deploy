#!/usr/bin/env bash
# aq-qa — AI Stack QA phase runner (Phase 21.1)
#
# Runs discrete test checks for a given QA plan phase and outputs
# structured pass/fail results. Replaces 10-20 individual Bash tool
# calls per session with a single invocation.
#
# Usage:
#   aq-qa 0               Run Phase 0 (pre-flight smoke)
#   aq-qa 1               Run Phase 1 (infrastructure)
#   aq-qa phase0          Same as aq-qa 0
#   aq-qa all             Run all implemented phases
#   aq-qa 0 --json        Machine-readable JSON output
#   aq-qa 0 --sudo        Enable checks that require sudo (AppArmor)
#   aq-qa --layer 5       Run only Session/Persistence checks (Postgres, AIDB)
#   aq-qa --layer 4 --causality  Check L4 + all dependencies (L1-L3)
#
# Exit codes: 0 = all pass, 1 = one or more failed, 2 = usage error

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

# shellcheck source=../config/service-endpoints.sh
source "${REPO_ROOT}/config/service-endpoints.sh"

# ---------------------------------------------------------------------------
# Options
# ---------------------------------------------------------------------------
PHASE="${1:-help}"
JSON_OUTPUT=0
USE_SUDO=0
LAYER_FILTER=0
CAUSALITY_MODE=0

# Filter out phase arg if it's a number, otherwise default to all
if [[ "$PHASE" =~ ^[0-9]+$ || "$PHASE" == "all" ]]; then
    shift 2>/dev/null || true
else
    PHASE="all"
fi

args=("$@")
for ((i=0; i<${#args[@]}; i++)); do
  case "${args[i]}" in
    --json) JSON_OUTPUT=1 ;;
    --sudo) USE_SUDO=1 ;;
    --layer) LAYER_FILTER="${args[i+1]}"; (( i += 1 )) ;;
    --causality) CAUSALITY_MODE=1 ;;
    --help|-h) PHASE="help" ;;
  esac
done

PHASE="${PHASE#phase}"   # strip optional "phase" prefix

AQ_QA_FIXTURE_LLAMA_DIAG="${AQ_QA_FIXTURE_LLAMA_DIAG:-}"
AQ_QA_FIXTURE_APPARMOR_DIAG="${AQ_QA_FIXTURE_APPARMOR_DIAG:-}"

# ---------------------------------------------------------------------------
# Test result tracking
# ---------------------------------------------------------------------------
PASS=0
FAIL=0
SKIP=0
RESULTS=()  # "PASS|FAIL|SKIP id description"
START_TS=$(date +%s)

_pass() { local layer="$1" id="$2" desc="$3"; ((++PASS)); RESULTS+=("PASS|$layer|$id|$desc"); }
_fail() { local layer="$1" id="$2" desc="$3" reason="${4:-}"; ((++FAIL)); RESULTS+=("FAIL|$layer|$id|$desc${reason:+ ($reason)}"); }
_skip() { local layer="$1" id="$2" desc="$3" reason="${4:-}"; ((++SKIP)); RESULTS+=("SKIP|$layer|$id|$desc${reason:+ ($reason)}"); }

# OSI Layer Enforcement
_should_run() {
    local layer="$1"
    [[ "$LAYER_FILTER" -eq 0 ]] && return 0
    [[ "$LAYER_FILTER" -eq "$layer" ]] && return 0
    [[ "$CAUSALITY_MODE" -eq 1 && "$LAYER_FILTER" -gt "$layer" ]] && return 0
    return 1
}

# Run a command silently; pass/fail based on exit code.
_check() {
  local layer="$1" id="$2" desc="$3"; shift 3
  if ! _should_run "$layer"; then return 0; fi
  if "$@" >/dev/null 2>&1; then
    _pass "$layer" "$id" "$desc"
  else
    _fail "$layer" "$id" "$desc"
  fi
}

# Run a command and check output matches a pattern.
_check_output() {
  local layer="$1" id="$2" desc="$3" pattern="$4"; shift 4
  if ! _should_run "$layer"; then return 0; fi
  local out
  out=$("$@" 2>&1) || { _fail "$layer" "$id" "$desc" "command failed"; return; }
  if printf '%s' "$out" | grep -qE "$pattern"; then
    _pass "$layer" "$id" "$desc"
  else
    _fail "$layer" "$id" "$desc" "output: ${out:0:80}"
  fi
}

_output_contains() {
  local pattern="$1"
  shift
  local out
  out=$("$@" 2>/dev/null || true)
  grep -qE "$pattern" <<<"$out"
}

_primary_user() {
  if [[ -n "${AQ_QA_PRIMARY_USER:-}" ]]; then
    printf '%s' "${AQ_QA_PRIMARY_USER}"
    return 0
  fi
  if [[ -n "${SUDO_USER:-}" ]]; then
    printf '%s' "${SUDO_USER}"
    return 0
  fi
  local repo_owner
  repo_owner="$(stat -c '%U' "${REPO_ROOT}" 2>/dev/null || true)"
  if [[ -n "${repo_owner}" && "${repo_owner}" != "UNKNOWN" ]]; then
    printf '%s' "${repo_owner}"
    return 0
  fi
  printf '%s' "${USER:-}"
}

_primary_home() {
  if [[ -n "${AQ_QA_PRIMARY_HOME:-}" ]]; then
    printf '%s' "${AQ_QA_PRIMARY_HOME}"
    return 0
  fi
  local user home_dir
  user="$(_primary_user)"
  home_dir="$(getent passwd "${user}" 2>/dev/null | cut -d: -f6)"
  if [[ -n "${home_dir}" ]]; then
    printf '%s' "${home_dir}"
    return 0
  fi
  printf '%s' "${HOME:-}"
}

_primary_user_path() {
  local home_dir
  home_dir="$(_primary_home)"
  printf '%s' "${home_dir}/.npm-global/bin:${home_dir}/.local/bin:${home_dir}/.nix-profile/bin:${PATH}"
}

_continue_cli_path() {
  local user home_dir
  if command -v cn >/dev/null 2>&1; then
    command -v cn
    return 0
  fi
  user="$(_primary_user)"
  home_dir="$(getent passwd "${user}" 2>/dev/null | cut -d: -f6)"
  for candidate in \
    "${HOME:-}/.nix-profile/bin/cn" \
    "${home_dir}/.nix-profile/bin/cn" \
    "/etc/profiles/per-user/${user}/bin/cn"
  do
    [[ -x "${candidate}" ]] || continue
    printf '%s' "${candidate}"
    return 0
  done
  return 1
}

_run_clean_primary_shell() {
  local primary_home primary_user
  primary_home="$(_primary_home)"
  primary_user="$(_primary_user)"
  env \
    HOME="${primary_home}" \
    USER="${primary_user}" \
    LOGNAME="${primary_user}" \
    PATH="$(_primary_user_path)" \
    bash --noprofile --norc -c "$1"
}

_continue_cli_help() {
  local cli
  cli="$(_continue_cli_path)" || return 1
  env \
    HOME="$(_primary_home)" \
    USER="$(_primary_user)" \
    LOGNAME="$(_primary_user)" \
    PATH="$(_primary_user_path)" \
    "${cli}" --help
}

# HTTP health check: curl URL, expect JSON with status=ok.
_http_health() {
  local layer="$1" id="$2" desc="$3" url="$4"
  if ! _should_run "$layer"; then return 0; fi
  local status
  status=$(curl -sf --max-time 5 "$url" 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('status',''))" 2>/dev/null || true)
  if [[ "$status" == "ok" ]]; then
    _pass "$layer" "$id" "$desc"
  else
    _fail "$layer" "$id" "$desc" "status='$status' url=$url"
  fi
}

_continue_config_ok() {
  local cfg="$(_primary_home)/.continue/config.json"
  [[ -f "$cfg" ]] || return 1
  python3 - "$cfg" "${SWITCHBOARD_URL}" <<'PY'
import json, sys
from urllib.request import urlopen

cfg_path = sys.argv[1]
switchboard_url = sys.argv[2].rstrip("/")
with open(cfg_path, "r", encoding="utf-8") as fh:
    data = json.load(fh)

if str(data.get("__configVersion") or "") not in {"23.0", "24.0", "25.0", "26.0", "27.0", "28.0", "29.0", "30.0", "31.0", "32.0", "33.0", "34.0"}:
    raise SystemExit(1)

with urlopen(f"{switchboard_url}/health", timeout=5) as response:
    health = json.load(response)

profiles = health.get("profiles") or {}
continue_profile = profiles.get("continue-local") or {}
local_agent_profile = profiles.get("local-agent") or {}
default_profile = profiles.get("default") or {}

# Interactive Continue chat should use the larger harness-aware local-agent
# lane, while compact switchboard response budgets stay reserved for the
# continue-local editor path and tab/autocomplete.
expected_chat_context = local_agent_profile.get("advertisedContextWindow") or default_profile.get("advertisedContextWindow")
expected_chat_context = int(expected_chat_context) if expected_chat_context is not None else None
bounded_chat_context = local_agent_profile.get("maxInputTokens")
bounded_chat_context = int(bounded_chat_context) if bounded_chat_context is not None else None
minimum_chat_context = bounded_chat_context or expected_chat_context or 4096
minimum_chat_context = max(4096, int(minimum_chat_context))
minimum_chat_max_tokens = 1024

expected_tab_context = continue_profile.get("advertisedContextWindow") or default_profile.get("advertisedContextWindow")
expected_tab_context = int(expected_tab_context) if expected_tab_context is not None else None
expected_tab_max_tokens = max(32, min(96, minimum_chat_max_tokens)) if minimum_chat_max_tokens is not None else None

models = data.get("models") or []
if not any(
    isinstance(model, dict)
    and model.get("apiBase") == "http://127.0.0.1:8085/v1"
    and ((model.get("requestOptions") or {}).get("headers") or {}).get("X-AI-Profile") == "local-agent"
    and int(model.get("contextLength") or 0) >= minimum_chat_context
    and int(model.get("maxTokens") or 0) >= minimum_chat_max_tokens
    for model in models
):
    raise SystemExit(1)

tab_model = data.get("tabAutocompleteModel") or {}
if tab_model.get("apiBase") != "http://127.0.0.1:8085/v1":
    raise SystemExit(1)
if ((tab_model.get("requestOptions") or {}).get("headers") or {}).get("X-AI-Profile") != "continue-local":
    raise SystemExit(1)
if expected_tab_context is not None and int(tab_model.get("contextLength") or 0) != expected_tab_context:
    raise SystemExit(1)
if (
    int(tab_model.get("maxTokens") or 0)
    != (expected_tab_max_tokens if expected_tab_max_tokens is not None else max(32, int(tab_model.get("maxTokens") or 0)))
):
    raise SystemExit(1)
# aq-hints context provider was removed in Continue v1.3.38+ (not a supported provider type);
# harness context is now delivered via the local-agent switchboard profile card instead.
PY
}

_continue_local_smoke() {
