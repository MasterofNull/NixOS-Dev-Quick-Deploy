run_phase_2() {
  local diag_json classification healthy
  if [[ -n "$AQ_QA_FIXTURE_LLAMA_DIAG" ]]; then
    diag_json="$(cat "$AQ_QA_FIXTURE_LLAMA_DIAG" 2>/dev/null || true)"
  else
    if diag_json="$("${SCRIPT_DIR}/aq-runtime-diagnose" --preset llama-cpp --json 2>/dev/null)"; then
      :
    else
      diag_json="$("${SCRIPT_DIR}/aq-runtime-diagnose" --preset llama-cpp --json 2>/dev/null || true)"
    fi
  fi

  if [[ -z "$diag_json" ]]; then
    _fail "2.1.1" "aq-runtime-diagnose returned diagnostics" "no output"
    return
  fi

  classification="$(python3 - <<'PY' "$diag_json"
import json, sys
try:
    print(json.loads(sys.argv[1]).get("classification", ""))
except Exception:
    print("")
PY
)"
  healthy="$(python3 - <<'PY' "$diag_json"
import json, sys
try:
    print("yes" if json.loads(sys.argv[1]).get("healthy") else "no")
except Exception:
    print("no")
PY
)"

  if [[ "$healthy" == "yes" ]]; then
    _pass "2.1.1" "runtime/package/confinement loop passes (${classification})"
  else
    _fail "2.1.1" "runtime/package/confinement loop passes" "classification=${classification}"
  fi

  if [[ "$classification" == "path_scoped_confinement_likely" ]]; then
    _fail "2.1.2" "no path-scoped confinement regression" "copied binary enumerates Vulkan but original does not"
  else
    _pass "2.1.2" "no path-scoped confinement regression detected"
  fi
}

