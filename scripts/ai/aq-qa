#!/usr/bin/env bash
# aq-qa — AI Stack QA phase runner
#
# Usage:
#   aq-qa [phase] [--machine]
#
# --machine: Strips ANSI styling and provides raw, deterministic output
#            for autonomous agents.

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Phase 177: honor REPO_ROOT env var when set (coordinator calls Nix-store copy;
# without this, SCRIPT_DIR resolves to the Nix store and git ops fail silently).
REPO_ROOT="${REPO_ROOT:-$(cd "${SCRIPT_DIR}/../.." && pwd)}"

HARNESS_PY="${REPO_ROOT}/scripts/ai/lib/harness_runner.py"

MACHINE_MODE=false
ARGS=()
for arg in "$@"; do
  if [[ "$arg" == "--machine" ]]; then
    MACHINE_MODE=true
  else
    ARGS+=("$arg")
  fi
done

if [[ ! -f "${HARNESS_PY}" ]]; then
  exec bash "${SCRIPT_DIR}/_aq-qa-bash" "${ARGS[@]}"
fi

if ! command -v python3 >/dev/null 2>&1; then
  exec bash "${SCRIPT_DIR}/_aq-qa-bash" "${ARGS[@]}"
fi

if [[ "${MACHINE_MODE}" == "true" ]]; then
    # Force NO_COLOR and machine-readable output
    NO_COLOR=1 exec python3 "${HARNESS_PY}" "${ARGS[@]}" --machine
else
    exec python3 "${HARNESS_PY}" "${ARGS[@]}"
fi
