  local aa_profile="/etc/apparmor.d/ai-llama-cpp"
  if [[ -f "$aa_profile" ]]; then
    local aa_mode
    aa_mode=$(grep -o '(enforce)\|(complain)' /sys/kernel/security/apparmor/profiles 2>/dev/null | grep -c 'enforce' || true)
    if [[ "$aa_mode" -ge 1 ]]; then
      _pass 3 "5.1.1" "AppArmor has enforce-mode profiles active"
    else
      _skip 3 "5.1.1" "AppArmor enforce mode" "no enforce-mode profiles (may need --sudo)"
    fi
  else
    _skip 3 "5.1.1" "AppArmor ai-llama-cpp profile" "profile file absent"
  fi

  # 5.2 SSRF protection module
  _check 3 "5.2.1" "ssrf_protection.py present" \
    test -f "${REPO_ROOT}/ai-stack/mcp-servers/shared/ssrf_protection.py"
  _check 3 "5.2.2" "ssrf_protection importable" \
    python3 -c "import sys, types; sys.modules.setdefault('structlog', types.SimpleNamespace(get_logger=lambda *a, **k: types.SimpleNamespace(info=lambda *x, **y: None, warning=lambda *x, **y: None, error=lambda *x, **y: None))); sys.path.insert(0,'${REPO_ROOT}/ai-stack/mcp-servers/shared'); import ssrf_protection"

  # 5.3 Prompt injection scanner
  _check 3 "5.3.1" "prompt_injection.py present" \
    test -f "${REPO_ROOT}/ai-stack/mcp-servers/hybrid-coordinator/prompt_injection.py"
  _check 3 "5.3.2" "prompt_injection importable" \
    python3 -c "import sys, types; sys.modules.setdefault('structlog', types.SimpleNamespace(get_logger=lambda *a, **k: types.SimpleNamespace(info=lambda *x, **y: None, warning=lambda *x, **y: None, error=lambda *x, **y: None))); sys.path.insert(0,'${REPO_ROOT}/ai-stack/mcp-servers/hybrid-coordinator'); import prompt_injection"

  # 5.5 Network isolation
  if nft list table ip ai_localhost_isolation >/dev/null 2>&1; then
    _pass 3 "5.5.1" "nftables AI localhost isolation table active"
  else
    _skip 3 "5.5.1" "nftables AI localhost isolation" "table not loaded (may need sudo)"
  fi

  # 5.6 Bubblewrap sandbox
  local bwrap_path
  bwrap_path="${BWRAP_PATH:-}"
  if [[ -z "$bwrap_path" ]]; then
    bwrap_path="$(systemctl show ai-aider-wrapper.service -p Environment --value 2>/dev/null | tr ' ' '\n' | sed -n 's/^BWRAP_PATH=//p' | head -1)"
  fi
  if command -v bwrap >/dev/null 2>&1; then
    _pass 3 "5.6.1" "bwrap (bubblewrap) available for aider sandbox"
  elif [[ -n "$bwrap_path" && -x "$bwrap_path" ]]; then
    _pass 3 "5.6.1" "bwrap (bubblewrap) available for aider sandbox via BWRAP_PATH"
  else
    _fail 3 "5.6.1" "bwrap (bubblewrap) available" "not in PATH and BWRAP_PATH missing"
  fi

  # 5.7 SafeCommandExecutor — agent immune system
  local _sce_dir="${REPO_ROOT}/ai-stack/mcp-servers/hybrid-coordinator"
  _check 3 "5.7.1" "safe_command_executor importable" \
    python3 -c "import sys; sys.path.insert(0,'${REPO_ROOT}/ai-stack/mcp-servers/hybrid-coordinator'); from safe_command_executor import check_command; ok,_=check_command('ls /tmp'); assert ok"
  _check 3 "5.7.2" "safe_command_executor blocks rm -rf" \
    python3 -c "import sys; sys.path.insert(0,'${REPO_ROOT}/ai-stack/mcp-servers/hybrid-coordinator'); from safe_command_executor import check_command; allowed,reason=check_command('rm -rf /critical'); assert not allowed and 'safety' in reason.lower()"
  _check 3 "5.7.3" "mcp-bridge-hybrid wires safe_command_executor" \
    python3 -c "src=open('${REPO_ROOT}/scripts/ai/mcp-bridge-hybrid.py').read(); assert 'safe_command_executor' in src and '_sce_check' in src and 'blocked' in src"
  # 5.8 Agent safety smoke test suite
  _check 3 "5.8.1" "test-agent-safety.sh exists and is executable" \
    test -x "${REPO_ROOT}/scripts/testing/test-agent-safety.sh"
  _check 3 "5.8.2" "agent safety smoke: all adversarial commands blocked" \
    bash "${REPO_ROOT}/scripts/testing/test-agent-safety.sh"
