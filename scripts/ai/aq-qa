# ---------------------------------------------------------------------------
# Output
# ---------------------------------------------------------------------------
_render_results() {
  local end_ts; end_ts=$(date +%s)
  local duration=$((end_ts - START_TS))

  if [[ "$JSON_OUTPUT" -eq 1 ]]; then
    python3 - "$PHASE" "$PASS" "$FAIL" "$SKIP" "$duration" "${RESULTS[@]}" <<'PYEOF'
import sys, json
phase, passed, failed, skipped, duration = sys.argv[1:6]
items = []
for entry in sys.argv[6:]:
    status, id_, desc = entry.split('|', 2)
    items.append({"id": id_, "status": status, "description": desc})
print(json.dumps({
    "phase": phase, "passed": int(passed), "failed": int(failed),
    "skipped": int(skipped), "duration_s": int(duration), "tests": items
}, indent=2))
PYEOF
    return
  fi

  local GREEN='\033[0;32m' RED='\033[0;31m' YELLOW='\033[1;33m' BLUE='\033[0;34m' NC='\033[0m'
  printf '\n%b━━━ aq-qa phase %s ━━━%b\n' "${BLUE}" "${PHASE}" "${NC}"
  for entry in "${RESULTS[@]}"; do
    IFS='|' read -r status id_ desc <<< "$entry"
    case "$status" in
      PASS) printf '%b✓%b %-14s %s\n' "${GREEN}" "${NC}" "$id_" "$desc" ;;
      FAIL) printf '%b✗%b %-14s %s\n' "${RED}" "${NC}" "$id_" "$desc" ;;
      SKIP) printf '%b–%b %-14s %s\n' "${YELLOW}" "${NC}" "$id_" "$desc" ;;
    esac
  done
  printf '\n%b%d passed%b · %b%d failed%b · %d skipped · %ds\n\n' \
    "${GREEN}" "${PASS}" "${NC}" "${RED}" "${FAIL}" "${NC}" "${SKIP}" "${duration}"
}

# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------
case "$PHASE" in
  help|"")
    printf 'Usage: aq-qa <phase> [--json] [--sudo]\n'
    printf '  phase: 0-10, all, or help\n'
    printf '    0  pre-flight smoke (services, ports, inference, editor, front-door)\n'
    printf '    1  infrastructure (redis, postgres, qdrant, aidb, hybrid-coordinator)\n'
    printf '    2  runtime/package/confinement diagnostics (llama preset)\n'
    printf '    3  AppArmor/confinement diagnostics\n'
    printf '    4  context engineering (aq-hints, switchboard trimming, policy files)\n'
    printf '    5  security hardening (SSRF, prompt injection, network isolation)\n'
    printf '    6  monitoring (Prometheus, tool audit log, aq-report, MCP integrity)\n'
    printf '    7  self-improvement (aq-prompt-eval, registry, query gaps)\n'
    printf '    8  E2E workflows (hints, /query, weekly report timer)\n'
    printf '    9  optimisation targets (llama health, Redis cache, embeddings)\n'
    printf '   10  regression (git hooks, verifier self-check, no failed units)\n'
    printf '  --json   Machine-readable JSON output\n'
    printf '  --sudo   Enable checks requiring sudo (AppArmor)\n'
    exit 0
    ;;
  0) run_phase_0 ;;
  1) run_phase_1 ;;
  2) run_phase_2 ;;
  3) run_phase_3 ;;
  4) run_phase_4 ;;
  5) run_phase_5 ;;
  6) run_phase_6 ;;
  7) run_phase_7 ;;
  8) run_phase_8 ;;
  9) run_phase_9 ;;
  10) run_phase_10 ;;
  all)
    PHASE="all"
    run_phase_0
    run_phase_1
    run_phase_2
    run_phase_3
    run_phase_4
    run_phase_5
    run_phase_6
    run_phase_7
    run_phase_8
    run_phase_9
    run_phase_10
    ;;
  *)
    printf 'aq-qa: unknown phase "%s"\n' "$PHASE" >&2
    exit 2
    ;;
esac

_render_results
[[ "$FAIL" -eq 0 ]]
