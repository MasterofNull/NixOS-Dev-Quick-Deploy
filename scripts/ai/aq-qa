d = json.load(open(sys.argv[1]))
rocm = d.get('accelerators', {}).get('rocm', {})
if rocm.get('promotion_gated') is not True:
    print('rocm entry missing promotion_gated:true', file=sys.stderr)
    sys.exit(1)
