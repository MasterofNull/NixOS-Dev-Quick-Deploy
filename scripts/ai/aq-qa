# ---------------------------------------------------------------------------
# Phase 5 — Security Hardening
# ---------------------------------------------------------------------------
run_phase_5() {
  # 5.1 AppArmor enforcement mode
  local aa_profile="/etc/apparmor.d/ai-llama-cpp"
  if [[ -f "$aa_profile" ]]; then
    local aa_mode
    aa_mode=$(grep -o '(enforce)\|(complain)' /sys/kernel/security/apparmor/profiles 2>/dev/null | grep -c 'enforce' || echo 0)
    if [[ "$aa_mode" -ge 1 ]]; then
      _pass "5.1.1" "AppArmor has enforce-mode profiles active"
    else
      _skip "5.1.1" "AppArmor enforce mode" "no enforce-mode profiles (may need --sudo)"
    fi
  else
    _skip "5.1.1" "AppArmor ai-llama-cpp profile" "profile file absent"
  fi

  # 5.2 SSRF protection module
  _check "5.2.1" "ssrf_protection.py present" \
    test -f "${REPO_ROOT}/ai-stack/mcp-servers/shared/ssrf_protection.py"
  _check "5.2.2" "ssrf_protection importable" \
    python3 -c "import sys; sys.path.insert(0,'${REPO_ROOT}/ai-stack/mcp-servers/shared'); import ssrf_protection"

  # 5.3 Prompt injection scanner
  _check "5.3.1" "prompt_injection.py present" \
    test -f "${REPO_ROOT}/ai-stack/mcp-servers/hybrid-coordinator/prompt_injection.py"
  _check "5.3.2" "prompt_injection importable" \
    python3 -c "import sys; sys.path.insert(0,'${REPO_ROOT}/ai-stack/mcp-servers/hybrid-coordinator'); import prompt_injection"

  # 5.5 Network isolation
  if nft list table ip ai_localhost_isolation >/dev/null 2>&1; then
    _pass "5.5.1" "nftables AI localhost isolation table active"
  else
    _skip "5.5.1" "nftables AI localhost isolation" "table not loaded (may need sudo)"
  fi

  # 5.6 Bubblewrap sandbox
  if command -v bwrap >/dev/null 2>&1; then
    _pass "5.6.1" "bwrap (bubblewrap) available for aider sandbox"
  else
    _fail "5.6.1" "bwrap (bubblewrap) available" "not in PATH"
  fi
}

