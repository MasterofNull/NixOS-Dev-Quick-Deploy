}

_editor_state_budget_ok() {
  local report_json budget_summary
  report_json="$(_aq_report_snapshot)" || report_json=""
  budget_summary="$(python3 - <<'PY' "${report_json}"
import json
import sys

raw = sys.argv[1]
if not raw:
    print("error|aq-report unavailable")
    raise SystemExit(0)

try:
    data = json.loads(raw)
except Exception:
    print("error|aq-report parse failed")
    raise SystemExit(0)

budget = ((data.get("continue_editor") or {}).get("state_budget") or {})
if not budget.get("available"):
    print("error|editor state budget unavailable")
    raise SystemExit(0)

checks = budget.get("checks") or []
failing = [
    f"{item.get('id')}={item.get('details') or item.get('description')}"
    for item in checks
    if str(item.get("status", "")).upper() == "FAIL"
]

if failing:
    print("error|" + "; ".join(failing[:4]))
    raise SystemExit(0)

overview = budget.get("overview") or {}
continue_overview = overview.get("continue") or {}
obsolete_overview = overview.get("obsolete_markers") or {}
codex_overview = overview.get("codex") or {}
print(
    "ok|"
    f"active_bytes={continue_overview.get('active_session_bytes', 0)},"
    f"active_sessions={continue_overview.get('active_session_count', 0)},"
    f"stale_ai_markers={obsolete_overview.get('ai_count', 0)},"
    f"codex_backups={codex_overview.get('backup_count', 0)}"
)
PY
)"
  case "${budget_summary%%|*}" in
    ok)
      return 0
      ;;
    *)
      printf '%s\n' "${budget_summary#*|}" >&2
      return 1
      ;;
  esac
}

# Port binding check.
_port() {
  local layer="$1" id="$2" desc="$3" port="$4"
  local attempts="${AQ_QA_PORT_RETRY_ATTEMPTS:-4}"
  local delay="${AQ_QA_PORT_RETRY_DELAY_SECONDS:-1}"
  local i
  for ((i=1; i<=attempts; i++)); do
    if _output_contains ":${port} " ss -tlnp; then
      _pass "$layer" "$id" "$desc"
      return 0
    fi
    (( i < attempts )) && sleep "${delay}"
  done
  _fail "$layer" "$id" "$desc" "port $port not bound"
}

# ---------------------------------------------------------------------------
# Phase 0 — Pre-flight smoke tests
# ---------------------------------------------------------------------------
run_phase_0() {
  # 0.1 systemd service health
  for unit in llama-cpp.service ai-aidb.service ai-hybrid-coordinator.service \
               ai-ralph-wiggum.service llama-cpp-embed.service ai-switchboard.service \
               redis-mcp.service qdrant.service postgresql.service; do
    local short="${unit%.service}"
    if ! _should_run 1; then continue; fi
    if systemctl is-active --quiet "$unit" 2>/dev/null; then
      _pass 1 "0.1.1:$short" "unit $unit active"
    else
      _fail 1 "0.1.1:$short" "unit $unit active" "not active"
    fi
  done

  # 0.1.2 No failed AI units
  local failed_units
  if _should_run 1; then
    failed_units=$(systemctl list-units 'ai-*' 'llama-*' --state=failed --no-legend 2>/dev/null || true)
    if [[ -z "$failed_units" ]]; then
    _pass 1 "0.1.2" "no AI units in failed state"
  else
    _fail 1 "0.1.2" "no AI units in failed state" "$failed_units"
    fi
  fi

  # 0.1.3 Timers scheduled
  for timer in ai-mcp-integrity-check.timer ai-mcp-process-watch.timer \
                ai-weekly-report.timer; do
    if ! _should_run 1; then continue; fi
    if _output_contains "$timer" systemctl list-timers "$timer" --no-legend; then
      _pass 1 "0.1.3:$timer" "timer $timer scheduled"
    else
      _fail 1 "0.1.3:$timer" "timer $timer scheduled" "not found in timers list"
    fi
  done

  # 0.2 Port binding
  local -A port_names=([6379]="redis" [5432]="postgres" [6333]="qdrant"
                       [8080]="llama-cpp" [8081]="llama-embed" [8002]="aidb"
                       [8003]="hybrid-coordinator" [8004]="ralph-wiggum"
                       [8085]="switchboard" [3001]="open-webui" [9090]="prometheus")
  for port in "${!port_names[@]}"; do
    if ! _should_run 3; then continue; fi
    _port 3 "0.2.1:${port_names[$port]}" "port ${port} (${port_names[$port]}) bound" "$port"
  done

  # 0.2.2 Port 3000 belongs to Grafana (Open-WebUI must be on 3001, not 3000)
  if _should_run 3; then
    local ss_listeners
    ss_listeners="$(ss -tlnp 2>/dev/null || true)"
    if systemctl is-active --quiet grafana.service 2>/dev/null && \
       grep -q ':3000 ' <<<"${ss_listeners}"; then
      _pass 3 "0.2.2" "port 3000 = Grafana (no Open-WebUI regression)"
    elif ! grep -q ':3000 ' <<<"${ss_listeners}"; then
      _skip 3 "0.2.2" "port 3000 Grafana check" "port 3000 not bound (Grafana disabled?)"
    else
      _fail 3 "0.2.2" "port 3000 Grafana check" "Grafana inactive but port 3000 is bound"
    fi
  fi

  # 0.3 AppArmor — check profile files (no sudo needed) + service active
  local aa_dir="/etc/apparmor.d"
  if _should_run 1; then
    if [[ -f "$aa_dir/ai-llama-cpp" && -f "$aa_dir/ai-mcp-base" ]]; then
      _pass 1 "0.3.1" "AppArmor profiles on disk ($aa_dir/ai-llama-cpp, ai-mcp-base)"
    else
      local found
      found=$(ls "$aa_dir"/ai-* 2>/dev/null | xargs -I{} basename {} | tr '\n' ' ' || echo "none")
      _fail 1 "0.3.1" "AppArmor profiles on disk" "found: $found"
    fi
    _check 1 "0.3.2" "AppArmor service active" systemctl is-active apparmor
  fi

  # 0.4 Quick inference pings
  if _should_run 2; then
    _http_health 2 "0.4.1" "llama-server /health" "${LLAMA_URL}/health"
    _http_health 2 "0.4.2" "embedding server /health" "http://127.0.0.1:8081/health"
  fi

  # 0.5 Continue/editor runtime basics
  if _should_run 7; then
    _check 7 "0.5.1" "Continue CLI help works" _continue_cli_help
    _check 7 "0.5.2" "Continue config targets switchboard ingress with local harness chat lane and continue-local tab lane" _continue_config_ok
    _check_output 7 "0.5.3" "VSCodium has Continue extension installed" '^continue\.continue$' _continue_extension_output
    _check 7 "0.5.4" "continue-local switchboard profile ready" _continue_local_smoke
    _check 7 "0.5.5" "continue-local trims oversized dense prompts" _continue_local_large_context_smoke
    _check 7 "0.5.6" "Continue/editor prompt to feedback smoke" _continue_editor_flow_smoke
    if [[ "${AQ_QA_SKIP_REPORT_BACKED_CHECKS:-0}" == "1" ]]; then
      _skip 7 "0.5.7" "Editor-local agent corpus stays within bounded budgets" "skipped to avoid aq-report recursion"
    else
      _check 7 "0.5.7" "Editor-local agent corpus stays within bounded budgets" _editor_state_budget_ok
    fi
  fi

  # 0.6 Flagship agent CLI surface basics
  if _should_run 7; then
    _check 7 "0.6.1" "flagship agent CLI help smokes" _flagship_cli_surface_smoke
    _check 7 "0.6.2" "gemini CLI live-state health check" _gemini_cli_health_check
  fi

  # 0.7 Front-door routing (Phase 0 Slice 0.2)
  if _should_run 4; then
    local _hk_07
    _hk_07=$(cat /run/secrets/hybrid_coordinator_api_key 2>/dev/null | tr -d '\n' || true)
    local orch_http orch_body orch_out
    orch_body=$(curl -s --max-time 10 -w '\n%{http_code}' \
      -H "Content-Type: application/json" \
      -H "X-API-Key: ${_hk_07}" \
      -d '{"prompt":"what is nixos","route":"Explore"}' \
      "${HYBRID_URL}/v1/orchestrate" 2>/dev/null || true)
    orch_http=$(printf '%s' "$orch_body" | tail -1)
    orch_out=$(printf '%s' "$orch_body" | head -n -1)
    if [[ "$orch_http" =~ ^2 ]] && \
       python3 -c "import json,sys; d=json.loads(sys.argv[1]); raise SystemExit(0 if 'error' not in d else 1)" "$orch_out" 2>/dev/null; then
      _pass 4 "0.7.1" "/v1/orchestrate front-door smoke (route=Explore)"
    elif [[ "$orch_http" =~ ^5 ]]; then
      _skip 4 "0.7.1" "/v1/orchestrate front-door smoke" "HTTP ${orch_http} — server error, nixos-rebuild needed to apply fix"
    else
      _fail 4 "0.7.1" "/v1/orchestrate front-door smoke" "HTTP ${orch_http:-conn-err} out: ${orch_out:0:60}"
    fi
    local query_out
    query_out=$(curl -sf --max-time 10 \
      -H "Content-Type: application/json" \
      -H "X-API-Key: ${_hk_07}" \
      -d '{"query":"what is nixos","mode":"retrieval","prefer_local":true,"limit":1}' \
      "${HYBRID_URL}/query" 2>/dev/null || echo "err")
    if [[ "$query_out" != "err" ]] && \
       python3 -c "import json,sys; d=json.loads(sys.argv[1]); raise SystemExit(0 if 'results' in d else 1)" "$query_out" 2>/dev/null; then
      _pass 4 "0.7.2" "hybrid /query retrieval smoke"
    else
      _fail 4 "0.7.2" "hybrid /query retrieval smoke" "out: ${query_out:0:80}"
    fi
  fi

  # 0.8.1 ai_coordinator_delegate success rate (last 24h) — Phase 9.3 gate
  # SKIP when <1 sample (fresh deploy / no traffic yet); FAIL only on clear regression.
  # Reads from JSONL audit log (consistent with aq-report; no PostgreSQL dependency).
  local delegate_rate_out
  delegate_rate_out=$(python3 - <<'PYEOF' 2>/dev/null
import json, os, time
from pathlib import Path

AUDIT_LOG = Path(os.getenv("TOOL_AUDIT_LOG_PATH", "/var/log/ai-audit-sidecar/tool-audit.jsonl"))
WINDOW_S = 86400  # 24 hours (extended from 1h for development-cadence systems)
now = time.time()

try:
    total = 0
    ok = 0
    if AUDIT_LOG.exists():
        with open(AUDIT_LOG, "r", encoding="utf-8", errors="replace") as fh:
            for raw in fh:
                raw = raw.strip()
                if not raw:
                    continue
                try:
                    entry = json.loads(raw)
                except Exception:
                    continue
                if entry.get("tool_name") != "ai_coordinator_delegate":
                    continue
                ts_str = entry.get("timestamp", "")
                try:
                    from datetime import datetime, timezone
                    ts = datetime.fromisoformat(ts_str.replace("Z", "+00:00")).timestamp()
                except Exception:
                    continue
                if now - ts > WINDOW_S:
                    continue
                # Exclude probe/smoke calls that should not affect the real success rate:
                #   1. check-ai-coordinator-delegate-smoke.sh: timeout_s=5, outcome=error,
                #      error_message=http_status_504, latency < 15s.
                #   2. Security-gate blocks: error_message starts with
                #      "blocked_endpoint_pattern:" — these are auth/routing rejections
                #      triggered by health checks, not real delegation attempts.
                latency_ms = float(entry.get("latency_ms") or 0)
                err_msg = entry.get("error_message") or ""
                is_probe = (
                    (entry.get("outcome") == "error"
                     and err_msg == "http_status_504"
                     and latency_ms < 15000)
                    or err_msg.startswith("blocked_endpoint_pattern:")
                )
                if is_probe:
                    continue
                total += 1
                if entry.get("outcome") == "success":
                    ok += 1
    print(json.dumps({"total": total, "ok": ok}))
except Exception as e:
    print(json.dumps({"error": str(e)}))
PYEOF
  )
  local delegate_total delegate_ok delegate_pct
  delegate_total=$(python3 -c "import json,sys; d=json.loads(sys.argv[1]); print(d.get('total',0))" "$delegate_rate_out" 2>/dev/null || echo 0)
  delegate_ok=$(python3 -c "import json,sys; d=json.loads(sys.argv[1]); print(d.get('ok',0))" "$delegate_rate_out" 2>/dev/null || echo 0)
  if python3 -c "import json,sys; d=json.loads(sys.argv[1]); raise SystemExit(0 if 'error' in d else 1)" "$delegate_rate_out" 2>/dev/null; then
    _skip 4 "0.8.1" "delegate 1h success rate" "DB query failed: $(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('error','?')[:60])" "$delegate_rate_out" 2>/dev/null)"
  elif [[ "$delegate_total" -lt 1 ]]; then
    _skip 4 "0.8.1" "delegate 24h success rate" "insufficient sample (0 calls in last 24h)"
  else
    delegate_pct=$(python3 -c "print(round(100*${delegate_ok}/${delegate_total}))" 2>/dev/null || echo 0)
    if [[ "$delegate_pct" -ge 50 ]]; then
      _pass 4 "0.8.1" "delegate 24h success rate ${delegate_pct}% (${delegate_ok}/${delegate_total})"
