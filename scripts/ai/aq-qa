}

_flagship_cli_surface_smoke() {
  AQ_PRIMARY_USER="$(_primary_user)" \
  AQ_PRIMARY_HOME="$(_primary_home)" \
  bash "${REPO_ROOT}/scripts/testing/smoke-flagship-cli-surfaces.sh"
}

_gemini_cli_health_check() {
  local _primary_h; _primary_h="$(_primary_home)"
  AQ_PRIMARY_USER="$(_primary_user)" \
  AQ_PRIMARY_HOME="${_primary_h}" \
  PATH="${_primary_h}/.npm-global/bin:${PATH}" \
  bash "${REPO_ROOT}/scripts/health/gemini-cli-health.sh" --check
}

_aq_report_snapshot() {
  if [[ -n "${AQ_QA_AQ_REPORT_JSON:-}" ]]; then
    printf '%s' "${AQ_QA_AQ_REPORT_JSON}"
    return 0
  fi
  AQ_QA_AQ_REPORT_JSON="$(
    cd "${REPO_ROOT}" && python3 "${SCRIPT_DIR}/aq-report" --format json 2>/dev/null || true
  )"
  [[ -n "${AQ_QA_AQ_REPORT_JSON}" ]] || return 1
  printf '%s' "${AQ_QA_AQ_REPORT_JSON}"
}

# Port binding check.
_port() {
  local id="$1" desc="$2" port="$3"
  local attempts="${AQ_QA_PORT_RETRY_ATTEMPTS:-4}"
  local delay="${AQ_QA_PORT_RETRY_DELAY_SECONDS:-1}"
  local i
  for ((i=1; i<=attempts; i++)); do
    if _output_contains ":${port} " ss -tlnp; then
      _pass "$id" "$desc"
      return 0
    fi
    (( i < attempts )) && sleep "${delay}"
  done
  _fail "$id" "$desc" "port $port not bound"
}

# ---------------------------------------------------------------------------
# Phase 0 — Pre-flight smoke tests
# ---------------------------------------------------------------------------
run_phase_0() {
  # 0.1 systemd service health
  for unit in llama-cpp.service ai-aidb.service ai-hybrid-coordinator.service \
               ai-ralph-wiggum.service llama-cpp-embed.service ai-switchboard.service \
               redis-mcp.service qdrant.service postgresql.service; do
    local short="${unit%.service}"
    if systemctl is-active --quiet "$unit" 2>/dev/null; then
      _pass "0.1.1:$short" "unit $unit active"
    else
      _fail "0.1.1:$short" "unit $unit active" "not active"
    fi
  done

  # 0.1.2 No failed AI units
  local failed_units
  failed_units=$(systemctl list-units 'ai-*' 'llama-*' --state=failed --no-legend 2>/dev/null || true)
  if [[ -z "$failed_units" ]]; then
    _pass "0.1.2" "no AI units in failed state"
  else
    _fail "0.1.2" "no AI units in failed state" "$failed_units"
  fi

  # 0.1.3 Timers scheduled
  for timer in ai-mcp-integrity-check.timer ai-mcp-process-watch.timer \
                ai-weekly-report.timer; do
    if _output_contains "$timer" systemctl list-timers "$timer" --no-legend; then
      _pass "0.1.3:$timer" "timer $timer scheduled"
    else
      _fail "0.1.3:$timer" "timer $timer scheduled" "not found in timers list"
    fi
  done

  # 0.2 Port binding
  local -A port_names=([6379]="redis" [5432]="postgres" [6333]="qdrant"
                       [8080]="llama-cpp" [8081]="llama-embed" [8002]="aidb"
                       [8003]="hybrid-coordinator" [8004]="ralph-wiggum"
                       [8085]="switchboard" [3001]="open-webui" [9090]="prometheus")
  for port in "${!port_names[@]}"; do
    _port "0.2.1:${port_names[$port]}" "port ${port} (${port_names[$port]}) bound" "$port"
  done

  # 0.2.2 Port 3000 belongs to Grafana (Open-WebUI must be on 3001, not 3000)
  # Use systemctl instead of ss process-name (requires no sudo)
  local ss_listeners
  ss_listeners="$(ss -tlnp 2>/dev/null || true)"
  if systemctl is-active --quiet grafana.service 2>/dev/null && \
     grep -q ':3000 ' <<<"${ss_listeners}"; then
    _pass "0.2.2" "port 3000 = Grafana (no Open-WebUI regression)"
  elif ! grep -q ':3000 ' <<<"${ss_listeners}"; then
    _skip "0.2.2" "port 3000 Grafana check" "port 3000 not bound (Grafana disabled?)"
  else
    _fail "0.2.2" "port 3000 Grafana check" "Grafana inactive but port 3000 is bound"
  fi

  # 0.3 AppArmor — check profile files (no sudo needed) + service active
  local aa_dir="/etc/apparmor.d"
  if [[ -f "$aa_dir/ai-llama-cpp" && -f "$aa_dir/ai-mcp-base" ]]; then
    _pass "0.3.1" "AppArmor profiles on disk ($aa_dir/ai-llama-cpp, ai-mcp-base)"
  else
    local found
    found=$(ls "$aa_dir"/ai-* 2>/dev/null | xargs -I{} basename {} | tr '\n' ' ' || echo "none")
    _fail "0.3.1" "AppArmor profiles on disk" "found: $found"
  fi
  _check "0.3.2" "AppArmor service active" systemctl is-active apparmor

  # 0.4 Quick inference pings
  _http_health "0.4.1" "llama-server /health" "${LLAMA_URL}/health"
  _http_health "0.4.2" "embedding server /health" "http://127.0.0.1:8081/health"

  # 0.5 Continue/editor runtime basics
  _check "0.5.1" "Continue CLI help works" _continue_cli_help
  _check "0.5.2" "Continue config targets switchboard ingress with continue-local lane" _continue_config_ok
  _check_output "0.5.3" "VSCodium has Continue extension installed" '^continue\.continue$' _continue_extension_output
  _check "0.5.4" "continue-local switchboard smoke" _continue_local_smoke
  _check "0.5.5" "continue-local trims oversized dense prompts" _continue_local_large_context_smoke
  _check "0.5.6" "Continue/editor prompt to feedback smoke" _continue_editor_flow_smoke

  # 0.6 Flagship agent CLI surface basics
  _check "0.6.1" "flagship agent CLI help smokes" _flagship_cli_surface_smoke
  _check "0.6.2" "gemini CLI live-state health check" _gemini_cli_health_check

  # 0.7 Front-door routing (Phase 0 Slice 0.2)
  local _hk_07
  _hk_07=$(cat /run/secrets/hybrid_coordinator_api_key 2>/dev/null | tr -d '\n' || true)
  local orch_http orch_body orch_out
  # Use -w to capture HTTP status separately; -s only (no -f) to read body on error
  orch_body=$(curl -s --max-time 10 -w '\n%{http_code}' \
    -H "Content-Type: application/json" \
    -H "X-API-Key: ${_hk_07}" \
    -d '{"prompt":"what is nixos","route":"Explore"}' \
    "${HYBRID_URL}/v1/orchestrate" 2>/dev/null || true)
  orch_http=$(printf '%s' "$orch_body" | tail -1)
  orch_out=$(printf '%s' "$orch_body" | head -n -1)
  if [[ "$orch_http" =~ ^2 ]] && \
     python3 -c "import json,sys; d=json.loads(sys.argv[1]); raise SystemExit(0 if 'error' not in d else 1)" "$orch_out" 2>/dev/null; then
    _pass "0.7.1" "/v1/orchestrate front-door smoke (route=Explore)"
  elif [[ "$orch_http" =~ ^5 ]]; then
    _skip "0.7.1" "/v1/orchestrate front-door smoke" "HTTP ${orch_http} — server error, nixos-rebuild needed to apply fix"
  else
    _fail "0.7.1" "/v1/orchestrate front-door smoke" "HTTP ${orch_http:-conn-err} out: ${orch_out:0:60}"
  fi
  local query_out
  query_out=$(curl -sf --max-time 10 \
    -H "Content-Type: application/json" \
    -H "X-API-Key: ${_hk_07}" \
    -d '{"query":"what is nixos","mode":"retrieval","prefer_local":true,"limit":1}' \
    "${HYBRID_URL}/query" 2>/dev/null || echo "err")
  if [[ "$query_out" != "err" ]] && \
     python3 -c "import json,sys; d=json.loads(sys.argv[1]); raise SystemExit(0 if 'results' in d else 1)" "$query_out" 2>/dev/null; then
    _pass "0.7.2" "hybrid /query retrieval smoke"
  else
    _fail "0.7.2" "hybrid /query retrieval smoke" "out: ${query_out:0:80}"
  fi
}

# ---------------------------------------------------------------------------
# Phase 1 — Infrastructure validation
# ---------------------------------------------------------------------------
run_phase_1() {
  # 1.1 Redis
  _check_output "1.1.1" "redis ping" "PONG" redis-cli ping
  # redis-cli --latency output: "min max avg samples" on one line
  local redis_latency redis_raw
  redis_raw=$(timeout 4 redis-cli --latency 2>/dev/null | tr -d '\n\r' | awk '{print $3}' || echo "")
  redis_latency=$(printf '%.0f' "${redis_raw:-999}" 2>/dev/null || echo 999)
  if [[ "$redis_latency" -le 5 ]]; then
    _pass "1.1.2" "redis latency <= 5ms (got ${redis_raw}ms avg)"
  else
    _fail "1.1.2" "redis latency <= 5ms" "got ${redis_raw}ms avg"
  fi

  # 1.2 PostgreSQL — user=aidb, password from secrets
  local pg_pass pg_out
  pg_pass=$(cat /run/secrets/postgres_password 2>/dev/null | tr -d '\n' || true)
  pg_out=$(PGPASSWORD="$pg_pass" psql -h 127.0.0.1 -U aidb -d aidb -c "SELECT 1;" 2>&1 | grep -c "1 row" || echo 0)
  if [[ "$pg_out" -ge 1 ]]; then
    _pass "1.2.1" "postgres responds (user=aidb)"
  else
    _fail "1.2.1" "postgres responds (user=aidb)"
  fi
  _check_output "1.2.2" "AIDB schema tables present" \
    "imported_documents|query_gaps|telemetry_events|learning_feedback" \
    bash -c "PGPASSWORD='$pg_pass' psql -h 127.0.0.1 -U aidb -d aidb -c '\dt' 2>&1"

  # 1.3 Qdrant
  _check_output "1.3.1" "qdrant cluster info" "qdrant" \
    bash -c "curl -sf '${QDRANT_URL}/' | python3 -c \"import sys,json; d=json.load(sys.stdin); print(d.get('title',''))\" 2>/dev/null"

  # 1.4 AIDB
  _http_health "1.4.1" "AIDB /health" "${AIDB_URL}/health"
  local doc_count
  doc_count=$(curl -sf "${AIDB_URL}/documents?limit=1" 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('total',0))" 2>/dev/null || echo "err")
  if [[ "$doc_count" != "err" ]]; then
    _pass "1.4.2" "AIDB /documents returns (count=${doc_count})"
  else
    _fail "1.4.2" "AIDB /documents returns"
  fi

  # 1.5 Hybrid coordinator — status is 'healthy', not 'ok'
  local hybrid_key hybrid_status
  hybrid_key=$(cat /run/secrets/hybrid_coordinator_api_key 2>/dev/null | tr -d '\n' || true)
  hybrid_status=$(curl -sf --max-time 5 "${HYBRID_URL}/health" 2>/dev/null | \
    python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('status',''))" 2>/dev/null || true)
  if [[ "$hybrid_status" == "ok" || "$hybrid_status" == "healthy" ]]; then
    _pass "1.5.1" "hybrid-coordinator /health (${hybrid_status})"
  else
    _fail "1.5.1" "hybrid-coordinator /health" "status='$hybrid_status'"
  fi
  local hints_count
  hints_count=$(curl -sf -H "X-API-Key: ${hybrid_key}" "${HYBRID_URL}/hints?q=test" 2>/dev/null | \
    python3 -c "import sys,json; d=json.load(sys.stdin); print(len(d.get('hints',d) if isinstance(d,dict) else d))" 2>/dev/null || echo "err")
  if [[ "$hints_count" != "err" ]]; then
    _pass "1.5.2" "hybrid-coordinator GET /hints returns hints (count=${hints_count})"
  else
    _fail "1.5.2" "hybrid-coordinator GET /hints" "no response or auth failed"
  fi

  local report_json retrieval_summary
  report_json="$(_aq_report_snapshot)" || report_json=""
  retrieval_summary="$(python3 - <<'PY' "${report_json}"
import json, sys

raw = sys.argv[1]
if not raw:
    print("error|aq-report unavailable")
    raise SystemExit(0)

try:
    data = json.loads(raw)
except Exception:
    print("error|aq-report parse failed")
    raise SystemExit(0)

rag = data.get("rag_posture") or {}
breadth = data.get("route_retrieval_breadth") or {}
fallback = data.get("provider_fallback_recovery") or {}

if not rag.get("available"):
    print("error|rag posture unavailable")
    raise SystemExit(0)
if "memory_recall_share_pct" not in rag:
    print("error|memory recall share missing")
    raise SystemExit(0)

recent_calls = int(rag.get("recent_retrieval_calls") or 0)
if recent_calls <= 0:
    print("skip|no recent retrieval calls")
    raise SystemExit(0)

if not breadth.get("available"):
    print("error|retrieval breadth unavailable")
    raise SystemExit(0)

avg = breadth.get("avg_collection_count")
if avg in (None, ""):
    print("error|retrieval breadth missing avg_collection_count")
    raise SystemExit(0)

route_calls = int(breadth.get("route_calls") or 0)
share = rag.get("memory_recall_share_pct")
fallback_available = bool(fallback.get("available"))
print(f"ok|recent_calls={recent_calls}, route_calls={route_calls}, avg_collection_count={avg}, memory_recall_share_pct={share}, fallback_available={'yes' if fallback_available else 'no'}")
PY
)"
  case "${retrieval_summary%%|*}" in
    ok)
      _pass "1.5.3" "aq-report exposes retrieval acceptance metrics (${retrieval_summary#*|})"
      ;;
    skip)
