# Phase 7 — Recursive Self-Improvement
# ---------------------------------------------------------------------------
run_phase_7() {
  # 7.1 aq-prompt-eval
  _check "7.1.1" "aq-prompt-eval script executable" \
    test -x "${SCRIPT_DIR}/aq-prompt-eval"

  # 7.2 Prompt registry
  local registry="${REPO_ROOT}/ai-stack/prompts/registry.yaml"
  _check "7.2.1" "prompt registry.yaml present" test -f "$registry"
  local prompt_count
  prompt_count=$(python3 -c "
import re, sys
txt = open('${registry}').read() if __import__('os').path.exists('${registry}') else ''
print(len(re.findall(r'^  [a-z_]+:', txt, re.MULTILINE)))
" 2>/dev/null || echo 0)
  if [[ "$prompt_count" -ge 3 ]]; then
    _pass "7.2.2" "prompt registry has ${prompt_count} entries (≥3)"
  else
    _fail "7.2.2" "prompt registry has ≥3 entries" "found: ${prompt_count}"
