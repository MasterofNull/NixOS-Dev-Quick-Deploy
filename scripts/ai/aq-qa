}
_p57_check_matrix_keys() {
  python3 -c "
import json, sys
d = json.load(open(sys.argv[1]))
required = {'hardware_classes','rocm_compatibility_matrix','promotion_pipeline','backend_definitions','class_detection_order'}
missing = required - set(d.keys())
if missing:
    print('missing keys:', missing, file=sys.stderr)
