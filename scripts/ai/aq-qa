#!/usr/bin/env bash
# aq-qa — AI Stack QA phase runner
#
# Usage:
#   aq-qa [phase] [--machine]
#
# --machine: Strips ANSI styling and provides raw, deterministic output
#            for autonomous agents.

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Usage telemetry (god-tier prompt 8): records direct invocations so `aq usage`
# sees both `aq qa` and direct `aq-qa` calls. Never fails the host script.
source "$SCRIPT_DIR/lib/aq-shim.sh" 2>/dev/null || true
# Phase 177: honor REPO_ROOT env var when set (coordinator calls Nix-store copy;
# without this, SCRIPT_DIR resolves to the Nix store and git ops fail silently).
REPO_ROOT="${REPO_ROOT:-$(cd "${SCRIPT_DIR}/../.." && pwd)}"

HARNESS_PY="${REPO_ROOT}/scripts/ai/lib/harness_runner.py"

MACHINE_MODE=false
ARGS=()
for arg in "$@"; do
  if [[ "$arg" == "--machine" ]]; then
    MACHINE_MODE=true
  else
    ARGS+=("$arg")
  fi
done

# Shared fallback: exec into _aq-qa-bash, applying machine-mode guards when needed.
# Machine mode: adds NO_COLOR=1 and an outer timeout so CI callers never block
# indefinitely (smoke scripts like smoke-continue-editor-flow.sh can stall 270s+
# on repeated 429s with no stdout — Tier 0 has its own timeout wrapper, standalone
# callers do not).
_exec_bash_fallback() {
    local _progress_dir="${AQ_QA_PROGRESS_DIR:-${REPO_ROOT}/.agent/qa}"
    mkdir -p "${_progress_dir}" 2>/dev/null || true
    export AQ_QA_PROGRESS_JSON="${AQ_QA_PROGRESS_JSON:-${_progress_dir}/latest-progress.json}"
    export AQ_QA_PROGRESS_JSONL="${AQ_QA_PROGRESS_JSONL:-${_progress_dir}/latest-progress.jsonl}"
    if [[ "${MACHINE_MODE}" == "true" ]]; then
        local _t="${AQ_QA_MACHINE_TIMEOUT_SECONDS:-300}"
        NO_COLOR=1 exec timeout --foreground "${_t}" bash "${SCRIPT_DIR}/_aq-qa-bash" "$@"
    else
        exec bash "${SCRIPT_DIR}/_aq-qa-bash" "$@"
    fi
}

if [[ ! -f "${HARNESS_PY}" ]]; then
  _exec_bash_fallback "${ARGS[@]}"
fi

if ! command -v python3 >/dev/null 2>&1; then
  _exec_bash_fallback "${ARGS[@]}"
fi

if [[ "${MACHINE_MODE}" == "true" ]]; then
    # Force NO_COLOR and machine-readable output
    NO_COLOR=1 exec python3 "${HARNESS_PY}" "${ARGS[@]}" --machine
else
    exec python3 "${HARNESS_PY}" "${ARGS[@]}"
fi
