  gap_count=$(PGPASSWORD="$pg_pass" psql -h 127.0.0.1 -U aidb -d aidb -t \
    -c "SELECT COUNT(*) FROM query_gaps;" 2>/dev/null | tr -d ' \n' || echo "err")
  if [[ "$gap_count" =~ ^[0-9]+$ ]]; then
    _pass "7.3.1" "query_gaps table accessible (${gap_count} rows)"
  else
    _fail "7.3.1" "query_gaps table accessible" "got: $gap_count"
  fi
