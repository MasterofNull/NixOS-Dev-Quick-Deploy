#!/usr/bin/env bash
#
# Local Orchestrator CLI
#
# Primary interface for all AI tasks - routes through local Gemma model
# with MCP tools, RAG, and remote agent delegation.
#
# Usage:
#   local-orchestrator                    # Interactive mode
#   local-orchestrator "prompt"           # Single prompt
#   local-orchestrator --route Reasoning "prompt"  # Single prompt via front-door alias
#   local-orchestrator --status           # Show status
#   local-orchestrator --plan "objective" # Create plan
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

# Add to Python path
export PYTHONPATH="${REPO_ROOT}/ai-stack:${PYTHONPATH:-}"

# Service URLs (configurable)
export HYBRID_URL="${HYBRID_URL:-http://127.0.0.1:8003}"
export AIDB_URL="${AIDB_URL:-http://127.0.0.1:8002}"
export LLAMA_URL="${LLAMA_URL:-http://127.0.0.1:8080}"

# OpenClaude-style front-door routing aliases, translated onto harness profiles.
export AI_LOCAL_FRONTDOOR_ROUTING_ENABLE="${AI_LOCAL_FRONTDOOR_ROUTING_ENABLE:-true}"
export AI_LOCAL_FRONTDOOR_DEFAULT_PROFILE="${AI_LOCAL_FRONTDOOR_DEFAULT_PROFILE:-default}"
export AI_LOCAL_FRONTDOOR_EXPLORE_PROFILE="${AI_LOCAL_FRONTDOOR_EXPLORE_PROFILE:-default}"
export AI_LOCAL_FRONTDOOR_PLAN_PROFILE="${AI_LOCAL_FRONTDOOR_PLAN_PROFILE:-default}"
export AI_LOCAL_FRONTDOOR_IMPLEMENTATION_PROFILE="${AI_LOCAL_FRONTDOOR_IMPLEMENTATION_PROFILE:-remote-coding}"
export AI_LOCAL_FRONTDOOR_REASONING_PROFILE="${AI_LOCAL_FRONTDOOR_REASONING_PROFILE:-remote-reasoning}"
export AI_LOCAL_FRONTDOOR_TOOL_CALLING_PROFILE="${AI_LOCAL_FRONTDOOR_TOOL_CALLING_PROFILE:-local-tool-calling}"
export AI_LOCAL_FRONTDOOR_CONTINUATION_PROFILE="${AI_LOCAL_FRONTDOOR_CONTINUATION_PROFILE:-default}"

# Parse arguments
MODE="interactive"
PROMPT=""
OBJECTIVE=""
ROUTE_ALIAS="${AI_LOCAL_FRONTDOOR_DEFAULT_ROUTE:-default}"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --status|-s)
            MODE="status"
            shift
            ;;
        --plan|-p)
            MODE="plan"
            OBJECTIVE="${2:-}"
            shift 2 || true
            ;;
        --route|-r)
            ROUTE_ALIAS="${2:-default}"
            shift 2 || true
            ;;
        --help|-h)
            echo "Local Orchestrator CLI"
            echo ""
            echo "Usage:"
            echo "  local-orchestrator                     Interactive mode"
            echo "  local-orchestrator \"prompt\"           Single prompt"
            echo "  local-orchestrator --route Reasoning \"prompt\"  Single prompt via front-door alias"
            echo "  local-orchestrator --status            Show status"
            echo "  local-orchestrator --plan \"objective\" Create plan"
            echo ""
            echo "Environment:"
            echo "  HYBRID_URL   Hybrid coordinator URL (default: http://127.0.0.1:8003)"
            echo "  AIDB_URL     AIDB URL (default: http://127.0.0.1:8002)"
            echo "  LLAMA_URL    Llama.cpp URL (default: http://127.0.0.1:8080)"
            echo "  AI_LOCAL_FRONTDOOR_*  Optional OpenClaude-style route mapping overrides"
            exit 0
            ;;
        *)
            PROMPT="$1"
            MODE="single"
            shift
            ;;
    esac
done

load_hybrid_api_key() {
    local api_key="${HYBRID_API_KEY:-}"
    local candidate

    if [[ -n "$api_key" ]]; then
        printf '%s' "$api_key"
        return 0
    fi

    for candidate in \
        "${HYBRID_API_KEY_FILE:-/run/secrets/hybrid_coordinator_api_key}" \
        /run/secrets/hybrid_coordinator_api_key \
        /run/secrets/hybrid_api_key
    do
        if [[ -r "$candidate" ]]; then
            tr -d '[:space:]' < "$candidate"
            return 0
        fi
    done

    return 1
}

frontdoor_profile_for_alias() {
    case "${1:-default}" in
        default) printf '%s' "${AI_LOCAL_FRONTDOOR_DEFAULT_PROFILE}" ;;
        Explore) printf '%s' "${AI_LOCAL_FRONTDOOR_EXPLORE_PROFILE}" ;;
        Plan) printf '%s' "${AI_LOCAL_FRONTDOOR_PLAN_PROFILE}" ;;
        Implementation) printf '%s' "${AI_LOCAL_FRONTDOOR_IMPLEMENTATION_PROFILE}" ;;
        Reasoning) printf '%s' "${AI_LOCAL_FRONTDOOR_REASONING_PROFILE}" ;;
        ToolCalling) printf '%s' "${AI_LOCAL_FRONTDOOR_TOOL_CALLING_PROFILE}" ;;
        Continuation) printf '%s' "${AI_LOCAL_FRONTDOOR_CONTINUATION_PROFILE}" ;;
        *) printf '%s' "${AI_LOCAL_FRONTDOOR_DEFAULT_PROFILE}" ;;
    esac
}

# Check services
check_services() {
    local all_ok=true

    if ! curl -sf --max-time 2 "${LLAMA_URL}/health" > /dev/null 2>&1; then
        echo "WARNING: llama-cpp not reachable at ${LLAMA_URL}" >&2
        all_ok=false
    fi

    if ! curl -sf --max-time 2 "${HYBRID_URL}/health" > /dev/null 2>&1; then
        echo "WARNING: hybrid-coordinator not reachable at ${HYBRID_URL}" >&2
        all_ok=false
    fi

    if ! curl -sf --max-time 2 "${AIDB_URL}/health" > /dev/null 2>&1; then
        echo "WARNING: AIDB not reachable at ${AIDB_URL}" >&2
        all_ok=false
    fi

    if [[ "$all_ok" == false ]]; then
        echo "" >&2
        echo "Some services are unavailable. Run: systemctl status llama-cpp hybrid-coordinator aidb" >&2
        return 1
    fi

    return 0
}

run_legacy_single_prompt() {
    python3 -c "
import asyncio
import sys
sys.path.insert(0, '${REPO_ROOT}/ai-stack')
from local_orchestrator import get_orchestrator

async def main():
    orch = get_orchestrator()
    response = await orch.process('''$PROMPT''')
    print(response.content)
    print()
    print(f'[{response.backend_used}, {response.execution_time:.2f}s, \${response.cost_usd:.4f}]')

asyncio.run(main())
"
}

# Status mode
if [[ "$MODE" == "status" ]]; then
    echo "Local Orchestrator Status"
    echo "========================="
    echo ""

    echo "Services:"
    if curl -sf --max-time 2 "${LLAMA_URL}/health" > /dev/null 2>&1; then
        model=$(curl -sf "${LLAMA_URL}/v1/models" 2>/dev/null | jq -r '.data[0].id // "unknown"')
        echo "  llama-cpp: OK (model: $model)"
    else
        echo "  llama-cpp: UNREACHABLE"
    fi

    if curl -sf --max-time 2 "${HYBRID_URL}/health" > /dev/null 2>&1; then
        echo "  hybrid-coordinator: OK"
    else
        echo "  hybrid-coordinator: UNREACHABLE"
    fi

    if curl -sf --max-time 2 "${AIDB_URL}/health" > /dev/null 2>&1; then
        echo "  AIDB: OK"
    else
        echo "  AIDB: UNREACHABLE"
    fi

    echo ""
    echo "Front-door routing:"
    echo "  enabled: ${AI_LOCAL_FRONTDOOR_ROUTING_ENABLE}"
    echo "  default route alias: ${ROUTE_ALIAS}"
    echo "  resolved profile: $(frontdoor_profile_for_alias "${ROUTE_ALIAS}")"

    exit 0
fi

# Plan mode
if [[ "$MODE" == "plan" ]]; then
    if [[ -z "$OBJECTIVE" ]]; then
        echo "Usage: local-orchestrator --plan \"objective\"" >&2
        exit 1
    fi

    check_services || true

    python3 -c "
import asyncio
import sys
sys.path.insert(0, '${REPO_ROOT}/ai-stack')
from local_orchestrator import get_orchestrator

async def main():
    orch = get_orchestrator()
    response = await orch.plan_task('$OBJECTIVE')
    print(response.content)

asyncio.run(main())
"
    exit 0
fi

# Single prompt mode
if [[ "$MODE" == "single" ]]; then
    check_services || true
    if [[ "${AI_LOCAL_FRONTDOOR_ROUTING_ENABLE}" == "true" ]]; then
        api_key="$(load_hybrid_api_key || true)"
        curl_args=(-sS --max-time "${AI_LOCAL_FRONTDOOR_MAX_TIME:-120}" -H "Content-Type: application/json")
        if [[ -n "${api_key}" ]]; then
            curl_args+=(-H "X-API-Key: ${api_key}")
        fi

        payload="$(python3 - <<'PY' "$PROMPT" "$ROUTE_ALIAS"
import json, sys
prompt = sys.argv[1]
route = sys.argv[2]
print(json.dumps({
    "prompt": prompt,
    "route": route,
    "context": {
        "entrypoint": "local-orchestrator",
    },
    "options": {
        "generate_response": True,
        "prefer_local": True,
        "mode": "hybrid",
    },
}))
PY
)"
        if response="$(curl "${curl_args[@]}" "${HYBRID_URL}/v1/orchestrate" -d "${payload}")"; then
            python3 - <<'PY' "$response"
import json, sys
data = json.loads(sys.argv[1])
print((data.get("response") or "").strip())
print()
route = data.get("route") or "unknown"
backend = data.get("backend") or "unknown"
latency = float(data.get("latency_ms") or 0.0) / 1000.0
print(f"[{backend}, {route}, {latency:.2f}s]")
PY
            exit 0
        fi
        echo "WARNING: front-door request failed; falling back to legacy local orchestrator path" >&2
    fi

    run_legacy_single_prompt
    exit 0
fi

# Interactive mode
check_services || true

exec python3 -c "
import asyncio
import sys
sys.path.insert(0, '${REPO_ROOT}/ai-stack')
from local_orchestrator.orchestrator import main
asyncio.run(main())
"
