#!/usr/bin/env python3
"""
aq-context-bootstrap — recommend minimal context and workflow entrypoints for a task.

This bridges broad task types (system fixes, feature work, PRSI, runtime incidents)
to the smallest useful context cards plus the next workflow/tool commands.
"""

from __future__ import annotations

import argparse
import json
import subprocess
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent.parent
CARD_TOOL = REPO_ROOT / "scripts" / "ai" / "aq-context-card"
STACK_HINTS_PATH = REPO_ROOT / "config" / "capability-stack-hints.json"

SCOPES = {
    "auto": {
        "summary": "Infer the initial workflow from the task query.",
        "starter_commands": [],
    },
    "system-fix": {
        "summary": "System-level debugging and rollback-safe NixOS changes.",
        "starter_commands": [
            "scripts/ai/aqd workflows primer --target . --objective \"classify system issue\"",
            "nix build .#nixosConfigurations.nixos-ai-dev.config.system.build.toplevel --no-link",
        ],
        "preferred_cards": ["system-fix", "repo-baseline", "token-discipline"],
    },
    "feature-development": {
        "summary": "Brownfield feature implementation with minimal planning overhead.",
        "starter_commands": [
            "scripts/ai/aqd workflows primer --target . --objective \"resume implementation\"",
            "scripts/ai/aqd workflows brownfield --target . --objective \"plan next validated slice\"",
        ],
        "preferred_cards": ["feature-development", "task-execution", "repo-baseline"],
    },
    "prsi-operations": {
        "summary": "PRSI policy, orchestration, and validation changes.",
        "starter_commands": [
            "scripts/testing/check-prsi-phase7-static-gates.sh",
            "scripts/testing/check-prsi-bootstrap-integrity.sh",
            "scripts/testing/check-prsi-budget-discipline.sh",
        ],
        "preferred_cards": ["prsi-operations", "token-discipline", "repo-baseline"],
    },
    "runtime-incident": {
        "summary": "Runtime/package/confinement diagnosis with low-token gating.",
        "starter_commands": [
            "aq-qa 0",
            "aq-qa 2",
            "aq-qa 3",
            "python3 scripts/ai/aq-runtime-plan",
        ],
        "preferred_cards": ["runtime-incident", "task-execution", "repo-baseline"],
    },
    "capability-gap": {
        "summary": "Classify and fix missing tools, workflows, and skills with declarative preference.",
        "starter_commands": [
            "aq-capability-gap --tool <name> --format json",
            "aq-capability-gap --workflow <id> --format json",
            "aq-capability-gap --skill <name> --format json"
        ],
        "preferred_cards": ["capability-gap", "repo-baseline", "token-discipline"],
    },
    "harness-first": {
        "summary": "Use hints/primer/brownfield entrypoints before broad manual exploration.",
        "starter_commands": [
            "aq-hints \"<task>\" --format=json --agent=codex",
