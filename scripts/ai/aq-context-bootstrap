        ],
        "preferred_cards": ["harness-first", "repo-baseline", "token-discipline"],
    },
    "context-offload": {
        "summary": "Keep long-running task history in the harness and retrieve compact context on demand.",
        "starter_commands": [
            "aq-context-card --card context-offload --level standard",
