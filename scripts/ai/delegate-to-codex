#!/usr/bin/env bash
# delegate-to-codex — Delegate a task to Codex CLI (headless, persistent)
#
# Usage:
#   delegate-to-codex --prompt "implement X in file Y"   # background by default
#   delegate-to-codex --check <task-id>                  # read output
#   delegate-to-codex --list                             # list all delegated tasks
#   delegate-to-codex --status <task-id>                 # check running/done/failed
#   delegate-to-codex --wait --prompt "..."              # block until done
#
# Modes (--mode flag):
#   safe      — default sandboxed execution (may prompt for shell commands)
#   edit      — bypass sandbox for trusted edit-only tasks (no destructive shell)
#
# Options:
#   --prompt TEXT         Task prompt
#   --prompt-file FILE    Read prompt from file
#   --mode MODE           Execution mode: safe|edit  [default: safe]
#   --model MODEL         Model override (e.g. o3, o4-mini)
#   --wait                Block until task completes
#   --force-quota-retry   Bypass an active quota cooldown for one call
#   --check ID            Print output of a completed task
#   --status ID           Show task status
#   --list                List all registered tasks
#   --help                Show this help
#
# Quota-aware pre-check: after a "usage limit" error, dispatches fast-fail
# until the parsed reset time (.agents/delegation/.codex-quota-cooldown).
# Bypass once: DELEGATE_CODEX_IGNORE_COOLDOWN=1 or --force-quota-retry.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_PATH="$SCRIPT_DIR/$(basename "${BASH_SOURCE[0]}")"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
DELEGATION_DIR="$REPO_ROOT/.agents/delegation"
OUTPUTS_DIR="$DELEGATION_DIR/outputs"
REGISTRY="$DELEGATION_DIR/registry.jsonl"
CODEX_BIN="${CODEX_BIN:-$HOME/.npm-global/bin/codex}"
# delegate-codex-quota-precheck: single ISO-8601 UTC timestamp = the parsed
# codex quota reset time. Absent/empty = no known cooldown. Runtime state
# only — gitignored, never a candidate artifact.
COOLDOWN_FILE="$DELEGATION_DIR/.codex-quota-cooldown"

# Phase 56.1/56.7 — delegation audit bridge
# shellcheck disable=SC1091
source "${SCRIPT_DIR}/lib/audit-write.sh" 2>/dev/null || true
source "${SCRIPT_DIR}/lib/harness-grounding.sh" 2>/dev/null || true

# ── helpers ─────────────────────────────────────────────────────────────────

die()  { echo "ERROR: $*" >&2; exit 1; }
info() { echo "[delegate-to-codex] $*"; }

# A2A outbound safeguard: scan the prompt for secrets BEFORE it leaves the harness
# for codex (an external agent runtime = a data-exfiltration path). block=True: if a
# secret is found, refuse to dispatch and audit the finding (kind only, never the raw
# value). Fails OPEN if a2a_guard is unavailable — a missing guard must not break
# delegation, but the common path is guarded. Env A2A_GUARD_BLOCK=0 -> audit-only.
guard_outbound_prompt() {
    local prompt="$1" task_id="$2" from_agent="${AQ_AGENT_ROLE:-claude}"
    local guard="$SCRIPT_DIR/lib/a2a_guard.py"
    [[ -f "$guard" ]] || return 0
    local block="True"; [[ "${A2A_GUARD_BLOCK:-1}" == "0" ]] && block="False"
    local verdict
    verdict="$(A2A_GUARD_TEXT="$prompt" python3 - "$guard" "$from_agent" "$task_id" "$block" <<'PY' 2>/dev/null
import os, sys
from importlib.machinery import SourceFileLoader
guard_path, from_agent, task_id, block = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4] == "True"
mod = SourceFileLoader("a2a_guard", guard_path).load_module()
res = mod.guard_outbound(os.environ.get("A2A_GUARD_TEXT", ""), from_agent=from_agent,
                         to_agent="codex", task_id=task_id, block=block)
print("BLOCKED" if not res["ok"] else "OK", ",".join(f["kind"] for f in res["findings"]))
PY
)"
    if [[ "$verdict" == BLOCKED* ]]; then
        die "A2A outbound blocked — prompt contains secret-like content (${verdict#BLOCKED }).
  Refusing to send secrets to codex (external runtime). Redact the prompt or set
  A2A_GUARD_BLOCK=0 to audit-only. Audit: .agent/collaboration/a2a-audit.log"
    fi
    [[ "$verdict" == OK\ ?* ]] && info "A2A guard: audited outbound (findings: ${verdict#OK })"
    return 0  # never fail the caller under `set -e` (clean prompt = non-matching [[ ]] above)
}

# A2A action policy gate: authorize the execution MODE before launching the external
# CLI (config/agent-action-policy.json). Blocks invalid/kill-switched modes and — when
# the policy is hardened — privileged modes lacking authorization. Every decision is
# audited. Fails OPEN if the evaluator is unavailable (rc != 3), so a config problem
# never silently breaks delegation; only an explicit BLOCK (rc 3) stops dispatch.
policy_gate_action() {
    local agent="$1" mode="$2" task_id="$3"
    local pol="$SCRIPT_DIR/lib/agent_action_policy.py"
    [[ -f "$pol" ]] || return 0
    local authorized="0"
    case "${A2A_ALLOW_PRIVILEGED:-0}" in 1|true|yes|on) authorized="1" ;; esac
    local verdict rc
    verdict="$(AQ_TASK_ID="$task_id" python3 "$pol" "$agent" "$mode" "$authorized" 2>/dev/null)"; rc=$?
    if [[ $rc -eq 3 ]]; then
        die "A2A action policy BLOCKED this delegation: ${verdict#BLOCK }
  Hardened privileged mode? Authorize with: export A2A_ALLOW_PRIVILEGED=1
  Policy: config/agent-action-policy.json | Audit: .agent/collaboration/a2a-audit.log"
    fi
}

# A2A dispatch budget: rate/budget limit on external dispatches
# (config/agent-dispatch-budget.json) — counts recent dispatches per agent + globally from
# the shared registry and refuses when a rolling-window cap is exceeded, bounding runaway
# loops. Blocks only on an explicit BLOCK (rc 3); fails open otherwise.
# A2A_BUDGET_BYPASS=1 skips one call.
budget_gate_dispatch() {
    local agent="$1"
    local bud="$SCRIPT_DIR/lib/agent_dispatch_budget.py"
    [[ -f "$bud" ]] || return 0
    local verdict rc
    verdict="$(python3 "$bud" "$agent" 2>/dev/null)"; rc=$?
    if [[ $rc -eq 3 ]]; then
        die "A2A dispatch budget BLOCKED this delegation: ${verdict#BLOCK }
  Too many recent dispatches. Wait for the window to clear, or bypass one call with:
  export A2A_BUDGET_BYPASS=1  |  Policy: config/agent-dispatch-budget.json"
    fi
    [[ "$verdict" == WARN* ]] && info "A2A dispatch budget WARNING: ${verdict#WARN }"
    return 0  # never fail the caller under `set -e`
}

require_codex() {
    [[ -x "$CODEX_BIN" ]] || die "Codex CLI not found at $CODEX_BIN
  Install: npm install -g @openai/codex
  Or set:  export CODEX_BIN=/path/to/codex"
}

ensure_dirs() {
    mkdir -p "$OUTPUTS_DIR"
    touch "$REGISTRY"
}

task_id() {
    echo "codex-$(date +%Y%m%d-%H%M%S)-$(tr -dc 'a-z0-9' </dev/urandom 2>/dev/null | head -c6 || echo 'xxxxxx')"
}

registry_append() {
    local id="$1" description="$2" output_file="$3"
    local ts; ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    printf '{"id":"%s","agent":"codex","description":%s,"output_file":"%s","pid":null,"status":"running","created":"%s"}\n' \
        "$id" \
        "$(printf '%s' "$description" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))')" \
        "$output_file" \
        "$ts" >> "$REGISTRY"
}

update_registry() {
    # update_registry <registry> <id> <field> <value>
    python3 - "$1" "$2" "$3" "$4" <<'PYEOF'
import sys, json
rf, tid, field, val = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]
lines = []
with open(rf) as f:
    for line in f:
        line = line.strip()
        if not line: continue
        try:
            e = json.loads(line)
            if e.get("id") == tid:
                try: e[field] = int(val)
                except (ValueError, TypeError): e[field] = val
            lines.append(json.dumps(e))
        except Exception: lines.append(line)
with open(rf, "w") as f:
    f.write("\n".join(lines) + "\n")
PYEOF
}

check_pid_alive() {
    local pid="$1"
    [[ -n "$pid" ]] && [[ "$pid" != "null" ]] && kill -0 "$pid" 2>/dev/null
}

# ── quota-aware pre-check (delegate-codex-quota-precheck slice) ─────────────
# See .agents/plans/delegate-codex-quota-precheck/SLICE-DESIGN-AND-AUTHORIZATION.md

# Prints the cooldown_until timestamp and returns 0 if a cooldown is currently
# active. Clears a stale/expired/corrupt cooldown file and returns 1 otherwise.
# Never fails the caller under set -e.
quota_cooldown_active() {
    [[ -f "$COOLDOWN_FILE" ]] || return 1
    local cooldown_until; cooldown_until="$(tr -d '[:space:]' < "$COOLDOWN_FILE" 2>/dev/null || true)"
    if [[ -z "$cooldown_until" ]]; then
        rm -f "$COOLDOWN_FILE" 2>/dev/null || true
        return 1
    fi
    local cooldown_epoch; cooldown_epoch="$(date -u -d "$cooldown_until" +%s 2>/dev/null || true)"
    if [[ -z "$cooldown_epoch" ]]; then
        # Corrupt/unparseable stored value — treat as stale, clear it.
        rm -f "$COOLDOWN_FILE" 2>/dev/null || true
        return 1
    fi
    local now_epoch; now_epoch="$(date -u +%s)"
    if [[ "$now_epoch" -lt "$cooldown_epoch" ]]; then
        echo "$cooldown_until"
        return 0
    fi
    rm -f "$COOLDOWN_FILE" 2>/dev/null || true
    return 1
}

# quota_capture_from_output <output_file>
# Scans a completed codex run's output for the quota-exhausted error. On a
# match, parses the "try again at <date>" reset time to ISO-8601 UTC and
# atomically writes it to $COOLDOWN_FILE. Fail-safe: an unparseable reset line
# writes a bounded default (now + 1h) — never unbounded, never absent, never
# crashes the dispatch path. A healthy run (no match) writes nothing. Never
# fails the caller under set -e.
quota_capture_from_output() {
    local output_file="$1"
    [[ -f "$output_file" ]] || return 0
    local reset_ts
    reset_ts="$(python3 - "$output_file" <<'PYEOF' 2>/dev/null || true
import re, sys
from datetime import datetime, timedelta, timezone

path = sys.argv[1]
try:
    with open(path, "r", encoding="utf-8", errors="replace") as f:
        text = f.read()
except Exception:
    sys.exit(0)

if "You've hit your usage limit" not in text:
    sys.exit(0)

now = datetime.now(timezone.utc)
fallback = (now + timedelta(hours=1)).strftime("%Y-%m-%dT%H:%M:%SZ")

m = re.search(r"try again at\s+([^\n\r.]+)", text)
if not m:
    print(fallback)
    sys.exit(0)

raw = re.sub(r"(\d+)(st|nd|rd|th)\b", r"\1", m.group(1).strip())
parsed = None
for fmt in ("%Y-%m-%dT%H:%M:%SZ", "%Y-%m-%d %H:%M:%S", "%Y-%m-%d",
            "%b %d %Y", "%B %d %Y", "%b %d", "%B %d"):
    try:
        parsed = datetime.strptime(raw, fmt)
        break
    except ValueError:
        continue

if parsed is None:
    print(fallback)
    sys.exit(0)

if parsed.year == 1900:
    # Year-less format (e.g. "Jul 25") — anchor to the nearest future occurrence.
    parsed = parsed.replace(year=now.year)
    if parsed.replace(tzinfo=timezone.utc) < now:
        parsed = parsed.replace(year=now.year + 1)
if parsed.tzinfo is None:
    parsed = parsed.replace(tzinfo=timezone.utc)

print(parsed.strftime("%Y-%m-%dT%H:%M:%SZ"))
PYEOF
)"
    [[ -n "$reset_ts" ]] || return 0
    mkdir -p "$DELEGATION_DIR" 2>/dev/null || true
    local tmp; tmp="$(mktemp "${COOLDOWN_FILE}.XXXXXX" 2>/dev/null || echo "${COOLDOWN_FILE}.tmp.$$")"
    printf '%s\n' "$reset_ts" > "$tmp" 2>/dev/null && mv -f "$tmp" "$COOLDOWN_FILE" 2>/dev/null || true
    return 0
}

# ── subcommands ──────────────────────────────────────────────────────────────

cmd_list() {
    [[ -f "$REGISTRY" ]] || { info "No delegated tasks yet."; return; }
    printf "%-32s  %-8s  %-10s  %s\n" "TASK ID" "STATUS" "AGENT" "DESCRIPTION"
    printf "%-32s  %-8s  %-10s  %s\n" "--------------------------------" "--------" "----------" "-----------"
    python3 - "$REGISTRY" <<'PYEOF'
import sys, json
with open(sys.argv[1]) as f:
    for line in f:
        line = line.strip()
        if not line: continue
        try:
            e = json.loads(line)
            desc = e.get("description","")[:55]
            print(f"{e['id']:<32}  {e.get('status','?'):<8}  {e.get('agent','?'):<10}  {desc}")
        except Exception: pass
PYEOF
}

cmd_status() {
    local id="$1"
    [[ -f "$REGISTRY" ]] || die "No registry found at $REGISTRY"
    python3 - "$REGISTRY" "$id" <<'PYEOF'
import sys, json
registry_file, task_id = sys.argv[1], sys.argv[2]
found = False
with open(registry_file) as f:
    for line in f:
        line = line.strip()
        if not line: continue
        try:
            e = json.loads(line)
            if e.get("id") == task_id:
                found = True
                print(json.dumps(e, indent=2))
        except Exception: pass
if not found:
    print(f"Task not found: {task_id}", file=sys.stderr)
    sys.exit(1)
PYEOF
}

cmd_check() {
    local id="$1"
    local output_file; output_file=$(python3 - "$REGISTRY" "$id" <<'PYEOF'
import sys, json
registry_file, task_id = sys.argv[1], sys.argv[2]
with open(registry_file) as f:
    for line in f:
        line = line.strip()
        if not line: continue
        try:
            e = json.loads(line)
            if e.get("id") == task_id:
                print(e.get("output_file",""))
        except Exception: pass
PYEOF
)
    [[ -n "$output_file" ]] || die "Task not found in registry: $id"
    [[ "$output_file" = /* ]] || output_file="$REPO_ROOT/$output_file"
    [[ -f "$output_file" ]] || die "Output file not found: $output_file (task may still be running)"
    cat "$output_file"
}

cmd_delegate() {
    local prompt="$1" mode="${2:-safe}" model_flag="${3:-}" wait_mode="${4:-false}" force_quota_retry="${5:-false}"

    require_codex
    ensure_dirs

    local id; id="$(task_id)"
    # A2A safeguards: authorize the mode, scan the outbound prompt, check the dispatch budget.
    policy_gate_action codex "$mode" "$id"
    guard_outbound_prompt "$prompt" "$id"
    budget_gate_dispatch codex

    # Quota-aware pre-check: fast-fail before spawning codex if a prior run
    # recorded a quota-exhausted cooldown. Bypass once with
    # DELEGATE_CODEX_IGNORE_COOLDOWN=1 or --force-quota-retry (a forced
    # attempt that still hits the limit re-arms the cooldown below).
    if [[ "${DELEGATE_CODEX_IGNORE_COOLDOWN:-0}" != "1" && "$force_quota_retry" != "true" ]]; then
        local _cooldown_until
        if _cooldown_until="$(quota_cooldown_active)"; then
            die "Codex quota cooldown active until ${_cooldown_until} (recorded from a prior 'usage limit' error).
  Bypass once with: export DELEGATE_CODEX_IGNORE_COOLDOWN=1  (or --force-quota-retry)"
        fi
    fi

    local output_file="$OUTPUTS_DIR/${id}.log"
    local rel_output=".agents/delegation/outputs/${id}.log"

    info "Delegating task: $id"
    info "Mode:            $mode"
    info "Output file:     $output_file"

    # Prepend the canonical harness grounding SSOT (config/local-agent-grounding.md)
    # so codex receives the SAME facts as local/antigravity, then the codex-specific
    # behavioral delegation contract below.
    local grounding; grounding="$(harness_grounding codex 2>/dev/null || true)"

    # Phase 82: prepend harness constraints to prompt (mirrors delegate-to-gemini).
    # CRITICAL: These rules are non-negotiable and override any conflicting instruction.
    # Keep in sync with delegate-to-gemini constraints block.
    local full_prompt="${grounding:+$grounding

}=== HARNESS CONSTRAINTS (NON-NEGOTIABLE) ===
1. SCOPE LOCK: Work ONLY on what the task requests. No unsolicited refactors, cleanups, or
   adjacent features. One slice, one concern. If in doubt about scope, STOP and report.
2. PRD GATE: Write a brief plan (problem/goal/files/validation) to .agent/collaboration/PULSE.log
   BEFORE editing any file. Format: [ISO-timestamp] [codex] [plan]: <scope> — <approach>
3. PORT POLICY: NEVER hardcode ports or URLs. Source of truth: nix/modules/core/options.nix.
   Python reads from env vars; shell uses \${PORT:-default}. Known ports: llama=8080,
   embed=8081, aidb=8002, coordinator=8003, switchboard=8085, dashboard=8889.
4. HARDWARE: GPU layers ceiling = 12 (Renoir APU). enable_thinking: false in ALL llama.cpp
   requests. Never suggest n_gpu_layers > 12.
5. LOGGING: switchboard.py uses print(..., file=sys.stderr) — there is NO logger object.
6. COMMIT DISCIPLINE: After work is done, list all modified files and validate with:
   python3 -m py_compile <py-files> && bash -n <sh-files>
   DO NOT commit — the orchestrator (Claude) reviews and commits.
7. SECURITY: No hardcoded secrets, tokens, or credentials. No injection patterns.
   Run py_compile on every Python file you touch before declaring work complete.
8. ATOMIC PULSE: Append one line to .agent/collaboration/PULSE.log after every file write:
   [ISO-timestamp] [codex] [write]: <file> — <what changed>
9. ATOMIC RESUME: At every phase start and on task completion, update
   .agent/collaboration/RESUME.json with: current_objective, phase, todo_snapshot[],
   uncommitted_changes[], resume_hint. This is the compaction anchor for all agents.
=== END CONSTRAINTS ===

${prompt}"

    # Build command — codex exec is the correct headless subcommand
    local cmd=("$CODEX_BIN" "exec")
    [[ -n "$model_flag" ]] && cmd+=("-m" "$model_flag")
    if [[ "$mode" == "edit" ]]; then
        cmd+=("--dangerously-bypass-approvals-and-sandbox")
    fi
    # Last argument: full prompt with harness constraints prepended
    cmd+=("$full_prompt")

    registry_append "$id" "$prompt" "$rel_output"
    audit_event_start "codex" "$id" "${prompt:0:200}"

    if [[ "$wait_mode" == "true" ]]; then
        info "Running in blocking mode..."
        # < /dev/null: codex exec reads stdin by default; close it so it doesn't block
        # exit_code defaults to 0; on a non-zero pipeline exit (set -e + pipefail would
        # otherwise abort here) the `||` branch captures PIPESTATUS[0] — the true codex
        # exit code — into exit_code. A bare `|| true` would run `true` as its own
        # one-element pipeline and reset PIPESTATUS[0] to 0, masking every failure; a
        # plain variable assignment does not invoke a pipeline, so PIPESTATUS[0] still
        # reflects the codex|tee pipeline when it is read here. This keeps both the
        # failure path (status update + quota capture) reachable AND the real exit
        # code intact, so the success/failure branches below are accurate.
        local exit_code=0
        "${cmd[@]}" < /dev/null 2>&1 | tee "$output_file" || exit_code="${PIPESTATUS[0]}"
        quota_capture_from_output "$output_file" || true
        if [[ "$exit_code" -eq 0 ]]; then
            update_registry "$REGISTRY" "$id" "status" "done"
            audit_event_end "codex" "$id" "success" "0" "completed: ${prompt:0:100}" "$mode"
            audit_save_session "codex" "$id" "$prompt" "$output_file"
        else
            update_registry "$REGISTRY" "$id" "status" "failed"
            audit_event_end "codex" "$id" "error" "0" "failed exit=${exit_code}: ${prompt:0:100}" "$mode"
            audit_save_session "codex" "$id" "$prompt" "$output_file"
        fi
        info "Task $id $([ "$exit_code" -eq 0 ] && echo 'completed' || echo 'failed')."
    else
        local _coord_url="${HYBRID_COORDINATOR_URL:-http://127.0.0.1:8003}"
        local _prompt_brief; _prompt_brief="${prompt:0:100}"
        local _audit_helper; _audit_helper="$SCRIPT_DIR/lib/audit-post.sh"
        # Background — write output to persistent file, not /tmp
        nohup bash -c "
            _start_ms=\$(date +%s%3N 2>/dev/null || echo 0)
            $(printf '%q ' "${cmd[@]}") > \"$output_file\" 2>&1
            exit_code=\$?
            _end_ms=\$(date +%s%3N 2>/dev/null || echo 0)
            _lat=\$(( _end_ms - _start_ms ))
            \"$SCRIPT_PATH\" --internal-quota-capture \"$output_file\" >/dev/null 2>&1 || true
            if [[ \$exit_code -eq 0 ]]; then
                bash \"$_audit_helper\" \"$_coord_url\" task_completed codex success \"\$_lat\" \"$id\" \"completed: $_prompt_brief\" \"$mode\" \"$prompt\" \"$output_file\" || true
            else
                bash \"$_audit_helper\" \"$_coord_url\" error_resolution codex error \"\$_lat\" \"$id\" \"failed exit=\$exit_code: $_prompt_brief\" \"$mode\" \"$prompt\" \"$output_file\" || true
            fi
            python3 - \"$REGISTRY\" \"$id\" status \"\$([ \$exit_code -eq 0 ] && echo done || echo failed)\" <<'PYEOF'
import sys, json
rf, tid, field, val = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]
lines = []
with open(rf) as f:
    for line in f:
        line = line.strip()
        if not line: continue
        try:
            e = json.loads(line)
            if e.get('id') == tid: e[field] = val
            lines.append(json.dumps(e))
        except Exception: lines.append(line)
with open(rf, 'w') as f: f.write('\n'.join(lines) + '\n')
PYEOF
        " > /dev/null 2>&1 &
        local pid=$!
        disown "$pid"
        update_registry "$REGISTRY" "$id" "pid" "$pid"

        info "Task $id started in background (pid $pid)"
        info "Check output:  delegate-to-codex --check $id"
        info "Check status:  delegate-to-codex --status $id"
        echo "$id"
    fi
}

# ── argument parsing ─────────────────────────────────────────────────────────

PROMPT=""
PROMPT_FILE=""
MODE="safe"
MODEL=""
WAIT=false
FORCE_QUOTA_RETRY=false
SUBCMD=""
SUBCMD_ARG=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --prompt)      PROMPT="$2";       shift 2 ;;
        --prompt-file) PROMPT_FILE="$2";  shift 2 ;;
        --mode)        MODE="$2";         shift 2 ;;
        --model)       MODEL="$2";        shift 2 ;;
        --wait)        WAIT=true;         shift   ;;
        --force-quota-retry) FORCE_QUOTA_RETRY=true; shift ;;
        --check)       SUBCMD="check";   SUBCMD_ARG="$2"; shift 2 ;;
        --status)      SUBCMD="status";  SUBCMD_ARG="$2"; shift 2 ;;
        --list)        SUBCMD="list";    shift   ;;
        --internal-quota-capture) SUBCMD="quota-capture"; SUBCMD_ARG="$2"; shift 2 ;;
        --help|-h)     grep "^#" "$0" | sed 's/^# \?//'; exit 0 ;;
        *) die "Unknown option: $1 (run with --help for usage)" ;;
    esac
done

case "$MODE" in
    safe|edit) ;;
    *) die "Invalid --mode '$MODE'. Valid: safe | edit" ;;
esac

case "${SUBCMD:-}" in
    list)   ensure_dirs; cmd_list ;;
    status) ensure_dirs; cmd_status "$SUBCMD_ARG" ;;
    check)  ensure_dirs; cmd_check "$SUBCMD_ARG" ;;
    # Internal re-entry point: the background (nohup) run mode is a separate
    # bash process that cannot see this script's functions, so it re-invokes
    # the script itself to run quota_capture_from_output after the run
    # completes. Not part of the public CLI surface.
    quota-capture) ensure_dirs; quota_capture_from_output "$SUBCMD_ARG" ;;
    "")
        if [[ -n "$PROMPT_FILE" ]]; then
            [[ -f "$PROMPT_FILE" ]] || die "Prompt file not found: $PROMPT_FILE"
            PROMPT="$(cat "$PROMPT_FILE")"
        fi
        [[ -n "$PROMPT" ]] || die "Provide --prompt TEXT or --prompt-file FILE (or --help)"
        cmd_delegate "$PROMPT" "$MODE" "$MODEL" "$WAIT" "$FORCE_QUOTA_RETRY"
        ;;
esac
