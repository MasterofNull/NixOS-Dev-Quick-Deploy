#!/usr/bin/env bash
# aq-commit-facts — Extract semantic facts from recent commits via local model (Phase 56.4)
#
# Usage:
#   aq-commit-facts [--since COMMIT_SHA] [--dry-run]
#
# Process:
#   1. Extract diff + commit message
#   2. Local Qwen distills into 2-4 structured facts (JSON)
#   3. POSTs facts to /api/memory/facts for semantic storage

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
# shellcheck disable=SC1091
source "${REPO_ROOT}/config/service-endpoints.sh"
HYBRID_COORDINATOR_URL="${HYBRID_COORDINATOR_URL:-${HYBRID_URL:-http://127.0.0.1:8003}}"

SINCE="HEAD~1"
DRY_RUN=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --since)   SINCE="$2";   shift 2 ;;
    --dry-run) DRY_RUN=1;    shift   ;;
    *)
      printf 'usage: aq-commit-facts [--since SHA] [--dry-run]\n' >&2
      exit 2
      ;;
  esac
done

printf "🔍 Analyzing recent commits since %s...\n" "${SINCE}"

# 1. Get Diff Summary
DIFF_CONTENT=$(git diff "${SINCE}"..HEAD --stat --patch | head -c 2000)
COMMIT_MSGS=$(git log "${SINCE}"..HEAD --oneline | head -n 5)

if [[ -z "${DIFF_CONTENT}" ]]; then
    printf "No changes detected.\n"
    exit 0
fi

# 2. Extract Facts via Local Agent
# Use direct mode for bounded distillation
PROMPT="As a Senior NixOS Architect, extract 2-4 institutional memory facts from this git diff and commit history.
Focus on architectural decisions, constraints, or bug patterns. Ignore implementation noise.

Output MUST be a JSON array of objects:
[{\"fact\": \"string\", \"scope\": \"coordinator|nix|scripts|dashboard\", \"confidence\": 0.9}]

COMMIT HISTORY:
${COMMIT_MSGS}

DIFF SUMMARY:
${DIFF_CONTENT}"

printf "  [*] Distilling architectural facts via local Qwen...\n"
FACTS_RAW=$("${SCRIPT_DIR}/delegate-to-local" --mode direct --prompt "${PROMPT}" --wait 2>/dev/null || true)
FACTS_JSON=$(printf '%s\n' "${FACTS_RAW}" | python3 -c '
import json, sys
text = sys.stdin.read()
decoder = json.JSONDecoder()
for idx, char in enumerate(text):
    if char != "[":
        continue
    try:
        value, _ = decoder.raw_decode(text[idx:])
    except json.JSONDecodeError:
        continue
    if isinstance(value, list):
        print(json.dumps(value))
        raise SystemExit(0)
print("[]")
')

if [[ "${FACTS_JSON}" == "[]" ]]; then
    printf "No significant facts extracted.\n"
    exit 0
fi

printf "  [*] Extracted facts:\n%s\n" "$(echo "${FACTS_JSON}" | python3 -m json.tool)"

if [[ "${DRY_RUN}" -eq 1 ]]; then
    printf "Dry run: skipping storage.\n"
    exit 0
fi

# 3. Store Facts in Semantic Memory
printf "  [*] Storing facts in semantic memory...\n"
curl -sf -X POST "${HYBRID_COORDINATOR_URL}/api/memory/facts" \
    -H 'Content-Type: application/json' \
    -d "{\"facts\": ${FACTS_JSON}, \"source_commit\": \"$(git rev-parse HEAD)\"}" \
    >/dev/null || printf "⚠️ Failed to store facts (coordinator unreachable)\n"

# 4. Post Event (Phase 56.6)
# shellcheck disable=SC1091
source "${SCRIPT_DIR}/lib/audit-write.sh"
audit_event_end "coordinator" "fact-extraction" "success" "0" "Stored $(echo "${FACTS_JSON}" | python3 -c "import json,sys; print(len(json.load(sys.stdin)))") architectural facts" "decision"

printf "✅ Done.\n"
