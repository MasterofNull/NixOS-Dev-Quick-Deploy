#!/usr/bin/env bash
# CLI wrapper for multi-agent collaboration tooling
# Part of NixOS-Dev-Quick-Deploy AI stack - Phase 4

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
COLLAB_DIR="$REPO_ROOT/lib/l4-coord/agents"

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

usage() {
    cat <<EOF
Usage: aq-collaborate <command> [options]

Commands:
  start <objective>               Start new collaboration
  plan <collab-id> <objective>    Create collaborative plan
  contribute <plan-id> ...        Add contribution to plan
  synthesize <plan-id>            Synthesize plan from contributions
  review <item-id> ...            Submit review for consensus
  decide <item-id>                Calculate consensus decision
  list [--status STATUS]          List collaborations
  stats <collab-id>               Get collaboration statistics
  messages <collab-id>            View collaboration messages

Options:
  --agent ID          Agent identifier
  --capability SCORE  Agent capability score (0-1)
  --verdict VERDICT   Review verdict (approve, reject, etc.)
  --score SCORE       Overall score (0-1)
  --confidence SCORE  Confidence level (0-1)
  --help              Show this help message

Examples:
  # Start collaboration
  aq-collaborate start "Implement user authentication system"

  # Create plan
  aq-collaborate plan collab_123 "Design auth flow"

  # Add contribution
  aq-collaborate contribute plan_456 \\
    --agent security_expert \\
    --phase design \\
    --description "OAuth 2.0 flow" \\
    --approach "JWT tokens with refresh"

  # Submit review
  aq-collaborate review item_789 \\
    --agent reviewer_1 \\
    --verdict approve \\
    --score 0.85 \\
    --feedback "Looks good"

  # Get statistics
  aq-collaborate stats collab_123

Environment Variables:
  POSTGRES_HOST          PostgreSQL host (default: 127.0.0.1)
  POSTGRES_PORT          PostgreSQL port (default: 5432)
  POSTGRES_USER          PostgreSQL user (default: aidb)
  POSTGRES_DB            PostgreSQL database (default: aidb)
  POSTGRES_PASSWORD      PostgreSQL password
  POSTGRES_PASSWORD_FILE PostgreSQL password file
  LLAMA_CHAT_URL         Local LLM URL (default: http://127.0.0.1:8080)
EOF
}

ensure_python_deps() {
    if ! command -v python3 &> /dev/null; then
        echo -e "${RED}Error: python3 not found${NC}"
        exit 1
    fi
}

get_postgres_password() {
    if [ -n "${POSTGRES_PASSWORD:-}" ]; then
        echo "$POSTGRES_PASSWORD"
    elif [ -n "${POSTGRES_PASSWORD_FILE:-}" ] && [ -f "$POSTGRES_PASSWORD_FILE" ]; then
        cat "$POSTGRES_PASSWORD_FILE"
    elif [ -f "/run/secrets/postgres_password" ]; then
        cat "/run/secrets/postgres_password"
    else
        echo ""
    fi
}

postgres_user() {
    printf '%s' "${POSTGRES_USER:-aidb}"
}

postgres_db() {
    printf '%s' "${POSTGRES_DB:-aidb}"
}

export_postgres_password() {
    export POSTGRES_PASSWORD="$(get_postgres_password)"
    export PGPASSWORD="$POSTGRES_PASSWORD"
}

psql_collab() {
    psql -h "${POSTGRES_HOST:-127.0.0.1}" \
         -p "${POSTGRES_PORT:-5432}" \
         -U "$(postgres_user)" \
         -d "$(postgres_db)" \
         "$@"
}

relation_exists() {
    local relation="$1"
    local exists
    exists="$(psql_collab -Atc "SELECT to_regclass('${relation}')" 2>/dev/null || true)"
    [[ "$exists" == "$relation" ]]
}

function_exists() {
    local signature="$1"
    local exists
    exists="$(psql_collab -Atc "SELECT to_regprocedure('${signature}')" 2>/dev/null || true)"
    [[ -n "$exists" ]]
}

safe_collab_id() {
    local value="$1"
    [[ "$value" =~ ^[A-Za-z0-9_.:-]+$ ]]
}

cmd_start() {
    if [ $# -lt 1 ]; then
        echo -e "${RED}Error: objective required${NC}"
        usage
        exit 1
    fi

    local objective="$1"

    echo -e "${BLUE}Starting collaboration: $objective${NC}"

    export_postgres_password

    cd "$COLLAB_DIR"
    python3 -c "
import asyncio
from agent_communication_protocol import AgentCommunicationProtocol

async def main():
    protocol = AgentCommunicationProtocol()
    collaboration_id = f'collab_{len(protocol.shared_contexts) + 1}'
    context = protocol.create_shared_context(collaboration_id)
    await protocol.update_shared_context(
        collaboration_id,
        'codex',
        {'objective': '$objective', 'status': 'started'},
        broadcast=False,
    )

    print(f'✓ Collaboration started: {collaboration_id}')
    print(f'  Objective: $objective')

asyncio.run(main())
"
}

cmd_plan() {
    if [ $# -lt 2 ]; then
        echo -e "${RED}Error: collaboration-id and objective required${NC}"
        usage
        exit 1
    fi

    local collab_id="$1"
    local objective="$2"

    echo -e "${BLUE}Creating plan for collaboration: $collab_id${NC}"

    cd "$COLLAB_DIR"
    python3 -c "
from collaborative_planning import CollaborativePlanning

planner = CollaborativePlanning()
plan_id = planner.create_plan(task_id='$collab_id', team_id='collab')
planner._save_state()
print(f'✓ Plan created: {plan_id}')
print(f'  Objective: $objective')
"
}

cmd_contribute() {
    if [ $# -lt 1 ]; then
        echo -e "${RED}Error: plan-id required${NC}"
        usage
        exit 1
    fi

    local plan_id="$1"
    shift

    local agent_id=""
    local content=""
    local confidence="0.7"
    while [[ $# -gt 0 ]]; do
        case $1 in
            --agent)      agent_id="$2"; shift 2 ;;
            --content)    content="$2"; shift 2 ;;
            --confidence) confidence="$2"; shift 2 ;;
            *) echo "Unknown option: $1"; usage; exit 1 ;;
        esac
    done

    if [ -z "$agent_id" ]; then
        echo -e "${RED}Error: --agent required${NC}"
        exit 1
    fi

    echo -e "${BLUE}Adding contribution to plan: $plan_id${NC}"

    # User inputs via ENV, not interpolation (injection fix — see cmd_review).
    cd "$COLLAB_DIR"
    AQC_PLAN="$plan_id" AQC_AGENT="$agent_id" AQC_CONTENT="$content" AQC_CONF="$confidence" python3 -c "
import os
from collaborative_planning import CollaborativePlanning

plan_id = os.environ['AQC_PLAN']; agent = os.environ['AQC_AGENT']
planner = CollaborativePlanning()
try:
    cid = planner.add_contribution(
        plan_id=plan_id,
        agent_id=agent,
        content=os.environ.get('AQC_CONTENT', ''),
        confidence=float(os.environ['AQC_CONF']),
    )
    plan = planner.get_plan(plan_id)
    print(f'✓ Contribution added: {cid}')
    print(f'  Agent: {agent} | plan contributions: {len(plan.contributions) if plan else \"?\"}')
except ValueError as e:
    print(f'Error: {e} (create the plan first: aq-collaborate plan <collab-id> <objective>)')
"
}

cmd_synthesize() {
    if [ $# -lt 1 ]; then
        echo -e "${RED}Error: plan-id required${NC}"
        usage
        exit 1
    fi

    local plan_id="$1"

    echo -e "${BLUE}Synthesizing plan: $plan_id${NC}"

    cd "$COLLAB_DIR"
    python3 -c "
import asyncio
import json
from collaborative_planning import CollaborativePlanning

async def main():
    planner = CollaborativePlanning()

    # Get plan (active_plans is in-memory per-process; cross-invocation synth
    # requires the plan to have been created in this same process/session)
    plan = planner.active_plans.get('$plan_id')
    if not plan:
        print(f'Error: Plan not found: $plan_id')
        print('  (plans are held in-memory per invocation — see follow-up: aq-collaborate-plan-persistence)')
        return

    # Mock agent capabilities (Dict[str, List[str]] as expected by _assign_phases_to_agents)
    agent_capabilities = {
        'agent_1': ['implementation', 'testing'],
        'agent_2': ['analysis', 'review'],
        'agent_3': ['architecture', 'planning'],
    }

    # Synthesize
    synthesized = await planner.synthesize_plan('$plan_id', agent_capabilities)

    print(f'✓ Plan synthesized: {len(synthesized.phases)} phases')
    for i, phase in enumerate(synthesized.phases, 1):
        print(f'  {i}. {phase.name} ({phase.phase_type.value})')
        print(f'     Assigned to: {phase.assigned_agent}')

asyncio.run(main())
"
}

cmd_review() {
    if [ $# -lt 1 ]; then
        echo -e "${RED}Error: item-id required${NC}"
        usage
        exit 1
    fi

    local item_id="$1"
    shift

    # Parse options
    local agent_id=""
    local verdict=""
    local score=""
    local confidence="0.8"
    local feedback=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            --agent) agent_id="$2"; shift 2 ;;
            --verdict) verdict="$2"; shift 2 ;;
            --score) score="$2"; shift 2 ;;
            --confidence) confidence="$2"; shift 2 ;;
            --feedback) feedback="$2"; shift 2 ;;
            *) echo "Unknown option: $1"; usage; exit 1 ;;
        esac
    done

    if [ -z "$agent_id" ] || [ -z "$verdict" ] || [ -z "$score" ]; then
        echo -e "${RED}Error: --agent, --verdict, and --score required${NC}"
        exit 1
    fi

    echo -e "${BLUE}Submitting review for item: $item_id${NC}"

    # Pass user inputs via ENV (not string interpolation into python -c) — a quote in
    # --feedback previously broke the literal and is a code-injection vector. Decided
    # FIX by the corrected expert-team debate (injection-fix-decision, unanimous).
    cd "$COLLAB_DIR"
    AQC_ITEM="$item_id" AQC_AGENT="$agent_id" AQC_VERDICT="$verdict" \
    AQC_CONF="$confidence" AQC_FEEDBACK="$feedback" python3 -c "
import os
from quality_consensus import QualityConsensus, VoteType

item = os.environ['AQC_ITEM']; agent = os.environ['AQC_AGENT']
consensus = QualityConsensus()
session_id = consensus.get_or_create_session(artifact_id=item, team_id='collab')
try:
    review_id = consensus.submit_review(
        session_id=session_id,
        reviewer_id=agent,
        vote=VoteType(os.environ['AQC_VERDICT'].strip().lower()),
        confidence=float(os.environ['AQC_CONF']),
        reasoning=os.environ.get('AQC_FEEDBACK', ''),
    )
    sess = consensus.active_sessions[session_id]
    print(f'✓ Review submitted: {review_id}')
    print(f'  Reviewer: {agent} | Vote: {os.environ[\"AQC_VERDICT\"]} | Confidence: {os.environ[\"AQC_CONF\"]}')
    print(f'  Reviews: {len(sess.reviews)}/{sess.required_reviewers} '
          f'(need {sess.required_reviewers} before: aq-collaborate decide {item})')
except ValueError as e:
    print(f'Error: {e}')
except Exception as e:
    print(f'Error: invalid vote (use approve|reject|abstain|request_changes): {e}')
"
}

cmd_decide() {
    if [ $# -lt 1 ]; then
        echo -e "${RED}Error: item-id required${NC}"
        usage
        exit 1
    fi

    local item_id="$1"

    echo -e "${BLUE}Calculating consensus for item: $item_id${NC}"

    cd "$COLLAB_DIR"
    python3 -c "
import asyncio, json
from quality_consensus import QualityConsensus

consensus = QualityConsensus()
# Find the persisted session for this item.
session_id = next((sid for sid, s in consensus.active_sessions.items()
                   if s.artifact_id == '$item_id'), None)
if not session_id:
    print('Error: no consensus session for item $item_id — run: aq-collaborate review $item_id --agent A --verdict approve --score 0.8')
    raise SystemExit(1)

sess = consensus.active_sessions[session_id]
n, need = len(sess.reviews), sess.required_reviewers
if n < need:
    print(f'Not enough reviews: {n}/{need}. Need {need - n} more reviewer(s) before deciding.')
    raise SystemExit(0)

result = asyncio.run(consensus.evaluate_consensus(session_id))
print('✓ Consensus decision:')
print(json.dumps(result.to_dict(), indent=2, default=str))
"
}

cmd_list() {
    local status="active"
    while [[ $# -gt 0 ]]; do
        case $1 in
            --status) status="$2"; shift 2 ;;
            *) echo "Unknown option: $1"; usage; exit 1 ;;
        esac
    done

    echo -e "${BLUE}Collaborations (status=$status):${NC}"

    export_postgres_password

    if ! relation_exists "public.active_collaborations_summary"; then
        echo -e "${YELLOW}No collaboration database view found in $(postgres_user)@$(postgres_db).${NC}"
        echo "Durable collaboration state is available in:"
        echo "  .agent/collaboration/PENDING.json"
        echo "  .agent/collaboration/HANDOFF.md"
        echo "  .agent/collaboration/PULSE.log"
        echo "  .agents/delegation/registry.jsonl"
        return 0
    fi

    psql_collab -c "SELECT * FROM active_collaborations_summary ORDER BY started_at DESC LIMIT 20"
}

cmd_stats() {
    if [ $# -lt 1 ]; then
        echo -e "${RED}Error: collaboration-id required${NC}"
        usage
        exit 1
    fi

    local collab_id="$1"

    echo -e "${BLUE}Collaboration Statistics: $collab_id${NC}"

    export_postgres_password

    if ! safe_collab_id "$collab_id"; then
        echo -e "${RED}Error: unsafe collaboration id${NC}"
        exit 1
    fi
    if ! function_exists "public.get_collaboration_stats(text)"; then
        echo -e "${YELLOW}No collaboration stats function found in $(postgres_user)@$(postgres_db).${NC}"
        return 0
    fi

    psql_collab -v collab_id="$collab_id" -c "SELECT * FROM get_collaboration_stats(:'collab_id')"
}

cmd_messages() {
    if [ $# -lt 1 ]; then
        echo -e "${RED}Error: collaboration-id required${NC}"
        usage
        exit 1
    fi

    local collab_id="$1"

    echo -e "${BLUE}Collaboration Messages: $collab_id${NC}"

    export_postgres_password

    if ! safe_collab_id "$collab_id"; then
        echo -e "${RED}Error: unsafe collaboration id${NC}"
        exit 1
    fi
    if ! relation_exists "public.collaboration_messages"; then
        echo -e "${YELLOW}No collaboration messages table found in $(postgres_user)@$(postgres_db).${NC}"
        return 0
    fi

    psql_collab -v collab_id="$collab_id" -c "SELECT sender_id, recipient_id, message_type, sent_at FROM collaboration_messages WHERE collaboration_id = :'collab_id' ORDER BY sent_at DESC LIMIT 50"
}

# Main command dispatch
ensure_python_deps

if [ $# -eq 0 ]; then
    usage
    exit 1
fi

COMMAND="$1"
shift

case "$COMMAND" in
    start) cmd_start "$@" ;;
    plan) cmd_plan "$@" ;;
    contribute) cmd_contribute "$@" ;;
    synthesize) cmd_synthesize "$@" ;;
    review) cmd_review "$@" ;;
    decide) cmd_decide "$@" ;;
    list) cmd_list "$@" ;;
    stats) cmd_stats "$@" ;;
    messages) cmd_messages "$@" ;;
    --help|-h) usage ;;
    *) echo -e "${RED}Unknown command: $COMMAND${NC}"; usage; exit 1 ;;
esac
