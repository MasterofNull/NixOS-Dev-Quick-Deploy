#!/usr/bin/env python3
"""
aq-review <id> — Phase 86 alert detail viewer.

Shows full detail, payload, proposed action, and executor for one alert.
"""
from __future__ import annotations

import json
import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
sys.path.insert(0, str(_HERE / "lib"))

from attention_queue import get_by_id  # noqa: E402

_RESET = "\033[0m"
_BOLD  = "\033[1m"
_RED   = "\033[0;31m"
_YEL   = "\033[0;33m"
_GRN   = "\033[0;32m"
_CYN   = "\033[0;36m"

_SEV_COLOR = {"critical": _RED, "high": _RED, "medium": _YEL, "low": _GRN}


def _c(text: str, color: str) -> str:
    return f"{color}{text}{_RESET}" if sys.stdout.isatty() else text


def _candidate_review(args: list[str]) -> int:
    """Phase 150 Slice 4: candidate lifecycle review subcommand."""
    _HERE2 = Path(__file__).resolve().parent.parent.parent / "ai-stack" / "local-agents"
    sys.path.insert(0, str(_HERE2))
    from candidate_lifecycle import CandidateLifecycleManager  # noqa: E402

    _STATE_MAP = {
        "propose": "proposed",
        "evaluate": "evaluating",
        "approve": "reviewed",
        "adopt": "adopted",
        "reject": "rejected",
        "retire": "retired",
    }
    candidates_path = Path(__file__).resolve().parents[2] / ".agents" / "improvement" / "candidates.json"
    candidate_id = ""
    action = ""
    note = ""
    by = "system"
    i = 0
    while i < len(args):
        if args[i] == "--candidate-id" and i + 1 < len(args):
            candidate_id = args[i + 1]; i += 2
        elif args[i] == "--action" and i + 1 < len(args):
            action = args[i + 1]; i += 2
        elif args[i] == "--note" and i + 1 < len(args):
            note = args[i + 1]; i += 2
        elif args[i] == "--by" and i + 1 < len(args):
            by = args[i + 1]; i += 2
        elif args[i] == "list":
            action = "list"; i += 1
        else:
            i += 1

    mgr = CandidateLifecycleManager(candidates_path)
    cands = mgr.load()

    if action == "list":
        fmt = "{:<8}  {:<60}  {:<12}"
        print(fmt.format("PRIORITY", "ID", "STATE"))
        print("-" * 85)
        for c in sorted(cands, key=lambda x: int(x.get("priority", 9) or 9)):
            print(fmt.format(str(c.get("priority", "?")), c.get("id", "?")[:60], c.get("state", "proposed")))
        return 0

    if not candidate_id or not action:
        print("Usage: aq-review --candidate-id <ID> --action <propose|evaluate|approve|adopt|reject|retire> [--note TEXT] [--by AGENT]")
        print("       aq-review --candidate-id list")
        return 1

    new_state = _STATE_MAP.get(action, action)
    try:
        updated = mgr.transition(candidate_id, new_state, by=by, note=note)
        mgr.save(cands)
        print(f"OK: {updated['id']} → {updated['state']}")
        if updated.get("lifecycle_log"):
            last = updated["lifecycle_log"][-1]
            print(f"  logged: {last['from_state']} → {last['to_state']} by {last['by']}")
    except ValueError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1
    return 0


def main() -> int:
    # Phase 150: route --candidate-id subcommand
    if "--candidate-id" in sys.argv[1:] or (len(sys.argv) > 1 and sys.argv[1] == "list" and "--candidate-id" not in sys.argv):
        # list without an alert-id looks like candidate list if first arg is "list"
        # use --candidate-id presence as the reliable gate
        pass
    if "--candidate-id" in sys.argv[1:] or (len(sys.argv) > 1 and sys.argv[1] in ("list",) and len(sys.argv) == 2):
        return _candidate_review(sys.argv[1:])

    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print("Usage: aq-review <alert-id>")
        print("       aq-review --candidate-id <ID> --action <action>  (Phase 150 candidate review)")
        return 1

    alert_id = sys.argv[1]
    alert = get_by_id(alert_id)

    if not alert:
        print(f"Alert {alert_id!r} not found in active queue.", file=sys.stderr)
        return 1

    sev = alert.get("severity", "?")
    boundary = alert.get("autonomy_boundary", "?")
    status = alert.get("status", "?")

    print()
    print(_c(f"  Alert: {alert['id']}", _BOLD))
    print(f"  Status:   {status}")
    print(f"  Severity: {_c(sev.upper(), _SEV_COLOR.get(sev, ''))}")
    print(f"  Boundary: {_c(boundary, _CYN)}")
    print(f"  Source:   {alert.get('source', '?')}")
    print(f"  Created:  {alert.get('created_at', '?')}")
    print(f"  Expires:  {alert.get('expires_at', '?')}")
    print()
    print(_c("  TITLE", _BOLD))
    print(f"    {alert.get('title', '')}")
    print()
    print(_c("  DETAIL", _BOLD))
    for line in alert.get("detail", "").splitlines():
        print(f"    {line}")
    print()
    print(_c("  PROPOSED ACTION", _BOLD))
    for line in alert.get("proposed_action", "").splitlines():
        print(f"    {line}")

    payload = alert.get("payload")
    if payload:
        print()
        print(_c("  PAYLOAD", _BOLD))
        for line in json.dumps(payload, indent=4).splitlines():
            print(f"    {line}")

    executor = alert.get("executor")
    if executor:
        print()
        print(_c("  EXECUTOR (runs on approve)", _BOLD))
        print(f"    {executor}")

    print()
    if status == "pending":
        print(f"  Approve: aq-approve {alert_id}")
        print(f"  Reject:  aq-reject {alert_id} --reason \"...\"")
        print(f"  Defer:   aq-defer {alert_id} --hours 4")
    else:
        print(f"  Resolved at {alert.get('resolved_at', '?')} by {alert.get('resolved_by', '?')}")
    print()
    return 0


if __name__ == "__main__":
    sys.exit(main())
