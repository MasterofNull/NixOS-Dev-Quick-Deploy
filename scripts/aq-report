#!/usr/bin/env python3
"""
aq-report — AI Stack weekly performance digest (Phase 18.1.1)

Synthesises tool_audit.jsonl, scores.sqlite, Postgres query_gaps, and
Prometheus counters into a human-readable report that surfaces:
  - Tool call latency (P50 / P95) and success rates
  - Routing split (local vs remote %)
  - Semantic cache hit rate
  - Eval score trend
  - Top recurring query gaps
  - Workflow recommendations based on the above data

Usage:
  aq-report [--since=7d] [--format=md|text|json] [--aidb-import]

Environment variables (all optional — uses sensible defaults):
  TOOL_AUDIT_LOG_PATH    Path to tool-audit.jsonl
  EVAL_SCORES_DB         Path to scores.sqlite
  PROMETHEUS_URL         Prometheus base URL
  POSTGRES_HOST / PORT / DB / USER / PASSWORD
  AIDB_URL               Base URL for AIDB REST API (used by --aidb-import)
"""

import argparse
import json
import math
import os
import sqlite3
import statistics
import sys
import urllib.error
import urllib.parse
import urllib.request
from datetime import datetime, timedelta, timezone
from pathlib import Path
from typing import Any, Dict, List, Optional, Tuple

# ---------------------------------------------------------------------------
# Configuration (env-var driven — never hardcoded per project policy)
# ---------------------------------------------------------------------------

TOOL_AUDIT_PATH = Path(
    os.getenv("TOOL_AUDIT_LOG_PATH", "/var/log/nixos-ai-stack/tool-audit.jsonl")
)
AUDIT_FALLBACK_PATH = Path(
    os.getenv("TOOL_AUDIT_LOG_PATH_FALLBACK",
              "/var/log/ai-audit-sidecar/tool-audit.jsonl")
)
# Phase 19.3.4 — hint adoption log (written by aider-wrapper alongside tool-audit.jsonl)
HINT_AUDIT_PATH = Path(
    os.getenv("HINT_AUDIT_LOG_PATH", str(TOOL_AUDIT_PATH.parent / "hint-audit.jsonl"))
)
TASK_AUDIT_PATH = Path(
    os.getenv("TASK_AUDIT_LOG_PATH", str(TOOL_AUDIT_PATH.parent / "aider-task-audit.jsonl"))
)
_default_eval_scores_db = Path(
    os.getenv("EVAL_SCORES_DB", "~/.local/share/nixos-ai-stack/eval/results/scores.sqlite")
).expanduser()
if "EVAL_SCORES_DB" not in os.environ:
    # Back-compat fallback for existing repo-local score DBs.
    repo_scores_db = Path(__file__).parent.parent / "ai-stack/eval/results/scores.sqlite"
    if not _default_eval_scores_db.exists() and repo_scores_db.exists():
        _default_eval_scores_db = repo_scores_db
EVAL_SCORES_DB = _default_eval_scores_db
PROMETHEUS_URL = os.getenv(
    "PROMETHEUS_URL",
    f"http://{os.getenv('SERVICE_HOST', '127.0.0.1')}:{os.getenv('PROMETHEUS_PORT', '9090')}",
)
AIDB_URL = os.getenv("AIDB_URL", f"http://{os.getenv('SERVICE_HOST', '127.0.0.1')}:{os.getenv('AIDB_PORT', '8002')}")
WORKFLOW_SESSIONS_PATH = Path(
    os.getenv("WORKFLOW_SESSIONS_PATH", "/var/lib/ai-stack/hybrid/workflow-sessions.json")
)

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------


def _parse_since(s: str) -> timedelta:
    """Parse '7d', '30d', '1h' etc. into a timedelta."""
    s = s.strip()
    if s.endswith("d"):
        return timedelta(days=int(s[:-1]))
    if s.endswith("h"):
        return timedelta(hours=int(s[:-1]))
    if s.endswith("w"):
        return timedelta(weeks=int(s[:-1]))
    raise ValueError(f"Unknown --since format: {s!r}. Use Nd, Nh, or Nw.")


def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(
        description="AI Stack performance digest",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p.add_argument("--since", default="7d", help="Time window, e.g. 7d, 30d, 1h (default: 7d)")
    p.add_argument(
        "--format", default="text", choices=["md", "text", "json"],
        dest="fmt", help="Output format (default: text)"
    )
    p.add_argument(
        "--aidb-import", action="store_true",
        help="Ingest the generated report into AIDB after printing"
    )
    return p.parse_args()


# ---------------------------------------------------------------------------
# Data source helpers
# ---------------------------------------------------------------------------


def _tool_audit_path() -> Optional[Path]:
    def _exists(p: Path) -> bool:
        try:
            return p.exists()
        except PermissionError:
            return False
    if _exists(TOOL_AUDIT_PATH):
        return TOOL_AUDIT_PATH
    if _exists(AUDIT_FALLBACK_PATH):
        return AUDIT_FALLBACK_PATH
    return None


def _hint_audit_path() -> Optional[Path]:
    """Resolve hint-audit path with fallback to active tool-audit directory."""
    env_hint = os.getenv("HINT_AUDIT_LOG_PATH")
    if env_hint:
        p = Path(env_hint)
        try:
            if p.exists():
                return p
        except PermissionError:
            pass
    candidates = [
        HINT_AUDIT_PATH,
        TOOL_AUDIT_PATH.parent / "hint-audit.jsonl",
        AUDIT_FALLBACK_PATH.parent / "hint-audit.jsonl",
    ]
    for p in candidates:
        try:
            if p.exists():
                return p
        except PermissionError:
            continue
    return None


def _task_audit_path() -> Optional[Path]:
    env_task = os.getenv("TASK_AUDIT_LOG_PATH")
    if env_task:
        p = Path(env_task)
        try:
            if p.exists():
                return p
        except PermissionError:
            pass
    candidates = [
        TASK_AUDIT_PATH,
        TOOL_AUDIT_PATH.parent / "aider-task-audit.jsonl",
        AUDIT_FALLBACK_PATH.parent / "aider-task-audit.jsonl",
    ]
    for p in candidates:
        try:
            if p.exists():
                return p
        except PermissionError:
            continue
    return None


def read_tool_audit(since: datetime) -> List[dict]:
    """Read tool_audit.jsonl entries newer than `since`."""
    path = _tool_audit_path()
    if not path:
        return []
    entries = []
    try:
        with path.open(encoding="utf-8", errors="replace") as fh:
            for line in fh:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                except json.JSONDecodeError:
                    continue
                ts_raw = entry.get("timestamp", "")
                try:
                    ts = datetime.fromisoformat(ts_raw.rstrip("Z")).replace(tzinfo=timezone.utc)
                    if ts >= since:
                        entries.append(entry)
                except (ValueError, AttributeError):
                    continue
    except OSError:
        pass
    return entries


def read_eval_scores(since: datetime) -> List[dict]:
    """Read eval_scores rows from scores.sqlite."""
    if not EVAL_SCORES_DB.exists():
        return []
    try:
        conn = sqlite3.connect(str(EVAL_SCORES_DB))
        conn.row_factory = sqlite3.Row
        # strategy_tag column added in Phase 18.2.1; use IFNULL for older DBs
        cur = conn.execute(
            "SELECT timestamp, config, passed, total, pct_passed, threshold, "
            "IFNULL(strategy_tag, '') AS strategy_tag "
            "FROM eval_scores WHERE timestamp >= ? ORDER BY timestamp",
            (since.isoformat(),),
        )
        rows = [dict(r) for r in cur.fetchall()]
        conn.close()
        return rows
    except (sqlite3.Error, OSError):
        return []


def strategy_leaderboard(rows: List[dict]) -> List[dict]:
    """Group eval rows by strategy_tag and compute mean pct_passed per tag."""
    from collections import defaultdict
    buckets: Dict[str, List[int]] = defaultdict(list)
    for r in rows:
        tag = r.get("strategy_tag") or "untagged"
        buckets[tag].append(r["pct_passed"])
    board = [
        {"tag": tag, "mean_pct": round(sum(v) / len(v), 1), "runs": len(v)}
        for tag, v in buckets.items()
    ]
    return sorted(board, key=lambda x: -x["mean_pct"])


def read_prompt_registry() -> List[dict]:
    """Load ai-stack/prompts/registry.yaml; return list of prompt entries."""
    registry_path = Path(
        os.getenv("REGISTRY_PATH",
                  str(Path(__file__).parent.parent / "ai-stack/prompts/registry.yaml"))
    )
    if not registry_path.exists():
        return []
    try:
        import yaml  # type: ignore[import-untyped]
        with registry_path.open(encoding="utf-8") as fh:
            data = yaml.safe_load(fh)
        return data.get("prompts", []) if data else []
    except Exception:
        return []


def prom_query(metric: str) -> Optional[float]:
    """Fetch an instant Prometheus metric value (scalar or single series)."""
    url = f"{PROMETHEUS_URL}/api/v1/query?" + urllib.parse.urlencode({"query": metric})
    try:
        req = urllib.request.Request(url, headers={"Accept": "application/json"})
        with urllib.request.urlopen(req, timeout=5) as resp:
            data = json.loads(resp.read())
        results = data.get("data", {}).get("result", [])
        if not results:
            return None
        return float(results[0]["value"][1])
    except Exception:
        return None


def prom_query_range(metric: str, start: datetime, step: str = "1h") -> List[Tuple[float, float]]:
    """Fetch a Prometheus range query. Returns [(unix_ts, value), ...]."""
    end_ts = datetime.now(tz=timezone.utc).timestamp()
    start_ts = start.timestamp()
    url = f"{PROMETHEUS_URL}/api/v1/query_range?" + urllib.parse.urlencode({
        "query": metric,
        "start": start_ts,
        "end": end_ts,
        "step": step,
    })
    try:
        req = urllib.request.Request(url, headers={"Accept": "application/json"})
        with urllib.request.urlopen(req, timeout=10) as resp:
            data = json.loads(resp.read())
        results = data.get("data", {}).get("result", [])
        if not results:
            return []
        return [(float(v[0]), float(v[1])) for v in results[0].get("values", [])]
    except Exception:
        return []


def _pg_creds() -> tuple[str, int, str, str, str]:
    """Return (host, port, db, user, password) with sensible defaults."""
    host = os.getenv("POSTGRES_HOST", "127.0.0.1")
    port = int(os.getenv("POSTGRES_PORT", "5432"))
    db = os.getenv("POSTGRES_DB", "aidb")
    user = os.getenv("POSTGRES_USER", "aidb")
    password = os.getenv("POSTGRES_PASSWORD", "")
    if not password:
        secret = Path("/run/secrets/postgres_password")
        if secret.exists():
            password = secret.read_text().strip()
    return host, port, db, user, password


def read_query_gaps(since: datetime, limit: int = 10) -> List[dict]:
    """Fetch top repeated query gaps from Postgres.

    Tries psycopg first (available in service envs), then falls back to
    the psql CLI which is always present on this NixOS system.
    """
    host, port, db, user, password = _pg_creds()
    dsn = f"postgresql://{user}:{password}@{host}:{port}/{db}"
    query = (
        "SELECT query_text, score, collection, COUNT(*) AS occurrences "
        "FROM query_gaps "
        f"WHERE created_at >= '{since.isoformat()}' "
        "GROUP BY query_text, score, collection "
        "ORDER BY occurrences DESC, score ASC "
        f"LIMIT {limit};"
    )

    # ── psycopg path (fast, available inside systemd service environments) ──
    try:
        import psycopg  # type: ignore[import-untyped]
        conn = psycopg.connect(dsn, connect_timeout=5)
        cur = conn.execute(
            "SELECT query_text, score, collection, COUNT(*) AS occurrences "
            "FROM query_gaps WHERE created_at >= %s "
            "GROUP BY query_text, score, collection "
            "ORDER BY occurrences DESC, score ASC LIMIT %s",
            (since, limit),
        )
        rows = [dict(r._mapping) for r in cur.fetchall()]
        conn.close()
        return rows
    except ImportError:
        pass
    except Exception:
        return []

    # ── psql subprocess path (shell invocations where psycopg is absent) ──
    import subprocess, csv, io
    try:
        result = subprocess.run(
            ["psql", dsn, "--tuples-only", "--no-align",
             "--field-separator=\t", "--command", query],
            capture_output=True, text=True, timeout=10,
        )
        if result.returncode != 0:
            return []
        rows = []
        for line in csv.reader(io.StringIO(result.stdout), delimiter="\t"):
            if len(line) < 4:
                continue
            rows.append({
                "query_text": line[0],
                "score": float(line[1]) if line[1] else None,
                "collection": line[2],
                "occurrences": int(line[3]),
            })
        return rows
    except Exception:
        return []


def read_workflow_sessions(since: datetime) -> Dict[str, Any]:
    """Summarise workflow run intent-contract compliance from persisted sessions."""
    path = WORKFLOW_SESSIONS_PATH
    if not path.exists():
        return {"available": False, "source": str(path)}
    try:
        raw = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {"available": False, "source": str(path)}

    if not isinstance(raw, dict):
        return {"available": False, "source": str(path)}

    since_ts = int(since.timestamp())
    sessions = []
    for _sid, sess in raw.items():
        if not isinstance(sess, dict):
            continue
        created = int(sess.get("created_at", 0) or 0)
        updated = int(sess.get("updated_at", 0) or 0)
        if max(created, updated) < since_ts:
            continue
        sessions.append(sess)

    total = len(sessions)
    if total == 0:
        return {
            "available": True,
            "source": str(path),
            "total_runs": 0,
            "with_contract": 0,
            "missing_contract": 0,
            "contract_coverage_pct": None,
            "depth_distribution": {},
            "top_blueprints": [],
        }

    with_contract = 0
    missing_contract = 0
    depth_counts: Dict[str, int] = {}
    blueprint_counts: Dict[str, int] = {}
    for sess in sessions:
        contract = sess.get("intent_contract")
        has_contract = (
            isinstance(contract, dict)
            and bool(str(contract.get("user_intent", "")).strip())
            and bool(str(contract.get("definition_of_done", "")).strip())
        )
        if has_contract:
            with_contract += 1
            depth = str(contract.get("depth_expectation", "unknown")).strip().lower() or "unknown"
            depth_counts[depth] = depth_counts.get(depth, 0) + 1
        else:
            missing_contract += 1
        bp = str(sess.get("blueprint_id", "") or "").strip()
        if bp:
            blueprint_counts[bp] = blueprint_counts.get(bp, 0) + 1

    top_blueprints = sorted(blueprint_counts.items(), key=lambda x: -x[1])[:5]
    return {
        "available": True,
        "source": str(path),
        "total_runs": total,
        "with_contract": with_contract,
        "missing_contract": missing_contract,
        "contract_coverage_pct": round((with_contract / total) * 100.0, 1) if total else None,
        "depth_distribution": depth_counts,
        "top_blueprints": top_blueprints,
    }


def _is_synthetic_gap(query_text: str) -> bool:
    text = (query_text or "").strip().lower()
    if not text:
        return True
    # Ignore local probe/test prompts and command-like diagnostics that should
    # not become knowledge-import recommendations.
    if text in {"test", "nix", "ping", "health"}:
        return True
    synthetic_prefixes = (
        "analysis only task ",
        "analysis only:",
        "analysis task ",
        "analyze docs/",
        "please analyze and summarize docs/",
        "analyze and summarize docs/",
        "summarize docs/",
        "fetch http://127.0.0.1",
        "fetch https://127.0.0.1",
        "fetch http://localhost",
        "curl http://127.0.0.1",
        "curl http://localhost",
        "get http://127.0.0.1",
        "get http://localhost",
    )
    return text.startswith(synthetic_prefixes)


def _count_aidb_docs_for_topic(topic: str) -> int:
    """Return count of imported_documents whose title matches the topic keyword."""
    host, port, db, user, password = _pg_creds()
    keyword = topic[:40].replace("'", "''")
    query = f"SELECT COUNT(*) FROM imported_documents WHERE title ILIKE '%{keyword}%';"
    dsn = f"postgresql://{user}:{password}@{host}:{port}/{db}"
    try:
        import psycopg  # type: ignore[import-untyped]
        conn = psycopg.connect(dsn, connect_timeout=3)
        cur = conn.execute(
            "SELECT COUNT(*) FROM imported_documents WHERE title ILIKE %s",
            (f"%{topic[:40]}%",),
        )
        count = cur.fetchone()[0]
        conn.close()
        return int(count)
    except ImportError:
        pass
    except Exception:
        return 0
    import subprocess
    try:
        result = subprocess.run(
            ["psql", dsn, "--tuples-only", "--no-align", "--command", query],
            capture_output=True, text=True, timeout=5,
        )
        line = result.stdout.strip()
        return int(line) if line.isdigit() else 0
    except Exception:
        return 0


def hint_adoption(since: datetime) -> Dict[str, Any]:
    """Phase 19.3.4 — read hint-audit.jsonl and compute adoption stats.

    'Adoption' = the aider task that received an injected hint completed
    successfully (returncode 0 + at least one file modified).
    """
    hint_path = _hint_audit_path()
    if not hint_path:
        # File not yet written — normal on a fresh deploy; treat as zero activity
        return {"available": True, "total": 0, "accepted": 0, "adoption_pct": None, "top_hints": []}
    total = 0
    accepted = 0
    tooling_plan_total = 0
    tooling_plan_success = 0
    analysis_profile_total = 0
    analysis_profile_success = 0
    top_hints: Dict[str, int] = {}
    try:
        with hint_path.open(encoding="utf-8", errors="replace") as fh:
            for line in fh:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                except json.JSONDecodeError:
                    continue
                ts_raw = entry.get("timestamp", "")
                try:
                    ts = datetime.fromisoformat(ts_raw.rstrip("Z")).replace(tzinfo=timezone.utc)
                    if ts < since:
                        continue
                except (ValueError, AttributeError):
                    continue
                total += 1
                if entry.get("hint_accepted"):
                    accepted += 1
                if bool(entry.get("tooling_plan_injected", False)):
                    tooling_plan_total += 1
                    if entry.get("hint_accepted"):
                        tooling_plan_success += 1
                if bool(entry.get("analysis_only_profile", False)):
                    analysis_profile_total += 1
                    if entry.get("hint_accepted"):
                        analysis_profile_success += 1
                hid = entry.get("hint_id", "unknown")
                top_hints[hid] = top_hints.get(hid, 0) + 1
    except OSError:
        # File not yet created — normal on a fresh deploy; treat as zero activity
        return {"available": True, "total": 0, "accepted": 0, "adoption_pct": None, "top_hints": []}
    if total == 0:
        return {"available": True, "total": 0, "accepted": 0, "adoption_pct": None, "top_hints": []}
    sorted_hints = sorted(top_hints.items(), key=lambda x: -x[1])
    unique_hints = len(sorted_hints)
    dominant_hint_id = sorted_hints[0][0] if sorted_hints else None
    dominant_hint_count = int(sorted_hints[0][1]) if sorted_hints else 0
    dominant_share_pct = round(100 * dominant_hint_count / total, 1) if total else None
    entropy_bits = 0.0
    for _, count in sorted_hints:
        if count <= 0:
            continue
        prob = count / total
        entropy_bits += -prob * math.log2(prob)
    max_entropy_bits = math.log2(unique_hints) if unique_hints > 1 else 0.0
    normalized_entropy_pct = (
        round(100 * entropy_bits / max_entropy_bits, 1) if max_entropy_bits > 0 else (0.0 if unique_hints == 1 else None)
    )
    effective_hints = round(2 ** entropy_bits, 2) if total else None
    return {
        "available": True,
        "total": total,
        "accepted": accepted,
        "adoption_pct": round(100 * accepted / total, 1),
        "tooling_plan_total": tooling_plan_total,
        "tooling_plan_success": tooling_plan_success,
        "tooling_plan_success_pct": round(100 * tooling_plan_success / tooling_plan_total, 1) if tooling_plan_total else None,
        "analysis_profile_total": analysis_profile_total,
        "analysis_profile_success": analysis_profile_success,
        "analysis_profile_success_pct": round(100 * analysis_profile_success / analysis_profile_total, 1) if analysis_profile_total else None,
        "top_hints": sorted_hints[:5],
        "unique_hints": unique_hints,
        "dominant_hint_id": dominant_hint_id,
        "dominant_hint_count": dominant_hint_count,
        "dominant_share_pct": dominant_share_pct,
        "entropy_bits": round(entropy_bits, 3),
        "normalized_entropy_pct": normalized_entropy_pct,
        "effective_hints": effective_hints,
    }


def hint_diversity(adoption: Optional[Dict[str, Any]]) -> Dict[str, Any]:
    """Compute concentration/diversity quality signals for injected hints."""
    if not adoption or not adoption.get("available"):
        return {"available": False}

    total = int(adoption.get("total", 0) or 0)
    if total == 0:
        return {
            "available": True,
            "total_injections": 0,
            "unique_hints": 0,
            "dominant_hint_id": None,
            "dominant_share_pct": None,
            "normalized_entropy_pct": None,
            "effective_hints": None,
            "status": "no_data",
        }

    unique_hints = int(adoption.get("unique_hints", 0) or 0)
    dominant_share_pct = adoption.get("dominant_share_pct")
    normalized_entropy_pct = adoption.get("normalized_entropy_pct")
    effective_hints = adoption.get("effective_hints")
    dominant_hint_id = adoption.get("dominant_hint_id")

    if unique_hints <= 1:
        status = "monoculture"
    elif dominant_share_pct is not None and float(dominant_share_pct) >= 70:
        status = "highly_concentrated"
    elif dominant_share_pct is not None and float(dominant_share_pct) >= 50:
        status = "concentrated"
    elif (
        dominant_share_pct is not None
        and normalized_entropy_pct is not None
        and float(dominant_share_pct) < 50
        and float(normalized_entropy_pct) >= 60
    ):
        status = "balanced"
    elif normalized_entropy_pct is not None and float(normalized_entropy_pct) >= 75:
        status = "healthy"
    else:
        status = "mixed"

    return {
        "available": True,
        "total_injections": total,
        "unique_hints": unique_hints,
        "dominant_hint_id": dominant_hint_id,
        "dominant_share_pct": dominant_share_pct,
        "normalized_entropy_pct": normalized_entropy_pct,
        "effective_hints": effective_hints,
        "status": status,
    }


def _task_tooling_from_hint_adoption(adoption: Optional[Dict[str, Any]]) -> Dict[str, Any]:
    if not isinstance(adoption, dict):
        return {"available": True, "total": 0}
    plan_total = int(adoption.get("tooling_plan_total", 0) or 0)
    plan_success = int(adoption.get("tooling_plan_success", 0) or 0)
    if plan_total <= 0:
        return {"available": True, "total": 0}
    return {
        "available": True,
        "source": "hint_adoption_fallback",
        "total": plan_total,
        "success": plan_success,
        "success_pct": round(100 * plan_success / plan_total, 1) if plan_total else None,
        "plan_total": plan_total,
        "plan_success": plan_success,
        "plan_success_pct": round(100 * plan_success / plan_total, 1) if plan_total else None,
        "baseline_total": 0,
        "baseline_success": 0,
        "baseline_success_pct": None,
    }


def task_tooling_quality(since: datetime, adoption: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
    """Read aider task audit and compare injected-plan success vs baseline."""
    task_path = _task_audit_path()
    if not task_path:
        return _task_tooling_from_hint_adoption(adoption)

    total = 0
    success = 0
    plan_total = 0
    plan_success = 0
    baseline_total = 0
    baseline_success = 0
    try:
        with task_path.open(encoding="utf-8", errors="replace") as fh:
            for line in fh:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                except json.JSONDecodeError:
                    continue
                ts_raw = entry.get("timestamp", "")
                try:
                    ts = datetime.fromisoformat(ts_raw.rstrip("Z")).replace(tzinfo=timezone.utc)
                    if ts < since:
                        continue
                except (ValueError, AttributeError):
                    continue
                total += 1
                ok = bool(entry.get("status") == "success")
                if ok:
                    success += 1
                if bool(entry.get("tooling_plan_injected", False)):
                    plan_total += 1
                    if ok:
                        plan_success += 1
                else:
                    baseline_total += 1
                    if ok:
                        baseline_success += 1
    except OSError:
        return _task_tooling_from_hint_adoption(adoption)

    if total == 0:
        return _task_tooling_from_hint_adoption(adoption)

    return {
        "available": True,
        "total": total,
        "success": success,
        "success_pct": round(100 * success / total, 1) if total else None,
        "plan_total": plan_total,
        "plan_success": plan_success,
        "plan_success_pct": round(100 * plan_success / plan_total, 1) if plan_total else None,
        "baseline_total": baseline_total,
        "baseline_success": baseline_success,
        "baseline_success_pct": round(100 * baseline_success / baseline_total, 1) if baseline_total else None,
    }


# ---------------------------------------------------------------------------
# Analysis helpers
# ---------------------------------------------------------------------------


def _percentile(data: List[float], pct: float) -> float:
    """Return the p-th percentile of a sorted list."""
    if not data:
        return 0.0
    data = sorted(data)
    idx = (len(data) - 1) * pct / 100
    lo, hi = int(idx), min(int(idx) + 1, len(data) - 1)
    return data[lo] + (data[hi] - data[lo]) * (idx - lo)


def aggregate_tool_audit(entries: List[dict]) -> Dict[str, dict]:
    """Aggregate per-tool latency and outcome stats."""
    per_tool: Dict[str, Dict[str, Any]] = {}
    for e in entries:
        service = str(e.get("service", "")).strip().lower()
        # Ignore internal first-use tool-security auditor events from tool-latency table.
        if service.endswith("-tool-security"):
            continue
        name = e.get("tool_name", "unknown")
        if name not in per_tool:
            per_tool[name] = {"latencies": [], "success": 0, "error": 0}
        lat = e.get("latency_ms")
        if isinstance(lat, (int, float)):
            per_tool[name]["latencies"].append(float(lat))
        outcome = e.get("outcome", "")
        if outcome == "success":
            per_tool[name]["success"] += 1
        else:
            per_tool[name]["error"] += 1
    result = {}
    for tool, stats in per_tool.items():
        lats = stats["latencies"]
        total = stats["success"] + stats["error"]
        result[tool] = {
            "calls": total,
            "p50_ms": _percentile(lats, 50),
            "p95_ms": _percentile(lats, 95),
            "success_pct": round(100 * stats["success"] / total, 1) if total else 0.0,
        }
    return result


def security_auditor_health(entries: List[dict]) -> Dict[str, Any]:
    """Summarize first-use tool security auditor behavior from audit stream."""
    events = [
        e for e in entries
        if str(e.get("service", "")).strip().lower().endswith("-tool-security")
    ]
    if not events:
        return {"available": True, "events": 0}

    approved = 0
    blocked = 0
    cached = 0
    first_seen = 0
    by_tool: Dict[str, Dict[str, int]] = {}
    for e in events:
        tool = str(e.get("tool_name", "unknown")).strip() or "unknown"
        metadata = e.get("metadata") if isinstance(e.get("metadata"), dict) else {}
        safe = bool(metadata.get("approved")) if "approved" in metadata else (e.get("outcome") == "success")
        if safe:
            approved += 1
        else:
            blocked += 1
        if bool(metadata.get("cached")):
            cached += 1
        if bool(metadata.get("first_seen")):
            first_seen += 1
        bucket = by_tool.setdefault(tool, {"events": 0, "blocked": 0})
        bucket["events"] += 1
        if not safe:
            bucket["blocked"] += 1

    top_blocked = sorted(
        [(name, stats["blocked"]) for name, stats in by_tool.items() if stats["blocked"] > 0],
        key=lambda x: -x[1],
    )[:5]
    return {
        "available": True,
        "events": len(events),
        "approved": approved,
        "blocked": blocked,
        "cache_hits": cached,
        "first_seen": first_seen,
        "cache_hit_pct": round(100 * cached / len(events), 1) if events else None,
        "top_blocked_tools": top_blocked,
    }


def semantic_autorun_health(entries: List[dict]) -> Dict[str, Any]:
    """Summarize semantic tooling autorun behavior from /query audit metadata."""
    route_events = [
        e for e in entries
        if str(e.get("tool_name", "")).strip().lower() == "route_search"
        and str(e.get("service", "")).strip().lower() in {"hybrid-coordinator-http", "hybrid-coordinator"}
    ]
    if not route_events:
        return {"available": True, "route_calls": 0}

    autorun_enabled = 0
    planned_total = 0
    executed_total = 0
    blocked_total = 0
    cache_hits_total = 0
    first_seen_total = 0
    backend_counts: Dict[str, int] = {}
    with_metadata = 0
    for e in route_events:
        service = str(e.get("service", "")).strip().lower()
        metadata = e.get("metadata") if isinstance(e.get("metadata"), dict) else {}
        if not metadata:
            continue
        with_metadata += 1
        if service == "hybrid-coordinator-http" and bool(metadata.get("semantic_autorun_enabled")):
            autorun_enabled += 1
        if service == "hybrid-coordinator-http":
            planned_total += int(metadata.get("semantic_autorun_planned", 0) or 0)
            executed_total += int(metadata.get("semantic_autorun_executed", 0) or 0)
            blocked_total += int(metadata.get("tool_security_blocked", 0) or 0)
            cache_hits_total += int(metadata.get("tool_security_cache_hits", 0) or 0)
            first_seen_total += int(metadata.get("tool_security_first_seen", 0) or 0)
        backend = str(metadata.get("backend", "") or "").strip().lower()
        if backend:
            backend_counts[backend] = backend_counts.get(backend, 0) + 1

    return {
        "available": True,
        "route_calls": len(route_events),
        "with_metadata": with_metadata,
        "autorun_enabled_calls": autorun_enabled,
        "autorun_enabled_pct": round(100 * autorun_enabled / len(route_events), 1) if route_events else None,
        "avg_planned_tools": round(planned_total / len(route_events), 2) if route_events else 0.0,
        "avg_executed_tools": round(executed_total / len(route_events), 2) if route_events else 0.0,
        "tool_security_blocked_total": blocked_total,
        "tool_security_cache_hits_total": cache_hits_total,
        "tool_security_first_seen_total": first_seen_total,
        "backend_counts": backend_counts,
    }


def routing_split() -> Dict[str, Any]:
    """Fetch local vs remote routing split from Prometheus."""
    local_val = prom_query('sum(hybrid_llm_backend_selections_total{backend="local"}) or vector(0)')
    remote_val = prom_query('sum(hybrid_llm_backend_selections_total{backend="remote"}) or vector(0)')
    local_n = local_val or 0.0
    remote_n = remote_val or 0.0
    total = local_n + remote_n
    query_ok = prom_query('sum(hybrid_requests_total{endpoint="/query",status="200"}) or vector(0)')
    if query_ok is None:
        query_ok = prom_query('sum(hybrid_requests_total{endpoint="/query"}) or vector(0)')
    return {
        "local_n": int(local_n),
        "remote_n": int(remote_n),
        "local_pct": round(100 * local_n / total, 1) if total else None,
        "query_ok_n": int(query_ok or 0.0),
        "fallback_used": bool((query_ok or 0.0) > 0 and total == 0),
        "available": local_val is not None,  # None only on connection error
    }


def cache_hit_rate() -> Dict[str, Any]:
    """Fetch embedding cache hit rate from Prometheus counters."""
    hits = prom_query("sum(embedding_cache_hits_total) or vector(0)")
    misses = prom_query("sum(embedding_cache_misses_total) or vector(0)")
    if hits is None and misses is None:
        # Fallback counter names (Phase 17.4.1)
        hits = prom_query("EMBEDDING_CACHE_HITS_total")
        misses = prom_query("EMBEDDING_CACHE_MISSES_total")
    h = hits or 0.0
    m = misses or 0.0
    total = h + m
    return {
        "hits": int(h),
        "misses": int(m),
        "hit_pct": round(100 * h / total, 1) if total else None,
        "available": hits is not None or misses is not None,  # None only on connection error
    }


def eval_score_trend(rows: List[dict]) -> Dict[str, Any]:
    """Compute eval score statistics over the window."""
    if not rows:
        return {"available": False}
    pcts = [r["pct_passed"] for r in rows]
    return {
        "available": True,
        "latest_pct": pcts[-1],
        "mean_pct": round(statistics.mean(pcts), 1),
        "min_pct": min(pcts),
        "max_pct": max(pcts),
        "trend": "rising" if len(pcts) >= 2 and pcts[-1] > pcts[0] else
                 "falling" if len(pcts) >= 2 and pcts[-1] < pcts[0] else "stable",
        "n_runs": len(rows),
    }


def build_recommendations(
    tool_stats: Dict[str, dict],
    route: Dict[str, Any],
    cache: Dict[str, Any],
    eval_trend: Dict[str, Any],
    gaps: List[dict],
    adoption: Optional[Dict[str, Any]] = None,
    intent_compliance: Optional[Dict[str, Any]] = None,
    security_auditor: Optional[Dict[str, Any]] = None,
    semantic_autorun: Optional[Dict[str, Any]] = None,
    tooling_quality: Optional[Dict[str, Any]] = None,
    hint_diversity_stats: Optional[Dict[str, Any]] = None,
) -> List[str]:
    """Derive actionable workflow recommendations from measured data."""
    recs: List[str] = []
    ignored_flaky_tools = {
        t.strip().lower()
        for t in os.getenv("AQ_REPORT_FLAKY_TOOL_IGNORE", "run_sandboxed,shell_execute").split(",")
        if t.strip()
    }

    # Routing
    if route["available"]:
        if route["local_pct"] is not None and route["local_pct"] < 30:
            recs.append(
                f"Local routing is low ({route['local_pct']}%). "
                "Check `systemctl status ai-llama-cpp` and `llama.cpp` model load; "
                "run `scripts/check-mcp-health.sh` to diagnose."
            )
    else:
        recs.append(
            "Routing metrics unavailable (Prometheus unreachable). "
            "Verify `systemctl status prometheus` and that ai-hybrid-coordinator exposes /metrics."
        )

    # Cache
    if cache["available"]:
        if cache["hit_pct"] is not None and cache["hit_pct"] < 50:
            recs.append(
                f"Embedding cache hit rate is low ({cache['hit_pct']}%). "
                "Consider pre-warming the cache by running common queries, "
                "or increase `AI_CACHE_MAX_SIZE` if memory allows."
            )
    else:
        recs.append(
            "Cache metrics unavailable. "
            "Ensure `embedding_cache.py` emits Prometheus counters and Prometheus scrapes the service."
        )

    # Query gaps — check AIDB for existing docs before recommending import
    top_gaps = [
        g for g in gaps
        if g.get("occurrences", 1) >= 3 and not _is_synthetic_gap(str(g.get("query_text", "")))
    ]
    for g in top_gaps[:3]:
        topic = g["query_text"][:80].replace("\n", " ")
        occurrences = g.get("occurrences", "?")
        existing = _count_aidb_docs_for_topic(topic)
        if existing > 0:
            recs.append(
                f"Recurring gap ({occurrences}x): \"{topic}\". "
                f"Docs exist in AIDB ({existing} match{'es' if existing != 1 else ''}). "
                f"Verify Qdrant embedding with: scripts/aq-qa 2. "
                f"Clear stale gap: psql $AIDB_DSN -c \"DELETE FROM query_gaps "
                f"WHERE query_text ILIKE '%{topic[:30]}%';\""
            )
        else:
            recs.append(
                f"Recurring unanswered query ({occurrences}x): \"{topic}\". "
                f"No matching docs in AIDB. "
                f"Import: scripts/aq-knowledge-import.sh \"{topic[:40]}\""
            )

    # Eval trend
    if eval_trend.get("available") and eval_trend.get("trend") == "falling":
        recs.append(
            f"Eval score trending down (latest: {eval_trend['latest_pct']}%, "
            f"mean: {eval_trend['mean_pct']}%). "
            "Review recent prompt changes and run `scripts/run-eval.sh --full` to confirm."
        )

    # Hint adoption quality
    if adoption and adoption.get("available") and int(adoption.get("total", 0)) >= 5:
        pct = adoption.get("adoption_pct")
        if pct is not None and float(pct) < 60:
            recs.append(
                f"Hint adoption is low ({pct}% successful across {adoption['total']} injected tasks). "
                "Review hint matching quality and validate aider-wrapper acceptance paths."
            )
        tp_total = int(adoption.get("tooling_plan_total", 0) or 0)
        tp_pct = adoption.get("tooling_plan_success_pct")
        if tp_total >= 5 and tp_pct is not None and float(tp_pct) < 60:
            recs.append(
                f"Tooling-plan injected tasks underperform ({tp_pct}% success across {tp_total} runs). "
                "Review /workflow/plan relevance and tighten injected phase/tool selection."
            )

    # Intent contract coverage
    if intent_compliance and intent_compliance.get("available"):
        total_runs = int(intent_compliance.get("total_runs", 0) or 0)
        coverage = intent_compliance.get("contract_coverage_pct")
        if total_runs >= 3 and coverage is not None and float(coverage) < 90:
            recs.append(
                f"Workflow intent-contract coverage is low ({coverage}% over {total_runs} runs). "
                "Ensure /workflow/run/start always includes intent_contract fields "
                "(user_intent, definition_of_done, depth_expectation, spirit_constraints)."
            )

    # Semantic tooling autorun quality
    if semantic_autorun and semantic_autorun.get("available"):
        route_calls = int(semantic_autorun.get("route_calls", 0) or 0)
        if route_calls >= 5:
            enabled_pct = semantic_autorun.get("autorun_enabled_pct")
            if enabled_pct is not None and float(enabled_pct) < 80:
                recs.append(
                    f"Semantic tooling autorun is inconsistently active ({enabled_pct}% across {route_calls} route calls). "
                    "Verify `AI_SEMANTIC_TOOLING_AUTORUN=true` in hybrid-coordinator runtime env."
                )
            if int(semantic_autorun.get("tool_security_blocked_total", 0) or 0) > 0:
                recs.append(
                    "Tool security auditor blocked one or more planned tools during autorun. "
                    "Review `tool-security-policy.json` and blocked tool metadata in tool-audit logs."
                )

    # Security auditor cache behavior
    if security_auditor and security_auditor.get("available"):
        events = int(security_auditor.get("events", 0) or 0)
        cache_hit_pct = security_auditor.get("cache_hit_pct")
        if events >= 10 and cache_hit_pct is not None and float(cache_hit_pct) < 50:
            recs.append(
                f"Security-auditor cache hit rate is low ({cache_hit_pct}% over {events} decisions). "
                "Consider increasing `AI_TOOL_SECURITY_CACHE_TTL_HOURS` to reduce repeated full audits."
            )

    if tooling_quality and tooling_quality.get("available"):
        plan_total = int(tooling_quality.get("plan_total", 0) or 0)
        baseline_total = int(tooling_quality.get("baseline_total", 0) or 0)
        plan_pct = tooling_quality.get("plan_success_pct")
        baseline_pct = tooling_quality.get("baseline_success_pct")
        if (
            plan_total >= 5
            and baseline_total >= 5
            and plan_pct is not None
            and baseline_pct is not None
            and float(plan_pct) + 5.0 < float(baseline_pct)
        ):
            recs.append(
                f"Tooling-plan injected tasks are under baseline ({plan_pct}% vs {baseline_pct}%). "
                "Refine /workflow/plan phase/tool selection and hint-plan alignment."
            )

    if hint_diversity_stats and hint_diversity_stats.get("available"):
        total_injections = int(hint_diversity_stats.get("total_injections", 0) or 0)
        dominant_share_pct = hint_diversity_stats.get("dominant_share_pct")
        unique_hints = int(hint_diversity_stats.get("unique_hints", 0) or 0)
        if total_injections >= 10 and (unique_hints <= 1 or (dominant_share_pct is not None and float(dominant_share_pct) >= 70)):
            recs.append(
                "Hint diversity is overly concentrated. Add at least one data/tool-error/system-state hint path, "
                "and weight down over-repeated registry-only hints."
            )

    # Slow tools
    slow_tools = [
        (t, s) for t, s in tool_stats.items()
        if s["p95_ms"] > 5000 and s["calls"] >= 5
    ]
    for tool, stats in sorted(slow_tools, key=lambda x: -x[1]["p95_ms"])[:2]:
        recs.append(
            f"Tool `{tool}` P95 latency is {stats['p95_ms']:.0f}ms — "
            "consider caching, connection pooling, or model size reduction."
        )

    # Tool reliability
    flaky_tools = [
        (t, s) for t, s in tool_stats.items()
        if s["calls"] >= 3
        and s["success_pct"] < 80
        and t.lower() not in ignored_flaky_tools
    ]
    for tool, stats in sorted(flaky_tools, key=lambda x: x[1]["success_pct"])[:2]:
        recs.append(
            f"Tool `{tool}` success rate is low ({stats['success_pct']}% across {stats['calls']} calls). "
            "Inspect recent failures and tighten retries/timeouts or fallback behavior."
        )

    # Code-gen quality guidance (Phase 18 user goal: measure prompt efficiency for systems code gen)
    code_gen_tools = {t: s for t, s in tool_stats.items()
                     if any(kw in t.lower() for kw in ("aider", "code", "edit", "generate"))}
    for tool, stats in code_gen_tools.items():
        if stats["success_pct"] < 70:
            recs.append(
                f"Code-gen tool `{tool}` has low success rate ({stats['success_pct']}%). "
                "Try more specific file context (--file flags), smaller task scope per request, "
                "or a higher-tier model. See ai-stack/prompts/registry.yaml for vetted templates."
            )

    if not recs:
        recs.append("No critical issues detected. System is operating within normal parameters.")

    return recs


def build_structured_actions(
    tool_stats: Dict[str, dict],
    route: Dict[str, Any],
    cache: Dict[str, Any],
    eval_trend: Dict[str, Any],
    gaps: List[dict],
) -> List[dict]:
    """Machine-readable optimization actions for aq-optimizer."""
    actions: List[dict] = []

    timeout_gaps = [g for g in gaps if g.get("collection") == "inference_timeout"]
    timeout_count = sum(int(g.get("occurrences", 1)) for g in timeout_gaps)
    if timeout_count >= 3:
        actions.append({
            "type": "routing",
            "action": "prefer_remote",
            "reason": "inference_timeout_count=" + str(timeout_count),
            "safe": True,
            "confidence": min(1.0, timeout_count / 10),
            "env_overrides": {"DEFAULT_PROVIDER": "remote"},
            "services": ["ai-hybrid-coordinator", "ai-switchboard"],
        })

    if (route.get("available") and route.get("local_pct") is not None
            and float(route["local_pct"]) < 30):
        actions.append({
            "type": "routing",
            "action": "nudge_local_threshold_down",
            "reason": "local_pct_low=" + str(route["local_pct"]),
            "safe": True,
            "confidence": 0.65,
            "env_overrides": {
                "DEFAULT_PROVIDER": "local",
                "LOCAL_CONFIDENCE_THRESHOLD": "0.35",
            },
            "services": ["ai-hybrid-coordinator", "ai-switchboard"],
        })

    if (route.get("available") and route.get("local_pct") is not None
            and float(route["local_pct"]) > 70 and timeout_count == 0):
        actions.append({
            "type": "routing",
            "action": "prefer_local",
            "reason": "local_healthy_pct=" + str(route["local_pct"]),
            "safe": True,
            "confidence": 0.75,
            "env_overrides": {"DEFAULT_PROVIDER": "local"},
            "services": ["ai-hybrid-coordinator", "ai-switchboard"],
        })

    if cache.get("available") and cache.get("hit_pct") is not None and float(cache["hit_pct"]) < 50:
        actions.append({
            "type": "maintenance",
            "action": "prewarm_cache",
            "reason": "cache_hit_pct_low=" + str(cache["hit_pct"]),
            "safe": True,
            "confidence": 0.7,
            "script": "seed-routing-traffic.sh",
            "script_args": ["--count", "8"],
        })

    knowledge_gaps = [
        g for g in gaps
        if g.get("collection") != "inference_timeout"
        and int(g.get("occurrences", 1)) >= 3
        and not _is_synthetic_gap(str(g.get("query_text", "")))
    ]
    for g in knowledge_gaps[:3]:
        actions.append({
            "type": "knowledge",
            "action": "import_gap",
            "reason": "recurring_gap occurrences=" + str(g["occurrences"]),
            "safe": True,
            "confidence": min(1.0, int(g.get("occurrences", 1)) / 5),
            "topic": g["query_text"][:80],
        })

    if eval_trend.get("available") and eval_trend.get("trend") == "falling":
        actions.append({
            "type": "eval",
            "action": "alert_human",
            "reason": "eval_score_falling latest=" + str(eval_trend.get("latest_pct")) + "%",
            "safe": True,
            "confidence": 0.9,
            "message": (
                "Eval trend falling: " + str(eval_trend.get("latest_pct")) + "% "
                "(mean " + str(eval_trend.get("mean_pct")) + "%). "
                "Run: scripts/run-eval.sh --full"
            ),
        })

    return actions


# ---------------------------------------------------------------------------
# Formatters
# ---------------------------------------------------------------------------


def _na(val: Optional[float], fmt: str = ".1f", suffix: str = "") -> str:
    if val is None:
        return "n/a"
    return f"{val:{fmt}}{suffix}"


def format_md(
    since_label: str,
    tool_stats: Dict[str, dict],
    route: Dict[str, Any],
    cache: Dict[str, Any],
    eval_trend: Dict[str, Any],
    leaderboard: List[dict],
    top_prompts: List[dict],
    gaps: List[dict],
    recs: List[str],
    adoption: Optional[Dict[str, Any]] = None,
    intent_compliance: Optional[Dict[str, Any]] = None,
    security_auditor: Optional[Dict[str, Any]] = None,
    semantic_autorun: Optional[Dict[str, Any]] = None,
    tooling_quality: Optional[Dict[str, Any]] = None,
    hint_diversity_stats: Optional[Dict[str, Any]] = None,
) -> str:
    lines = [
        f"# AI Stack Performance Report — last {since_label}",
        f"*Generated: {datetime.now(tz=timezone.utc).strftime('%Y-%m-%d %H:%M UTC')}*",
        "",
    ]

    # 1. Tool performance
    lines += ["## 1. Tool Call Performance", ""]
    if tool_stats:
        lines += [
            "| Tool | Calls | P50 ms | P95 ms | Success % |",
            "|------|------:|-------:|-------:|----------:|",
        ]
        for tool, s in sorted(tool_stats.items(), key=lambda x: -x[1]["calls"]):
            lines.append(
                f"| `{tool}` | {s['calls']} | {s['p50_ms']:.0f} | {s['p95_ms']:.0f} | {s['success_pct']} |"
            )
    else:
        lines.append("*No tool audit entries found for this window.*")
    lines.append("")

    # 2. Routing split
    lines += ["## 2. Routing Split", ""]
    if route["available"]:
        lines += [
            f"- Local requests: **{route['local_n']}** ({_na(route['local_pct'], '.1f', '%')})",
            f"- Remote requests: **{route['remote_n']}** ({_na(100 - route['local_pct'] if route['local_pct'] is not None else None, '.1f', '%')})",
        ]
        if route.get("fallback_used"):
            lines.append(
                f"- Backend split metric missing; observed **{route['query_ok_n']}** successful `/query` requests."
            )
    else:
        lines.append("*Prometheus unreachable — routing metrics unavailable.*")
    lines.append("")

    # 3. Cache hit rate
    lines += ["## 3. Semantic Cache", ""]
    if cache["available"]:
        lines += [
            f"- Hits: **{cache['hits']}**, Misses: **{cache['misses']}**",
            f"- Hit rate: **{_na(cache['hit_pct'], '.1f', '%')}**",
        ]
    else:
        lines.append("*Cache metrics unavailable.*")
    lines.append("")

    # 4. Eval score trend
    lines += ["## 4. Eval Score Trend", ""]
    if eval_trend.get("available"):
        lines += [
            f"- Runs in window: {eval_trend['n_runs']}",
            f"- Latest: **{eval_trend['latest_pct']}%**  |  Mean: {eval_trend['mean_pct']}%"
            f"  |  Range: {eval_trend['min_pct']}–{eval_trend['max_pct']}%",
            f"- Trend: **{eval_trend['trend']}**",
        ]
    else:
        lines.append("*No eval runs found for this window.*")
    lines.append("")

    # 5. Strategy Leaderboard (18.2.2)
    lines += ["## 5. Strategy Leaderboard", ""]
    visible = [r for r in leaderboard if r["tag"] != "untagged"]
    if len(visible) >= 2:
        lines += [
            "| Rank | Strategy | Mean % | Runs |",
            "|-----:|----------|-------:|-----:|",
        ]
        for i, r in enumerate(visible[:5], 1):
            lines.append(f"| {i} | `{r['tag']}` | {r['mean_pct']} | {r['runs']} |")
        lines.append("")
        lines.append(f"*Run `scripts/run-eval.sh --strategy <name>` to tag a new variant.*")
    else:
        lines.append("*No tagged strategy runs yet. Use `--strategy LABEL` with run-eval.sh.*")
    lines.append("")

    # 6. Recommended Prompts (18.3.3)
    lines += ["## 6. Recommended Prompts", ""]
    if top_prompts:
        for p in top_prompts:
            lines.append(
                f"- **{p['name']}** (`{p['id']}`) — score {p['mean_score']:.1%}  \n"
                f"  {p.get('description', '').strip()[:120]}"
            )
    else:
        lines.append("*Run `scripts/aq-prompt-eval` to score prompts in registry.yaml.*")
    lines.append("")

    # 7. Query gaps
    lines += ["## 7. Top Query Gaps", ""]
    if gaps:
        lines += [
            "| # | Query | Score | Collection | Occurrences |",
            "|---|-------|------:|-----------|------------:|",
        ]
        for i, g in enumerate(gaps[:10], 1):
            q = str(g.get("query_text", ""))[:60].replace("|", "\\|")
            lines.append(
                f"| {i} | {q} | {g.get('score', 0):.2f} | {g.get('collection', '')} | {g.get('occurrences', 1)} |"
            )
        lines += [
            "",
            "*Import suggestion: `aidb import --query \"<query text>\"` to pull relevant docs.*",
        ]
    else:
        lines.append("*No query gaps found (Postgres unreachable or table empty).*")
    lines.append("")

    # 8. Recommendations
    lines += ["## 8. Workflow Recommendations", ""]
    for i, rec in enumerate(recs, 1):
        lines.append(f"{i}. {rec}")
    lines.append("")

    # 9. Hint Adoption (Phase 19.3.4)
    lines += ["## 9. Hint Adoption (aq-hints → aider-wrapper)", ""]
    if adoption and adoption.get("available"):
        if adoption["total"] == 0:
            lines.append("*No hint-injected aider tasks in this window.*")
        else:
            lines += [
                f"- Tasks with hint injection: **{adoption['total']}**",
                f"- Successful completions: **{adoption['accepted']}**",
                f"- Adoption rate: **{_na(adoption['adoption_pct'], '.1f', '%')}**",
            ]
            if int(adoption.get("tooling_plan_total", 0) or 0) > 0:
                lines.append(
                    f"- Tooling-plan injected success: **{adoption.get('tooling_plan_success', 0)}"
                    f"/{adoption.get('tooling_plan_total', 0)}**"
                    f" ({_na(adoption.get('tooling_plan_success_pct'), '.1f', '%')})"
                )
            if adoption.get("top_hints"):
                lines += ["", "Top hints by injection frequency:", ""]
                lines += [
                    "| Hint ID | Injections |",
                    "|---------|----------:|",
                ]
                for hid, count in adoption["top_hints"]:
                    lines.append(f"| `{hid}` | {count} |")
            if tooling_quality and int(tooling_quality.get("total", 0) or 0) > 0:
                lines += [
                    "",
                    f"- Aider task success (all): **{tooling_quality.get('success', 0)}/{tooling_quality.get('total', 0)}** ({_na(tooling_quality.get('success_pct'), '.1f', '%')})",
                    f"- Tooling-plan injected: **{tooling_quality.get('plan_success', 0)}/{tooling_quality.get('plan_total', 0)}** ({_na(tooling_quality.get('plan_success_pct'), '.1f', '%')})",
                    f"- Non-injected baseline: **{tooling_quality.get('baseline_success', 0)}/{tooling_quality.get('baseline_total', 0)}** ({_na(tooling_quality.get('baseline_success_pct'), '.1f', '%')})",
                ]
    else:
        lines.append("*Hint audit unavailable — ensure AI_HINTS_ENABLED=true in aider-wrapper.*")
    lines.append("")

    # 10. Intent-contract compliance
    lines += ["## 10. Intent Contract Compliance", ""]
    if intent_compliance and intent_compliance.get("available"):
        total = int(intent_compliance.get("total_runs", 0) or 0)
        if total == 0:
            lines.append("*No workflow runs in this window.*")
        else:
            lines += [
                f"- Workflow runs: **{total}**",
                f"- With valid contract: **{intent_compliance.get('with_contract', 0)}**",
                f"- Coverage: **{_na(intent_compliance.get('contract_coverage_pct'), '.1f', '%')}**",
            ]
            depth = intent_compliance.get("depth_distribution", {})
            if isinstance(depth, dict) and depth:
                items = ", ".join(f"{k}:{v}" for k, v in sorted(depth.items(), key=lambda x: (-x[1], x[0])))
                lines.append(f"- Depth distribution: {items}")
            top_bp = intent_compliance.get("top_blueprints", [])
            if top_bp:
                lines += ["", "Top blueprints by runs:"]
                for bp, n in top_bp:
                    lines.append(f"- `{bp}`: {n}")
    else:
        lines.append("*Workflow session store unavailable.*")
    lines.append("")

    # 11. Security auditor
    lines += ["## 11. Tool Security Auditor", ""]
    if security_auditor and security_auditor.get("available"):
        events = int(security_auditor.get("events", 0) or 0)
        if events == 0:
            lines.append("*No tool-security auditor decisions observed in this window.*")
        else:
            lines += [
                f"- Decisions: **{events}**",
                f"- Approved: **{security_auditor.get('approved', 0)}**",
                f"- Blocked: **{security_auditor.get('blocked', 0)}**",
                f"- Cache hits: **{security_auditor.get('cache_hits', 0)}** ({_na(security_auditor.get('cache_hit_pct'), '.1f', '%')})",
                f"- First-seen audits: **{security_auditor.get('first_seen', 0)}**",
            ]
    else:
        lines.append("*Tool-security auditor metrics unavailable.*")
    lines.append("")

    # 12. Semantic autorun
    lines += ["## 12. Semantic Tooling Autorun", ""]
    if semantic_autorun and semantic_autorun.get("available"):
        route_calls = int(semantic_autorun.get("route_calls", 0) or 0)
        if route_calls == 0:
            lines.append("*No `/query` route_search traffic in this window.*")
        else:
            lines += [
                f"- Route calls: **{route_calls}**",
                f"- Route calls with metadata: **{semantic_autorun.get('with_metadata', 0)}**",
                f"- Autorun enabled: **{semantic_autorun.get('autorun_enabled_calls', 0)}** ({_na(semantic_autorun.get('autorun_enabled_pct'), '.1f', '%')})",
                f"- Avg planned tools/call: **{semantic_autorun.get('avg_planned_tools', 0.0)}**",
                f"- Avg executed tools/call: **{semantic_autorun.get('avg_executed_tools', 0.0)}**",
                f"- Security blocks during autorun: **{semantic_autorun.get('tool_security_blocked_total', 0)}**",
            ]
    else:
        lines.append("*Semantic autorun metrics unavailable.*")
    lines.append("")

    # 13. Hint Diversity
    lines += ["## 13. Hint Diversity", ""]
    if hint_diversity_stats and hint_diversity_stats.get("available"):
        total_injections = int(hint_diversity_stats.get("total_injections", 0) or 0)
        if total_injections == 0:
            lines.append("*No hint-injection activity in this window.*")
        else:
            lines += [
                f"- Total injections: **{total_injections}**",
                f"- Unique hint IDs: **{hint_diversity_stats.get('unique_hints', 0)}**",
                f"- Dominant hint share: **{_na(hint_diversity_stats.get('dominant_share_pct'), '.1f', '%')}**",
                f"- Normalized entropy: **{_na(hint_diversity_stats.get('normalized_entropy_pct'), '.1f', '%')}**",
                f"- Effective hints (entropy-based): **{_na(hint_diversity_stats.get('effective_hints'), '.2f')}**",
                f"- Status: **{hint_diversity_stats.get('status', 'unknown')}**",
            ]
            if hint_diversity_stats.get("dominant_hint_id"):
                lines.append(f"- Dominant hint ID: `{hint_diversity_stats.get('dominant_hint_id')}`")
    else:
        lines.append("*Hint-diversity metrics unavailable.*")
    lines.append("")

    return "\n".join(lines)


def format_text(
    since_label: str,
    tool_stats: Dict[str, dict],
    route: Dict[str, Any],
    cache: Dict[str, Any],
    eval_trend: Dict[str, Any],
    leaderboard: List[dict],
    top_prompts: List[dict],
    gaps: List[dict],
    recs: List[str],
    adoption: Optional[Dict[str, Any]] = None,
    intent_compliance: Optional[Dict[str, Any]] = None,
    security_auditor: Optional[Dict[str, Any]] = None,
    semantic_autorun: Optional[Dict[str, Any]] = None,
    tooling_quality: Optional[Dict[str, Any]] = None,
    hint_diversity_stats: Optional[Dict[str, Any]] = None,
) -> str:
    sep = "─" * 60
    now = datetime.now(tz=timezone.utc).strftime("%Y-%m-%d %H:%M UTC")
    lines = [
        sep,
        f"  AI STACK PERFORMANCE REPORT — last {since_label}",
        f"  Generated: {now}",
        sep,
        "",
        "[ 1. Tool Call Performance ]",
    ]

    if tool_stats:
        ignored_flaky_tools = {
            t.strip().lower()
            for t in os.getenv("AQ_REPORT_FLAKY_TOOL_IGNORE", "run_sandboxed,shell_execute").split(",")
            if t.strip()
        }
        visible_tool_rows = [
            (tool, stats)
            for tool, stats in sorted(tool_stats.items(), key=lambda x: -x[1]["calls"])
            if tool.lower() not in ignored_flaky_tools
        ]
        suppressed_tool_rows = [
            (tool, stats)
            for tool, stats in sorted(tool_stats.items(), key=lambda x: -x[1]["calls"])
            if tool.lower() in ignored_flaky_tools
        ]
        lines.append(f"  {'Tool':<30} {'Calls':>6} {'P50ms':>7} {'P95ms':>7} {'OK%':>6}")
        lines.append(f"  {'─'*30} {'─'*6} {'─'*7} {'─'*7} {'─'*6}")
        for tool, s in visible_tool_rows:
            lines.append(
                f"  {tool:<30} {s['calls']:>6} {s['p50_ms']:>7.0f} {s['p95_ms']:>7.0f} {s['success_pct']:>5.1f}%"
            )
        if not visible_tool_rows:
            lines.append("  (all observed tools are currently in the flaky-ignore list)")
        if suppressed_tool_rows:
            suppressed_names = ", ".join(t for t, _ in suppressed_tool_rows[:4])
            lines.append(f"  Suppressed noisy tools: {suppressed_names}")
    else:
        lines.append("  No tool audit data.")
    lines.append("")

    lines += ["[ 2. Routing Split ]"]
    if route["available"]:
        if route["local_pct"] is not None:
            local_pct = route["local_pct"]
            remote_pct = 100 - local_pct
            lines += [
                f"  Local:  {route['local_n']:6d}  ({local_pct:.1f}%)",
                f"  Remote: {route['remote_n']:6d}  ({remote_pct:.1f}%)",
            ]
        else:
            lines += [
                f"  Local:  {route['local_n']:6d}  (n/a — no routing events yet)",
                f"  Remote: {route['remote_n']:6d}  (n/a — no routing events yet)",
            ]
        if route.get("fallback_used"):
            lines.append(
                f"  Backend split metric missing; successful /query requests observed: {route['query_ok_n']}"
            )
    else:
        lines.append("  Prometheus unreachable.")
    lines.append("")

    lines += ["[ 3. Semantic Cache ]"]
    if cache["available"]:
        lines += [
            f"  Hits:    {cache['hits']}",
            f"  Misses:  {cache['misses']}",
            f"  Hit rate: {_na(cache['hit_pct'], '.1f', '%')}",
        ]
    else:
        lines.append("  Cache metrics unavailable.")
    lines.append("")

    lines += ["[ 4. Eval Score Trend ]"]
    if eval_trend.get("available"):
        lines += [
            f"  Runs: {eval_trend['n_runs']}  Latest: {eval_trend['latest_pct']}%"
            f"  Mean: {eval_trend['mean_pct']}%  Range: {eval_trend['min_pct']}–{eval_trend['max_pct']}%",
            f"  Trend: {eval_trend['trend'].upper()}",
        ]
    else:
        lines.append("  No eval data.")
    lines.append("")

    lines += ["[ 5. Strategy Leaderboard ]"]
    visible = [r for r in leaderboard if r["tag"] != "untagged"]
    if len(visible) >= 2:
        for i, r in enumerate(visible[:5], 1):
            lines.append(f"  {i}. {r['tag']:<40} {r['mean_pct']:>5.1f}%  ({r['runs']} runs)")
    else:
        lines.append("  No tagged strategies yet (use --strategy with run-eval.sh).")
    lines.append("")

    lines += ["[ 6. Recommended Prompts ]"]
    if top_prompts:
        for p in top_prompts:
            lines.append(f"  {p['mean_score']:.0%}  {p['id']}  — {p.get('name', '')}")
    else:
        lines.append("  Run scripts/aq-prompt-eval to score registry prompts.")
    lines.append("")

    lines += ["[ 7. Top Query Gaps ]"]
    if gaps:
        for i, g in enumerate(gaps[:5], 1):
            q = str(g.get("query_text", ""))[:70].replace("\n", " ")
            lines.append(f"  {i}. [{g.get('occurrences', 1)}x] {q}")
    else:
        lines.append("  No gaps data (Postgres unavailable or table empty).")
    lines.append("")

    lines += ["[ 8. Workflow Recommendations ]"]
    for i, rec in enumerate(recs, 1):
        # Wrap at ~72 chars
        words = rec.split()
        cur_line = f"  {i}. "
        indent = "     "
        for word in words:
            if len(cur_line) + len(word) + 1 > 72 and len(cur_line) > len(indent):
                lines.append(cur_line)
                cur_line = indent + word
            else:
                cur_line = cur_line + (" " if len(cur_line) > len(indent) else "") + word
        lines.append(cur_line)
    lines.append("")

    lines += ["[ 9. Hint Adoption (aq-hints → aider-wrapper) ]"]
    if adoption and adoption.get("available"):
        if adoption["total"] == 0:
            lines.append("  No hint-injected aider tasks in this window.")
        else:
            lines += [
                f"  Injected: {adoption['total']}   Successful: {adoption['accepted']}"
                f"   Rate: {_na(adoption['adoption_pct'], '.1f', '%')}",
            ]
            if int(adoption.get("tooling_plan_total", 0) or 0) > 0:
                lines.append(
                    f"  Tooling-plan success: {adoption.get('tooling_plan_success', 0)}"
                    f"/{adoption.get('tooling_plan_total', 0)}"
                    f"   ({_na(adoption.get('tooling_plan_success_pct'), '.1f', '%')})"
                )
            if adoption.get("top_hints"):
                lines.append("  Top hints:")
                for hid, count in adoption["top_hints"]:
                    lines.append(f"    {count:3d}x  {hid}")
            if tooling_quality and int(tooling_quality.get("total", 0) or 0) > 0:
                lines += [
                    f"  Aider task success (all): {tooling_quality.get('success', 0)}/{tooling_quality.get('total', 0)}"
                    f" ({_na(tooling_quality.get('success_pct'), '.1f', '%')})",
                    f"  Tooling-plan injected: {tooling_quality.get('plan_success', 0)}/{tooling_quality.get('plan_total', 0)}"
                    f" ({_na(tooling_quality.get('plan_success_pct'), '.1f', '%')})",
                    f"  Non-injected baseline: {tooling_quality.get('baseline_success', 0)}/{tooling_quality.get('baseline_total', 0)}"
                    f" ({_na(tooling_quality.get('baseline_success_pct'), '.1f', '%')})",
                ]
    else:
        lines.append("  Hint audit unavailable (AI_HINTS_ENABLED=true required).")
    lines.append("")

    lines += ["[ 10. Intent Contract Compliance ]"]
    if intent_compliance and intent_compliance.get("available"):
        total = int(intent_compliance.get("total_runs", 0) or 0)
        if total == 0:
            lines.append("  No workflow runs in this window.")
        else:
            lines += [
                f"  Runs: {total}",
                f"  With contract: {intent_compliance.get('with_contract', 0)}",
                f"  Coverage: {_na(intent_compliance.get('contract_coverage_pct'), '.1f', '%')}",
            ]
            depth = intent_compliance.get("depth_distribution", {})
            if isinstance(depth, dict) and depth:
                items = ", ".join(f"{k}:{v}" for k, v in sorted(depth.items(), key=lambda x: (-x[1], x[0])))
                lines.append(f"  Depth mix: {items}")
            top_bp = intent_compliance.get("top_blueprints", [])
            if top_bp:
                lines.append("  Top blueprints:")
                for bp, n in top_bp:
                    lines.append(f"    {n:3d}x  {bp}")
    else:
        lines.append("  Workflow session store unavailable.")
    lines.append("")

    lines += ["[ 11. Tool Security Auditor ]"]
    if security_auditor and security_auditor.get("available"):
        events = int(security_auditor.get("events", 0) or 0)
        if events == 0:
            lines.append("  No tool-security auditor decisions in this window.")
        else:
            lines += [
                f"  Decisions: {events}",
                f"  Approved: {security_auditor.get('approved', 0)}",
                f"  Blocked: {security_auditor.get('blocked', 0)}",
                f"  Cache hits: {security_auditor.get('cache_hits', 0)}  ({_na(security_auditor.get('cache_hit_pct'), '.1f', '%')})",
                f"  First-seen audits: {security_auditor.get('first_seen', 0)}",
            ]
    else:
        lines.append("  Tool-security auditor metrics unavailable.")
    lines.append("")

    lines += ["[ 12. Semantic Tooling Autorun ]"]
    if semantic_autorun and semantic_autorun.get("available"):
        route_calls = int(semantic_autorun.get("route_calls", 0) or 0)
        if route_calls == 0:
            lines.append("  No route_search traffic in this window.")
        else:
            lines += [
                f"  Route calls: {route_calls}",
                f"  Route calls with metadata: {semantic_autorun.get('with_metadata', 0)}",
                f"  Autorun enabled: {semantic_autorun.get('autorun_enabled_calls', 0)}"
                f"  ({_na(semantic_autorun.get('autorun_enabled_pct'), '.1f', '%')})",
                f"  Avg planned tools/call: {semantic_autorun.get('avg_planned_tools', 0.0)}",
                f"  Avg executed tools/call: {semantic_autorun.get('avg_executed_tools', 0.0)}",
                f"  Security blocks during autorun: {semantic_autorun.get('tool_security_blocked_total', 0)}",
            ]
    else:
        lines.append("  Semantic autorun metrics unavailable.")
    lines.append("")

    lines += ["[ 13. Hint Diversity ]"]
    if hint_diversity_stats and hint_diversity_stats.get("available"):
        total_injections = int(hint_diversity_stats.get("total_injections", 0) or 0)
        if total_injections == 0:
            lines.append("  No hint-injection activity in this window.")
        else:
            lines += [
                f"  Total injections: {total_injections}",
                f"  Unique hint IDs: {hint_diversity_stats.get('unique_hints', 0)}",
                f"  Dominant share: {_na(hint_diversity_stats.get('dominant_share_pct'), '.1f', '%')}",
                f"  Normalized entropy: {_na(hint_diversity_stats.get('normalized_entropy_pct'), '.1f', '%')}",
                f"  Effective hints: {_na(hint_diversity_stats.get('effective_hints'), '.2f')}",
                f"  Status: {hint_diversity_stats.get('status', 'unknown')}",
            ]
            if hint_diversity_stats.get("dominant_hint_id"):
                lines.append(f"  Dominant hint ID: {hint_diversity_stats.get('dominant_hint_id')}")
    else:
        lines.append("  Hint-diversity metrics unavailable.")
    lines += ["", sep]
    return "\n".join(lines)


def format_json(
    since_label: str,
    tool_stats: Dict[str, dict],
    route: Dict[str, Any],
    cache: Dict[str, Any],
    eval_trend: Dict[str, Any],
    leaderboard: List[dict],
    top_prompts: List[dict],
    gaps: List[dict],
    recs: List[str],
    adoption: Optional[Dict[str, Any]] = None,
    intent_compliance: Optional[Dict[str, Any]] = None,
    security_auditor: Optional[Dict[str, Any]] = None,
    semantic_autorun: Optional[Dict[str, Any]] = None,
    tooling_quality: Optional[Dict[str, Any]] = None,
    hint_diversity_stats: Optional[Dict[str, Any]] = None,
    structured_actions: Optional[List[dict]] = None,
) -> str:
    doc = {
        "generated_at": datetime.now(tz=timezone.utc).isoformat(),
        "window": since_label,
        "tool_performance": tool_stats,
        "routing": route,
        "cache": cache,
        "eval_trend": eval_trend,
        "strategy_leaderboard": leaderboard,
        "top_prompts": [
            {"id": p["id"], "name": p.get("name"), "mean_score": p.get("mean_score")}
            for p in top_prompts
        ],
        "query_gaps": [g for g in gaps[:10] if not _is_synthetic_gap(str(g.get("query_text", "")))],
        "recommendations": recs,
        "hint_adoption": adoption or {"available": False},
        "task_tooling_quality": tooling_quality or {"available": False},
        "intent_contract_compliance": intent_compliance or {"available": False},
        "tool_security_auditor": security_auditor or {"available": False},
        "semantic_tooling_autorun": semantic_autorun or {"available": False},
        "hint_diversity": hint_diversity_stats or {"available": False},
        "structured_actions": structured_actions or [],
    }
    return json.dumps(doc, indent=2, default=str)


# ---------------------------------------------------------------------------
# AIDB import
# ---------------------------------------------------------------------------


def aidb_import(content: str, week_label: str) -> bool:
    """POST the report to AIDB as a searchable document."""
    aidb_key = os.getenv("AIDB_API_KEY", "").strip()
    if not aidb_key:
        key_file = os.getenv("AIDB_API_KEY_FILE", "/run/secrets/aidb_api_key")
        p = Path(key_file)
        if p.exists():
            try:
                aidb_key = p.read_text(encoding="utf-8").strip()
            except OSError:
                aidb_key = ""

    headers = {"Content-Type": "application/json"}
    if aidb_key:
        headers["X-API-Key"] = aidb_key

    docs_payload = json.dumps({
        "project": "aq-report",
        "relative_path": f"weekly/{week_label}.md",
        "title": f"AI Stack Weekly Report ({week_label})",
        "content_type": "text/markdown",
        "content": content,
        "status": "approved",
        "source_trust_level": "generated",
    }).encode("utf-8")
    legacy_payload = json.dumps({
        "text": content,
        "metadata": {
            "type": "weekly_report",
            "week": week_label,
            "source": "aq-report",
        },
    }).encode("utf-8")

    attempts = [
        (f"{AIDB_URL}/documents", docs_payload),
        (f"{AIDB_URL}/import", legacy_payload),
    ]
    last_exc: Optional[Exception] = None
    for url, payload in attempts:
        try:
            req = urllib.request.Request(
                url,
                data=payload,
                headers=headers,
                method="POST",
            )
            with urllib.request.urlopen(req, timeout=15) as resp:
                if resp.status < 300:
                    return True
        except Exception as exc:
            last_exc = exc
            continue
    print(f"[aq-report] AIDB import failed: {last_exc}", file=sys.stderr)
    return False


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------


def main() -> None:
    args = parse_args()
    window = _parse_since(args.since)
    since_dt = datetime.now(tz=timezone.utc) - window
    since_label = args.since

    # Collect data (independent sources — order doesn't matter)
    audit_entries = read_tool_audit(since_dt)
    eval_rows = read_eval_scores(since_dt)
    gaps = read_query_gaps(since_dt, limit=10)
    gaps = [g for g in gaps if not _is_synthetic_gap(str(g.get("query_text", "")))]
    prompts = read_prompt_registry()

    # Analyse
    tool_stats = aggregate_tool_audit(audit_entries)
    route = routing_split()
    cache = cache_hit_rate()
    eval_trend = eval_score_trend(eval_rows)
    adoption = hint_adoption(since_dt)  # Phase 19.3.4
    tooling_quality = task_tooling_quality(since_dt, adoption)
    intent_compliance = read_workflow_sessions(since_dt)
    security_auditor = security_auditor_health(audit_entries)
    semantic_autorun = semantic_autorun_health(audit_entries)
    hint_diversity_stats = hint_diversity(adoption)
    leaderboard = strategy_leaderboard(eval_rows)
    top_prompts = sorted(
        [p for p in prompts if isinstance(p.get("mean_score"), float) and p["mean_score"] > 0],
        key=lambda x: -x["mean_score"],
    )[:3]
    recs = build_recommendations(
        tool_stats,
        route,
        cache,
        eval_trend,
        gaps,
        adoption,
        intent_compliance,
        security_auditor,
        semantic_autorun,
        tooling_quality,
        hint_diversity_stats,
    )
    structured_actions = build_structured_actions(tool_stats, route, cache, eval_trend, gaps)

    # Render
    fmt_args = (
        since_label,
        tool_stats,
        route,
        cache,
        eval_trend,
        leaderboard,
        top_prompts,
        gaps,
        recs,
        adoption,
        intent_compliance,
        security_auditor,
        semantic_autorun,
        tooling_quality,
        hint_diversity_stats,
    )
    if args.fmt == "md":
        output = format_md(*fmt_args)
    elif args.fmt == "json":
        output = format_json(*fmt_args, structured_actions=structured_actions)
    else:
        output = format_text(*fmt_args)

    print(output)

    # Optional AIDB import
    if args.aidb_import:
        week_label = (datetime.now(tz=timezone.utc) - timedelta(days=3)).strftime("W%W-%Y")
        ok = aidb_import(output, week_label)
        if ok:
            print(f"\n[aq-report] Report imported to AIDB (week={week_label})", file=sys.stderr)
        # failure already printed by aidb_import()


if __name__ == "__main__":
    main()
