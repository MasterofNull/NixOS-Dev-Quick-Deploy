diff --git a/src/llama.cpp b/src/llama.cpp
index 987fe38..0e05a56 100644
--- a/src/llama.cpp
+++ b/src/llama.cpp
@@ -972,10 +972,10 @@ struct llama_model * llama_model_load_from_file_impl(
         // add GPUs
         model->devices.insert(model->devices.end(), gpus.begin(), gpus.end());
 
-        // add integrated GPUs only if no other devices were found
-        if (model->devices.empty()) {
-            model->devices.insert(model->devices.end(), igpus.begin(), igpus.end());
-        }
+        // Keep integrated GPUs available for offload as well. Vulkan on AMD APUs
+        // reports these as iGPUs with shared memory, and excluding them here
+        // prevents later server/runtime paths from attempting GPU offload at all.
+        model->devices.insert(model->devices.end(), igpus.begin(), igpus.end());
     }
 
     // if using single GPU mode, remove all except the main GPU
