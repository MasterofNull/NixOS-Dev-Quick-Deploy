+static const char * debug_backend_dev_type_name(enum ggml_backend_dev_type type) {
+    switch (type) {
+        case GGML_BACKEND_DEVICE_TYPE_CPU:  return "CPU";
+        case GGML_BACKEND_DEVICE_TYPE_GPU:  return "GPU";
+        case GGML_BACKEND_DEVICE_TYPE_ACCEL:return "ACCEL";
+        case GGML_BACKEND_DEVICE_TYPE_IGPU: return "IGPU";
+        default:                            return "UNKNOWN";
+    }
+}
+
+static llama_example debug_backend_registry_example = LLAMA_EXAMPLE_COMMON;
+
+static void debug_backend_registry_dump(const char * stage) {
+    if (debug_backend_registry_example != LLAMA_EXAMPLE_SERVER) {
+        return;
+    }
+
+#if defined(GGML_USE_VULKAN)
+    auto * vk_reg = ggml_backend_vk_reg();
+    fprintf(stderr, "diagnostic[%s]: vk_reg=%p vk_reg_device_count=%zu\n",
+        stage, (void *) vk_reg, vk_reg ? ggml_backend_reg_dev_count(vk_reg) : 0);
+#endif
+
+    fprintf(stderr, "diagnostic[%s]: backend_count=%zu device_count=%zu gpu_offload=%d\n",
+        stage, ggml_backend_reg_count(), ggml_backend_dev_count(), llama_supports_gpu_offload() ? 1 : 0);
+
+    for (size_t i = 0; i < ggml_backend_reg_count(); ++i) {
+        auto * reg = ggml_backend_reg_get(i);
+        fprintf(stderr, "diagnostic[%s]: backend[%zu]=%s reg_device_count=%zu\n",
+            stage, i, ggml_backend_reg_name(reg), ggml_backend_reg_dev_count(reg));
+    }
+
+    for (size_t i = 0; i < ggml_backend_dev_count(); ++i) {
+        auto * dev = ggml_backend_dev_get(i);
+        fprintf(stderr, "diagnostic[%s]: device[%zu]=%s type=%s desc=%s\n",
+            stage, i, ggml_backend_dev_name(dev), debug_backend_dev_type_name(ggml_backend_dev_type(dev)),
+            ggml_backend_dev_description(dev));
+    }
+}
