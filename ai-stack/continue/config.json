{
  "$schema": "https://raw.githubusercontent.com/continuedev/continue/main/extensions/vscode/config_schema.json",
  "contextProviders": [
    {
      "name": "http",
      "params": {
        "url": "http://127.0.0.1:${HYBRID_COORDINATOR_PORT:-8003}/hints",
        "title": "aq-hints",
        "description": "Ranked AI workflow hints from registry.yaml, query gaps, and CLAUDE.md rules",
        "displayTitle": "AI Stack Hints"
      }
    },
    {
      "name": "http",
      "params": {
        "url": "http://127.0.0.1:${HYBRID_COORDINATOR_PORT:-8003}/discovery/capabilities",
        "title": "ai-tools",
        "description": "Live catalog of all AI stack tools, MCP endpoints, CLI scripts, and agents",
        "displayTitle": "AI Stack Tools"
      }
    }
  ],
  "models": [
    {
      "title": "Switchboard Router (Authoritative)",
      "provider": "openai",
      "apiBase": "http://127.0.0.1:${SWITCHBOARD_PORT:-8085}/v1",
      "apiKey": "dummy",
      "model": "AUTODETECT"
    },
    {
      "title": "Local llama.cpp (direct)",
      "provider": "openai",
      "apiBase": "http://127.0.0.1:${LLAMA_CPP_PORT:-8080}/v1",
      "apiKey": "dummy",
      "model": "AUTODETECT"
    },
    {
      "title": "Ollama (local)",
      "provider": "ollama",
      "model": "AUTODETECT"
    }
  ],
  "tabAutocompleteModel": {
    "title": "Local Autocomplete",
    "provider": "openai",
    "apiBase": "http://127.0.0.1:${SWITCHBOARD_PORT:-8085}/v1",
    "apiKey": "dummy",
    "model": "AUTODETECT",
    "requestOptions": {
      "headers": {
        "X-AI-Profile": "continue-local"
      }
    }
  },
  "mcpServers": {
    "hybrid-coordinator": {
      "command": "bash",
      "args": [
        "-c",
        "exec python3 /home/hyperd/Documents/NixOS-Dev-Quick-Deploy/scripts/ai/mcp-bridge-hybrid.py"
      ]
    }
  }
}
